@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "ลงทะเบียนผ่าน ThaiID — DPIM Portal";

  // Mock ThaiID data (in production: from OAuth callback)
  var thaiIdName = "นายสมชาย ใจดี";
  var thaiIdIdNumber = "1-1234-56789-01-2";
  var thaiIdDob = "1 มกราคม 2520";
  var thaiIdAddress = "123 ถนนพหลโยธิน แขวงสามเสนใน เขตพญาไท กรุงเทพมหานคร 10400";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/@@form-validation/form-validation.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/@@form-validation/popular.js"></script>
<script src="~/vendor/libs/@@form-validation/bootstrap5.js"></script>
<script src="~/vendor/libs/@@form-validation/auto-focus.js"></script>
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  if (typeof $ !== 'undefined' && $.fn.select2) {
    $('#memberTypeThaiID').select2({ dropdownParent: document.body });
  }
});
</script>
}

@* ============================================================ *@
<div class="authentication-wrapper authentication-cover">
  <a href="/" class="auth-cover-brand d-flex align-items-center gap-2">
    <img src="~/img/dpim-logo.png" alt="DPIM Logo" style="width:48px;height:48px;object-fit:contain;" />
    <span class="app-brand-text demo text-heading fw-semibold d-none d-sm-inline">DPIM Portal</span>
  </a>

  <div class="authentication-inner row m-0">

    <!-- Left: Banner -->
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 p-0 position-relative" style="min-height:100vh;overflow:hidden;">
      <img src="~/img/dpim-banner.jpg" alt="Mining for the Community" style="width:100%;height:100%;object-fit:cover;" />
      <div style="position:absolute;bottom:2rem;left:2rem;right:2rem;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.6);">
        <div class="fw-bold" style="font-size:1.4rem;">MINING FOR THE COMMUNITY</div>
        <div>เหมืองแร่เพื่อชุมชน — กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่</div>
      </div>
    </div>

    <!-- Right: Form -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-start authentication-bg position-relative py-sm-12 px-12 py-6" style="overflow-y:auto;">
      <div class="w-100 mx-auto pt-12 pt-lg-0" style="max-width:400px;">

        <!-- Header -->
        <div class="text-center mb-5">
          <span class="badge bg-label-success px-3 py-2 mb-3">
            <i class="ri ri-shield-check-line me-1"></i> ยืนยันตัวตนสำเร็จ
          </span>
          <h5 class="fw-bold mb-1">กรอกข้อมูลเพิ่มเติม</h5>
          <p class="text-muted small mb-0">ข้อมูลด้านล่างดึงจาก ThaiID อัตโนมัติ</p>
        </div>

        <!-- Read-only ThaiID Data -->
        <div class="card border mb-4">
          <div class="card-header py-3 bg-label-success">
            <span class="fw-semibold"><i class="ri ri-id-card-line me-1"></i> ข้อมูลจาก ThaiID</span>
          </div>
          <div class="card-body p-3">
            <dl class="row mb-0 small">
              <dt class="col-5 text-muted">ชื่อ-นามสกุล</dt>
              <dd class="col-7 fw-semibold">@thaiIdName</dd>
              <dt class="col-5 text-muted">เลขบัตรประชาชน</dt>
              <dd class="col-7 fw-semibold">@thaiIdIdNumber</dd>
              <dt class="col-5 text-muted">วันเกิด</dt>
              <dd class="col-7">@thaiIdDob</dd>
              <dt class="col-5 text-muted mb-0">ที่อยู่</dt>
              <dd class="col-7 mb-0">@thaiIdAddress</dd>
            </dl>
          </div>
        </div>

        <!-- Hidden ThaiID fields -->
        <input type="hidden" name="thaiIdName" value="@thaiIdName" />
        <input type="hidden" name="thaiIdIdNumber" value="@thaiIdIdNumber" />

        <!-- Additional fields -->
        <form id="formThaiIDCallback" method="post" action="#">

          <div class="mb-4">
            <label class="form-label" for="memberTypeThaiID">ประเภทสมาชิก <span class="text-danger">*</span></label>
            <select id="memberTypeThaiID" name="memberType" class="form-select">
              <option value="">-- กรุณาเลือกประเภทสมาชิก --</option>
              <option>บุคคลธรรมดา</option>
              <option>นิติบุคคล</option>
              <option>วิสาหกิจชุมชน</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label" for="emailThaiID">อีเมล <span class="text-danger">*</span></label>
            <div class="form-floating form-floating-outline">
              <input type="email" id="emailThaiID" name="email" class="form-control" placeholder="name@example.com" />
              <label for="emailThaiID">อีเมล</label>
            </div>
          </div>

          <div class="mb-5">
            <label class="form-label" for="phoneThaiID">เบอร์โทรศัพท์ <span class="text-danger">*</span></label>
            <div class="form-floating form-floating-outline">
              <input type="tel" id="phoneThaiID" name="phone" class="form-control" placeholder="0XX-XXX-XXXX" maxlength="10" />
              <label for="phoneThaiID">เบอร์โทรศัพท์ 10 หลัก</label>
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="ri ri-check-line me-1"></i> ยืนยันและลงทะเบียน
          </button>

          <a href="/Auth/RegisterChannel" class="btn btn-outline-secondary w-100">
            <i class="ri ri-arrow-left-line me-1"></i> ยกเลิก / เปลี่ยนช่องทาง
          </a>

        </form>
      </div>
    </div>

  </div>
</div>
