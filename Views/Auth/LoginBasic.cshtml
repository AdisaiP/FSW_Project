@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "เข้าสู่ระบบ — DPIM Portal";
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  html, body { height:100%; }
  .authentication-wrapper.authentication-cover { min-height:100vh; max-height:100vh; overflow:hidden; }
  .authentication-inner { height:100vh; }
  .dpim-banner-left {
    width:100%; height:100%; object-fit:cover; object-position:70% center;
    image-rendering:crisp-edges;
  }
  .dpim-cover-left { position:relative; overflow:hidden; }
  .dpim-cover-left::after {
    content:""; position:absolute; inset:0;
    background:linear-gradient(to right, rgba(0,0,0,.05) 0%, rgba(0,0,0,.18) 100%);
    pointer-events:none;
  }
  .dpim-brand-logo { width:150px; height:150px; object-fit:contain; }
  .dpim-logo-header { width:52px; height:52px; object-fit:contain; }
  .dpim-brand-divider { width:40px; height:3px; background:var(--bs-primary); border-radius:2px; margin:.6rem auto .75rem; }
  .dpim-sso-btn {
    display:flex; align-items:center; gap:.65rem;
    border:1.5px solid #dee2e6; border-radius:8px;
    padding:.55rem .9rem; text-decoration:none; color:inherit;
    transition:all .18s ease; font-size:.88rem; font-weight:500;
  }
  .dpim-sso-btn:hover { border-color:var(--dpim-blue); box-shadow:0 2px 8px rgba(35,64,143,.15); color:inherit; }
  .dpim-sso-icon { width:28px; height:28px; border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:.95rem; flex-shrink:0; }
  .btn-dpim-primary { background:var(--dpim-blue) !important; border-color:var(--dpim-blue) !important; color:#fff !important; }
  .btn-dpim-primary:hover { background:#1b3175 !important; border-color:#1b3175 !important; }
</style>
}

@* ============================================================ *@
<div class="authentication-wrapper authentication-cover">
  <a href="/" class="auth-cover-brand d-flex align-items-center gap-2">
    <img src="~/img/dpim-logo.png" alt="DPIM Logo" class="dpim-logo-header" />
    <span class="app-brand-text demo text-heading fw-semibold d-none d-sm-inline">DPIM Portal</span>
  </a>

  <div class="authentication-inner row m-0">
    <!-- Left: Banner -->
    <div class="d-none d-lg-flex col-lg-7 col-xl-8 p-0 dpim-cover-left">
      <img src="~/img/dpim-banner.jpg" alt="Mining for the Community" class="dpim-banner-left" />
    </div>
    <!-- /Left -->

    <!-- Right: Login Form -->
    <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg position-relative px-4 px-sm-5" style="overflow-y:auto;">
      <div class="w-100 mx-auto py-4" style="max-width:380px;">

        <!-- Header -->
        <div class="text-center mb-4">
          <img src="~/img/dpim-logo.png" alt="กพร." class="dpim-brand-logo mb-2" />
          <h5 class="fw-bold mb-0">กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่</h5>
          <div class="dpim-brand-divider"></div>
          <div class="fw-semibold text-primary" style="font-size:.85rem;letter-spacing:.5px;">MINING FOR THE COMMUNITY</div>
          <p class="text-muted mt-1 mb-0" style="font-size:.8rem;">เข้าสู่ระบบเพื่อใช้งาน DPIM Portal</p>
        </div>

        <!-- Form -->
        <form id="formAuthentication" class="mb-3" action="/" method="POST">
          <div class="mb-3">
            <div class="form-floating form-floating-outline">
              <input type="text" class="form-control" id="email" name="email-username"
                     placeholder="อีเมล หรือ ชื่อผู้ใช้" autofocus />
              <label for="email">อีเมล / ชื่อผู้ใช้งาน</label>
            </div>
          </div>
          <div class="mb-3">
            <div class="form-password-toggle">
              <div class="input-group input-group-merge">
                <div class="form-floating form-floating-outline">
                  <input type="password" id="password" class="form-control" name="password"
                         placeholder="รหัสผ่าน" />
                  <label for="password">รหัสผ่าน</label>
                </div>
                <span class="input-group-text cursor-pointer">
                  <i class="icon-base ri ri-eye-off-line icon-20px"></i>
                </span>
              </div>
            </div>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="remember-me" />
              <label class="form-check-label" for="remember-me">จดจำฉัน</label>
            </div>
            <a href="/Auth/ForgotPasswordBasic" class="text-decoration-none" style="font-size:.85rem;">ลืมรหัสผ่าน?</a>
          </div>
          <button class="btn btn-dpim-primary d-grid w-100 py-2 fw-semibold" type="submit">
            <i class="ri ri-login-box-line me-1"></i> เข้าสู่ระบบ
          </button>
        </form>

        <p class="text-center mb-3" style="font-size:.85rem;">
          ยังไม่มีบัญชี?
          <a href="/Auth/RegisterChannel" class="fw-semibold" style="color:var(--dpim-green);">ลงทะเบียน</a>
        </p>

        <div class="divider my-3">
          <div class="divider-text text-muted" style="font-size:.8rem;">หรือเข้าสู่ระบบด้วย</div>
        </div>

        <!-- SSO Buttons -->
        <div class="d-flex flex-column gap-2">
          <a href="/Auth/SSORedirectIndustry" class="dpim-sso-btn">
            <div class="dpim-sso-icon" style="background:#e8f0fe;">
              <i class="ri ri-home-office-line" style="color:#23408F;"></i>
            </div>
            <div>
              <div class="fw-semibold" style="font-size:.83rem;color:#23408F;">i-Industry</div>
              <div class="text-muted" style="font-size:.75rem;">สำหรับผู้ประกอบการ</div>
            </div>
          </a>
          <a href="/Auth/SSORedirectOfficer" class="dpim-sso-btn">
            <div class="dpim-sso-icon" style="background:#fff3e0;">
              <i class="ri ri-user-follow-line" style="color:#e65100;"></i>
            </div>
            <div>
              <div class="fw-semibold" style="font-size:.83rem;color:#e65100;">i-Industry Officer</div>
              <div class="text-muted" style="font-size:.75rem;">สำหรับเจ้าหน้าที่</div>
            </div>
          </a>
          <a href="/Auth/SSORedirectThaiID" class="dpim-sso-btn">
            <div class="dpim-sso-icon" style="background:#e3f2fd;">
              <i class="ri ri-id-card-line" style="color:#0277bd;"></i>
            </div>
            <div>
              <div class="fw-semibold" style="font-size:.83rem;color:#0277bd;">ThaiID</div>
              <div class="text-muted" style="font-size:.75rem;">ยืนยันตัวตนด้วย ThaiID</div>
            </div>
          </a>
        </div>

      </div>
    </div>
    <!-- /Right -->
  </div>
</div>
