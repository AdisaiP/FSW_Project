                <input type="text" id="filterCertNo" class="form-control" placeholder="เช่น AC821B2171101" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterRequestNo" class="form-label">เลขที่คำขอ</label>
                <input type="text" id="filterRequestNo" class="form-control" placeholder="เช่น 10611180131800118" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterEstablishment" class="form-label">ชื่อสถานประกอบการ</label>
                <input type="text" id="filterEstablishment" class="form-control" placeholder="ชื่อสถานประกอบการ" />
            </div>
            @* Row 2 *@
            <div class="col-md-4 col-lg-3">
                <label for="filterApprovalNo" class="form-label">หมายเลขรับรองโรงงาน</label>
                <input type="text" id="filterApprovalNo" class="form-control" placeholder="เช่น AP-74110-001" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterProduct" class="form-label">ชื่อสินค้า</label>
                <input type="text" id="filterProduct" class="form-control" placeholder="ชื่อสินค้า / HS Code" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCountry" class="form-label">ประเทศปลายทาง</label>
                <select id="filterCountry" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="AR">AR — อาร์เจนตินา</option>
                    <option value="AU">AU — ออสเตรเลีย</option>
                    <option value="CN">CN — จีน</option>
                    <option value="EU">EU — สหภาพยุโรป</option>
                    <option value="JP">JP — ญี่ปุ่น</option>
                    <option value="KR">KR — เกาหลีใต้</option>
                    <option value="US">US — สหรัฐอเมริกา</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ฉบับร่าง">ฉบับร่าง</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติ">อนุมัติ</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                </select>
            </div>
            @* Row 3 *@
            <div class="col-md-4 col-lg-3">
                <label for="filterSubmitDateFrom" class="form-label">วันที่ยื่น (ตั้งแต่)</label>
                <input type="text" id="filterSubmitDateFrom" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterSubmitDateTo" class="form-label">วันที่ยื่น (ถึง)</label>
                <input type="text" id="filterSubmitDateTo" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterReceiveNo" class="form-label">เลขที่รับ</label>
                <input type="text" id="filterReceiveNo" class="form-control" placeholder="เช่น RCV-PS-2569-00118" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterReceiveDate" class="form-label">วันที่รับ</label>
                <input type="text" id="filterReceiveDate" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            @* Row 4 *@
            <div class="col-md-4 col-lg-3">
                <label for="filterExportDateFrom" class="form-label">วันที่ส่งออก (ตั้งแต่)</label>
                <input type="text" id="filterExportDateFrom" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterExportDateTo" class="form-label">วันที่ส่งออก (ถึง)</label>
                <input type="text" id="filterExportDateTo" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterInspDateFrom" class="form-label">วันที่ตรวจปล่อย (ตั้งแต่)</label>
                <input type="text" id="filterInspDateFrom" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-2">
                <label for="filterInspDateTo" class="form-label">วันที่ตรวจปล่อย (ถึง)</label>
                <input type="text" id="filterInspDateTo" class="form-control flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square" title="ล้างการค้นหา">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการขอเปลี่ยนแปลงใบรับรองฯ</h5>
            <p class="text-muted small mb-0">จัดการข้อมูลขอเปลี่ยนแปลงใบรับรองการแปรรูปสัตว์นํ้า (PS) และใบรับรองไม่แปรรูปสัตว์นํ้า (Declaration)</p>
        </div>
        <div class="d-flex align-items-center gap-2">
                <a href="@Url.Action("CreateUpdateCertificate", "PSDeclaration")" class="btn btn-primary btn-sm">
                <i class="ri ri-add-line me-1"></i> สร้างคำขอ
            </a>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:200px;">เลขที่คำขอ / ใบรับรอง</th>
                    <th style="min-width:160px;">สถานประกอบการ / รับรองโรงงาน</th>
                    <th style="min-width:160px;">สินค้า / ประเทศ</th>
                    <th style="min-width:130px;">วันส่งออก / ตรวจปล่อย</th>
                    <th style="min-width:140px;">เลขที่รับ / วันที่รับ</th>
                    <th style="min-width:130px;">วันที่ทำรายการ</th>
                    <th style="width:6rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey"
                        data-status="@request.StatusText"
                        data-draft-date="@request.TransactionAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-cert-no="@request.CertNo"
                        data-request-no="@request.RequestNumber"
                        data-establishment="@request.Establishment"
                        data-approval-no="@request.ApprovalNo"
                        data-product="@request.Product"
                        data-country="@request.Country"
                        data-submit-date="@request.RequestDate.ToString("yyyy-MM-dd")"
                        data-receive-no="@request.ReceiveNo"
                        data-receive-date="@request.ReceiveDate.ToString("yyyy-MM-dd")"
                        data-export-date="@request.ExportDate.ToString("yyyy-MM-dd")"
                        data-insp-date="@request.InspectionDate.ToString("yyyy-MM-dd")">
                        <td>
                            <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateUpdateCertificate", "PSDeclaration") : Url.Action("CreateUpdateCertificate", "PSDeclaration"))"
                                   class="fw-semibold text-primary text-decoration-none d-block mb-1">
                                @request.RequestNumber
                            </a>
                            <div class="small text-muted mb-1">@request.CertNo</div>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>@request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                            </div>
                        </td>
                        <td class="small">
                            <div class="fw-semibold text-dark mb-1">@request.Establishment</div>
                            <div class="text-muted">@request.ApprovalNo</div>
                        </td>
                        <td class="small">
                            <div class="mb-1">@request.Product</div>
                            <span class="badge bg-label-info">@request.Country</span>
                        </td>
                        <td class="text-center small text-nowrap">
                            <div><i class="ri ri-ship-line me-1 text-muted"></i>@request.ExportDate.ToString("dd/MM/yyyy")</div>
                            <div class="text-muted"><i class="ri ri-checkbox-circle-line me-1"></i>@request.InspectionDate.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="small text-nowrap">
                            <div class="fw-semibold">@request.ReceiveNo</div>
                            <div class="text-muted">@request.ReceiveDate.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="text-center small text-nowrap">
                            @request.TransactionAt.ToString("dd/MM/yyyy")<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm:ss"))</span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (request.StatusText == "ฉบับร่าง" || request.StatusText == "ไม่อนุมัติ")
                                {
                                    <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateManageCertificatePS", "PSDeclaration") : Url.Action("CreateManageCertificateNoPS", "PSDeclaration"))" class="btn btn-sm btn-icon btn-outline-warning" data-bs-toggle="tooltip" title="แก้ไข">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary" data-bs-toggle="tooltip" title="ยืนยันส่งคำขอ">
                                        <i class="ri ri-send-plane-line text-primary"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" data-bs-toggle="tooltip" title="ลบ">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                                @if (request.StatusText == "รออนุมัติ")
                                {
                                    <span class="text-muted small">รอดำเนินการ</span>
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ยกเลิก")
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="7" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>