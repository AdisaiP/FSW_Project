@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Initialize flatpickr for all date filter inputs
        document.querySelectorAll('.flatpickr-date').forEach(function(el) {
            flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certType   = (document.getElementById('filterCertType').value || '').trim();
            var certNo     = (document.getElementById('filterCertNo').value || '').trim().toLowerCase();
            var requestNo  = (document.getElementById('filterRequestNo').value || '').trim().toLowerCase();
            var estab      = (document.getElementById('filterEstablishment').value || '').trim().toLowerCase();
            var approvalNo = (document.getElementById('filterApprovalNo').value || '').trim().toLowerCase();
            var product    = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
            var country    = (document.getElementById('filterCountry').value || '').trim();
            var submitFrom = parseDateInput(document.getElementById('filterSubmitDateFrom').value, false);
            var submitTo   = parseDateInput(document.getElementById('filterSubmitDateTo').value, true);
            var receiveNo  = (document.getElementById('filterReceiveNo').value || '').trim().toLowerCase();
            var receiveDate = parseDateInput(document.getElementById('filterReceiveDate').value, false);
            var status     = (document.getElementById('filterStatus').value || '').trim();
            var exportFrom = parseDateInput(document.getElementById('filterExportDateFrom').value, false);
            var exportTo   = parseDateInput(document.getElementById('filterExportDateTo').value, true);
            var inspFrom   = parseDateInput(document.getElementById('filterInspDateFrom').value, false);
            var inspTo     = parseDateInput(document.getElementById('filterInspDateTo').value, true);
            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var certTypeMatch   = !certType   || row.dataset.certificate === certType;
                var certNoMatch     = !certNo     || (row.dataset.certNo || '').toLowerCase().includes(certNo);
                var requestNoMatch  = !requestNo  || (row.dataset.requestNo || '').toLowerCase().includes(requestNo);
                var estabMatch      = !estab      || (row.dataset.establishment || '').toLowerCase().includes(estab);
                var approvalMatch   = !approvalNo || (row.dataset.approvalNo || '').toLowerCase().includes(approvalNo);
                var productMatch    = !product    || (row.dataset.product || '').toLowerCase().includes(product);
                var countryMatch    = !country    || (row.dataset.country || '') === country;
                var statusMatch     = !status     || (row.dataset.status || '') === status;
                var receiveNoMatch  = !receiveNo  || (row.dataset.receiveNo || '').toLowerCase().includes(receiveNo);

                var rowSubmitDate   = new Date(row.dataset.submitDate || '');
                var rowReceiveDate  = new Date(row.dataset.receiveDate || '');
                var rowExportDate   = new Date(row.dataset.exportDate || '');
                var rowInspDate     = new Date(row.dataset.inspDate || '');

                var submitDateMatch  = (!submitFrom && !submitTo)  || ((!submitFrom || rowSubmitDate >= submitFrom) && (!submitTo  || rowSubmitDate <= submitTo));
                var receiveDateMatch = !receiveDate || (rowReceiveDate >= receiveDate && rowReceiveDate <= parseDateInput(document.getElementById('filterReceiveDate').value, true));
                var exportDateMatch  = (!exportFrom && !exportTo)  || ((!exportFrom || rowExportDate >= exportFrom) && (!exportTo  || rowExportDate <= exportTo));
                var inspDateMatch    = (!inspFrom   && !inspTo)    || ((!inspFrom   || rowInspDate >= inspFrom)   && (!inspTo    || rowInspDate <= inspTo));

                var isVisible = certTypeMatch && certNoMatch && requestNoMatch && estabMatch && approvalMatch && productMatch && countryMatch && statusMatch && receiveNoMatch && submitDateMatch && receiveDateMatch && exportDateMatch && inspDateMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) { visibleCount += 1; }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        ['filterCertType','filterCertNo','filterRequestNo','filterEstablishment','filterApprovalNo',
         'filterProduct','filterCountry','filterStatus','filterReceiveNo',
         'filterSubmitDateFrom','filterSubmitDateTo','filterReceiveDate',
         'filterExportDateFrom','filterExportDateTo','filterInspDateFrom','filterInspDateTo'
        ].forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('change', filterRows);
            el.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });
        document.getElementById('btnResetRequests').addEventListener('click', function () {
            ['filterCertNo','filterRequestNo','filterEstablishment','filterApprovalNo','filterProduct',
             'filterReceiveNo','filterSubmitDateFrom','filterSubmitDateTo','filterReceiveDate',
             'filterExportDateFrom','filterExportDateTo','filterInspDateFrom','filterInspDateTo'
            ].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.value = '';
            });
            document.getElementById('filterCertType').value = '';
            document.getElementById('filterStatus').value = '';
            filterRows();
        });
    });
</script>
}

