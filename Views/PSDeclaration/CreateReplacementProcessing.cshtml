@section PageScripts {
<script>
    // TOR 1.9(1): toggle placeholder ของ textarea รายละเอียดตามเหตุผลที่เลือก
    function toggleReasonOtherDetail() {
        var selected = document.querySelector('input[name="replacementReason"]:checked');
        var ta = document.getElementById('replacementDetail');
        if (!selected || !ta) return;
        var placeholders = {
            'lost': 'ระบุรายละเอียดการสูญหาย เช่น วันที่สูญหาย สถานที่ ฯลฯ',
            'post_export': 'ระบุรายละเอียดข้อมูลที่ผิดพลาด และยืนยันว่าสินค้าออกจากประเทศไทยแล้ว',
            'linked_external': 'ระบุระบบภายนอกหรือลูกค้าที่ได้รับการเชื่อมโยง/สำแดงใบรับรองนี้',
            'damaged': 'ระบุรายละเอียดความเสียหาย เช่น สาเหตุ ระดับความเสียหาย ฯลฯ',
            'other': 'ระบุรายละเอียดเหตุผลการขอใบรับรองทดแทน'
        };
        ta.placeholder = placeholders[selected.value] || 'ระบุรายละเอียดเหตุผลการขอใบรับรองทดแทน';
    }

    $(document).ready(function () {
        // Select2
        $('.select2').select2({ width: '100%' });

        // Flatpickr
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, {
                    dateFormat: 'd/m/Y',
                    allowInput: true,
                    locale: { firstDayOfWeek: 1 }
                });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function (el) { initFlatpickr(el); });

        $('#modalSearchRMBS1').on('shown.bs.modal', function () {
            $(this).find('.flatpickr-date').each(function () { initFlatpickr(this); });
        });

        $('#modalAddEvidence').on('shown.bs.modal', function () {
            $(this).find('.flatpickr-date').each(function () { initFlatpickr(this); });
            $('#ev_doctype').val('');
            $('#ev_date').val('');
            $('#ev_description').val('');
            $('#ev_file').val('');
            $('#ev_remark').val('');
        });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Toggle sub-row
        $(document).on('click', '.btn-toggle-sub', function () {
            var target = $(this).data('target');
            var $sub = $('#' + target);
            var $icon = $(this).find('i');
            if ($sub.hasClass('d-none')) {
                $sub.removeClass('d-none');
                $icon.removeClass('ri-arrow-right-s-line').addClass('ri-arrow-down-s-line');
            } else {
                $sub.addClass('d-none');
                $icon.removeClass('ri-arrow-down-s-line').addClass('ri-arrow-right-s-line');
            }
        });

        // Click RMBS1 result row
        $(document).on('click', '.rmbs1-result-row', function () {
            $('.rmbs1-result-row').removeClass('table-active');
            $(this).addClass('table-active');
            $(this).find('input[type=radio]').prop('checked', true);
        });

        // Select RMBS1
        $('#btnSelectRmbs1').on('click', function () {
            var $sel = $('input[name=rmbs1Select]:checked');
            if ($sel.length === 0) { alert('กรุณาเลือกรายการก่อน'); return; }
            bootstrap.Modal.getInstance(document.getElementById('modalSearchRMBS1')).hide();
        });

        // Remove RMBS1 row
        $(document).on('click', '.btn-remove-row', function () {
            var target = $(this).data('target');
            $(this).closest('tr').next('#' + target).remove();
            $(this).closest('tr').remove();
        });

        // Evidence functions
        function reindexEvidence() {
            $('#evidenceTbody tr:not(#evidenceTableEmpty)').each(function (i) {
                $(this).find('td:first').text(i + 1);
            });
        }

        $('#btnConfirmAddEvidence').on('click', function () {
            var doctype = $('#ev_doctype').val();
            var doctypeText = $('#ev_doctype option:selected').text();
            var desc = $('#ev_description').val().trim();
            var evDate = $('#ev_date').val().trim();
            var fileName = '';
            if ($('#ev_file')[0].files.length > 0) {
                fileName = $('#ev_file')[0].files[0].name;
            }

            if (!doctype || !desc) {
                alert('กรุณากรอกข้อมูลที่จำเป็นให้ครบถ้วน');
                return;
            }

            var rowCount = $('#evidenceTbody tr:not(#evidenceTableEmpty)').length + 1;
            var fileHtml = fileName
                ? '<span class="badge bg-label-secondary"><i class="ri ri-file-line me-1"></i>' + fileName + '</span>'
                : '<span class="text-muted small">-</span>';

            var $row = $('<tr>' +
                '<td class="text-center text-muted">' + rowCount + '</td>' +
                '<td><span class="badge bg-label-danger">' + doctypeText + '</span></td>' +
                '<td>' + desc + '</td>' +
                '<td class="text-center">' + (evDate || '-') + '</td>' +
                '<td class="text-center">' + fileHtml + '</td>' +
                '<td class="text-center">' +
                '<button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-evidence" title="ลบ">' +
                '<i class="ri ri-delete-bin-line text-danger"></i></button>' +
                '</td></tr>');

            $('#evidenceTbody').append($row);
            bootstrap.Modal.getInstance(document.getElementById('modalAddEvidence')).hide();
        });

        $(document).on('click', '.btn-remove-evidence', function () {
            $(this).closest('tr').remove();
            reindexEvidence();
        });

        // ==================== TOR 1.8(4): E-Signature Canvas ====================
        // Toggle draw/upload panel
        $('input[name=signMethod]').on('change', function () {
            if ($(this).val() === 'draw') {
                $('#panelDraw').removeClass('d-none');
                $('#panelUpload').addClass('d-none');
            } else {
                $('#panelDraw').addClass('d-none');
                $('#panelUpload').removeClass('d-none');
            }
        });

        // Canvas drawing
        var canvas = document.getElementById('signatureCanvas');
        if (canvas) {
            var ctx = canvas.getContext('2d');
            // Make canvas fill its container
            function resizeCanvas() {
                var rect = canvas.parentElement.getBoundingClientRect();
                canvas.width = rect.width || 400;
                canvas.height = 150;
                ctx.strokeStyle = '#1a1a2e';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
            }
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            var drawing = false;
            var hasDraw = false;
            var lastX = 0, lastY = 0;

            function getPos(e) {
                var rect = canvas.getBoundingClientRect();
                if (e.touches && e.touches[0]) {
                    return { x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top };
                }
                return { x: e.clientX - rect.left, y: e.clientY - rect.top };
            }

            canvas.addEventListener('mousedown', function (e) {
                drawing = true;
                var p = getPos(e);
                lastX = p.x; lastY = p.y;
                if (!hasDraw) {
                    document.getElementById('canvasHint').classList.add('d-none');
                    hasDraw = true;
                }
            });
            canvas.addEventListener('mousemove', function (e) {
                if (!drawing) return;
                var p = getPos(e);
                ctx.beginPath();
                ctx.moveTo(lastX, lastY);
                ctx.lineTo(p.x, p.y);
                ctx.stroke();
                lastX = p.x; lastY = p.y;
            });
            canvas.addEventListener('mouseup', function () { drawing = false; });
            canvas.addEventListener('mouseleave', function () { drawing = false; });

            canvas.addEventListener('touchstart', function (e) {
                e.preventDefault();
                drawing = true;
                var p = getPos(e);
                lastX = p.x; lastY = p.y;
                if (!hasDraw) {
                    document.getElementById('canvasHint').classList.add('d-none');
                    hasDraw = true;
                }
            }, { passive: false });
            canvas.addEventListener('touchmove', function (e) {
                e.preventDefault();
                if (!drawing) return;
                var p = getPos(e);
                ctx.beginPath();
                ctx.moveTo(lastX, lastY);
                ctx.lineTo(p.x, p.y);
                ctx.stroke();
                lastX = p.x; lastY = p.y;
            }, { passive: false });
            canvas.addEventListener('touchend', function () { drawing = false; });

            document.getElementById('btnClearSign').addEventListener('click', function () {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                hasDraw = false;
                document.getElementById('canvasHint').classList.remove('d-none');
                var saveBtn = document.getElementById('btnSaveSign');
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="ri ri-save-line me-1"></i>บันทึกลายเซ็น';
                document.getElementById('signedBadge').classList.add('d-none');
            });
        }
        // ==================== /TOR 1.8(4) ====================

    });
</script>
}
