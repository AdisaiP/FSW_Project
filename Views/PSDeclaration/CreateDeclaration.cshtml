        <!-- TOR 1.7(13): banner ตรวจสอบสถานะสุขอนามัยก่อนขอ PS/NMD -->
        <div id="bannerHealthCertNMD">
            <!-- สถานะปกติ (default แสดง) -->
            <div id="alertHealthPassNMD" class="alert alert-success d-flex align-items-center gap-2 mb-3">
                <i class="ri ri-checkbox-circle-fill fs-5"></i>
                <div>
                    <strong>สถานประกอบการ บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด</strong>
                    ผ่านการรับรองสุขอนามัย — สถานะปกติ <span class="badge bg-success ms-1">สามารถขอ PS/NMD ได้</span>
                    <span class="text-muted small ms-2">ข้อมูล ณ วันที่ 28/04/2569 | อ้างอิง: DOF-SHC-2025-0312</span>
                </div>
                <div class="ms-auto">
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="simulateHealthFailNMD()">
                        <i class="ri ri-refresh-line me-1"></i>จำลองสถานะไม่ผ่าน
                    </button>
                </div>
            </div>
            <!-- สถานะไม่ผ่าน (ซ่อน) -->
            <div id="alertHealthFailNMD" class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="display:none !important;">
                <i class="ri ri-close-circle-fill fs-5"></i>
                <div>
                    <strong>สถานประกอบการ บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด</strong>
                    <span class="text-danger fw-semibold">ไม่ผ่านการรับรองสุขอนามัย</span> —
                    <span class="badge bg-danger ms-1">ไม่สามารถยื่นคำขอได้</span>
                    <div class="small mt-1">กรุณาติดต่อเจ้าหน้าที่กรมประมงเพื่อตรวจสอบสถานะก่อนดำเนินการ</div>
                </div>
                <div class="ms-auto">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="simulateHealthPassNMD()">
                        <i class="ri ri-refresh-line me-1"></i>จำลองสถานะผ่าน
                    </button>
                </div>
            </div>
        </div>

        <!-- TOR 1.7(14): banner ตรวจสอบสถานะย้อนกลับก่อนขอ PS/NMD -->
