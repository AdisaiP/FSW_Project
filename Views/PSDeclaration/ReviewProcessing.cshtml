                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label fw-semibold">รายละเอียด <span class="text-danger">*</span></label>
                                        <textarea class="form-control form-control-sm" id="newHistDetail" rows="2"
                                                  placeholder="อธิบายรายละเอียดการดำเนินการ..."></textarea>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">หมายเหตุ</label>
                                        <textarea class="form-control form-control-sm" id="newHistRemark" rows="2"
