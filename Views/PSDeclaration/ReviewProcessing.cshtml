@section PageScripts {
<script>
    $(document).ready(function () {

        // ── 2.4(30): ปุ่มดึงข้อมูลใหม่จากด่าน ──
        $('#btnSyncFromPort').on('click', function () {
            var $btn = $(this);
            var orig = $btn.html();
            $btn.html('<span class="spinner-border spinner-border-sm me-1" role="status"></span>กำลังดึง...').prop('disabled', true);
            setTimeout(function () {
                $btn.html(orig).prop('disabled', false);
                // TODO: call API to sync inspection data from port system
                alert('ข้อมูลตรวจปล่อยล่าสุดแล้ว (Mockup)');
            }, 1500);
        });

        // ── 2.4(31): Demo toggle สถานะ Push to Port ──
        var _pushSentState = true; // default: ส่งแล้ว
        $('#btnTogglePushDemo').on('click', function () {
            _pushSentState = !_pushSentState;
            if (_pushSentState) {
                // สถานะ: ส่งแล้ว
                $('#badgePushSent').removeClass('d-none');
                $('#badgePushPending').addClass('d-none');
                $('#btnResendToPort').removeClass('d-none');
                $('#btnFirstSendToPort').addClass('d-none');
            } else {
                // สถานะ: ยังไม่ส่ง
                $('#badgePushSent').addClass('d-none');
                $('#badgePushPending').removeClass('d-none');
                $('#btnResendToPort').addClass('d-none');
                $('#btnFirstSendToPort').removeClass('d-none');
            }
        });

        // ── 2.4(31): ยืนยันส่งข้อมูลไปด่าน ──
        $('#btnConfirmSendToPort').on('click', function () {
            var $form = $('#selectTargetPort, #sendToPortRemark');
            // show spinner
            $form.prop('disabled', true);
            $(this).prop('disabled', true);
            $('#sendToPortFooter button').prop('disabled', true);
            $('#sendToPortSpinner').removeClass('d-none');
            setTimeout(function () {
                $('#sendToPortSpinner').addClass('d-none');
                var portName = $('#selectTargetPort option:selected').text().split(' (')[0];
                var now = new Date();
                var thYear = now.getFullYear() + 543;
                var pad = function(n){ return String(n).padStart(2,'0'); };
                var ts = pad(now.getDate()) + '/' + pad(now.getMonth()+1) + '/' + thYear
                       + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ' น.';
                $('#sendSuccessDetail').text(portName + ' รับข้อมูลแล้ว เมื่อ ' + ts);
                $('#sendToPortSuccess').removeClass('d-none');
                $('#sendToPortFooter').html(
                    '<button type="button" class="btn btn-success" data-bs-dismiss="modal" id="btnDoneAfterSend">'
                  + '<i class="ri ri-checkbox-circle-fill me-1"></i>เสร็จสิ้น</button>'
                );
                // update badge in header + panel
                _pushSentState = true;
                $('#badgePushSent').text('').html(
                    '<i class="ri ri-checkbox-circle-fill me-1"></i>ส่งข้อมูลแล้ว ✅ เมื่อ ' + ts
                ).removeClass('d-none');
                $('#badgePushPending').addClass('d-none');
                $('#badgeSentToInspection').removeClass('d-none');
                $('#btnFirstSendToPort').addClass('d-none');
                $('#btnResendToPort').removeClass('d-none');
                $('#pushSentTimestamp').text(ts);
                // TODO: call API to send cert data to port system
            }, 2000);
        });

        // reset modal state on close
        $('#modalSendToPort').on('hidden.bs.modal', function () {
            $('#sendToPortSpinner').addClass('d-none');
            $('#sendToPortSuccess').addClass('d-none');
            $('#selectTargetPort, #sendToPortRemark').prop('disabled', false);
            $('#sendToPortFooter').html(
                '<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>'
              + '<button type="button" class="btn btn-success" id="btnConfirmSendToPort">'
              + '<i class="ri ri-send-plane-2-line me-1"></i>ยืนยันส่งข้อมูลไปด่านตรวจปล่อย</button>'
            );
            // re-bind confirm button after DOM replacement
            $(document).off('click', '#btnConfirmSendToPort').on('click', '#btnConfirmSendToPort', function () {
                $('#modalSendToPort').trigger('confirmSend');
            });
        });
        $(document).on('click', '#btnConfirmSendToPort', function () {
            $('#modalSendToPort').find('#btnConfirmSendToPort').trigger('click');
        });

        // ── Toggle sub-row (expand/collapse) ──
        $(document).on('click', '.btn-toggle-sub', function () {
            var target = $(this).data('target');
            var $sub = $('#' + target);
            var $icon = $(this).find('i');
            if ($sub.hasClass('d-none')) {
                $sub.removeClass('d-none');
                $icon.removeClass('ri-arrow-right-s-line').addClass('ri-arrow-down-s-line');
            } else {
                $sub.addClass('d-none');
                $icon.removeClass('ri-arrow-down-s-line').addClass('ri-arrow-right-s-line');
            }
        });

        // ── Action buttons → populate confirm modal ──
        $('[data-bs-target="#modalConfirmAction"]').on('click', function () {
            var actionText  = $(this).data('action-text');
            var actionClass = $(this).data('action-class');
            var noteVal     = $('#officerNote').val();
            $('#confirmActionText').text(actionText);
            $('#confirmActionBtnText').text(actionText);
            $('#modalNote').val(noteVal);
            $('#btnConfirmAction')
                .removeClass('btn-primary btn-danger btn-warning btn-success')
                .addClass(actionClass);
        });

        // ── Confirm action ──
        $('#btnConfirmAction').on('click', function () {
            // TODO: submit to server
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmAction')).hide();
            // Placeholder feedback
            alert('ดำเนินการเรียบร้อยแล้ว');
        });

        // ── RMBS2/P2 Grouping Tab ──
        $('#chkSelectAllGroup').on('change', function () {
            $('.chk-group').prop('checked', $(this).is(':checked'));
        });

        $('#btnMergeAll').on('click', function () {
            // Simulate: mark all mergeable rows as merged
            $('.chk-group').each(function () {
                var group = $(this).data('group');
                var $row = $(this).closest('tr');
                if (group !== 'D') {
                    // already merged, just highlight
                    $row.find('.badge.bg-label-warning').replaceWith('<span class="badge bg-label-success"><i class="ri ri-check-line me-1"></i>รวมแล้ว &#x2705;</span>');
                }
            });
            $(this).prop('disabled', true).html('<i class="ri ri-check-double-line me-1"></i>รวมแล้ว');
            // TODO: call API to merge RMBS2/P2 records
        });

        $('#btnConfirmGrouping').on('click', function () {
            // TODO: confirm grouping and proceed to certificate creation
            alert('ยืนยันการรวมรายการเรียบร้อยแล้ว สามารถสร้างใบรับรองได้');
        });

        $('#btnResetGrouping').on('click', function () {
            location.reload();
        });

        // ── ลงทะเบียนรับคำขอ ──
        $('#btnConfirmRegisterReceive').on('click', function () {
            var newNo = 'รบ. 2026-00' + (Math.floor(Math.random() * 50) + 900);
            document.getElementById('newReceiptNoText').textContent = newNo;
            document.getElementById('registerReceiveResult').classList.remove('d-none');
            $(this).prop('disabled', true);
            // Update status banner
            $('#bannerReceiptNo').text(newNo);
            $('#receiptNoBanner').removeClass('d-none');
            $('#btnOpenRegister').remove();
            // Show จัดทำใบรับรอง, hide ลงทะเบียน+แจ้งแก้ไข
            $('#btnActionRegister, #btnActionNotify').addClass('d-none');
            $('#btnActionPrepareCert').removeClass('d-none');
            // Update status badge
            $('#bannerStatusBadge').removeClass().addClass('badge bg-label-primary rounded-pill px-3 py-2 fs-6');
            $('#bannerStatusText').text('รับคำขอแล้ว');
            // Show next-step flow
            $('#nextStepFlow').removeClass('d-none');
            // Update history tab
            $('#histStepRegIcon').removeClass('bg-label-secondary').addClass('bg-label-primary');
            $('#histStepRegTitle').text('ลงทะเบียนรับคำขอแล้ว');
            $('#histStepRegDate').text('28/04/2569 — เจ้าหน้าที่ระบบ');
            $('#histStepRegNo').html('<span class="badge bg-label-primary">เลขที่รับคำขอ: ' + newNo + '</span>');
            $('#receiptBadgeHistory').removeClass('d-none').find('.receipt-no-ref').text(newNo);
            // TODO: submit form or call API
        });

        // ── ปรับน้ำหนักส่งออก (≤ ที่ขอ) ──
        (function () {
            var MAX_WEIGHT = 12450; // mock — น้ำหนักที่ขอตามใบรับรอง (กก.)
            var weightInput = document.getElementById('adjustedWeightKg');
            var exceedAlert = document.getElementById('weightExceedAlert');
            var okMsg = document.getElementById('weightOkMsg');
            if (!weightInput) return;
            weightInput.addEventListener('input', function () {
                var val = parseFloat(this.value);
                var exceed = !isNaN(val) && val > MAX_WEIGHT;
                exceedAlert.classList.toggle('d-none', !exceed);
                okMsg.classList.add('d-none');
            });
            document.getElementById('btnConfirmAdjustWeight').addEventListener('click', function () {
                var val = parseFloat(weightInput.value);
                if (isNaN(val) || val <= 0) { alert('กรุณาระบุน้ำหนักที่ถูกต้อง'); return; }
                if (val > MAX_WEIGHT) {
                    exceedAlert.classList.remove('d-none');
                    return;
                }
                exceedAlert.classList.add('d-none');
                okMsg.classList.remove('d-none');
                // TODO: submit form or call API — adjust export weight
            });
        })();

        // ── ถอยสถานะ (ReviewProcessing) ──
        $('#btnConfirmRevertReview').on('click', function () {
            var reason = $('#revertReviewReason').val().trim();
            if (!reason) { alert('กรุณาระบุเหตุผลการถอยสถานะ'); return; }
            document.getElementById('revertReviewSuccess').classList.remove('d-none');
            $(this).prop('disabled', true);
            // Update status badge
            $('#bannerStatusBadge').removeClass().addClass('badge bg-label-warning rounded-pill px-3 py-2 fs-6');
            $('#bannerStatusText').text('รอพิจารณา');
            // Swap buttons
            $('#btnActionRevert').addClass('d-none');
            $('#btnActionPrepareCert').addClass('d-none');
            $('#btnActionRegister, #btnActionNotify').removeClass('d-none');
            // TODO: submit form or call API — revert status
        });

        // ── แจ้งแก้ไข (Review page) ──
        $('#btnSendNotifyFixReview').on('click', function () {
            var detail = $('#notifyFixReviewDetail').val().trim();
            if (!detail) { alert('กรุณาระบุรายละเอียดที่ต้องแก้ไข'); return; }
            document.getElementById('notifyFixReviewSuccess').classList.remove('d-none');
            $(this).prop('disabled', true);
            // TODO: submit form or call API — notify fix to operator
        });

        // ── จัดทำใบรับรอง ──
        $('#btnConfirmPrepareCert').on('click', function () {
            document.getElementById('prepareCertSuccess').classList.remove('d-none');
            $(this).prop('disabled', true);
            // Update status badge
            $('#bannerStatusBadge').removeClass().addClass('badge bg-label-info rounded-pill px-3 py-2 fs-6');
            $('#bannerStatusText').html('กำลังจัดทำใบรับรอง &#x1F4CB;');
            // Update next-step flow
            $('#nextStepCertBadge').removeClass('bg-label-info').addClass('bg-label-success');
            $('#nextStepCertText').html('จัดทำใบรับรอง &#x2705;');
            $('#nextStepApproveBadge').removeClass('bg-label-secondary').addClass('bg-label-warning');
            $('#nextStepHint').addClass('d-none');
            $('#nextStepDone').removeClass('d-none');
            // Hide จัดทำ button, show approve
            $('#btnActionPrepareCert').addClass('d-none');
            // TODO: submit form or call API — prepare certificate
        });

        // ── ประวัติการดำเนินการ (2.4(21)) ──
        (function () {
            var btnTable    = document.getElementById('btnViewTable');
            var btnTimeline = document.getElementById('btnViewTimeline');
            var viewTable   = document.getElementById('viewTable');
            var viewTL      = document.getElementById('viewTimeline');
            if (!btnTable) return;

            // Toggle table / timeline
            btnTable.addEventListener('click', function () {
                viewTable.classList.remove('d-none');
                viewTL.classList.add('d-none');
                btnTable.classList.add('active');
                btnTimeline.classList.remove('active');
            });
            btnTimeline.addEventListener('click', function () {
                viewTable.classList.add('d-none');
                viewTL.classList.remove('d-none');
                btnTimeline.classList.add('active');
                btnTable.classList.remove('active');
            });

            // Filter
            var actionFilter = document.getElementById('histFilterAction');
            var textFilter   = document.getElementById('histFilterText');
            var visibleCountEl = document.getElementById('histVisibleCount');
            var emptyRow     = document.getElementById('historyEmpty');

            function applyHistFilter() {
                var act  = (actionFilter.value || '').toLowerCase();
                var txt  = (textFilter.value || '').trim().toLowerCase();
                var rows = document.querySelectorAll('#historyTable tbody tr[data-action-key]');
                var tl   = document.querySelectorAll('#viewTimeline [data-action-key]');
                var vis  = 0;
                var actMap = { 'submit':'submit|upload_doc', 'review':'review_start|review_continue', 'sign':'propose_sign|signed', 'issue':'issue_cert|inspection', 'request_doc':'request_doc' };
                var actPattern = act ? (actMap[act] || act) : '';

                rows.forEach(function (row) {
                    var rowAct    = row.dataset.actionKey || '';
                    var rowActor  = row.dataset.actor     || '';
                    var rowDetail = row.dataset.detail    || '';
                    var actMatch  = !actPattern || actPattern.split('|').some(function (p) { return rowAct.includes(p); });
                    var txtMatch  = !txt || rowActor.includes(txt) || rowDetail.includes(txt);
                    var show = actMatch && txtMatch;
                    row.classList.toggle('d-none', !show);
                    if (show) vis++;
                });
                tl.forEach(function (item) {
                    var rowAct    = item.dataset.actionKey || '';
                    var rowActor  = item.dataset.actor     || '';
                    var rowDetail = item.dataset.detail    || '';
                    var actMatch  = !actPattern || (actMap[act]||act).split('|').some(function (p) { return rowAct.includes(p); });
                    var txtMatch  = !txt || rowActor.includes(txt) || rowDetail.includes(txt);
                    item.classList.toggle('d-none', !(actMatch && txtMatch));
                });
                if (emptyRow) emptyRow.classList.toggle('d-none', vis !== 0);
                if (visibleCountEl) visibleCountEl.textContent = vis;
            }

            actionFilter.addEventListener('change', applyHistFilter);
            textFilter.addEventListener('input', applyHistFilter);
            var btnClearHist = document.getElementById('btnClearHistFilter');
            if (btnClearHist) {
                btnClearHist.addEventListener('click', function () {
                    actionFilter.value = '';
                    textFilter.value   = '';
                    applyHistFilter();
                });
            }

            // Add entry
            var btnSaveEntry = document.getElementById('btnSaveHistEntry');
            if (btnSaveEntry) {
                btnSaveEntry.addEventListener('click', function () {
                    var actionType = document.getElementById('newHistActionType').value;
                    var detail     = document.getElementById('newHistDetail').value.trim();
                    if (!actionType || !detail) { alert('กรุณาเลือกประเภทการกระทำและระบุรายละเอียด'); return; }
                    document.getElementById('histSaveSuccess').classList.remove('d-none');
                    this.disabled = true;
                    setTimeout(function () {
                        document.getElementById('histSaveSuccess').classList.add('d-none');
                        document.getElementById('btnSaveHistEntry').disabled = false;
                        document.getElementById('newHistDetail').value = '';
                        document.getElementById('newHistRemark').value = '';
                        document.getElementById('newHistActionType').value = '';
                        // TODO: submit form or call API — save new history entry
                    }, 2500);
                });
            }

            // Auto-open tab if URL hash is #tab-history
            if (window.location.hash === '#tab-history') {
                var tabBtn = document.querySelector('[data-bs-target="#tab-history"]');
                if (tabBtn) tabBtn.click();
            }
        })();

    });
</script>
}
