@{
    ViewData["Title"] = "ตรวจสอบคำขอใบรับรองการแปรรูปสัตว์น้ำ";

    // Mock data — ในระบบจริงรับจาก Model
    var requestNo    = "REQ-2569-00901";
    var submittedBy  = "บริษัท ซีฟู้ด อินเตอร์เนชั่นแนล จำกัด";
    var submittedAt  = "20/04/2569 09:32 น.";
    var statusKey    = "pending"; // pending | reviewing | approved | returned | rejected
    var statusText   = "รอพิจารณา";
    var statusClass  = "bg-label-warning";
    var statusIcon   = "ri-time-line";
    var receiptNo    = ""; // เลขที่รับคำขอ (ว่าง = ยังไม่ลงทะเบียน)
    var isRegistered = string.IsNullOrEmpty(receiptNo) ? false : true;
}

@* ************** Content ************** *@
<h4 class="mb-1">ตรวจสอบคำขอ</h4>
<p class="mb-1">ตรวจสอบและพิจารณาคำร้องขอใบรับรองการแปรรูปสัตว์น้ำ</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexIssueCertificate", "Officer")" class="text-primary fw-semibold">พิจารณาออกใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active text-secondary">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</li>
    </ol>
</nav>

<!-- ===== Status Banner ===== -->
<div class="card mb-4 border-0 shadow-none" style="background: linear-gradient(135deg,#f0f7ff 0%,#e8f3ff 100%);">
    <div class="card-body py-3">
        <div class="row align-items-center g-3">
            <div class="col-auto">
                <span id="bannerStatusBadge" class="badge @statusClass rounded-pill px-3 py-2 fs-6">
                    <i class="ri @statusIcon me-1"></i><span id="bannerStatusText">@statusText</span>
                </span>
            </div>
            <div class="col">
                <div class="d-flex flex-wrap gap-4">
                    <div>
                        <div class="small text-muted">เลขที่คำขอ</div>
                        <div class="fw-semibold text-primary">@requestNo</div>
                    </div>
                    <div>
                        <div class="small text-muted">ผู้ยื่นคำขอ</div>
                        <div class="fw-semibold">@submittedBy</div>
                    </div>
                    <div>
                        <div class="small text-muted">วันที่ยื่น</div>
                        <div class="fw-semibold">@submittedAt</div>
                    </div>
                    <div>
                        <div class="small text-muted">ประเภทใบรับรอง</div>
                        <div class="fw-semibold">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</div>
                    </div>
                    <div id="receiptNoBanner" class="@(isRegistered ? "" : "d-none")">
                        <div class="small text-muted">เลขที่รับคำขอ</div>
                        <div class="fw-semibold text-success">
                            <i class="ri ri-checkbox-circle-line me-1"></i>
                            <span id="bannerReceiptNo">@receiptNo</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-auto">
                @if (!isRegistered && statusKey == "pending")
                {
                    <button type="button" class="btn btn-primary btn-sm" id="btnOpenRegister"
                        data-bs-toggle="modal" data-bs-target="#modalRegisterReceive">
                        <i class="ri ri-file-add-line me-1"></i>ลงทะเบียนรับคำขอ
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- ===== ขั้นตอนต่อไป (แสดงเมื่อลงทะเบียนรับเรื่องแล้ว) ===== -->
<div id="nextStepFlow" class="d-none mb-4">
    <div class="card border-0" style="background:linear-gradient(135deg,#e8f8f0 0%,#d4f1e4 100%);">
        <div class="card-body py-3">
            <div class="d-flex align-items-center gap-2 mb-3">
                <i class="ri ri-route-line text-success fs-5"></i>
                <span class="fw-semibold text-success">ขั้นตอนดำเนินการ</span>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <!-- Step 1: ยื่นคำขอ -->
                <div class="d-flex align-items-center gap-1">
                    <span class="badge bg-label-success px-2 py-1">
                        <i class="ri ri-send-plane-line me-1"></i>ยื่นคำขอ &#x2705;
                    </span>
                </div>
                <i class="ri ri-arrow-right-line text-muted"></i>
                <!-- Step 2: ลงทะเบียนรับเรื่อง -->
                <div class="d-flex align-items-center gap-1">
                    <span class="badge bg-label-success px-2 py-1">
                        <i class="ri ri-file-add-line me-1"></i>ลงทะเบียนรับเรื่อง &#x2705;
                    </span>
                </div>
                <i class="ri ri-arrow-right-line text-muted"></i>
                <!-- Step 3: จัดทำใบรับรอง (current/done) -->
                <div class="d-flex align-items-center gap-1">
                    <span id="nextStepCertBadge" class="badge bg-label-info px-2 py-1">
                        <i class="ri ri-file-text-line me-1"></i><span id="nextStepCertText">จัดทำใบรับรอง &#x1F4CB;</span>
                    </span>
                </div>
                <i class="ri ri-arrow-right-line text-muted"></i>
                <!-- Step 4: พิจารณา/อนุมัติ -->
                <div class="d-flex align-items-center gap-1">
                    <span id="nextStepApproveBadge" class="badge bg-label-secondary px-2 py-1">
                        <i class="ri ri-checkbox-circle-line me-1"></i>พิจารณา/อนุมัติ
                    </span>
                </div>
                <i class="ri ri-arrow-right-line text-muted"></i>
                <!-- Step 5: ออกใบรับรอง -->
                <div class="d-flex align-items-center gap-1">
                    <span class="badge bg-label-secondary px-2 py-1">
                        <i class="ri ri-file-certificate-line me-1"></i>ออกใบรับรอง
                    </span>
                </div>
            </div>
            <!-- next-action hint -->
            <div id="nextStepHint" class="mt-3 small text-success d-flex align-items-center gap-2">
                <i class="ri ri-arrow-right-circle-line fs-5"></i>
                <span>ขั้นตอนถัดไป: กด <strong>"จัดทำใบรับรอง"</strong> ใน Action Bar ด้านล่างเพื่อเริ่มกระบวนการออกใบรับรอง</span>
            </div>
            <div id="nextStepDone" class="mt-3 small text-info d-flex align-items-center gap-2 d-none">
                <i class="ri ri-checkbox-circle-fill fs-5"></i>
                <span>กระบวนการจัดทำใบรับรองเริ่มต้นแล้ว — รอผลการพิจารณาขั้นสุดท้าย</span>
            </div>
        </div>
    </div>
</div>

