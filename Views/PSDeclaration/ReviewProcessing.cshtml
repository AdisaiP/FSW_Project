                                <button type="button" class="btn btn-outline-primary btn-sm active" id="btnViewTable" style="font-size:0.75rem;">
                                    <i class="ri ri-table-line me-1"></i>ตาราง
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" id="btnViewTimeline" style="font-size:0.75rem;">
                                    <i class="ri ri-git-branch-line me-1"></i>Timeline
                                </button>
                            </div>
                            <button type="button" class="btn btn-outline-success btn-sm" id="btnAddHistoryEntry"
                                    data-bs-toggle="collapse" data-bs-target="#collapseAddHistory"
                                    style="font-size:0.75rem;">
                                <i class="ri ri-add-line me-1"></i>บันทึกรายการใหม่
                            </button>
                        </div>
                    </div>

                    <!-- Summary bar -->
                    <div class="row g-2 mb-4">
                        @{
                            var hSubmit   = historyLog.Count(h => h.ActionKey == "submit" || h.ActionKey == "upload_doc");
                            var hReview   = historyLog.Count(h => h.ActionKey.StartsWith("review"));
                            var hSign     = historyLog.Count(h => h.ActionKey == "propose_sign" || h.ActionKey == "signed");
                            var hIssue    = historyLog.Count(h => h.ActionKey == "issue_cert" || h.ActionKey == "inspection");
                        }
                        <div class="col-6 col-md-3">
                            <div class="rounded p-2 text-center" style="background:#f0f9f0;border:1px solid #c3e6cb;font-size:0.78rem;">
                                <div class="fw-semibold">@hSubmit</div>
                                <div class="text-muted small">ยื่น/แนบเอกสาร</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="rounded p-2 text-center" style="background:#e8f4fd;border:1px solid #bee5eb;font-size:0.78rem;">
                                <div class="fw-semibold">@hReview</div>
                                <div class="text-muted small">พิจารณา</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="rounded p-2 text-center" style="background:#fff3cd;border:1px solid #ffc107;font-size:0.78rem;">
                                <div class="fw-semibold">@hSign</div>
                                <div class="text-muted small">เสนอ/ลงนาม</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="rounded p-2 text-center" style="background:#d4edda;border:1px solid #28a745;font-size:0.78rem;">
                                <div class="fw-semibold">@hIssue</div>
                                <div class="text-muted small">ออกใบรับรอง/ตรวจปล่อย</div>
                            </div>
                        </div>
                    </div>

                    <!-- Filter bar -->
                    <div class="d-flex gap-2 align-items-center flex-wrap mb-3" style="font-size:0.8rem;">
                        <label class="mb-0 text-muted">กรองตาม:</label>
                        <select class="form-select form-select-sm" id="histFilterAction" style="width:auto;">
                            <option value="">ทุกการกระทำ</option>
                            <option value="submit">ยื่น/แนบเอกสาร</option>
                            <option value="review">พิจารณา</option>
                            <option value="sign">เสนอ/ลงนาม</option>
                            <option value="issue">ออกใบรับรอง</option>
                            <option value="request_doc">ขอเอกสารเพิ่ม</option>
                        </select>
                        <input type="text" class="form-control form-control-sm" id="histFilterText"
                               placeholder="ค้นหาผู้ดำเนินการ / รายละเอียด..." style="width:220px;" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearHistFilter">
                            <i class="ri ri-refresh-line"></i>
                        </button>
                        <div class="ms-auto">
                            <span class="text-muted small">แสดง <span id="histVisibleCount">@historyLog.Length</span> / @historyLog.Length รายการ</span>
                        </div>
                    </div>

                    <!-- ── TABLE VIEW ── -->
                    <div id="viewTable">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle mb-0" style="font-size:0.78rem;" id="historyTable">
                                <thead class="table-light text-center">
                                    <tr>
                                        <th style="width:30px;">#</th>
                                        <th style="width:120px;">วันที่/เวลา</th>
                                        <th>ผู้ดำเนินการ</th>
                                        <th style="width:80px;">บทบาท</th>
                                        <th style="width:140px;">การกระทำ</th>
                                        <th>รายละเอียด</th>
                                        <th style="width:130px;">หมายเหตุ</th>
                                        <th style="width:40px;">ไฟล์</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in historyLog)
                                    {
                                        <tr data-action-key="@h.ActionKey" data-actor="@h.Actor.ToLower()" data-detail="@h.Detail.ToLower()">
                                            <td class="text-center text-muted">@h.No</td>
                                            <td class="text-center" style="white-space:nowrap;">
                                                @{
                                                    var dateParts = h.DateStr.Split(' ');
                                                }
                                                <div class="fw-semibold">@dateParts[0]</div>
                                                @if (dateParts.Length > 1) {
                                                    <div class="text-muted small">@dateParts[1] น.</div>
                                                }
                                            </td>
                                            <td>
                                                <div class="fw-semibold">@h.Actor</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-label-secondary" style="font-size:0.62rem;">@h.Role</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @h.ActionClass" style="font-size:0.68rem;">@h.ActionText</span>
                                            </td>
                                            <td>@h.Detail</td>
                                            <td class="text-muted small">
                                                @if (!string.IsNullOrEmpty(h.Remark)) {
                                                    <span>@h.Remark</span>
                                                } else {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (h.HasFile) {
                                                    <a href="#" class="text-danger" data-bs-toggle="tooltip" title="ดาวน์โหลดไฟล์แนบ">
                                                        <i class="ri ri-file-pdf-line"></i>
                                                    </a>
                                                } else {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    <tr id="historyEmpty" class="d-none">
                                        <td colspan="8" class="text-center text-muted py-3">ไม่พบรายการที่ตรงกับเงื่อนไข</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- ── TIMELINE VIEW ── -->
                    <div id="viewTimeline" class="d-none">
                        <div class="timeline-history ps-2" style="font-size:0.82rem;">
                            @foreach (var h in historyLog)
                            {
                                var isLast = h.No == historyLog.Length;
                                <div class="d-flex gap-3 @(isLast ? "mb-2" : "mb-4")" data-action-key="@h.ActionKey" data-actor="@h.Actor.ToLower()" data-detail="@h.Detail.ToLower()">
                                    <div class="flex-shrink-0 d-flex flex-column align-items-center" style="width:2rem;">
                                        <span class="badge @h.ActionClass rounded-circle d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;">
                                            @{
                                                var icon = h.ActionKey switch {
                                                    "submit"         => "ri-upload-2-line",
                                                    "register"       => "ri-file-add-line",
                                                    "review_start"   => "ri-search-eye-line",
                                                    "review_continue"=> "ri-search-eye-line",
                                                    "request_doc"    => "ri-question-line",
                                                    "upload_doc"     => "ri-attachment-2",
                                                    "approve_draft"  => "ri-draft-line",
                                                    "propose_sign"   => "ri-send-plane-line",
                                                    "signed"         => "ri-pen-nib-line",
                                                    "issue_cert"     => "ri-award-line",
                                                    "inspection"     => "ri-shield-check-line",
                                                    _                => "ri-checkbox-circle-line"
                                                };
                                            }
                                            <i class="ri @icon"></i>
                                        </span>
                                        @if (!isLast) {
                                            <div class="flex-grow-1 border-start border-2 border-light mt-1" style="min-height:2.5rem;"></div>
                                        }
                                    </div>
                                    <div class="pt-1">
                                        <div class="fw-semibold">@h.ActionText</div>
                                        <div class="text-muted small">@h.DateStr น. — @h.Actor
                                            <span class="badge bg-label-secondary ms-1" style="font-size:0.6rem;">@h.Role</span>
                                        </div>
                                        <div class="mt-1 small">@h.Detail</div>
                                        @if (!string.IsNullOrEmpty(h.Remark)) {
                                            <div class="mt-1">
                                                <span class="badge bg-label-light border" style="font-size:0.65rem;color:#555;">
                                                    <i class="ri ri-chat-1-line me-1"></i>@h.Remark
                                                </span>
                                            </div>
                                        }
                                        @if (h.HasFile) {
                                            <div class="mt-1">
                                                <a href="#" class="small text-danger">
                                                    <i class="ri ri-file-pdf-line me-1"></i>ดาวน์โหลดไฟล์แนบ
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

