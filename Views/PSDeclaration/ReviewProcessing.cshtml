                    <!-- Header + Summary Stats -->
                    <div class="row g-3 mb-4">
                        <div class="col">
                            <h6 class="fw-semibold mb-0" style="font-size:0.88rem;">
                                <i class="ri ri-history-line me-1 text-primary"></i>ประวัติการดำเนินการทั้งหมด
