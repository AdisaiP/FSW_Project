                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                data-bs-toggle="collapse" data-bs-target="#collapseAddHistory">
                                            ยกเลิก
                                        </button>
                                        <div id="histSaveSuccess" class="d-none ms-2 d-flex align-items-center">
                                            <span class="badge bg-label-success px-2 py-1 small">
                                                <i class="ri ri-checkbox-circle-line me-1"></i>บันทึกแล้ว
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!-- /collapseAddHistory -->

                    <div class="d-flex align-items-center gap-2 mt-3">
