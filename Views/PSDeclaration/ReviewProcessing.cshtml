                                            <option value="return">ส่งกลับแก้ไข</option>
                                            <option value="other">อื่นๆ</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-semibold">ผู้ดำเนินการ</label>
                                        <input type="text" class="form-control form-control-sm" id="newHistActor"
                                               value="นางสาว วรรณา พิมพ์ทอง" placeholder="ชื่อเจ้าหน้าที่" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label fw-semibold">วันที่/เวลา</label>
