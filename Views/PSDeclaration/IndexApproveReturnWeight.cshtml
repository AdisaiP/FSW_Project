                    <option value="อนุมัติให้คืนน้ำหนัก">อนุมัติให้คืนน้ำหนัก</option>
                    <option value="อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข">อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข</option>
                    <option value="ไม่อนุมัติให้คืนน้ำหนัก">ไม่อนุมัติให้คืนน้ำหนัก</option>
