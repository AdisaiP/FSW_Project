                    <div class="col-auto">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                            <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="d-flex gap-2 filter-action-buttons">
                            <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4 col-lg-3">
                        <label for="filterExportDateFrom" class="form-label">วันที่ส่งออก (ตั้งแต่)</label>
                        <input type="text" id="filterExportDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <label for="filterExportDateTo" class="form-label">ถึงวันที่</label>
                        <input type="text" id="filterExportDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="filterExportNearOnly" />
                            <label class="form-check-label small" for="filterExportNearOnly">เฉพาะใกล้วันส่งออก (≤ 3 วัน)</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการติดตามสถานะคำขอใบรับรอง</h5>
            <p class="text-muted small mb-0">แสดงสถานะการตรวจสอบ อนุมัติ และลายมือชื่ออิเล็กทรอนิกส์ของคำขอทั้งหมด</p>
        </div>
        <!-- TOR 1.7(34): Export Excel -->
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-success btn-sm"
                onclick="alert('Export Excel รายการติดตามสถานะคำขอใบรับรอง (mockup)\n\nรายการที่ export:\n- เลขที่คำขอ\n- เลขที่รับ\n- Health Certificate Number\n- HS Code\n- สถานะการตรวจสอบ\n- สถานะอนุมัติ\n- ลายมือชื่ออิเล็กทรอนิกส์')">
                <i class="ri ri-file-excel-2-line me-1"></i> Export Excel
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:250px;">เลขที่คำขอ</th>
                    <th style="width:70px;">เลขที่<br/>รับ</th>
                    <th style="min-width:155px;">Health Certificate<br/>Number</th>
                    <th style="width:90px;">HS Code</th>
                    <th style="min-width:210px;">ใบรับรอง</th>
                    <th style="min-width:200px;">ผู้ผลิตสินค้า</th>
                    <th style="min-width:120px;">ประเทศปลายทาง</th>
                    <th style="min-width:130px;">วันที่ยื่นคำขอ</th>
                    <th style="min-width:120px;">วันส่งออก</th>
                    <th style="width:100px;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    var expDate = exportDates.ContainsKey(request.RequestNumber) ? exportDates[request.RequestNumber] : (DateTime?)null;
                    var daysLeft = expDate.HasValue ? (int)((expDate.Value - today).TotalDays) : 999;
                    var isNearExport = daysLeft >= 0 && daysLeft <= alertThresholdDays;
                    <tr data-certificate="@request.CertificateKey" data-status="@request.StatusText" data-draft-date="@request.DraftedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-export-date="@(expDate.HasValue ? expDate.Value.ToString("yyyy-MM-dd") : "")" data-days-left="@(expDate.HasValue ? daysLeft.ToString() : "")" data-near-export="@(isNearExport ? "true" : "false")">
                        <td>
                            <a href="@request.DetailUrl" class="fw-semibold text-primary text-decoration-none">@request.RequestNumber</a>
                            <div class="mt-1 d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.StatusClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                        @if (request.StatusText == "ส่งคำขอแล้ว")
                                        {
                                            <i class="ri ri-send-plane-fill" style="font-size:0.6rem;"></i>
                                        }
                                        else if (request.StatusText == "ร่างคำขอ")
                                        {
                                            <i class="ri ri-draft-line" style="font-size:0.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="ri ri-checkbox-blank-circle-fill" style="font-size:0.6rem;"></i>
                                        }
