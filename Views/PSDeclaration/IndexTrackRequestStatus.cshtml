    </ol>
</nav>

<!-- ==================== TOR 1.7(22): notification panel ==================== -->
@if (nearCount > 0)
{
    <div id="panelNearExport" class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
        <i class="ri ri-notification-3-fill fs-4 flex-shrink-0 mt-1 text-warning"></i>
        <div class="flex-grow-1">
            <h6 class="alert-heading mb-1">แจ้งเตือน: คำขอใกล้ถึงวันที่ส่งออก</h6>
            <span>มี <strong>@nearCount คำขอ</strong> ที่ใกล้ถึงวันที่ส่งออก (ภายใน @alertThresholdDays วัน) — กรุณาตรวจสอบและดำเนินการโดยเร็ว</span>
            <div class="mt-2 d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-warning"
                    onclick="document.getElementById('filterExportNearOnly').checked=true; filterRows(); this.closest('.alert').scrollIntoView({behavior:'smooth'});">
                    <i class="ri ri-filter-line me-1"></i>กรองเฉพาะใกล้วันส่งออก
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="alert">
                    <i class="ri ri-close-line me-1"></i>ปิด
                </button>
            </div>
        </div>
    </div>
}

<!-- ==================== TOR 1.7(22): threshold setting ==================== -->
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="text-muted small"><i class="ri ri-settings-3-line me-1"></i>ตั้งค่าการแจ้งเตือนล่วงหน้า:</span>
    <div class="input-group input-group-sm" style="width:auto;">
        <input type="number" id="inputThresholdDays" class="form-control form-control-sm" value="@alertThresholdDays" min="1" max="30" style="width:5rem;" />
        <span class="input-group-text">วัน</span>
    </div>
    <button type="button" class="btn btn-sm btn-outline-primary" onclick="applyThresholdSetting()">
        <i class="ri ri-refresh-line me-1"></i>ใช้งาน
    </button>
    <span id="thresholdAppliedMsg" class="badge bg-label-success" style="display:none;">บันทึกแล้ว ✓</span>
</div>

<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ตัวกรองการค้นหา</h5>
            <p class="text-muted small mb-0">ค้นหารายการคำขอตามประเภทใบรับรองและช่วงวันที่ร่างคำขอ</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4 col-lg-3">
                <label for="filterCertificate" class="form-label">ใบรับรอง</label>
                <select id="filterCertificate" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="declaration">ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)</option>
                    <option value="processing">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ส่งคำขอแล้ว">ส่งคำขอแล้ว</option>
                    <option value="ร่างคำขอ">ร่างคำขอ</option>
                </select>
            </div>
            <div class="col-md-12 col-lg-6">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label for="filterDraftDateFrom" class="form-label">วันที่ยื่นคำขอ</label>
                        <input type="text" id="filterDraftDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-md-4">
                        <label for="filterDraftDateTo" class="form-label">ถึงวันที่</label>
                        <input type="text" id="filterDraftDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
