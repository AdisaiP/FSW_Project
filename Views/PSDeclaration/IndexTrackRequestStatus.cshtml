                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.AutoProcessClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
