@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');
        var exportFromInput = document.getElementById('filterExportDateFrom');
        var exportToInput = document.getElementById('filterExportDateTo');

        [fromInput, toInput, exportFromInput, exportToInput].forEach(function (el) {
            if (el) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) { return null; }
            var parts = value.split('/');
            if (parts.length !== 3) { return null; }
            var day   = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year  = parseInt(parts[2], 10);
            var parsed = new Date(year, month, day, endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certificate   = (document.getElementById('filterCertificate').value || '').trim();
            var status        = (document.getElementById('filterStatus').value || '').trim();
            var fromDate      = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate        = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var excludeRange  = document.getElementById('filterDateExclude').checked;
            var expFrom       = parseDateInput(document.getElementById('filterExportDateFrom').value, false);
            var expTo         = parseDateInput(document.getElementById('filterExportDateTo').value, true);
            var nearOnly      = document.getElementById('filterExportNearOnly').checked;
            var rows          = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount  = 0;

            rows.forEach(function (row) {
                var rowCertificate = row.dataset.certificate || '';
                var rowStatus      = row.dataset.status      || '';
                var rowDraftDate   = new Date(row.dataset.draftDate || '');
                var rowExpDateStr  = row.dataset.exportDate  || '';
                var rowNearExport  = row.dataset.nearExport  === 'true';
                var rowExpDate     = rowExpDateStr ? new Date(rowExpDateStr) : null;

                var certMatch   = !certificate || rowCertificate === certificate;
                var statusMatch = !status      || rowStatus       === status;

                var dateMatch;
                if (!fromDate && !toDate) {
                    dateMatch = true;
                } else if (excludeRange) {
                    var inRange = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                    dateMatch = !inRange;
                } else {
                    dateMatch = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                }

                var expDateMatch;
                if (nearOnly) {
                    expDateMatch = rowNearExport;
                } else if (!expFrom && !expTo) {
                    expDateMatch = true;
                } else {
                    expDateMatch = rowExpDate && (!expFrom || rowExpDate >= expFrom) && (!expTo || rowExpDate <= expTo);
                }

                var isVisible = certMatch && statusMatch && dateMatch && expDateMatch;
                row.classList.toggle('d-none', !isVisible);
                if (isVisible) { visibleCount += 1; }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterCertificate').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateTo').addEventListener('change', filterRows);
        document.getElementById('filterDateExclude').addEventListener('change', filterRows);
        document.getElementById('filterExportDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterExportDateTo').addEventListener('change', filterRows);
        document.getElementById('filterExportNearOnly').addEventListener('change', filterRows);

        document.querySelectorAll('#filterCertificate, #filterStatus, #filterDraftDateFrom, #filterDraftDateTo, #filterExportDateFrom, #filterExportDateTo').forEach(function (element) {
            element.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') { event.preventDefault(); filterRows(); }
            });
        });

        document.getElementById('btnResetRequests').addEventListener('click', function () {
            document.getElementById('filterCertificate').value       = '';
            document.getElementById('filterStatus').value            = '';
            document.getElementById('filterDraftDateFrom').value     = '';
            document.getElementById('filterDraftDateTo').value       = '';
            document.getElementById('filterDateExclude').checked     = false;
            document.getElementById('filterExportDateFrom').value    = '';
            document.getElementById('filterExportDateTo').value      = '';
            document.getElementById('filterExportNearOnly').checked  = false;
            filterRows();
        });
    });

    // TOR 1.7(22): ตั้งค่าล่วงหน้า — ปรับ threshold แล้ว re-highlight badge ใน table
    function applyThresholdSetting() {
        var thresholdInput = document.getElementById('inputThresholdDays');
        var threshold = parseInt(thresholdInput.value, 10);
        if (isNaN(threshold) || threshold < 1) { threshold = 3; thresholdInput.value = 3; }
        var today = new Date(2026, 3, 27); // fixed mockup date 27/04/2026
        var rows = document.querySelectorAll('#requestTableBody tr[data-export-date]');
        rows.forEach(function (row) {
            var expDateStr = row.dataset.exportDate;
            if (!expDateStr) { return; }
            var parts = expDateStr.split('-');
            var expDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
            var daysLeft = Math.round((expDate - today) / 86400000);
            var isNear = daysLeft >= 0 && daysLeft <= threshold;
            row.dataset.nearExport = isNear ? 'true' : 'false';
            row.dataset.daysLeft = daysLeft.toString();
            // update the export date cell (column index 8)
            var exportCell = row.querySelectorAll('td')[8];
            if (exportCell) {
                var dateDiv = exportCell.querySelector('div');
                var badge = exportCell.querySelector('span.badge');
                if (dateDiv) {
                    dateDiv.className = 'text-nowrap fw-semibold' + (isNear ? ' text-danger' : '');
                }
                if (badge) {
                    if (isNear) {
                        badge.className = 'badge bg-label-danger';
                        badge.textContent = 'เหลือ ' + daysLeft + ' วัน ⚠️';
                    } else {
                        badge.className = 'badge bg-label-secondary';
                        badge.textContent = daysLeft + ' วัน';
                    }
                }
            }
        });
        // update notification panel count
        var nearCount = document.querySelectorAll('#requestTableBody tr[data-near-export="true"]').length;
        var panel = document.getElementById('panelNearExport');
        if (panel) {
            var strongEl = panel.querySelector('strong');
            if (strongEl) { strongEl.textContent = nearCount + ' คำขอ'; }
            var infoSpan = panel.querySelector('span');
            if (infoSpan) {
                infoSpan.innerHTML = 'มี <strong>' + nearCount + ' คำขอ</strong> ที่ใกล้ถึงวันที่ส่งออก (ภายใน ' + threshold + ' วัน) — กรุณาตรวจสอบและดำเนินการโดยเร็ว';
            }
            panel.style.display = nearCount > 0 ? '' : 'none';
        }
        // show saved msg
        var msg = document.getElementById('thresholdAppliedMsg');
        if (msg) {
            msg.style.display = '';
            setTimeout(function () { msg.style.display = 'none'; }, 2000);
        }
        // update nearOnly checkbox label
        var nearLabel = document.querySelector('label[for="filterExportNearOnly"]');
        if (nearLabel) { nearLabel.textContent = 'เฉพาะใกล้วันส่งออก (≤ ' + threshold + ' วัน)'; }
    }
</script>
}

@* ************** Content ************** *@
<h4 class="mb-1">ติดตามสถานะคำขอใบรับรอง</h4>
<p class="mb-1">ติดตามสถานะการตรวจสอบและอนุมัติของคำขอใบรับรองสัตว์น้ำไม่แปรรูป และใบรับรองการแปรรูปสัตว์น้ำ รวมถึงสถานะลายมือชื่ออิเล็กทรอนิกส์</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "PSDeclaration")" class="text-primary fw-semibold">ติดตามสถานะคำขอใบรับรอง</a>
