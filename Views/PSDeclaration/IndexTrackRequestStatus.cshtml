                                <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียดข้อมูล" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="รายละเอียดข้อมูล">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                @if (request.AllowClone)
                                {
                                    <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-secondary" title="บันทึกเป็นคำขอใหม่" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="บันทึกเป็นคำขอใหม่">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </a>
                                }
                                @if (request.AllowEdit)
                                {
                                    <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไขคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="แก้ไขคำขอ">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </a>
                                }
                                @if (request.AllowCancel)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-dark" title="ยกเลิกคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ยกเลิกคำขอ">
                                        <i class="ri ri-close-circle-line text-dark"></i>
                                    </button>
                                }
                                @if (request.AllowSubmit)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" title="ส่งคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ส่งคำขอ">
                                        <i class="ri ri-send-plane-line text-success"></i>
                                    </button>
                                }
                                @if (request.AllowDelete)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ลบคำขอ">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="10" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>