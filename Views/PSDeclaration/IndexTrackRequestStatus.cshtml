                                    <span><span class="fw-semibold">สถานะ:</span> @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    @if (request.SignatureStatusText == "ลงลายมือชื่อแล้ว")
                                    {
                                        <span class="badge rounded-circle bg-label-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-check-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-circle bg-label-warning d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
                                            <i class="ri ri-time-line" style="font-size:0.6rem;"></i>
                                        </span>
                                    }
                                    <span><span class="fw-semibold">ลายมือชื่อ:</span> @request.SignatureStatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @request.WrittenByClass d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.2rem;height:1.2rem;padding:0;">
