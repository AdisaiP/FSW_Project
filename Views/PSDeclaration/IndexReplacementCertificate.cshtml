                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ฉบับร่าง">ฉบับร่าง</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติ">อนุมัติ</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="declaration">Declaration (NMD)</option>
                    <option value="processing">Processing Statement (PS)</option>
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label for="filterLinked" class="form-label">สถานะเชื่อมโยง</label>
                <select id="filterLinked" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="false">สามารถแก้ไขได้</option>
                    <option value="true">เชื่อมโยง/สำแดงแล้ว</option>
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-3">
                <label for="filterRequestNo" class="form-label">เลขที่คำขอ</label>
                <input type="text" id="filterRequestNo" class="form-control" placeholder="REP821B..." />
            </div>
            <div class="col-6 col-md-3 col-lg-3">
                <label for="filterCertNo" class="form-label">เลขที่ใบรับรอง</label>
                <input type="text" id="filterCertNo" class="form-control" placeholder="HC... / AC..." />
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label for="filterReceiveNo" class="form-label">เลขที่รับคำขอ</label>
                <input type="text" id="filterReceiveNo" class="form-control" placeholder="RCV-2569..." />
            </div>
            <!-- แถว 2: text filters เพิ่มเติม -->
            <div class="col-md-4 col-lg-3">
                <label for="filterEstab" class="form-label">ชื่อสถานประกอบการ</label>
                <input type="text" id="filterEstab" class="form-control" placeholder="บริษัท..."/>
            </div>
            <div class="col-md-4 col-lg-2">
                <label for="filterApprovalNo" class="form-label">หมายเลขรับรองโรงงาน</label>
                <input type="text" id="filterApprovalNo" class="form-control" placeholder="AP-74110..." />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterProduct" class="form-label">ชื่อสินค้า</label>
