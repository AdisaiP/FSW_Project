@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, { dateFormat: 'd/m/Y', allowInput: true });
        }
        if (toInput) {
            flatpickr(toInput, { dateFormat: 'd/m/Y', allowInput: true });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var h = endOfDay ? 23 : 0, m = endOfDay ? 59 : 0, s = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, h, m, s);
            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var status = (document.getElementById('filterStatus').value || '').trim();
            var certType = (document.getElementById('filterCertType').value || '').trim();
            var linked = (document.getElementById('filterLinked').value || '').trim();
            var requestNo = (document.getElementById('filterRequestNo').value || '').trim().toLowerCase();
            var certNo = (document.getElementById('filterCertNo').value || '').trim().toLowerCase();
            var receiveNo = (document.getElementById('filterReceiveNo').value || '').trim().toLowerCase();
            var estab = (document.getElementById('filterEstab').value || '').trim().toLowerCase();
            var approvalNo = (document.getElementById('filterApprovalNo').value || '').trim().toLowerCase();
            var product = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
            var country = (document.getElementById('filterCountry').value || '').trim().toLowerCase();
            var fromDate = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var excludeRange = document.getElementById('filterDateExclude').checked;
            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowStatus = row.dataset.status || '';
                var rowCert = row.dataset.certificate || '';
                var rowLinked = row.dataset.linked || '';
                var rowReqNo = row.dataset.requestNo || '';
                var rowCertNo = row.dataset.certNo || '';
                var rowReceiveNo = row.dataset.receiveNo || '';
                var rowEstab = row.dataset.estab || '';
                var rowApprovalNo = row.dataset.approvalNo || '';
                var rowProduct = row.dataset.product || '';
                var rowCountry = row.dataset.country || '';
                var rowDate = new Date(row.dataset.draftDate || '');
                var statusMatch = !status || rowStatus === status;
                var certMatch = !certType || rowCert === certType;
                var linkedMatch = !linked || rowLinked === linked;
                var reqNoMatch = !requestNo || rowReqNo.includes(requestNo);
                var certNoMatch = !certNo || rowCertNo.includes(certNo);
                var receiveNoMatch = !receiveNo || rowReceiveNo.includes(receiveNo);
                var estabMatch = !estab || rowEstab.includes(estab);
                var approvalNoMatch = !approvalNo || rowApprovalNo.includes(approvalNo);
                var productMatch = !product || rowProduct.includes(product);
                var countryMatch = !country || rowCountry.includes(country);
                var dateMatch;
                if (!fromDate && !toDate) {
                    dateMatch = true;
                } else if (excludeRange) {
                    var inRange = (!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate);
                    dateMatch = !inRange;
                } else {
                    dateMatch = (!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate);
                }
                var isVisible = statusMatch && certMatch && linkedMatch && reqNoMatch && certNoMatch && receiveNoMatch && estabMatch && approvalNoMatch && productMatch && countryMatch && dateMatch;
                row.classList.toggle('d-none', !isVisible);
                if (isVisible) visibleCount++;
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterCertType').addEventListener('change', filterRows);
        document.getElementById('filterLinked').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateTo').addEventListener('change', filterRows);
        document.getElementById('filterDateExclude').addEventListener('change', filterRows);

        ['filterStatus', 'filterCertType', 'filterLinked',
         'filterRequestNo', 'filterCertNo', 'filterReceiveNo',
         'filterEstab', 'filterApprovalNo', 'filterProduct', 'filterCountry',
         'filterDraftDateFrom', 'filterDraftDateTo'].forEach(function (id) {
            document.getElementById(id).addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });

        document.getElementById('btnResetRequests').addEventListener('click', function () {
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterCertType').value = '';
            document.getElementById('filterLinked').value = '';
            document.getElementById('filterRequestNo').value = '';
            document.getElementById('filterCertNo').value = '';
            document.getElementById('filterReceiveNo').value = '';
            document.getElementById('filterEstab').value = '';
            document.getElementById('filterApprovalNo').value = '';
            document.getElementById('filterProduct').value = '';
            document.getElementById('filterCountry').value = '';
            document.getElementById('filterDraftDateFrom').value = '';
            document.getElementById('filterDraftDateTo').value = '';
            document.getElementById('filterDateExclude').checked = false;
            filterRows();
        });
    });
</script>
}

