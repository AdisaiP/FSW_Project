                    <div class="col-md-4">
                        <label for="filterDraftDateFrom" class="form-label">วันที่ยื่นคำขอ</label>
                        <input type="text" id="filterDraftDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-md-4">
                        <label for="filterDraftDateTo" class="form-label">ถึงวันที่</label>
                        <input type="text" id="filterDraftDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                            <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="d-flex gap-2 filter-action-buttons">
                            <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square" title="รีเซ็ต">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอใบรับรองทดแทนฉบับเก่า</h5>
            <p class="text-muted small mb-0">รายการคำขอใบรับรองทดแทนสำหรับใบรับรองสูญหายหรือชำรุดเสียหาย</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a href="@Url.Action("SelectTypeReplacement", "PSDeclaration")" class="btn btn-primary btn-sm">
                <i class="ri ri-add-line me-1"></i> สร้างคำขอ
            </a>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:180px;">เลขที่คำขอ</th>
                    <th style="min-width:200px;">ใบรับรอง</th>
                    <th style="min-width:160px;">เลขที่ใบรับรองเดิม</th>
                    @* TOR 1.9(8): เลขที่ใบรับรองใหม่ (ใบแทน) *@
                    <th style="min-width:160px;">เลขที่ใบรับรองใหม่ (ใบแทน)</th>
                    <th>เหตุผลการขอ</th>
                    <th style="min-width:150px;">วันที่ทำรายการ</th>
                    <th style="min-width:160px;">สถานะการเชื่อมโยง</th>
                    <th style="width:7rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey"
                        data-status="@request.StatusText"
                        data-draft-date="@request.TransactionAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-linked="@request.IsLinkedExternal.ToString().ToLower()"
                        data-request-no="@request.RequestNumber.ToLower()"
                        data-cert-no="@((request.OriginalCertNumber + " " + request.NewCertNumber).ToLower())"
                        data-estab="@request.Establishment.ToLower()"
                        data-approval-no="@request.ApprovalNo.ToLower()"
                        data-product="@request.Product.ToLower()"
                        data-country="@request.Country.ToLower()"
                        data-receive-no="@request.ReceiveNo.ToLower()">
                        <td>
                            <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateReplacementProcessing", "PSDeclaration") : Url.Action("CreateReplacementDeclaration", "PSDeclaration"))"
                               class="fw-semibold text-primary text-decoration-none d-block mb-1">
                                @request.RequestNumber
                            </a>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <i class="ri ri-building-2-line" style="font-size:0.7rem;"></i>
                                    <span>@request.Establishment</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <i class="ri ri-file-list-3-line" style="font-size:0.7rem;"></i>
                                    <span>เลขรับ: @request.ReceiveNo</span>
                                </div>
                            </div>
                        </td>
                        <td class="small">
                            @request.CertificateName
                            <div class="mt-1">
                                <span class="badge bg-label-secondary small me-1">@request.Product</span>
                                <span class="badge bg-label-info small">ปลายทาง: @request.Country</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="fw-semibold text-secondary">@request.OriginalCertNumber</span>
                        </td>
                        <td class="small">@request.ReplacementReason</td>
                        @* TOR 1.9(8): เลขที่ใบรับรองใหม่ (ใบแทน) *@
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(request.NewCertNumber))
                            {
                                <span class="fw-semibold text-success d-block mb-1">@request.NewCertNumber</span>
                                <span class="badge bg-label-info small">
                                    <i class="ri ri-file-copy-2-line me-1"></i>ใบแทน
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-center small text-nowrap">
                            @request.TransactionAt.ToString("dd/MM/yyyy")<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm:ss"))</span>
                        </td>
                        @* TOR 1.8(1): สถานะการเชื่อมโยง *@
                        <td class="text-center">
                            @if (request.IsLinkedExternal)
                            {
                                <span class="badge bg-danger small">
                                    <i class="ri ri-lock-2-line me-1"></i>@request.LinkStatusText
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-label-success small">
                                    <i class="ri ri-checkbox-circle-line me-1"></i>สามารถแก้ไขได้ ✅
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (request.StatusText == "ฉบับร่าง" || request.StatusText == "ไม่อนุมัติ")
                                {
                                    @if (request.IsLinkedExternal)
                                    {
                                        <button type="button" class="btn btn-sm btn-icon btn-secondary disabled"
                                                data-bs-toggle="tooltip"
                                                title="ไม่สามารถแก้ไขได้ — ใบรับรองนี้ถูกส่งต่อระบบภายนอกหรือสำแดงกับลูกค้าแล้ว"
                                                aria-disabled="true">
                                            <i class="ri ri-lock-2-line text-secondary"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="@(request.CertificateKey == "processing" ? Url.Action("CreateReplacementProcessing", "PSDeclaration") : Url.Action("CreateReplacementDeclaration", "PSDeclaration"))"
                                           class="btn btn-sm btn-icon btn-outline-warning" data-bs-toggle="tooltip" title="แก้ไข">
                                            <i class="ri ri-pencil-line text-warning"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-primary"
                                                data-bs-toggle="tooltip" title="ยืนยันส่งคำขอ">
                                            <i class="ri ri-send-plane-line text-primary"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                                data-bs-toggle="tooltip" title="แนบหลักฐาน"
                                                onclick="new bootstrap.Modal(document.getElementById('modalAttachEvidence')).show();">
                                            <i class="ri ri-attachment-line"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                                data-bs-toggle="tooltip" title="ลบ">
                                            <i class="ri ri-delete-bin-line text-danger"></i>
                                        </button>
                                    }
                                }
                                @if (request.StatusText == "รออนุมัติ")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                            data-bs-toggle="tooltip" title="ยกเลิกคำขอ"
                                            onclick="document.getElementById('cancelReqNo').textContent='@request.RequestNumber'; new bootstrap.Modal(document.getElementById('modalCancelRequest')).show();">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                            data-bs-toggle="tooltip" title="แนบหลักฐาน"
                                            onclick="new bootstrap.Modal(document.getElementById('modalAttachEvidence')).show();">
                                        <i class="ri ri-attachment-line"></i>
                                    </button>
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ยกเลิก")
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="8" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== Modal: ยกเลิกคำขอ ==================== -->
<div class="modal fade" id="modalCancelRequest" tabindex="-1" aria-labelledby="modalCancelRequestLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCancelRequestLabel">
                    <i class="ri ri-close-circle-line text-danger me-2"></i>ยืนยันยกเลิกคำขอ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning small mb-3">
                    <i class="ri ri-alert-line me-2"></i>
                    <strong>การยกเลิกคำขอไม่สามารถย้อนกลับได้</strong>
                </div>
                <p class="mb-1">คุณต้องการยกเลิกคำขอเลขที่:</p>
                <p class="fw-bold text-danger" id="cancelReqNo"></p>
                <div class="mb-2">
                    <label for="cancelReason" class="form-label">เหตุผลการยกเลิก <span class="text-danger">*</span></label>
                    <textarea id="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลการยกเลิก"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ปิด
                </button>
                <button type="button" class="btn btn-danger"
                        onclick="alert('[mockup] ยกเลิกคำขอ ' + document.getElementById(\'cancelReqNo\').textContent + ' เรียบร้อยแล้ว'); bootstrap.Modal.getInstance(document.getElementById(\'modalCancelRequest\')).hide();">
                    <i class="ri ri-check-line me-1"></i>ยืนยันยกเลิก
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: แนบหลักฐาน ==================== -->
<div class="modal fade" id="modalAttachEvidence" tabindex="-1" aria-labelledby="modalAttachEvidenceLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAttachEvidenceLabel">
                    <i class="ri ri-attachment-line me-2"></i>แนบหลักฐานประกอบการคำขอ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">เอกสาร/ไฟล์แนบ <span class="text-danger">*</span></label>
                    <input type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" multiple />
                    <div class="form-text">รองรับ PDF, JPG, PNG ขนาดไม่เกิน 20 MB/ไฟล์</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">หมายเหตุ</label>
                    <input type="text" class="form-control" placeholder="อธิบายเอกสารที่แนบ" />
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered small">
                        <thead class="table-light">
                            <tr>
                                <th>ชื่อไฟล์</th>
                                <th>ประเภท</th>
                                <th>วันที่แนบ</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>REP821B211302_สำเนาใบส่ง.pdf</td>
                                <td>PDF</td>
                                <td>19/04/2569</td>
                                <td><button class="btn btn-xs btn-outline-danger p-0 px-1">ลบ</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
                <button type="button" class="btn btn-primary"
                        onclick="alert('[mockup] บันทึกแนบหลักฐานเรียบร้อยแล้ว')">
                    <i class="ri ri-save-line me-1"></i>บันทึกหลักฐาน
                </button>
            </div>
        </div>
    </div>
</div>
