@{
    ViewData["Title"] = "เลือกประเภทใบรับรองที่จะยกเลิก";
}

@* ************** Content ************** *@
<h4 class="mb-1">เลือกประเภทใบรับรองที่จะยกเลิก</h4>
<p class="mb-1">กรุณาเลือกประเภทใบรับรองที่ต้องการยื่นคำขอยกเลิก</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexCancelCertificate", "PSDeclaration")" class="text-primary fw-semibold">ขอยกเลิกใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active text-secondary">เลือกประเภทใบรับรองที่จะยกเลิก</li>
    </ol>
</nav>

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">

            <!-- Info Banner -->
            <div class="alert alert-info d-flex align-items-start mb-4" role="alert">
                <i class="ri ri-information-line me-2 mt-1 flex-shrink-0" style="font-size:1.1rem;"></i>
                <div class="small">
                    <strong>การยกเลิกใบรับรอง (Certificate Cancellation):</strong>
                    หลังจากผู้ประกอบการยื่นคำขอยกเลิกและเจ้าหน้าที่อนุมัติแล้ว
                    ระบบจะ<strong>ยกเลิกใบรับรองอัตโนมัติ</strong> สำหรับประเภท
                    <span class="badge bg-label-success">PS-TH</span>
                    และ <span class="badge bg-label-success">NMD-TH</span>
                    โดยไม่ต้องดำเนินการเพิ่มเติม
                </div>
            </div>

            <!-- Selection Cards: 4 ประเภท -->
            <div class="row g-4 justify-content-center">

                <!-- Processing Statement (PS) -->
                <div class="col-12 col-sm-6">
                    <a href="@Url.Action("CreateCancelCertificate", "PSDeclaration")?type=PS" class="text-decoration-none">
                        <div class="card card-hover-shadow h-100 border border-2 border-transparent"
                             style="cursor: pointer; transition: border-color .2s, box-shadow .2s;"
                             onmouseover="this.style.borderColor='var(--bs-primary)'"
                             onmouseout="this.style.borderColor='transparent'">
                            <div class="card-body d-flex flex-column align-items-center text-center p-6">
                                <div class="mb-4">
                                    <span class="badge bg-label-primary rounded-circle p-3">
                                        <i class="ri ri-settings-3-line" style="font-size: 2rem;"></i>
                                    </span>
                                </div>
                                <h5 class="card-title mb-2">ใบรับรองการแปรรูปสัตว์น้ำ</h5>
                                <p class="text-muted small mb-3">Processing Statement (PS)</p>
                                <p class="text-body-secondary small mb-4">
                                    ยกเลิกใบรับรองสินค้าสัตว์น้ำที่ผ่านกระบวนการแปรรูป<br>
                                    ต้องผ่านการพิจารณาของเจ้าหน้าที่
                                </p>
                                <span class="btn btn-primary btn-sm mt-auto">
                                    <i class="ri ri-arrow-right-line me-1"></i> เลือกประเภทนี้
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Processing Statement Thailand (PS-TH) — ออกอัตโนมัติ -->
                <div class="col-12 col-sm-6">
                    <a href="@Url.Action("CreateCancelCertificate", "PSDeclaration")?type=PS-TH" class="text-decoration-none">
                        <div class="card card-hover-shadow h-100 border border-2 border-transparent"
                             style="cursor: pointer; transition: border-color .2s, box-shadow .2s;"
                             onmouseover="this.style.borderColor='var(--bs-success)'"
                             onmouseout="this.style.borderColor='transparent'">
                            <div class="card-body d-flex flex-column align-items-center text-center p-6">
                                <div class="mb-3">
                                    <span class="badge bg-label-success rounded-circle p-3">
                                        <i class="ri ri-settings-3-line" style="font-size: 2rem;"></i>
                                    </span>
                                </div>
                                <div class="mb-2">
                                    <span class="badge bg-label-success small">
                                        <i class="ri ri-robot-line me-1"></i>ยกเลิกอัตโนมัติหลังอนุมัติ
                                    </span>
                                </div>
                                <h5 class="card-title mb-2">ใบรับรองการแปรรูปสัตว์น้ำ (ไทย)</h5>
                                <p class="text-muted small mb-3">Processing Statement Thailand (PS-TH)</p>
                                <p class="text-body-secondary small mb-4">
                                    สำหรับสินค้าปลายทางภายในประเทศไทย<br>
                                    ระบบยกเลิกใบรับรองอัตโนมัติหลังอนุมัติ
                                </p>
                                <span class="btn btn-success btn-sm mt-auto">
                                    <i class="ri ri-arrow-right-line me-1"></i> เลือกประเภทนี้
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Non-Manipulation Document (NMD) -->
                <div class="col-12 col-sm-6">
                    <a href="@Url.Action("CreateCancelCertificate", "PSDeclaration")?type=NMD" class="text-decoration-none">
                        <div class="card card-hover-shadow h-100 border border-2 border-transparent"
                             style="cursor: pointer; transition: border-color .2s, box-shadow .2s;"
                             onmouseover="this.style.borderColor='var(--bs-primary)'"
                             onmouseout="this.style.borderColor='transparent'">
                            <div class="card-body d-flex flex-column align-items-center text-center p-6">
                                <div class="mb-4">
                                    <span class="badge bg-label-primary rounded-circle p-3">
                                        <i class="ri ri-leaf-line" style="font-size: 2rem;"></i>
                                    </span>
                                </div>
                                <h5 class="card-title mb-2">ใบรับรองสัตว์น้ำไม่แปรรูป</h5>
                                <p class="text-muted small mb-3">Non-Manipulation Document (NMD)</p>
                                <p class="text-body-secondary small mb-4">
                                    ยกเลิกใบรับรองสินค้าสัตว์น้ำสดที่ยังไม่ผ่านการแปรรูป<br>
                                    ต้องผ่านการพิจารณาของเจ้าหน้าที่
                                </p>
                                <span class="btn btn-primary btn-sm mt-auto">
                                    <i class="ri ri-arrow-right-line me-1"></i> เลือกประเภทนี้
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Non-Manipulation Document Thailand (NMD-TH) — ออกอัตโนมัติ -->
                <div class="col-12 col-sm-6">
                    <a href="@Url.Action("CreateCancelCertificate", "PSDeclaration")?type=NMD-TH" class="text-decoration-none">
                        <div class="card card-hover-shadow h-100 border border-2 border-transparent"
                             style="cursor: pointer; transition: border-color .2s, box-shadow .2s;"
                             onmouseover="this.style.borderColor='var(--bs-success)'"
                             onmouseout="this.style.borderColor='transparent'">
                            <div class="card-body d-flex flex-column align-items-center text-center p-6">
                                <div class="mb-3">
                                    <span class="badge bg-label-success rounded-circle p-3">
                                        <i class="ri ri-leaf-line" style="font-size: 2rem;"></i>
                                    </span>
                                </div>
                                <div class="mb-2">
                                    <span class="badge bg-label-success small">
                                        <i class="ri ri-robot-line me-1"></i>ยกเลิกอัตโนมัติหลังอนุมัติ
                                    </span>
                                </div>
                                <h5 class="card-title mb-2">ใบรับรองสัตว์น้ำไม่แปรรูป (ไทย)</h5>
                                <p class="text-muted small mb-3">Non-Manipulation Document Thailand (NMD-TH)</p>
                                <p class="text-body-secondary small mb-4">
                                    สำหรับสินค้าสัตว์น้ำสดปลายทางภายในประเทศไทย<br>
                                    ระบบยกเลิกใบรับรองอัตโนมัติหลังอนุมัติ
                                </p>
                                <span class="btn btn-success btn-sm mt-auto">
                                    <i class="ri ri-arrow-right-line me-1"></i> เลือกประเภทนี้
                                </span>
                            </div>
                        </div>
                    </a>
                </div>

            </div><!-- /row cards -->

            <!-- Note: ความแตกต่าง auto vs manual -->
            <div class="alert alert-secondary mt-5 small">
                <div class="d-flex align-items-start gap-2">
                    <i class="ri ri-lightbulb-line text-warning flex-shrink-0 mt-1"></i>
                    <div>
                        <strong>ความแตกต่างระหว่างประเภท:</strong>
                        <ul class="mb-0 mt-1 ps-3">
                            <li>
                                <span class="badge bg-label-primary me-1">PS / NMD</span>
                                หลังเจ้าหน้าที่อนุมัติ ระบบจะยกเลิกใบรับรองและแจ้งผลให้ทราบ
                                (ต้องรอการพิจารณาตามขั้นตอนปกติ)
                            </li>
                            <li class="mt-1">
                                <span class="badge bg-label-success me-1"><i class="ri ri-robot-line me-1"></i>PS-TH / NMD-TH</span>
                                ระบบ<strong>ยกเลิกอัตโนมัติทันที</strong>หลังเจ้าหน้าที่อนุมัติ
                                โดยไม่ต้องดำเนินการเพิ่มเติม
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action -->
            <div class="mt-4 text-start">
                <a href="@Url.Action("IndexCancelCertificate", "PSDeclaration")" class="btn btn-outline-secondary">
                    <i class="ri ri-arrow-left-line me-1"></i> ย้อนกลับรายการ
                </a>
            </div>

        </div><!-- /col -->
    </div><!-- /row -->
</div>
