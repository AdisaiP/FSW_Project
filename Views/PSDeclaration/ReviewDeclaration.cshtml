@section PageScripts {
<script>
    $(document).ready(function () {

        // ── 2.4(30): ปุ่มดึงข้อมูลใหม่จากด่าน ──
        $('#btnSyncFromPortDecl').on('click', function () {
            var $btn = $(this);
            var orig = $btn.html();
            $btn.html('<span class="spinner-border spinner-border-sm me-1" role="status"></span>กำลังดึง...').prop('disabled', true);
            setTimeout(function () {
                $btn.html(orig).prop('disabled', false);
                // TODO: call API to sync inspection data from port system
                alert('ข้อมูลตรวจปล่อยล่าสุดแล้ว (Mockup)');
            }, 1500);
        });

        // ── 2.4(31): Demo toggle สถานะ Push to Port (Declaration) ──
        var _pushSentStateDecl = true;
        $('#btnTogglePushDemoDecl').on('click', function () {
            _pushSentStateDecl = !_pushSentStateDecl;
            if (_pushSentStateDecl) {
                $('#badgePushSentDecl').removeClass('d-none');
                $('#badgePushPendingDecl').addClass('d-none');
                $('#btnResendToPortDecl').removeClass('d-none');
                $('#btnFirstSendToPortDecl').addClass('d-none');
            } else {
                $('#badgePushSentDecl').addClass('d-none');
                $('#badgePushPendingDecl').removeClass('d-none');
                $('#btnResendToPortDecl').addClass('d-none');
                $('#btnFirstSendToPortDecl').removeClass('d-none');
            }
        });

        // ── 2.4(31): ยืนยันส่งข้อมูลไปด่าน (Declaration) ──
        $('#btnConfirmSendToPortDecl').on('click', function () {
            $('#selectTargetPortDecl, #sendToPortRemarkDecl').prop('disabled', true);
            $(this).prop('disabled', true);
            $('#sendToPortFooterDecl button').prop('disabled', true);
            $('#sendToPortSpinnerDecl').removeClass('d-none');
            setTimeout(function () {
                $('#sendToPortSpinnerDecl').addClass('d-none');
                var portName = $('#selectTargetPortDecl option:selected').text().split(' (')[0];
                var now = new Date();
                var thYear = now.getFullYear() + 543;
                var pad = function(n){ return String(n).padStart(2,'0'); };
                var ts = pad(now.getDate()) + '/' + pad(now.getMonth()+1) + '/' + thYear
                       + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ' น.';
                $('#sendSuccessDetailDecl').text(portName + ' รับข้อมูลแล้ว เมื่อ ' + ts);
                $('#sendToPortSuccessDecl').removeClass('d-none');
                $('#sendToPortFooterDecl').html(
                    '<button type="button" class="btn btn-success" data-bs-dismiss="modal">'
                  + '<i class="ri ri-checkbox-circle-fill me-1"></i>เสร็จสิ้น</button>'
                );
                _pushSentStateDecl = true;
                $('#badgePushSentDecl').html(
                    '<i class="ri ri-checkbox-circle-fill me-1"></i>ส่งข้อมูลแล้ว ✅ เมื่อ ' + ts
                ).removeClass('d-none');
                $('#badgePushPendingDecl').addClass('d-none');
                $('#badgeSentToInspection').removeClass('d-none');
                $('#btnFirstSendToPortDecl').addClass('d-none');
                $('#btnResendToPortDecl').removeClass('d-none');
                $('#pushSentTimestampDecl').text(ts);
                // TODO: call API to send cert data to port system
            }, 2000);
        });

        // reset modal state on close
        $('#modalSendToPortDecl').on('hidden.bs.modal', function () {
            $('#sendToPortSpinnerDecl').addClass('d-none');
            $('#sendToPortSuccessDecl').addClass('d-none');
            $('#selectTargetPortDecl, #sendToPortRemarkDecl').prop('disabled', false);
        });

        // ── Toggle sub-row (expand/collapse) ──
        $(document).on('click', '.btn-toggle-sub', function () {
            var target = $(this).data('target');
            var $sub = $('#' + target);
            var $icon = $(this).find('i');
            if ($sub.hasClass('d-none')) {
                $sub.removeClass('d-none');
                $icon.removeClass('ri-arrow-right-s-line').addClass('ri-arrow-down-s-line');
            } else {
                $sub.addClass('d-none');
                $icon.removeClass('ri-arrow-down-s-line').addClass('ri-arrow-right-s-line');
            }
        });

        // ── Action buttons → populate confirm modal ──
        $('[data-bs-target="#modalConfirmAction"]').on('click', function () {
            var actionText  = $(this).data('action-text');
            var actionClass = $(this).data('action-class');
            $('#confirmActionText').text(actionText);
            $('#confirmActionBtnText').text(actionText);
            $('#btnConfirmAction')
                .removeClass('btn-primary btn-danger btn-warning btn-success')
                .addClass(actionClass);
        });

        // ── Confirm action ──
        $('#btnConfirmAction').on('click', function () {
            // TODO: submit to server
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmAction')).hide();
            // Placeholder feedback
            alert('ดำเนินการเรียบร้อยแล้ว');
        });

    });
</script>
}
