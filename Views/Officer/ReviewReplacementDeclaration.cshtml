                <button type="button" class="btn btn-outline-primary" id="btnDownloadPDFA3">
                    <i class="ri ri-download-2-line me-1"></i>ดาวน์โหลด PDF/A-3
                </button>
                <button type="button" class="btn btn-primary" id="btnDoPrint">
                    <i class="ri ri-printer-line me-1"></i>สั่งพิมพ์
                </button>
            </div>
