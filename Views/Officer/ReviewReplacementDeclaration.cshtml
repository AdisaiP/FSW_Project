@{
    ViewData["Title"] = "พิจารณาคำขอใบรับรองทดแทน (Declaration)";

    var requestStatus = "รออนุมัติ"; // mock: รออนุมัติ | อนุมัติ | ไม่อนุมัติ
    var isReadOnly = requestStatus != "รออนุมัติ";

    // 2.6(4): ลงทะเบียนรับคำขอ
    var receivedNo = ""; // mock: "รบ-ทดแทน.2569-00012" เมื่อลงทะเบียนแล้ว หรือ "" เมื่อยังไม่ลงทะเบียน
    var isRegistered = !string.IsNullOrEmpty(receivedNo);

    // 2.6(1): เหตุผลการขอทดแทน & เงื่อนไขเข้าเกณฑ์
    // mock values — เปลี่ยนได้เพื่อทดสอบ
    var replacementReason = "ใบรับรองชำรุด/เสียหาย";
    // เหตุผลทดแทนที่เข้าเกณฑ์ตาม TOR 2.6(1)
    var eligibleReasons = new[] {
        "ใบรับรองสูญหาย",
        "ใบรับรองชำรุด/เสียหาย",
        "ข้อผิดพลาดต้องแก้ไขหลังสินค้าออกจากประเทศ",
        "เชื่อมโยง/แลกเปลี่ยน/ส่งต่อข้อมูลไปยังระบบภายนอกแล้ว",
        "สำแดงใบรับรองกับลูกค้าแล้ว",
        "อื่น ๆ",
    };
    var isEligibleForReplacement = System.Array.IndexOf(eligibleReasons, replacementReason) >= 0;

    // 2.6(6): ประเภทการแก้ไขในใบรับรองทดแทน
    // mock: "weight" = แก้ไขน้ำหนักส่งออก | "other" = แก้ไขรายละเอียดอื่น (ไม่แก้น้ำหนัก)
    var editType = "weight";
    // mock: true = ยกเลิกตรวจปล่อยแล้ว, false = ยังไม่ยกเลิก (ใช้เมื่อ editType == "weight")
    var cancelledInspection = false;

    // 2.6(7): เลขที่ใบรับรองทดแทน (ออกหลังอนุมัติ)
    var replacementCertNo = requestStatus == "อนุมัติ" ? "REP-HC821B211301" : "";
    var originalCertNo = "HC821B211301"; // ใบรับรองเดิมที่ถูกยกเลิก
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@* ************** Content ************** *@
<h4 class="mb-1">พิจารณาคำขอ</h4>
<p class="mb-1">พิจารณาใบรับรองทดแทนฉบับเก่า — ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexReplacement", "Officer")" class="text-primary fw-semibold">พิจารณาใบรับรองทดแทนฉบับเก่า</a>
        </li>
        <li class="breadcrumb-item active text-secondary">ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)</li>
    </ol>
</nav>

<!-- Status Banner -->
@if (requestStatus == "อนุมัติ")
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-checkbox-circle-line fs-5"></i>
        <span><strong>อนุมัติแล้ว</strong> — คำขอนี้ได้รับการอนุมัติเรียบร้อยแล้ว</span>
    </div>
}
else if (requestStatus == "ไม่อนุมัติ")
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-close-circle-line fs-5"></i>
        <span><strong>ไม่อนุมัติ</strong> — คำขอนี้ถูกปฏิเสธ กรุณาดูเหตุผลในส่วนผลการพิจารณา</span>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-time-line fs-5"></i>
        <span><strong>รออนุมัติ</strong> — คำขอนี้รอการพิจารณาจากเจ้าหน้าที่</span>
    </div>
}

<!-- Request Info Badge -->
<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <div>
        <span class="text-muted small">เลขที่คำขอ</span>
        <div class="fw-bold text-primary fs-6">REP821B211301</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">เลขที่ใบรับรองเดิม</span>
        <div class="fw-bold">HC821B211301</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">ขอโดย</span>
        <div class="fw-bold">Alpha Office Automation Co., Ltd.</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">วันที่ส่งคำขอ</span>
        <div class="fw-bold">18/04/2569 (10:20:11)</div>
    </div>
    @if (isRegistered)
    {
        <div class="vr d-none d-md-block"></div>
        <div>
            <span class="text-muted small">เลขที่รับคำขอ</span>
            <div class="fw-bold text-success"><i class="ri ri-inbox-archive-line me-1"></i>@receivedNo</div>
        </div>
    }
    else if (!isReadOnly)
    {
        <div class="vr d-none d-md-block"></div>
        <div>
            <span class="text-muted small">เลขที่รับคำขอ</span>
            <div><span class="badge bg-label-warning"><i class="ri ri-time-line me-1"></i>ยังไม่ลงทะเบียน</span></div>
        </div>
    }
</div>

<div class="row">
    <div class="col-12">

        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-review" aria-controls="tab-review" aria-selected="false">
                        <i class="ri ri-shield-check-line me-1"></i> ผลการพิจารณา
                        @if (requestStatus == "รออนุมัติ")
                        {
                            <span class="badge bg-warning rounded-pill ms-1" style="font-size:0.65rem;">รอ</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-history" aria-controls="tab-history" aria-selected="false">
                        <i class="ri ri-history-line me-1"></i> ประวัติการดำเนินการ
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
                <div id="tab-detail" class="tab-pane fade show active" role="tabpanel">

                    <!-- Accordion: ข้อมูลคำขอทดแทน -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionReplacement">
                        <div class="accordion-item active">
                            <h2 class="accordion-header">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseReplacementContent" aria-expanded="true">
                                    <i class="icon-base ri ri-file-copy-2-line me-2"></i>
                                    ข้อมูลใบรับรองที่ต้องการขอทดแทน
                                </button>
                            </h2>
                            <div id="collapseReplacementContent" class="accordion-collapse collapse show">
                                <div class="accordion-body p-0">

                                    <!-- รายละเอียด -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-information-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">รายละเอียด</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-8">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="Alpha Office Automation Co., Ltd. (สาขา 00001)" readonly />
                                                    <label>ผู้ประกอบการ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="0105539133390" readonly />
                                                    <label>เลขประจำตัวผู้เสียภาษี</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="ใบรับรองสัตว์น้ำไม่แปรรูป (Declaration)" readonly />
                                                    <label>ประเภทใบรับรอง</label>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="HC821B211301" readonly />
                                                    <label>เลขที่ใบรับรองฉบับเดิม</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="ปกติ" readonly />
                                                    <label>สถานะใบรับรองเดิม</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="15/04/2026" readonly />
                                                    <label>วันที่ออกใบรับรองเดิม</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="15/04/2027" readonly />
                                                    <label>วันหมดอายุ</label>
                                                </div>
                                            </div>
                                            @* ─── 2.6(5): ค้นหาใบรับรองต้นฉบับ ─── *@
                                            <div class="col-md-4 d-flex align-items-center">
                                                <button type="button" class="btn btn-outline-primary w-100" id="btnSearchOriginalCert"
                                                    data-bs-toggle="modal" data-bs-target="#modalSearchOriginalCert">
                                                    <i class="ri ri-search-line me-1"></i>ค้นหาใบรับรองต้นฉบับ
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ─── 2.6(1): เหตุผลการขอทดแทน & เงื่อนไขเข้าเกณฑ์ ─── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-warning rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-question-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">เหตุผลการขอใบรับรองทดแทน</h6>
                                        </div>
                                        <div class="row g-3">
                                            @* Radio group เหตุผล 6 ตัวเลือก (readonly = disabled) *@
                                            <div class="col-12">
                                                <label class="form-label d-block mb-2">เลือกเหตุผลที่เข้าเกณฑ์ขอทดแทน</label>
                                                <div class="border rounded p-3 bg-light">
                                                    @{
                                                        var allReasons = new[]
                                                        {
                                                            new { Value = "ใบรับรองสูญหาย",                                               Icon = "ri-file-unknow-line",          Label = "ใบรับรองสูญหาย" },
                                                            new { Value = "ใบรับรองชำรุด/เสียหาย",                                        Icon = "ri-file-damage-line",          Label = "ใบรับรองชำรุด/เสียหาย" },
                                                            new { Value = "ข้อผิดพลาดต้องแก้ไขหลังสินค้าออกจากประเทศ",                   Icon = "ri-error-warning-line",        Label = "ข้อผิดพลาดต้องแก้ไขหลังสินค้าออกจากประเทศ" },
                                                            new { Value = "เชื่อมโยง/แลกเปลี่ยน/ส่งต่อข้อมูลไปยังระบบภายนอกแล้ว",      Icon = "ri-links-line",                Label = "เชื่อมโยง/แลกเปลี่ยน/ส่งต่อข้อมูลไปยังระบบภายนอกแล้ว" },
                                                            new { Value = "สำแดงใบรับรองกับลูกค้าแล้ว",                                  Icon = "ri-user-received-line",        Label = "สำแดงใบรับรองกับลูกค้าแล้ว" },
                                                            new { Value = "อื่น ๆ",                                                        Icon = "ri-more-line",                 Label = "อื่น ๆ (ระบุในรายละเอียด)" },
                                                        };
                                                    }
                                                    @for (int ri = 0; ri < allReasons.Length; ri++)
                                                    {
                                                        var r = allReasons[ri];
                                                        var isSelected = r.Value == replacementReason;
                                                        <div class="form-check @(ri < allReasons.Length - 1 ? "mb-2" : "")">
                                                            <input class="form-check-input" type="radio" name="replacementReasonRadio"
                                                                id="reason_@ri" value="@r.Value"
                                                                @(isSelected ? "checked" : "")
                                                                disabled />
                                                            <label class="form-check-label @(isReadOnly ? "text-muted" : "") @(isSelected ? "fw-semibold" : "")" for="reason_@ri">
                                                                <i class="ri @r.Icon me-1 text-muted small"></i>@r.Label
                                                            </label>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small text-muted">รายละเอียดเพิ่มเติม</label>
                                                <textarea class="form-control bg-light" rows="3" readonly>ใบรับรองได้รับความเสียหายจากน้ำท่วม ไม่สามารถอ่านข้อความได้ชัดเจน</textarea>
                                            </div>

                                            @* ─── badge เงื่อนไขเข้าเกณฑ์ ─── *@
                                            <div class="col-12">
                                                @if (isEligibleForReplacement)
                                                {
                                                    <div class="alert alert-success d-flex align-items-center gap-3 py-2 mb-0" role="alert">
                                                        <i class="ri ri-checkbox-circle-line fs-5 flex-shrink-0 text-success"></i>
                                                        <div>
                                                            <span class="fw-semibold">เหตุผลขอทดแทน: "@replacementReason"</span>
                                                            <span class="badge bg-success ms-2">✅ เข้าเกณฑ์ทดแทนได้</span>
                                                            <div class="small text-muted mt-1">เหตุผลนี้เป็นไปตามเงื่อนไขการออกใบรับรองทดแทนฉบับเก่าตาม TOR 2.6(1)</div>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="alert alert-danger d-flex align-items-center gap-3 py-2 mb-0" role="alert">
                                                        <i class="ri ri-close-circle-line fs-5 flex-shrink-0"></i>
                                                        <div>
                                                            <span class="fw-semibold">⛔ ใบรับรองนี้ไม่เข้าเกณฑ์ขอทดแทน</span>
                                                            <div class="small mt-1">เหตุผลที่ระบุไม่ตรงกับเงื่อนไขการออกใบรับรองทดแทนที่กำหนดไว้</div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ผู้ผ่านพิธีการ -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-user-star-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ผู้ผ่านพิธีการ / ผู้รับมอบอำนาจ</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด" readonly />
                                                    <label>ผู้ผ่านพิธีการ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="นาย สมชาย รักษาผล" readonly />
                                                    <label>ผู้รับมอบอำนาจ</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ผู้ส่งออก -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-building-2-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลผู้ส่งออก</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด (สาขาสำนักงานใหญ่)" readonly />
                                                    <label>ผู้ส่งออก</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- แจ้งความประสงค์ -->
                                    <div class="p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-file-text-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">แจ้งความประสงค์</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="กองตรวจสอบคุณภาพสินค้าประมง" readonly />
                                                    <label>หน่วยงาน</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="นางสาว วรรณา พิมพ์ทอง" readonly />
                                                    <label>ชื่อเจ้าหน้าที่</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="ก่อนนำเข้า/ส่งออก/นำผ่าน" readonly />
                                                    <label>ช่วงเวลาดำเนินการ</label>
                                                </div>
                                            </div>
