@section PageScripts {
<script>
    $(document).ready(function () {
        // Flatpickr
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function (el) { initFlatpickr(el); });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Sync radio with buttons
        $('#btnApproveRequest').on('click', function () {
            $('#resultApprove').prop('checked', true);
            var remark = $('#reviewRemark').val().trim();
            if (!remark) {
                alert('กรุณาระบุหมายเหตุ/เหตุผลประกอบการพิจารณาก่อนอนุมัติ');
                $('button[data-bs-target="#tab-review"]').tab('show');
                $('#reviewRemark').focus();
                return;
            }
            if (confirm('ยืนยันการอนุมัติคำขอใบรับรองทดแทนนี้?')) {
                // 2.6(7): แจ้งระบบยกเลิกใบรับรองเดิมอัตโนมัติและออกใบรับรองทดแทน
                alert('✅ ระบบยกเลิกใบรับรองเดิม [HC821B211301] อัตโนมัติแล้ว\nออกใบรับรองทดแทน [REP-HC821B211301] เรียบร้อย');
            }
        });

        $('#btnRejectRequest').on('click', function () {
            $('#resultReject').prop('checked', true);
            var remark = $('#reviewRemark').val().trim();
            if (!remark) {
                alert('กรุณาระบุเหตุผลการไม่อนุมัติก่อนดำเนินการ');
                $('button[data-bs-target="#tab-review"]').tab('show');
                $('#reviewRemark').focus();
                return;
            }
            if (confirm('ยืนยันการไม่อนุมัติคำขอใบรับรองทดแทนนี้?')) {
                alert('บันทึกผลการไม่อนุมัติเรียบร้อย');
            }
        });

        // ลงทะเบียนรับคำขอ
        var modalRegEl = document.getElementById('modalRegisterRequest');
        if (modalRegEl) {
            document.getElementById('btnConfirmRegister').addEventListener('click', function () {
                var modalInst = bootstrap.Modal.getInstance(modalRegEl);
                if (modalInst) modalInst.hide();
                alert('✅ รับคำขอทดแทนแล้ว\nเลขที่รับคำขอ: รบ-ทดแทน.2569-00012');
            });
        }

        // 2.6(8): พิมพ์ใบรับรองทดแทน / PDF/A-3
        $('input[name="printCopyType"]').on('change', function () {
            var isCopy = $(this).val() === 'copy';
            $('#copyCountSection').toggle(isCopy);
        });
        $('#btnCopyMinus').on('click', function () {
            var v = parseInt($('#printCopyCount').val(), 10) || 1;
            if (v > 1) $('#printCopyCount').val(v - 1);
        });
        $('#btnCopyPlus').on('click', function () {
            var v = parseInt($('#printCopyCount').val(), 10) || 1;
            if (v < 10) $('#printCopyCount').val(v + 1);
        });
        $('#btnDoPrint').on('click', function () {
            var type = $('input[name="printCopyType"]:checked').val();
            var count = type === 'copy' ? $('#printCopyCount').val() : 1;
            var label = type === 'copy' ? 'Copy (' + count + ' ชุด)' : 'Original';
            alert('🖨️ ส่งคำสั่งพิมพ์ใบรับรองทดแทน [REP-HC821B211301] — ' + label + '\nPDF/A-3 เรียบร้อยแล้ว');
        });
        $('#btnDownloadPDFA3').on('click', function () {
            var type = $('input[name="printCopyType"]:checked').val();
            var label = type === 'copy' ? 'Copy' : 'Original';
            alert('⬇️ ดาวน์โหลด PDF/A-3\nไฟล์: REP-HC821B211301_' + label + '.pdf\n(ฟอร์มอิเล็กทรอนิกส์ฝังข้อมูล XML e-Phyto standard)');
        });

        // 2.6(5): Modal ค้นหาใบรับรองต้นฉบับ
        function modalRepFilterRows() {
            var certType   = (document.getElementById('modalRepFilterCertType').value || '').trim();
            var certNo     = (document.getElementById('modalRepFilterCertNo').value || '').trim().toLowerCase();
            var receivedNo = (document.getElementById('modalRepFilterReceivedNo').value || '').trim().toLowerCase();
            var estab      = (document.getElementById('modalRepFilterEstab').value || '').trim().toLowerCase();
            var regNo      = (document.getElementById('modalRepFilterRegNo').value || '').trim().toLowerCase();
            var product    = (document.getElementById('modalRepFilterProduct').value || '').trim().toLowerCase();
            var country    = (document.getElementById('modalRepFilterCountry').value || '').trim().toLowerCase();
            var status     = (document.getElementById('modalRepFilterStatus').value || '').trim();
            var dateFrom   = (document.getElementById('modalRepFilterDateFrom').value || '').trim();
            var dateTo     = (document.getElementById('modalRepFilterDateTo').value || '').trim();

            function parseDate(s) {
                var p = s.split('/');
                if (p.length !== 3) return null;
                var y = parseInt(p[2]);
                if (y > 2500) y -= 543;
                return new Date(y, parseInt(p[1]) - 1, parseInt(p[0]));
            }

            var dfrom = dateFrom ? parseDate(dateFrom) : null;
            var dto   = dateTo   ? parseDate(dateTo)   : null;

            var rows = document.querySelectorAll('.modal-rep-cert-row');
            var visCount = 0;
            rows.forEach(function (row) {
                var match = true;
                if (certType   && row.dataset.certType   !== certType) match = false;
                if (certNo     && !row.dataset.certNo.toLowerCase().includes(certNo)) match = false;
                if (receivedNo && !row.dataset.receivedNo.toLowerCase().includes(receivedNo)) match = false;
                if (estab      && !row.dataset.estab.toLowerCase().includes(estab)) match = false;
                if (regNo      && !row.dataset.estab.toLowerCase().includes(regNo)) match = false;
                if (product    && !row.dataset.product.toLowerCase().includes(product)) match = false;
                if (country    && !row.dataset.country.toLowerCase().includes(country)) match = false;
                if (status     && row.dataset.certStatus !== status) match = false;
                if (dfrom || dto) {
                    var cells = row.querySelectorAll('td');
                    // วันที่ยื่น is 6th cell (index 5)
                    var dCell = cells[5] ? parseDate(cells[5].textContent.trim()) : null;
                    if (dCell) {
                        if (dfrom && dCell < dfrom) match = false;
                        if (dto   && dCell > dto)   match = false;
                    }
                }
                row.style.display = match ? '' : 'none';
                if (match) visCount++;
            });
            var empty = document.getElementById('modalRepSearchEmpty');
            if (empty) empty.classList.toggle('d-none', visCount > 0);
        }

        var btnModalRepSearch = document.getElementById('btnModalRepSearch');
        if (btnModalRepSearch) {
            btnModalRepSearch.addEventListener('click', modalRepFilterRows);
        }
        var btnModalRepReset = document.getElementById('btnModalRepReset');
        if (btnModalRepReset) {
            btnModalRepReset.addEventListener('click', function () {
                ['modalRepFilterCertType', 'modalRepFilterCertNo', 'modalRepFilterReceivedNo',
                 'modalRepFilterEstab', 'modalRepFilterRegNo', 'modalRepFilterProduct',
                 'modalRepFilterCountry', 'modalRepFilterStatus',
                 'modalRepFilterDateFrom', 'modalRepFilterDateTo'].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) el.value = '';
                });
                document.querySelectorAll('.modal-rep-cert-row').forEach(function (r) { r.style.display = ''; });
                var empty = document.getElementById('modalRepSearchEmpty');
                if (empty) empty.classList.add('d-none');
            });
        }
        // Enter key triggers search in modal text inputs
        ['modalRepFilterCertNo','modalRepFilterReceivedNo','modalRepFilterEstab',
         'modalRepFilterRegNo','modalRepFilterProduct','modalRepFilterCountry',
         'modalRepFilterDateFrom','modalRepFilterDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('keydown', function (e) { if (e.key === 'Enter') modalRepFilterRows(); });
        });
        // ปุ่มเลือก
        document.querySelectorAll('.btn-rep-select-cert').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var certNo = this.dataset.certNo;
                // TODO: อัปเดต field เลขที่ใบรับรองฉบับเดิมใน form
                alert('เลือกใบรับรอง: ' + certNo);
            });
        });

        // 2.6(6): Radio เปลี่ยนประเภทการแก้ไข
        function onEditTypeChange(val) {
            var sectionWeight = document.getElementById('sectionWeightEdit');
            var sectionOther  = document.getElementById('sectionOtherEdit');
            if (val === 'weight') {
                if (sectionOther)  sectionOther.style.display  = 'none';
                if (sectionWeight) sectionWeight.style.display = '';
                alert('⚠️ กรณีแก้ไขน้ำหนัก: ต้องลบ/ยกเลิกตรวจปล่อยจากด่านประมงก่อน\nหากยังไม่ยกเลิก ระบบจะไม่อนุมัติออกใบรับรองทดแทน');
            } else {
                if (sectionWeight) sectionWeight.style.display = 'none';
                if (sectionOther)  sectionOther.style.display  = '';
            }
        }
        document.querySelectorAll('input[name="editTypeRadio"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                if (this.checked) onEditTypeChange(this.value);
            });
        });
    });
</script>
}
