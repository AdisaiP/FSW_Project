                            </span>
                        </div>
                    </div>
                </div>

                @* ตัวเลือกการพิมพ์ *@
                <div class="card border mb-3">
                    <div class="card-header py-2 bg-light fw-semibold small">
                        <i class="ri ri-settings-3-line me-1"></i>ตัวเลือกการพิมพ์
                    </div>
                    <div class="card-body py-3">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">ประเภทสำเนา</label>
                                <div class="d-flex gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="printCopyType"
                                               id="printOriginal" value="original" checked />
