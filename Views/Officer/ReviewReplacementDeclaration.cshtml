                    <div class="table-responsive">
                        <table class="table table-bordered align-middle mb-0 small">
                            <thead class="text-center">
                                <tr>
                                    <th style="width:2.5rem;">#</th>
                                    <th>ประเภทเอกสาร</th>
                                    <th>ชื่อเอกสาร / คำอธิบาย</th>
                                    <th>วันที่เอกสาร</th>
                                    <th>ไฟล์แนบ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center text-muted">1</td>
                                    <td><span class="badge bg-label-danger">ใบแจ้งความ</span></td>
                                    <td>ใบแจ้งความกรณีเอกสารสูญหาย</td>
                                    <td class="text-center">18/04/2026</td>
                                    <td class="text-center">
                                        <a href="#" class="badge bg-label-secondary text-decoration-none">
                                            <i class="ri ri-file-pdf-line me-1"></i>report_lost_decl.pdf
                                        </a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- /TAB 2 -->

                <!-- ==================== TAB 3: ผลการพิจารณา ==================== -->
                <div id="tab-review" class="tab-pane fade" role="tabpanel">
                    <div class="accordion accordion-custom-button" id="accordionReview">
                        <div class="accordion-item active">
                            <h2 class="accordion-header">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseReviewContent" aria-expanded="true">
                                    <i class="icon-base ri ri-shield-check-line me-2"></i>
                                    ผลการพิจารณาของเจ้าหน้าที่
                                </button>
                            </h2>
                            <div id="collapseReviewContent" class="accordion-collapse collapse show">
                                <div class="accordion-body">

                                    @if (isReadOnly)
                                    {
                                        <!-- แสดงผลเท่านั้น -->
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label small text-muted">ผลการพิจารณา</label>
                                                <div>
                                                    @if (requestStatus == "อนุมัติ")
                                                    {
                                                        <span class="badge bg-label-success px-3 py-2 fs-6">
                                                            <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติ
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-label-danger px-3 py-2 fs-6">
                                                            <i class="ri ri-close-circle-line me-1"></i> ไม่อนุมัติ
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small text-muted">เจ้าหน้าที่ผู้พิจารณา</label>
                                                <div class="fw-semibold">นางสาว วรรณา พิมพ์ทอง</div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small text-muted">วันที่พิจารณา</label>
                                                <div class="fw-semibold">20/04/2026 (09:15:00)</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small text-muted">หมายเหตุ / เหตุผล</label>
                                                <textarea class="form-control bg-light" rows="3" readonly>เอกสารครบถ้วน ตรวจสอบแล้วอนุมัติออกใบรับรองทดแทน</textarea>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- ฟอร์มพิจารณา -->
                                        <div class="row g-4">
                                            <div class="col-12">
                                                <label class="form-label fw-semibold">ผลการพิจารณา <span class="text-danger">●</span></label>
                                                <div class="border rounded p-3">
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="radio" name="reviewResult"
                                                            id="resultApprove" value="approve" checked />
                                                        <label class="form-check-label text-success fw-semibold" for="resultApprove">
                                                            <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติ
                                                        </label>
                                                    </div>
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="radio" name="reviewResult"
                                                            id="resultReject" value="reject" />
                                                        <label class="form-check-label text-danger fw-semibold" for="resultReject">
                                                            <i class="ri ri-close-circle-line me-1"></i> ไม่อนุมัติ
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" value="นางสาว วรรณา พิมพ์ทอง" readonly />
                                                    <label>เจ้าหน้าที่ผู้พิจารณา</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="reviewDate" class="form-control flatpickr-date"
                                                        value="23/04/2026" />
                                                    <label for="reviewDate">วันที่พิจารณา</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <label for="reviewRemark" class="form-label">หมายเหตุ / เหตุผล <span class="text-danger">●</span></label>
                                                <textarea id="reviewRemark" class="form-control" rows="4"
                                                    placeholder="ระบุหมายเหตุหรือเหตุผลประกอบการพิจารณา" required></textarea>
                                            </div>
                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /TAB 3 -->

            </div><!-- /tab-content -->
        </div><!-- /nav-align-top -->

        <!-- Action Buttons -->
        <div class="d-flex justify-content-end gap-2 mt-3">
            <a href="@Url.Action("IndexReplacement", "Officer")" class="btn btn-outline-secondary">
                <i class="ri ri-arrow-left-line me-1"></i> ย้อนกลับ
            </a>
            @if (!isReadOnly)
            {
                <button type="button" class="btn btn-outline-danger" id="btnRejectRequest">
                    <i class="ri ri-close-circle-line me-1"></i> ไม่อนุมัติ
                </button>
                <button type="button" class="btn btn-success" id="btnApproveRequest">
                    <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติ
                </button>
            }
        </div>

    </div><!-- /col -->
</div><!-- /row -->

@section PageScripts {
<script>
    $(document).ready(function () {
        // Flatpickr
        function initFlatpickr(el) {
            if (el && !el._flatpickr) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
            }
        }
        document.querySelectorAll('.flatpickr-date').forEach(function (el) { initFlatpickr(el); });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Sync radio with buttons
        $('#btnApproveRequest').on('click', function () {
            $('#resultApprove').prop('checked', true);
            var remark = $('#reviewRemark').val().trim();
            if (!remark) {
                alert('กรุณาระบุหมายเหตุ/เหตุผลประกอบการพิจารณาก่อนอนุมัติ');
                $('button[data-bs-target="#tab-review"]').tab('show');
                $('#reviewRemark').focus();
                return;
            }
            if (confirm('ยืนยันการอนุมัติคำขอใบรับรองทดแทนนี้?')) {
                alert('บันทึกผลการอนุมัติเรียบร้อย');
            }
        });

        $('#btnRejectRequest').on('click', function () {
            $('#resultReject').prop('checked', true);
            var remark = $('#reviewRemark').val().trim();
            if (!remark) {
                alert('กรุณาระบุเหตุผลการไม่อนุมัติก่อนดำเนินการ');
                $('button[data-bs-target="#tab-review"]').tab('show');
                $('#reviewRemark').focus();
                return;
            }
            if (confirm('ยืนยันการไม่อนุมัติคำขอใบรับรองทดแทนนี้?')) {
                alert('บันทึกผลการไม่อนุมัติเรียบร้อย');
            }
        });
    });
</script>
}
