@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ── Flatpickr date ranges ──
    ['filterIssuedFrom','filterIssuedTo','filterReceivedFrom','filterReceivedTo',
     'filterExportFrom','filterExportTo','filterInspectionFrom','filterInspectionTo',
     'filterRequestedFrom','filterRequestedTo',
     'filterHcIssuedFrom','filterHcIssuedTo'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
    });

    // ── Tooltip ──
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) { new bootstrap.Tooltip(el); });
    }

    // ── Parse date dd/mm/yyyy (BE or CE — strip 543 if year > 2500) ──
    function parseDate(val, endOfDay) {
        if (!val) return null;
        var p = val.split('/');
        if (p.length !== 3) return null;
        var yr = parseInt(p[2]);
        if (yr > 2500) yr -= 543;
        var d = new Date(yr, parseInt(p[1]) - 1, parseInt(p[0]), endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
        return isNaN(d.getTime()) ? null : d;
    }

    // parse ISO date yyyy-mm-dd from data attr
    function parseIso(val) {
        if (!val) return null;
        var d = new Date(val);
        return isNaN(d.getTime()) ? null : d;
    }

    // ── Filter ──
    function filterRows() {
        var keyword         = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var certNo          = (document.getElementById('filterCertNo').value || '').trim().toLowerCase();
        var certType        = (document.getElementById('filterCertType').value || '').trim();
        var status          = (document.getElementById('filterStatus').value || '').trim();
        var country         = (document.getElementById('filterCountry').value || '').trim().toLowerCase();
        var companyName     = (document.getElementById('filterCompanyName').value || '').trim().toLowerCase();
        var productDesc     = (document.getElementById('filterProductDesc').value || '').trim().toLowerCase();
        var factoryReg      = (document.getElementById('filterFactoryReg').value || '').trim().toLowerCase();
        var receiptNo       = (document.getElementById('filterReceiptNo').value || '').trim().toLowerCase();
        var hcNo            = (document.getElementById('filterHcNo').value || '').trim().toLowerCase();
        var inspectionStatus= (document.getElementById('filterInspectionStatus').value || '').trim();
        var issuedFrom      = parseDate(document.getElementById('filterIssuedFrom').value, false);
        var issuedTo        = parseDate(document.getElementById('filterIssuedTo').value, true);
        var requestedFrom   = parseDate(document.getElementById('filterRequestedFrom').value, false);
        var requestedTo     = parseDate(document.getElementById('filterRequestedTo').value, true);
        var receivedFrom    = parseDate(document.getElementById('filterReceivedFrom').value, false);
        var receivedTo      = parseDate(document.getElementById('filterReceivedTo').value, true);
        var exportFrom      = parseDate(document.getElementById('filterExportFrom').value, false);
        var exportTo        = parseDate(document.getElementById('filterExportTo').value, true);
        var inspFrom        = parseDate(document.getElementById('filterInspectionFrom').value, false);
        var inspTo          = parseDate(document.getElementById('filterInspectionTo').value, true);
        var hcIssuedFrom    = parseDate(document.getElementById('filterHcIssuedFrom').value, false);
        var hcIssuedTo      = parseDate(document.getElementById('filterHcIssuedTo').value, true);
        var rows            = document.querySelectorAll('#searchTableBody tr[data-cert-no]');
        var count           = 0;

        rows.forEach(function(row) {
            var d = row.dataset;
            var text        = (d.searchText || '').toLowerCase();
            var rowIssuedDt = parseIso(d.issuedDate);
            var rowReqDt    = parseIso(d.requestedDate);
            var rowRecDt    = parseDate(d.receivedAt, false);
            var rowExpDt    = parseDate(d.exportDate, false);
            var rowInspDt   = parseDate(d.inspectionDate, false);
            var rowHcDt     = parseDate(d.hcIssuedDate, false);

            var keyOk       = !keyword          || text.includes(keyword);
            var certNoOk    = !certNo           || (d.certNo||'').toLowerCase().includes(certNo);
            var typeOk      = !certType         || d.certType === certType;
            var statusOk    = !status           || d.status === status;
            var countryOk   = !country          || (d.country||'').toLowerCase().includes(country);
            var companyOk   = !companyName      || (d.companyName||'').includes(companyName);
            var productOk   = !productDesc      || (d.productDesc||'').includes(productDesc);
            var factoryOk   = !factoryReg       || (d.factoryReg||'').toLowerCase().includes(factoryReg);
            var receiptOk   = !receiptNo        || (d.receiptNo||'').toLowerCase().includes(receiptNo);
            var hcNoOk      = !hcNo             || (d.hcNo||'').includes(hcNo);
            var inspStOk    = !inspectionStatus || d.inspectionStatus === inspectionStatus;

            function inRange(dt, from, to) {
                if (!from && !to) return true;
                if (!dt) return false;
                return (!from || dt >= from) && (!to || dt <= to);
            }
            var issuedOk   = inRange(rowIssuedDt, issuedFrom, issuedTo);
            var reqOk      = inRange(rowReqDt, requestedFrom, requestedTo);
            var recOk      = inRange(rowRecDt, receivedFrom, receivedTo);
            var expOk      = inRange(rowExpDt, exportFrom, exportTo);
            var inspDtOk   = inRange(rowInspDt, inspFrom, inspTo);
            var hcDtOk     = inRange(rowHcDt, hcIssuedFrom, hcIssuedTo);

            var show = keyOk && certNoOk && typeOk && statusOk && countryOk &&
                       companyOk && productOk && factoryOk && receiptOk && hcNoOk &&
                       inspStOk && issuedOk && reqOk && recOk && expOk && inspDtOk && hcDtOk;
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });

        document.getElementById('searchTableEmpty').classList.toggle('d-none', count !== 0);
        document.getElementById('resultCount').textContent = count;
    }

    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function() {
        ['filterKeyword','filterCertNo','filterCompanyName','filterProductDesc',
         'filterHcNo','filterIssuedFrom','filterIssuedTo','filterRequestedFrom','filterRequestedTo',
         'filterReceivedFrom','filterReceivedTo','filterExportFrom','filterExportTo',
         'filterInspectionFrom','filterInspectionTo','filterHcIssuedFrom','filterHcIssuedTo',
         'filterFactoryReg','filterReceiptNo'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.value = '';
        });
        ['filterCertType','filterStatus','filterCountry','filterInspectionStatus'].forEach(function(id) {
            document.getElementById(id).value = '';
        });
        filterRows();
    });

    ['filterCertType','filterStatus','filterCountry','filterInspectionStatus'].forEach(function(id) {
        document.getElementById(id).addEventListener('change', filterRows);
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') filterRows();
    });

    // 2.4(33): Export modal — switch to requested tab when dropdown item clicked
    document.addEventListener('show.bs.modal', function (e) {
        if (e.target.id !== 'modalSearchExport') return;
        var trigger = e.relatedTarget;
        if (!trigger) return;
        var tabId = trigger.getAttribute('data-export-tab');
        if (!tabId) return;
        var tabEl = document.querySelector('#modalSearchExport button[data-bs-target="#' + tabId + '"]');
        if (tabEl) {
            setTimeout(function () {
                var bsTab = bootstrap.Tab.getOrCreateInstance(tabEl);
                bsTab.show();
            }, 50);
        }
    });
});
</script>
}

