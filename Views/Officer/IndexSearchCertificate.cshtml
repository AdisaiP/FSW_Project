<!-- ── Filter Card ── -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ค้นหาใบรับรอง</h5>
            <p class="text-muted small mb-0">ค้นหาตามประเภทใบรับรอง สถานะ ประเทศ วันที่ต่างๆ และสถานะตรวจปล่อย</p>
        </div>
    </div>
    <div class="card-body">
        <!-- Row 1: basic -->
        <div class="row g-3 align-items-end mb-3">
            <div class="col-md-4 col-lg-3">
                <label for="filterKeyword" class="form-label">
                    <i class="ri ri-search-line me-1 text-muted"></i>ค้นหาทั่วไป (เลขที่ / ชื่อบริษัท / สินค้า)
                </label>
                <input id="filterKeyword" type="text" class="form-control"
                       placeholder="พิมพ์เพื่อค้นหา..." />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterCertNo" class="form-label">เลขที่ใบรับรอง</label>
                <input id="filterCertNo" type="text" class="form-control"
                       placeholder="เช่น PS-2026-00401" style="font-family:monospace;font-size:0.85rem;" />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="PS">PS — การแปรรูป</option>
                    <option value="NMD">NMD — ไม่แปรรูป</option>
                    <option value="PST">PST — การแปรรูป (ชั่วคราว)</option>
                    <option value="NMDT">NMDT — ไม่แปรรูป (ชั่วคราว)</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะใบรับรอง</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="มีผลบังคับ">มีผลบังคับ</option>
                    <option value="รอออก">รอออก</option>
                    <option value="ยกเลิก">ยกเลิกแล้ว ❌</option>
                    <option value="หมดอายุ">หมดอายุ</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-3">
                <label for="filterCompanyName" class="form-label">ชื่อบริษัท / ผู้ประกอบการ</label>
                <input id="filterCompanyName" type="text" class="form-control"
                       placeholder="ชื่อบริษัทหรือสถานประกอบการ" />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterProductDesc" class="form-label">ชนิดสินค้า / ผลิตภัณฑ์</label>
                <input id="filterProductDesc" type="text" class="form-control"
                       placeholder="เช่น FROZEN TUNA" />
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterInspectionStatus" class="form-label">
                    <i class="ri ri-ship-2-line me-1 text-primary"></i>สถานะตรวจปล่อย
                </label>
                <select id="filterInspectionStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ผ่านตรวจปล่อยแล้ว">ผ่านตรวจปล่อยแล้ว ✅</option>
                    <option value="รอตรวจปล่อย">รอตรวจปล่อย</option>
                </select>
            </div>
            <div class="col-md-3 col-lg-2">
                <label for="filterCountry" class="form-label">ประเทศปลายทาง</label>
                <select id="filterCountry" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ญี่ปุ่น">ญี่ปุ่น</option>
                    <option value="สหภาพยุโรป">สหภาพยุโรป</option>
                    <option value="สหรัฐอเมริกา">สหรัฐอเมริกา</option>
                    <option value="จีน">จีน</option>
                    <option value="เกาหลีใต้">เกาหลีใต้</option>
                    <option value="ออสเตรเลีย">ออสเตรเลีย</option>
                    <option value="สหราชอาณาจักร">สหราชอาณาจักร</option>
                    <option value="อิตาลี">อิตาลี</option>
                    <option value="เยอรมนี">เยอรมนี</option>
                    <option value="แคนาดา">แคนาดา</option>
                </select>
            </div>
        </div>

        <!-- ค้นหาขั้นสูง collapse -->
        <div>
            <button class="btn btn-outline-secondary btn-sm mb-2" type="button"
                    data-bs-toggle="collapse" data-bs-target="#advCertSearchCollapse" aria-expanded="false">
                <i class="ri ri-equalizer-line me-1"></i>ค้นหาขั้นสูง
            </button>
            <div class="collapse" id="advCertSearchCollapse">
                <div class="card border p-3">
                    <div class="row g-3 align-items-end">
                        <!-- เลขทะเบียนโรงงาน -->
                        <div class="col-md-4 col-lg-3">
                            <label for="filterFactoryReg" class="form-label small">เลขทะเบียนโรงงาน / สถานประกอบการ</label>
                            <input id="filterFactoryReg" type="text" class="form-control form-control-sm"
                                   placeholder="เช่น TH-1-6100-10-401/22" />
                        </div>
                        <!-- เลขที่รับคำขอ -->
                        <div class="col-md-4 col-lg-3">
                            <label for="filterReceiptNo" class="form-label small">เลขที่รับคำขอ</label>
                            <input id="filterReceiptNo" type="text" class="form-control form-control-sm"
                                   placeholder="เช่น รบ. 2026-00401" />
                        </div>
                        <!-- เลขที่ HC สุขอนามัย -->
                        <div class="col-md-4 col-lg-3">
                            <label for="filterHcNo" class="form-label small">
                                <i class="ri ri-heart-pulse-line me-1 text-danger"></i>เลขที่ HC สุขอนามัย
                            </label>
                            <input id="filterHcNo" type="text" class="form-control form-control-sm"
                                   placeholder="เช่น HA-2569-00401" style="font-family:monospace;" />
                        </div>
                        <!-- วันที่ออก HC -->
                        <div class="col-md-4 col-lg-4">
                            <label class="form-label small">
                                <i class="ri ri-heart-pulse-line me-1 text-danger"></i>วันที่ออก HC (ตั้งแต่ — ถึง)
                            </label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterHcIssuedFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterHcIssuedTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                        <!-- วันที่ยื่นคำขอ -->
                        <div class="col-md-4 col-lg-3">
                            <label class="form-label small">วันที่ยื่นคำขอ (ตั้งแต่ — ถึง)</label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterRequestedFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterRequestedTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                        <!-- วันที่รับคำขอ -->
                        <div class="col-md-4 col-lg-3">
                            <label class="form-label small">วันที่รับคำขอ (ตั้งแต่ — ถึง)</label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterReceivedFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterReceivedTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                        <!-- วันที่ออกใบรับรอง -->
                        <div class="col-md-4 col-lg-3">
                            <label class="form-label small">วันที่ออกใบรับรอง (ตั้งแต่ — ถึง)</label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterIssuedFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterIssuedTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                        <!-- วันที่ส่งออก -->
                        <div class="col-md-4 col-lg-3">
                            <label class="form-label small">วันที่ส่งออก (ตั้งแต่ — ถึง)</label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterExportFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterExportTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                        <!-- วันที่ตรวจปล่อย -->
                        <div class="col-md-4 col-lg-4">
                            <label class="form-label small">
                                <i class="ri ri-shield-check-line me-1 text-primary"></i>วันที่ตรวจปล่อย (ตั้งแต่ — ถึง)
                            </label>
                            <div class="d-flex gap-1 align-items-center">
                                <input type="text" id="filterInspectionFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                                <span class="small text-muted">–</span>
                                <input type="text" id="filterInspectionTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action buttons -->
        <div class="d-flex gap-2 mt-3">
            <button type="button" id="btnSearch" class="btn btn-primary btn-sm">
                <i class="ri ri-search-line me-1"></i>ค้นหา
            </button>
            <button type="button" id="btnReset" class="btn btn-outline-secondary btn-sm">
                <i class="ri ri-refresh-line me-1"></i>ล้างเงื่อนไข
            </button>
        </div>
    </div>
</div>

<!-- ── Results Table ── -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการใบรับรอง</h5>
            <p class="text-muted small mb-0">แสดงข้อมูลใบรับรองการแปรรูปสัตว์น้ำ (PS) และใบรับรองไม่แปรรูปสัตว์น้ำ (Declaration)</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <!-- 2.4(33): Export Excel split-button dropdown -->
            <div class="btn-group btn-sm">
                <button type="button" class="btn btn-success btn-sm"
                        data-bs-toggle="modal" data-bs-target="#modalSearchExport" data-export-tab="searchExportTab1">
                    <i class="ri ri-file-excel-line me-1"></i>Export Excel
                </button>
                <button type="button" class="btn btn-success btn-sm dropdown-toggle dropdown-toggle-split"
                        data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="visually-hidden">Toggle Dropdown</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header small">เลือกประเภทข้อมูล</h6></li>
                    <li>
                        <a class="dropdown-item small" href="#" data-bs-toggle="modal" data-bs-target="#modalSearchExport" data-export-tab="searchExportTab1">
                            <i class="ri ri-award-line me-2 text-success"></i>Export รายการใบรับรอง
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small" href="#" data-bs-toggle="modal" data-bs-target="#modalSearchExport" data-export-tab="searchExportTab2">
                            <i class="ri ri-list-check-3 me-2 text-primary"></i>Export RMBS2/P2 รายการ
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small" href="#" data-bs-toggle="modal" data-bs-target="#modalSearchExport" data-export-tab="searchExportTab3">
                            <i class="ri ri-ship-2-line me-2 text-info"></i>Export RMBS1/P1 รายการ
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item small" href="#" data-bs-toggle="modal" data-bs-target="#modalSearchExport" data-export-tab="searchExportTab4">
                            <i class="ri ri-scales-3-line me-2 text-warning"></i>Export ข้อมูลตัดน้ำหนักเพื่อขอหนังสือรับรองตนเอง
                        </a>
                    </li>
                </ul>
            </div>
            <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="tooltip" title="Export PDF">
                <i class="ri ri-file-pdf-line me-1"></i>PDF
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 cert-search-table">
            <thead class="text-center">
                <tr>
                    <th style="width:42px;">ลำดับ</th>
                    <th style="min-width:240px;">เลขที่ใบรับรอง / คำขอ</th>
                    <th style="min-width:200px;">สถานประกอบการ / เลขทะเบียน</th>
                    <th style="width:86px;">HS Code</th>
                    <th style="min-width:180px;">ชื่อสินค้า / ผลิตภัณฑ์</th>
                    <th style="min-width:120px;">ประเทศปลายทาง</th>
                    <th style="width:100px;" class="text-end">น้ำหนัก (กก.)</th>
                    <th style="width:100px;">วันที่ยื่น / วันที่รับ</th>
                    <th style="width:100px;">วันที่ออก / วันหมดอายุ</th>
                    <th style="width:110px;">ตรวจปล่อย</th>
                    <th style="min-width:110px;">เจ้าหน้าที่ผู้ออก</th>
                    <th style="width:70px;">จัดการ</th>
                </tr>
            </thead>
            <tbody id="searchTableBody">
                @foreach (var r in results)
                {
                    <tr data-cert-no="@r.CertNo"
                        data-cert-type="@r.CertType"
                        data-status="@r.StatusText"
                        data-country="@r.DestCountry"
                        data-issued-date="@r.IssuedAt.ToString("yyyy-MM-dd")"
                        data-requested-date="@r.RequestedAt.ToString("yyyy-MM-dd")"
                        data-received-at="@r.ReceivedAt"
                        data-export-date="@r.ExportDate"
                        data-inspection-date="@r.InspectionDate"
                        data-inspection-status="@r.InspectionStatus"
                        data-factory-reg="@r.FactoryRegNo"
                        data-receipt-no="@r.ReceiptNo"
                        data-company-name="@r.CompanyName.ToLower()"
                        data-product-desc="@r.ProductDesc.ToLower()"
                        data-hc-no="@(hcNos.GetValueOrDefault(r.RowNo, "").ToLower())"
                        data-hc-issued-date="@hcIssuedDates.GetValueOrDefault(r.RowNo, "")"
                        data-search-text="@r.CertNo.ToLower() @r.RequestNo.ToLower() @r.CompanyName.ToLower() @r.ProductDesc.ToLower() @r.DestCountry.ToLower() @r.HsCode.ToLower() @r.FactoryRegNo.ToLower() @r.ReceiptNo.ToLower() @hcNos.GetValueOrDefault(r.RowNo, "").ToLower()">
                        <!-- ลำดับ -->
                        <td class="text-center text-muted">@r.RowNo</td>
                        <!-- เลขที่ใบรับรอง -->
                        <td>
                            <a href="#" class="fw-semibold text-primary text-decoration-none d-block mb-1">@r.CertNo</a>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle bg-label-@(r.CertType == "PS" ? "info" : "secondary") d-inline-flex align-items-center justify-content-center flex-shrink-0"
                                          style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @(r.CertType == "PS" ? "ri-file-chart-line" : "ri-file-text-line")" style="font-size:0.58rem;"></i>
                                    </span>
                                    <span><span class="fw-semibold">ประเภท:</span> @r.CertType</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge rounded-circle @r.StatusClass d-inline-flex align-items-center justify-content-center flex-shrink-0"
                                          style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @r.StatusIcon" style="font-size:0.58rem;"></i>
                                    </span>
                                    <span><span class="fw-semibold">สถานะ:</span> @r.StatusText</span>
                                </div>
                                <div class="small text-muted">
                                    <i class="ri ri-file-list-line me-1"></i><span>คำขอ:</span> @r.RequestNo
                                </div>
                                @if (!string.IsNullOrEmpty(r.ReceiptNo)) {
                                    <div class="small text-muted">
                                        <i class="ri ri-inbox-archive-line me-1"></i><span>รับ:</span> @r.ReceiptNo
                                    </div>
                                }
                                @{
                                    var rowHcNo = hcNos.GetValueOrDefault(r.RowNo, "");
                                    var rowHcDate = hcIssuedDates.GetValueOrDefault(r.RowNo, "");
                                }
                                @if (!string.IsNullOrEmpty(rowHcNo)) {
                                    <div class="small mt-1" style="color:#b02a37;">
                                        <i class="ri ri-heart-pulse-line me-1"></i>HC: <span class="fw-semibold" style="font-family:monospace;font-size:0.75rem;">@rowHcNo</span>
                                        @if (!string.IsNullOrEmpty(rowHcDate)) {
                                            <span class="text-muted"> (@rowHcDate)</span>
                                        }
                                    </div>
                                }
                            </div>
                        </td>
                        <!-- สถานประกอบการ / เลขทะเบียน -->
                        <td>
                            <div class="fw-medium">@r.CompanyName</div>
                            <div class="small text-muted">(@r.CompanyBranch)</div>
                            <div class="small text-muted mt-1">
                                <i class="ri ri-barcode-line me-1 text-secondary"></i>@r.FactoryRegNo
                            </div>
                        </td>
                        <!-- HS Code -->
                        <td class="text-center"><span class="badge bg-label-secondary rounded-pill">@r.HsCode</span></td>
                        <!-- ชื่อสินค้า -->
                        <td>
                            <div class="fw-medium">@r.ProductDesc</div>
                            <div class="small text-muted">@r.CertTypeFull</div>
                        </td>
                        <!-- ประเทศปลายทาง -->
                        <td>
                            <div class="fw-medium">@r.DestCountry</div>
                            <div class="small text-muted">@r.DestCountryCode</div>
                        </td>
                        <!-- น้ำหนัก -->
                        <td class="text-end fw-semibold">@r.WeightKg.ToString("N0")</td>
                        <!-- วันที่ยื่น / วันที่รับ -->
                        <td class="text-center">
                            <div class="small">
                                <i class="ri ri-calendar-line me-1 text-muted"></i>@r.RequestedAt.ToString("dd/MM/yyyy")
                            </div>
                            @if (!string.IsNullOrEmpty(r.ReceivedAt)) {
                                <div class="small text-success mt-1">
                                    <i class="ri ri-inbox-archive-line me-1"></i>@r.ReceivedAt
                                </div>
                            }
                        </td>
                        <!-- วันที่ออก / วันหมดอายุ -->
                        <td class="text-center">
                            <div class="small">@r.IssuedAt.ToString("dd/MM/yyyy")</div>
                            <div class="small @(r.ExpiredAt < DateTime.Today ? "text-danger fw-semibold" : "text-muted") mt-1">
                                หมด: @r.ExpiredAt.ToString("dd/MM/yyyy")
                            </div>
                        </td>
                        <!-- ตรวจปล่อย -->
                        <td class="text-center">
                            @if (r.InspectionStatus == "ผ่านตรวจปล่อยแล้ว") {
                                <span class="badge bg-label-success d-block mb-1">
                                    <i class="ri ri-shield-check-line me-1"></i>ตรวจปล่อยแล้ว ✅
                                </span>
                                @if (!string.IsNullOrEmpty(r.InspectionDate)) {
                                    <div class="small text-muted">@r.InspectionDate</div>
                                }
                            } else if (r.InspectionStatus == "รอตรวจปล่อย") {
                                <span class="badge bg-label-warning d-block">
                                    <i class="ri ri-time-line me-1"></i>รอตรวจปล่อย
                                </span>
                            } else {
                                <span class="text-muted small">-</span>
                            }
                            @if (!string.IsNullOrEmpty(r.ExportDate)) {
                                <div class="small text-muted mt-1">
                                    <i class="ri ri-ship-line me-1"></i>@r.ExportDate
                                </div>
                            }
                        </td>
                        <!-- เจ้าหน้าที่ -->
                        <td>
                            @if (r.IssuedByName != "-") {
                                <span class="small"><i class="ri ri-user-star-line me-1 text-primary"></i>@r.IssuedByName</span>
                            } else {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <!-- จัดการ -->
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a href="@Url.Action("ReviewInspectedCertificate","Officer")"
                                   class="btn btn-icon btn-sm btn-outline-primary"
                                   data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                    <i class="ri ri-eye-line ri-16px"></i>
                                </a>
                                @* 2.9(1): ปุ่มดู RMBS2/RMBS1/P2/P1 เฉพาะ role กตส. *@
                                @if (isKtosRole)
                                {
                                    <button class="btn btn-icon btn-sm btn-outline-purple"
                                            style="border-color:#6f42c1; color:#6f42c1;"
                                            data-bs-toggle="modal" data-bs-target="#modalRmbsDetail"
                                            data-cert-no="@r.CertNo" data-cert-type="@r.CertType"
                                            data-company="@r.CompanyName"
                                            onclick="openRmbsModal(this)"
                                            title="ดู RMBS2/RMBS1/P2/P1">
                                        <i class="ri ri-git-branch-line ri-16px"></i>
                                    </button>
                                }
                                @if (r.StatusText == "มีผลบังคับ") {
                                    <button class="btn btn-icon btn-sm btn-outline-secondary"
                                            data-bs-toggle="tooltip" title="พิมพ์ใบรับรอง">
                                        <i class="ri ri-printer-line ri-16px"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tbody id="searchTableEmpty" class="d-none">
                <tr>
                    <td colspan="12" class="text-center text-muted py-5">
                        <i class="ri ri-search-line ri-2x d-block mb-2 opacity-50"></i>
                        ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

