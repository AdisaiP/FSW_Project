</div>

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">ค้นหารายการ</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <label for="filterRmbs1Number" class="form-label filter-form-label">เลขที่ RMBS1</label>
                <input type="text" id="filterRmbs1Number" class="form-control form-control-sm" placeholder="ระบุเลขที่ RMBS1" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterImdNumber" class="form-label filter-form-label">เลขที่ IMD</label>
                <input type="text" id="filterImdNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ IMD" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterCcNumber" class="form-label filter-form-label">เลขที่ Catch Certificate</label>
                <input type="text" id="filterCcNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ Catch Certificate" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterVessel" class="form-label filter-form-label">ชื่อเรือประมง</label>
                <input type="text" id="filterVessel" class="form-control form-control-sm" placeholder="ระบุชื่อเรือประมง" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterRegistrationNo" class="form-label filter-form-label">เลขทะเบียนเรือ</label>
                <input type="text" id="filterRegistrationNo" class="form-control form-control-sm" placeholder="ระบุเลขทะเบียนเรือ" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterCertType" class="form-label filter-form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select form-select-sm">
                    <option value="">ทั้งหมด (PS + NoPS)</option>
                    <option value="PS">PS (การแปรรูปสัตว์น้ำ)</option>
                    <option value="NoPS">NoPS (ไม่แปรรูปสัตว์น้ำ)</option>
                </select>
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterStatus" class="form-label filter-form-label">สถานะ</label>
                <select id="filterStatus" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                    <option value="ส่งคืนแก้ไข">ส่งคืนแก้ไข</option>
                </select>
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterAgency" class="form-label filter-form-label">หน่วยงานรับผิดชอบ</label>
                <select id="filterAgency" class="form-select form-select-sm">
                    <option value="">ทั้งหมด (กตส./ศตส.)</option>
                    <option value="GOV-KTS-00">กตส. (ส่วนกลาง)</option>
                    <option value="GOV-STS-01">ศตส.เขต 1 (ชลบุรี)</option>
                    <option value="GOV-STS-02">ศตส.เขต 2 (สุราษฎร์ธานี)</option>
                    <option value="GOV-STS-03">ศตส.เขต 3 (สงขลา)</option>
                    <option value="GOV-STS-04">ศตส.เขต 4 (นครศรีธรรมราช)</option>
                    <option value="GOV-STS-05">ศตส.เขต 5 (ระนอง)</option>
                    <option value="GOV-STS-06">ศตส.เขต 6 (ภูเก็ต)</option>
                </select>
            </div>
            <div class="col-12">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label filter-form-label">ช่วงวันที่บันทึก</label>
                        <input type="text" id="filterLogDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label for="filterLogDateTo" class="form-label filter-form-label">ถึงวันที่</label>
                        <input type="text" id="filterLogDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-1">
                            <input class="form-check-input" type="checkbox" id="filterLogDateExclude" />
                            <label class="form-check-label small" for="filterLogDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label filter-form-label">ช่วงเวลาทำการประมง</label>
                        <input type="text" id="filterFishingDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label for="filterFishingDateTo" class="form-label filter-form-label">ถึงวันที่</label>
                        <input type="text" id="filterFishingDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="range-actions">
                            <button type="button" id="btnSearch" class="btn btn-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการ RMBS1 รอพิจารณา (PS / NoPS)</h5>
            <p class="text-muted small mb-0">รายการเอกสารการควบคุมปริมาณวัตถุดิบสัตว์นํ้านำเข้าเพื่อแปรรูปส่งออก เอกสารที่ 1 (RMBS1) สำหรับสถานะ PS และ NoPS</p>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 imd-table">
            <thead class="text-center">
                <tr>
                    <th style="width:2.2rem;">
                        <input type="checkbox" class="form-check-input" id="chkSelectAll" title="เลือกทั้งหมด (เฉพาะรออนุมัติ)" />
                    </th>
                    <th style="min-width:280px;">เลขที่ RMBS1</th>
                    <th style="min-width:90px;">ประเภท</th>
                    <th>วันที่บันทึก</th>
                    <th style="min-width:160px;">เลขที่ IMD (วันที่)</th>
                    <th>ชื่อเรือประมง</th>
                    <th>เลขที่ Catch Certificate</th>
                    <th style="min-width:140px;">ช่วงเวลาทำการประมง</th>
                    <th>เครื่องมือทำการประมง</th>
                    <th style="min-width:280px;">ชนิดสัตว์น้ำ</th>
                    <th>ปริมาณสัตว์น้ำเข้าโรงงาน</th>
                    <th style="min-width:120px;">หน่วยงานรับผิดชอบ</th>
                    <th style="min-width:110px;">สถานะ</th>
                    <th style="width:10rem;">การดำเนินการ</th>
                </tr>
            </thead>
            <tbody id="imdTableBody">
                @foreach (var rec in imdRecords)
                {
                    <tr data-row="@rec.RowNo"
                        data-rmbs1-number="@rec.Rmbs1Number"
                        data-imd-number="@rec.ImdNumber"
                        data-doc-type="@rec.DocumentType"
                        data-cert-type="@rec.CertificateType"
                        data-status="@rec.StatusText"
                        data-vessel="@rec.VesselName"
                        data-agency-code="@rec.ResponsibleAgencyCode"
                        data-agency-name="@rec.ResponsibleAgencyName"
                        data-registration-no="@rec.RegistrationNo"
                        data-fishing-start-date="@rec.FishingStartDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-fishing-end-date="@rec.FishingEndDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-gear="@rec.GearType"
                        data-captain=""
                        data-cc-number="@rec.CcNumber"
                        data-product="@rec.FisheryProducts"
                        data-allocation="all"
                        data-change-type=""
                        data-tx-date="@rec.TransactionDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="text-center">
                            @if (rec.StatusText == "รออนุมัติ")
                            {
                                <input type="checkbox" class="form-check-input chk-row-select"
                                    data-rmbs1="@rec.Rmbs1Number" />
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("ReviewRMBS1PS", "Officer")" class="fw-semibold text-primary text-decoration-none">@rec.Rmbs1Number</a>
                            <div class="mt-1">
                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge @rec.CertificationStatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri @rec.CertificationStatusIcon" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะเอกสารรับรอง :</span> @rec.CertificationStatusText
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge @(rec.CertificateType == "PS" ? "bg-label-info" : "bg-label-secondary")">@rec.CertificateType</span>
                        </td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.TransactionDate)</td>
                        <td class="text-center">
                            <div>@rec.ImdNumber</div>
                            <div class="text-muted">(@ToThaiDate(rec.ValidationDate))</div>
                        </td>
                        <td>@rec.VesselName</td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.FishingStartDate)-<br />@ToThaiDate(rec.FishingEndDate)</td>
                        <td>@rec.GearType</td>
                        <td style="max-width:280px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <td class="text-center">
                            <span class="badge @(rec.ResponsibleAgencyCode == "GOV-KTS-00" ? "bg-label-primary" : "bg-label-info") d-block mb-1">@rec.ResponsibleAgencyName</span>
                            <button type="button" class="btn btn-xs btn-outline-secondary btn-assign-agency" style="font-size:0.65rem;padding:0.1rem 0.4rem;" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="เปลี่ยนหน่วยงาน">
                                <i class="ri ri-exchange-line"></i>
                            </button>
                        </td>
                        <td class="text-center">
                            <span class="badge @rec.StatusClass">@rec.StatusText</span>
                            @if (rec.StatusText == "อนุมัติแล้ว")
                            {
                                <div class="mt-1">
                                    <span class="badge bg-success" style="font-size:0.65rem;"><i class="ri ri-file-check-line me-1"></i>ออกเลขที่อัตโนมัติ ✅</span>
                                </div>
                                <div class="mt-1">
                                    <span class="badge bg-label-warning" style="font-size:0.6rem;">ยังไม่ถูกนำไปใช้ — ดึงกลับได้ ✅</span>
                                </div>
                                @if (rec.HasPendingChange)
                                {
                                    <div class="mt-1">
                                        <span class="badge bg-label-info" style="font-size:0.6rem;"><i class="ri ri-loop-left-line me-1"></i>มีคำขอเปลี่ยนแปลงค้างอยู่ 🔄</span>
                                    </div>
                                }
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <a href="@Url.Action("ReviewRMBS1PS", "Officer")" class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                    <i class="ri ri-eye-line"></i>
                                </a>
                                @if (rec.StatusText == "รออนุมัติ")
                                {
                                    <a href="@Url.Action("ReviewRMBS1PS", "Officer")" class="btn btn-sm btn-icon btn-outline-primary btn-edit-draft" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="แก้ไข (ร่าง)">
                                        <i class="ri ri-edit-line"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-cancel-record" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="ยกเลิกคำขอ">
                                        <i class="ri ri-close-circle-line text-warning"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-delete-record" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="ลบ">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" data-bs-toggle="tooltip" title="อนุมัติ">
                                        <i class="ri ri-checkbox-circle-line text-success"></i>
                                    </button>
                                }
                                @if (rec.StatusText == "อนุมัติแล้ว")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-revert-status" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="ดึงสถานะกลับ (เปลี่ยนแปลงผล)">
                                        <i class="ri ri-arrow-go-back-line" style="color:#fd7e14;"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-cancel-doc" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="ยกเลิกการออกเอกสาร">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                    @if (rec.HasPendingChange)
                                    {
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-secondary btn-cancel-change" data-rmbs1="@rec.Rmbs1Number" data-bs-toggle="tooltip" title="ยกเลิกผลการขอเปลี่ยนแปลง">
                                            <i class="ri ri-loop-left-line" style="color:#6c757d;"></i>
                                        </button>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="14" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: ยืนยันการยกเลิกคำขอ -->
<div class="modal fade" id="modalCancelRecord" tabindex="-1" aria-labelledby="modalCancelRecordLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalCancelRecordLabel">ยืนยันการยกเลิกคำขอ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="mb-1">คุณต้องการ <strong class="text-warning">ยกเลิก</strong> คำขอ RMBS1 หมายเลข</p>
                <p class="fw-semibold text-primary mb-3" id="cancelRecordRmbs1Number">-</p>
                <div class="alert alert-warning d-flex gap-2 py-2 mb-2">
                    <i class="ri ri-information-line mt-1 flex-shrink-0"></i>
                    <span class="small">การยกเลิกคำขอจะเปลี่ยนสถานะเป็น "ยกเลิก" และไม่สามารถส่งอนุมัติได้จนกว่าจะยกเลิกและสร้างใหม่</span>
                </div>
                <label class="form-label small fw-semibold">เหตุผลการยกเลิก <span class="text-danger">*</span></label>
                <textarea id="cancelRecordReason" class="form-control" rows="3" placeholder="ระบุเหตุผลการยกเลิก..."></textarea>
                <div class="invalid-feedback" id="cancelRecordReasonError">กรุณาระบุเหตุผลการยกเลิก</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
                <button type="button" id="btnConfirmCancel" class="btn btn-warning">
                    <i class="ri ri-close-circle-line me-1"></i> ยืนยันยกเลิกคำขอ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: ยืนยันการลบ -->
<div class="modal fade" id="modalDeleteRecord" tabindex="-1" aria-labelledby="modalDeleteRecordLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalDeleteRecordLabel">ยืนยันการลบ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="mb-1">คุณต้องการ <strong class="text-danger">ลบ</strong> คำขอ RMBS1 หมายเลข</p>
                <p class="fw-semibold text-primary mb-3" id="deleteRecordRmbs1Number">-</p>
                <div class="alert alert-danger d-flex gap-2 py-2 mb-0">
                    <i class="ri ri-error-warning-line mt-1 flex-shrink-0"></i>
                    <span class="small">การลบข้อมูลจะ<strong>ไม่สามารถกู้คืนได้</strong> กรุณาตรวจสอบให้แน่ใจก่อนดำเนินการ</span>
                </div>
            </div>
