@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var d = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10) - 1;
            var y = parseInt(parts[2], 10);
            var dt = new Date(y, m, d, endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
            return Number.isNaN(dt.getTime()) ? null : dt;
        }

        function filterRows() {
            var rmbs1No = (document.getElementById('filterRmbs1Number').value || '').trim().toLowerCase();
            var imdNo = (document.getElementById('filterImdNumber').value || '').trim().toLowerCase();
            var ccNo = (document.getElementById('filterCcNumber').value || '').trim().toLowerCase();
            var vessel = (document.getElementById('filterVessel').value || '').trim().toLowerCase();
            var registrationNo = (document.getElementById('filterRegistrationNo').value || '').trim().toLowerCase();
            var certTypeFilter = (document.getElementById('filterCertType').value || '').trim();
            var statusFilter = (document.getElementById('filterStatus').value || '').trim();
            var agencyFilter = (document.getElementById('filterAgency').value || '').trim();
            var logFromDate = parseDateInput(document.getElementById('filterLogDateFrom').value, false);
            var logToDate = parseDateInput(document.getElementById('filterLogDateTo').value, true);
            var logExcludeRange = document.getElementById('filterLogDateExclude').checked;
            var fishingFromDate = parseDateInput(document.getElementById('filterFishingDateFrom').value, false);
            var fishingToDate = parseDateInput(document.getElementById('filterFishingDateTo').value, true);

            var rows = document.querySelectorAll('#imdTableBody tr[data-row]');
            var visible = 0;

            rows.forEach(function (row) {
                var txDate = new Date(row.dataset.txDate);
                var fishingStart = new Date(row.dataset.fishingStartDate);
                var fishingEnd = new Date(row.dataset.fishingEndDate);
                var inLogRange = (!logFromDate || txDate >= logFromDate) && (!logToDate || txDate <= logToDate);
                var inFishingRange = (!fishingFromDate || fishingStart >= fishingFromDate) && (!fishingToDate || fishingEnd <= fishingToDate);
                var match =
                    (!rmbs1No || (row.dataset.rmbs1Number || '').toLowerCase().includes(rmbs1No)) &&
                    (!imdNo || (row.dataset.imdNumber || '').toLowerCase().includes(imdNo)) &&
                    (!ccNo || (row.dataset.ccNumber || '').toLowerCase().includes(ccNo)) &&
                    (!vessel || (row.dataset.vessel || '').toLowerCase().includes(vessel)) &&
                    (!registrationNo || (row.dataset.registrationNo || '').toLowerCase().includes(registrationNo)) &&
                    (!certTypeFilter || (row.dataset.certType || '') === certTypeFilter) &&
                    (!statusFilter || (row.dataset.status || '') === statusFilter) &&
                    (!agencyFilter || (row.dataset.agencyCode || '') === agencyFilter) &&
                    ((!logFromDate && !logToDate) || (logExcludeRange ? !inLogRange : inLogRange)) &&
                    ((!fishingFromDate && !fishingToDate) || inFishingRange);

                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });

            document.getElementById('imdTableEmpty').classList.toggle('d-none', visible !== 0);
        }

        document.getElementById('btnSearch').addEventListener('click', filterRows);
        document.getElementById('btnReset').addEventListener('click', function () {
            ['filterRmbs1Number', 'filterImdNumber', 'filterCcNumber', 'filterVessel', 'filterRegistrationNo', 'filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            document.getElementById('filterCertType').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterAgency').value = '';
            document.getElementById('filterLogDateExclude').checked = false;
            filterRows();
        });

        document.getElementById('filterCertType').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterAgency').addEventListener('change', filterRows);

        // Assign agency modal
        document.querySelectorAll('.btn-assign-agency').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var rmbs1 = this.dataset.rmbs1;
                var row = this.closest('tr');
                document.getElementById('assignModalRmbs1Number').textContent = rmbs1;
                document.getElementById('assignModalCurrentAgency').textContent = row.dataset.agencyName || '-';
                document.getElementById('assignModalNewAgency').value = '';
                new bootstrap.Modal(document.getElementById('assignAgencyModal')).show();
            });
        });

        document.getElementById('filterLogDateExclude').addEventListener('change', filterRows);

        ['filterRmbs1Number', 'filterImdNumber', 'filterCcNumber', 'filterVessel', 'filterRegistrationNo', 'filterLogDateFrom', 'filterLogDateTo', 'filterFishingDateFrom', 'filterFishingDateTo'].forEach(function (id) {
            document.getElementById(id).addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });

        // ── ยกเลิกคำขอ ──
        document.querySelectorAll('.btn-cancel-record').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var rmbs1 = this.dataset.rmbs1;
                document.getElementById('cancelRecordRmbs1Number').textContent = rmbs1;
                document.getElementById('cancelRecordReason').value = '';
                document.getElementById('cancelRecordReason').classList.remove('is-invalid');
                new bootstrap.Modal(document.getElementById('modalCancelRecord')).show();
            });
        });

        document.getElementById('btnConfirmCancel').addEventListener('click', function () {
            var reasonEl = document.getElementById('cancelRecordReason');
            if (!reasonEl.value.trim()) {
                reasonEl.classList.add('is-invalid');
                reasonEl.focus();
                return;
            }
            bootstrap.Modal.getInstance(document.getElementById('modalCancelRecord')).hide();
            showIndexToast('ยกเลิกคำขอ RMBS1 เรียบร้อยแล้ว', 'warning');
        });

        document.getElementById('cancelRecordReason').addEventListener('input', function () {
            if (this.value.trim()) this.classList.remove('is-invalid');
        });

        // ── ลบ ──
        document.querySelectorAll('.btn-delete-record').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var rmbs1 = this.dataset.rmbs1;
                document.getElementById('deleteRecordRmbs1Number').textContent = rmbs1;
                new bootstrap.Modal(document.getElementById('modalDeleteRecord')).show();
            });
        });

        document.getElementById('btnConfirmDelete').addEventListener('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('modalDeleteRecord')).hide();
            showIndexToast('ลบข้อมูล RMBS1 เรียบร้อยแล้ว', 'danger');
        });

        // ── Multi-Select (Multi-signature) ──
        function updateMultiBar() {
            var checked = document.querySelectorAll('.chk-row-select:checked');
            var bar = document.getElementById('multiApproveBar');
            document.getElementById('selectedCountText').textContent = checked.length;
            if (checked.length > 0) {
                bar.classList.remove('d-none');
                bar.style.display = 'flex';
            } else {
                bar.classList.add('d-none');
                bar.style.display = '';
            }
        }

        document.getElementById('chkSelectAll').addEventListener('change', function () {
            document.querySelectorAll('.chk-row-select').forEach(function (cb) {
                cb.checked = this.checked;
            }, this);
            updateMultiBar();
        });

        document.addEventListener('change', function (e) {
            if (e.target && e.target.classList.contains('chk-row-select')) {
                updateMultiBar();
                // Uncheck "select all" if any individual is unchecked
                var all = document.querySelectorAll('.chk-row-select');
                var checked = document.querySelectorAll('.chk-row-select:checked');
                document.getElementById('chkSelectAll').checked = (all.length === checked.length && all.length > 0);
                document.getElementById('chkSelectAll').indeterminate = (checked.length > 0 && checked.length < all.length);
            }
        });

        document.getElementById('btnClearSelection').addEventListener('click', function () {
            document.querySelectorAll('.chk-row-select').forEach(function (cb) { cb.checked = false; });
            document.getElementById('chkSelectAll').checked = false;
            document.getElementById('chkSelectAll').indeterminate = false;
            updateMultiBar();
        });

        document.getElementById('btnMultiApprove').addEventListener('click', function () {
            var checked = Array.from(document.querySelectorAll('.chk-row-select:checked'));
            var count = checked.length;
            document.getElementById('multiApproveCountText').textContent = count;
            document.getElementById('modalConfirmMultiCount').textContent = count;
            var listHtml = checked.map(function (cb) {
                return '<div class="py-1 border-bottom"><i class="ri ri-file-list-line me-1 text-primary"></i>' + cb.dataset.rmbs1 + '</div>';
            }).join('');
            document.getElementById('multiApproveList').innerHTML = listHtml || '<span class="text-muted">ไม่มีรายการ</span>';
            document.getElementById('multiApproveRemark').value = '';
            new bootstrap.Modal(document.getElementById('modalMultiApprove')).show();
        });

        document.getElementById('btnConfirmMultiApprove').addEventListener('click', function () {
            // TODO: submit bulk approval API call
            var count = document.querySelectorAll('.chk-row-select:checked').length;
            bootstrap.Modal.getInstance(document.getElementById('modalMultiApprove')).hide();
            document.querySelectorAll('.chk-row-select').forEach(function (cb) { cb.checked = false; });
            document.getElementById('chkSelectAll').checked = false;
            document.getElementById('chkSelectAll').indeterminate = false;
            updateMultiBar();
            showIndexToast('อนุมัติ ' + count + ' คำขอ RMBS1:PS เรียบร้อยแล้ว', 'success');
        });

        // ── Revert Status (Item 9) ──
        var _revertRmbs1 = '';
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-revert-status');
            if (!btn) return;
            _revertRmbs1 = btn.dataset.rmbs1;
            document.getElementById('revertRmbs1Text').textContent = _revertRmbs1;
            document.getElementById('revertReason').value = '';
            document.getElementById('revertReasonError').classList.add('d-none');
            document.getElementById('revertTypeDecision').checked = true;
            new bootstrap.Modal(document.getElementById('modalRevertStatus')).show();
        });

        document.getElementById('btnConfirmRevert').addEventListener('click', function () {
            var reason = document.getElementById('revertReason').value.trim();
            if (!reason) {
                document.getElementById('revertReasonError').classList.remove('d-none');
                return;
            }
            document.getElementById('revertReasonError').classList.add('d-none');
            // TODO: call API to revert status
            bootstrap.Modal.getInstance(document.getElementById('modalRevertStatus')).hide();
            showIndexToast('ดึงสถานะกลับ ' + _revertRmbs1 + ' เรียบร้อยแล้ว — พร้อมดำเนินการเปลี่ยนแปลง', 'warning');
        });

        // ── Cancel Doc (Item 10) ──
        var _cancelDocRmbs1 = '';
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-cancel-doc');
            if (!btn) return;
            _cancelDocRmbs1 = btn.dataset.rmbs1;
            document.getElementById('cancelDocRmbs1Text').textContent = _cancelDocRmbs1;
            document.getElementById('cancelDocReason').value = '';
            document.getElementById('cancelDocReasonError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('modalCancelDoc')).show();
        });

        document.getElementById('btnConfirmCancelDoc').addEventListener('click', function () {
            var reason = document.getElementById('cancelDocReason').value.trim();
            if (!reason) {
                document.getElementById('cancelDocReasonError').classList.remove('d-none');
                return;
            }
            document.getElementById('cancelDocReasonError').classList.add('d-none');
            // TODO: call API to cancel doc
            bootstrap.Modal.getInstance(document.getElementById('modalCancelDoc')).hide();
            // Update row badge to show ยกเลิกแล้ว
            document.querySelectorAll('[data-rmbs1-number="' + _cancelDocRmbs1 + '"] .badge').forEach(function (b) {
                if (b.textContent.trim() === 'อนุมัติแล้ว') {
                    b.className = 'badge bg-label-danger';
                    b.textContent = 'ยกเลิกแล้ว 🚫';
                }
            });
            showIndexToast('ยกเลิกการออกเอกสาร ' + _cancelDocRmbs1 + ' เรียบร้อยแล้ว', 'danger');
        });

        // ── Cancel Change Request (Item 10) ──
        var _cancelChangeRmbs1 = '';
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-cancel-change');
            if (!btn) return;
            _cancelChangeRmbs1 = btn.dataset.rmbs1;
            document.getElementById('cancelChangeRmbs1Text').textContent = _cancelChangeRmbs1;
            document.getElementById('cancelChangeReason').value = '';
            document.getElementById('cancelChangeReasonError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('modalCancelChange')).show();
        });

        document.getElementById('btnConfirmCancelChange').addEventListener('click', function () {
            var reason = document.getElementById('cancelChangeReason').value.trim();
            if (!reason) {
                document.getElementById('cancelChangeReasonError').classList.remove('d-none');
                return;
            }
            document.getElementById('cancelChangeReasonError').classList.add('d-none');
            // TODO: call API to cancel change request
            bootstrap.Modal.getInstance(document.getElementById('modalCancelChange')).hide();
            showIndexToast('ยกเลิกคำขอเปลี่ยนแปลงของ ' + _cancelChangeRmbs1 + ' เรียบร้อยแล้ว', 'info');
        });

        function showIndexToast(msg, type) {
            var bg = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : type === 'warning' ? 'bg-warning' : 'bg-info';
            var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-delete-bin-line' : 'ri-close-circle-line';
            var toastEl = document.createElement('div');
            toastEl.className = 'position-fixed bottom-0 end-0 p-3';
            toastEl.style.zIndex = 9999;
            toastEl.innerHTML =
                '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
                '  <div class="d-flex">' +
                '    <div class="toast-body d-flex align-items-center gap-2">' +
                '      <i class="ri ' + icon + ' fs-5"></i> ' + msg +
                '    </div>' +
                '    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '  </div>' +
                '</div>';
            document.body.appendChild(toastEl);
            setTimeout(function () { toastEl.remove(); }, 3500);
        }
    });
</script>
}

