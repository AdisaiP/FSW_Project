@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* --- Flatpickr --- */
    ['filterDateFrom', 'filterDateTo'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
    });

    /* --- Tooltips --- */
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    }

    /* --- Date parse helper --- */
    function parseDateInput(value, endOfDay) {
        if (!value) return null;
        var parts = value.split('/');
        if (parts.length !== 3) return null;
        var d = parseInt(parts[0], 10), m = parseInt(parts[1], 10) - 1, y = parseInt(parts[2], 10);
        var h = endOfDay ? 23 : 0, min = endOfDay ? 59 : 0, s = endOfDay ? 59 : 0;
        var dt = new Date(y, m, d, h, min, s);
        return isNaN(dt.getTime()) ? null : dt;
    }

    /* --- Filter --- */
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var certType = (document.getElementById('filterCertType').value || '').trim();
        var fromDate = parseDateInput(document.getElementById('filterDateFrom').value, false);
        var toDate = parseDateInput(document.getElementById('filterDateTo').value, true);
        // 2.10(1): advanced filters
        var filterFactory = (document.getElementById('filterFactory') ? document.getElementById('filterFactory').value : '').trim().toLowerCase();
        var filterEstCode = (document.getElementById('filterEstCode') ? document.getElementById('filterEstCode').value : '').trim().toLowerCase();
        var filterSpecies = (document.getElementById('filterSpecies') ? document.getElementById('filterSpecies').value : '').trim().toLowerCase();
        var filterOrigin = (document.getElementById('filterOriginCountry') ? document.getElementById('filterOriginCountry').value : '').trim().toLowerCase();

        var rows = document.querySelectorAll('#sdTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var rowCertType = row.dataset.certType || '';
            var rowDate = new Date(row.dataset.issuedDate || '');

            var ok = (!keyword || text.includes(keyword))
                && (!status || rowStatus === status)
                && (!certType || rowCertType === certType)
                && (!fromDate || rowDate >= fromDate)
                && (!toDate || rowDate <= toDate)
                // 2.10(1): advanced filters
                && (!filterFactory || (row.dataset.company || '').includes(filterFactory))
                && (!filterEstCode || (row.dataset.estCode || '').includes(filterEstCode))
                && (!filterSpecies || (row.dataset.species || '').includes(filterSpecies))
                && (!filterOrigin || (row.dataset.origin || '').includes(filterOrigin));

            row.classList.toggle('d-none', !ok);
            if (ok) count++;
        });
        document.getElementById('sdTableEmpty').classList.toggle('d-none', count !== 0);
    }

    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        ['filterKeyword', 'filterStatus', 'filterCertType', 'filterDateFrom', 'filterDateTo',
         'filterFactory', 'filterEstCode', 'filterSpecies', 'filterOriginCountry'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.value = '';
        });
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
    });
    ['filterStatus', 'filterCertType', 'filterDateFrom', 'filterDateTo', 'filterOriginCountry'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('change', filterRows);
    });

    /* --- Detail Modal --- */
    var detailModal = new bootstrap.Modal(document.getElementById('modalSelfDeclDetail'));

    document.querySelectorAll('[data-action="show-detail"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = this.dataset.docId;
            var card = document.getElementById('detail-' + id);
            if (!card) return;

            // Fill modal header
            document.getElementById('modalDocNo').textContent = card.dataset.docno;
            document.getElementById('modalDocNo2').textContent = card.dataset.docno;
            document.getElementById('modalCompany').textContent = card.dataset.company;
            document.getElementById('modalCertType').textContent = card.dataset.certtype;
            document.getElementById('modalHsCode').textContent = card.dataset.hscode;
            document.getElementById('modalProduct').textContent = card.dataset.product;
            document.getElementById('modalSpecies').textContent = card.dataset.species;
            document.getElementById('modalSourceCountry').textContent = card.dataset.sourcecountry;
            document.getElementById('modalEstCode').textContent = card.dataset.estcode;
            document.getElementById('modalIssuedAt').textContent = card.dataset.issuedat;
            document.getElementById('modalExpiresAt').textContent = card.dataset.expiresat;
            document.getElementById('modalWeightTotal').textContent = parseInt(card.dataset.weighttotal).toLocaleString('th-TH');
            document.getElementById('modalWeightUsed').textContent = parseInt(card.dataset.weightused).toLocaleString('th-TH');
            document.getElementById('modalWeightRemain').textContent = parseInt(card.dataset.weightremain).toLocaleString('th-TH');

            // Fill batches
            var batchContainer = document.getElementById('modalBatches');
            var batchTemplate = document.getElementById('batch-template-' + id);
            batchContainer.innerHTML = batchTemplate ? batchTemplate.innerHTML : '<p class="text-muted small">ไม่มีข้อมูลรุ่นวัตถุดิบ</p>';

            // 2.10(2): Fill measure summary
            var hasMeasure = card.dataset.hasmeasure === 'true';
            var measureCountry = card.dataset.measurecountry || '';
            var iuuFail = card.dataset.iuufail === 'true';
            var otherCond = card.dataset.othercond || '';
            var measureSummary = document.getElementById('modalMeasureSummary');
            if (measureSummary) {
                var measureHtml = '<hr class="mt-3 mb-3" />' +
                    '<h6 class="fw-bold mb-3"><i class="ri ri-shield-check-line me-1 text-danger"></i>สรุปข้อจำกัดมาตรการ</h6>' +
                    '<div class="row g-3 mb-3" style="font-size:0.82rem;">' +
                    '<div class="col-md-4">' +
                    '<span class="text-muted d-block mb-1">มาตรการประเทศคู่ค้า</span>' +
                    (hasMeasure
                        ? '<span class="badge bg-danger px-3 py-2">ติดมาตรการ ' + measureCountry + ' ❌</span>'
                        : '<span class="badge bg-label-success px-3 py-2">ไม่ติดมาตรการ ✅</span>') +
                    '</div>' +
                    '<div class="col-md-4">' +
                    '<span class="text-muted d-block mb-1">มาตรการสุขอนามัย (IUU)</span>' +
                    (iuuFail
                        ? '<span class="badge bg-danger px-3 py-2">ติดมาตรการ IUU ❌</span>'
                        : '<span class="badge bg-label-success px-3 py-2">ผ่าน ✅</span>') +
                    '</div>' +
                    '<div class="col-md-4">' +
                    '<span class="text-muted d-block mb-1">เงื่อนไขอื่น</span>' +
                    (otherCond
                        ? '<span class="badge bg-warning text-dark px-3 py-2">มีเงื่อนไข — ' + otherCond + ' ⚠️</span>'
                        : '<span class="badge bg-label-secondary px-3 py-2">ไม่มีเงื่อนไข ✅</span>') +
                    '</div>' +
                    '</div>';
                if (hasMeasure || iuuFail) {
                    var alertCountry = hasMeasure ? measureCountry : 'ประเทศที่ออกมาตรการ IUU';
                    measureHtml += '<div class="alert alert-danger d-flex gap-2 align-items-start py-2 px-3" style="font-size:0.82rem;">' +
                        '<i class="ri ri-forbid-2-line mt-1 flex-shrink-0" style="font-size:1.1rem;"></i>' +
                        '<div><strong>🚫 RMBS1 ในชุดนี้ติดมาตรการ — ไม่สามารถขอหนังสือรับรองตนเองไปยัง ' + alertCountry + ' ได้</strong>' +
                        '<div class="mt-1 text-danger">กรุณาตรวจสอบแหล่งที่มาและดำเนินการแก้ไขก่อนยื่นคำขอ</div>' +
                        '</div></div>';
                }
                measureSummary.innerHTML = measureHtml;
                // Re-init tooltips inside modal after content change
                if (window.bootstrap && bootstrap.Tooltip) {
                    measureSummary.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                        new bootstrap.Tooltip(el);
                    });
                }
            }

            // 2.10(3): Fill quota section
            var quotaSection = document.getElementById('modalQuotaSection');
            var quotaTemplate = document.getElementById('quota-template-' + id);
            if (quotaSection) {
                quotaSection.innerHTML = '';
                if (quotaTemplate && quotaTemplate.dataset.quota) {
                    try {
                        var rows = JSON.parse(quotaTemplate.dataset.quota);
                        var hasExhausted = rows.some(function (r) { return r.remain <= 0; });
                        var typeColors = { RMBS2: 'bg-label-purple', RMBS1: 'bg-label-primary', P2: 'bg-label-success', P1: 'bg-label-warning' };
                        var typeStyles = {
                            RMBS2: 'background:#f3eeff;color:#6f42c1;border:1px solid #b89fee;',
                            RMBS1: 'background:#e8f0ff;color:#0d6efd;border:1px solid #9ec5fe;',
                            P2:    'background:#e8f5ed;color:#198754;border:1px solid #a3cfbb;',
                            P1:    'background:#fff3e8;color:#fd7e14;border:1px solid #fecba1;'
                        };
                        var rowsHtml = rows.map(function (r) {
                            var pct = r.orig > 0 ? Math.round((r.deduct / r.orig) * 100) : 0;
                            var exhausted = r.remain <= 0;
                            var badgeHtml = exhausted
                                ? '<span class="badge bg-danger" style="font-size:0.63rem;">หมดโควตา ❌</span>'
                                : '<span class="badge bg-label-success" style="font-size:0.63rem;">ปกติ ✅</span>';
                            var style = typeStyles[r.type] || '';
                            return '<tr' + (exhausted ? ' class="table-warning"' : '') + '>' +
                                '<td class="text-center"><span class="badge px-2 py-1" style="font-size:0.68rem;' + style + '">' + r.type + '</span></td>' +
                                '<td class="text-nowrap" style="font-size:0.73rem;">' + r.docno + '</td>' +
                                '<td class="text-end text-nowrap">' + r.orig.toLocaleString('th-TH') + '</td>' +
                                '<td class="text-end text-nowrap fw-semibold text-primary">' + r.deduct.toLocaleString('th-TH') + '</td>' +
                                '<td class="text-end text-nowrap fw-semibold ' + (exhausted ? 'text-danger' : 'text-success') + '">' + r.remain.toLocaleString('th-TH') + '</td>' +
                                '<td class="text-center">' + badgeHtml + '</td>' +
                                '</tr>';
                        }).join('');
                        var quotaHtml = '<hr class="mt-3 mb-3" />' +
                            '<h6 class="fw-bold mb-2"><i class="ri ri-scales-3-line me-1 text-primary"></i>โควตา/ปริมาณที่ตัดจาก RMBS2/RMBS1/P2/P1' +
                            '&nbsp;<span class="badge bg-label-success ms-1" style="font-size:0.7rem;vertical-align:middle;">ตัดโควตาอัตโนมัติแล้ว ✅</span></h6>' +
                            '<div class="table-responsive mb-3">' +
                            '<table class="table table-sm table-bordered mb-0" style="font-size:0.78rem;">' +
                            '<thead class="table-light text-center"><tr>' +
                            '<th style="width:70px;">เอกสาร</th><th>เลขที่</th>' +
                            '<th>น้ำหนักเดิม (กก.)</th><th>ตัดไป (กก.)</th><th>คงเหลือ (กก.)</th><th>สถานะโควตา</th>' +
                            '</tr></thead><tbody>' + rowsHtml + '</tbody></table></div>' +
                            '<div class="alert alert-success d-flex gap-2 align-items-center py-2 px-3" style="font-size:0.82rem;">' +
                            '<i class="ri ri-checkbox-circle-line flex-shrink-0" style="font-size:1.1rem;"></i>' +
                            '<div>✅ ระบบตัดโควตาจาก RMBS2/RMBS1/P2/P1 อัตโนมัติเรียบร้อยแล้ว — ยอดคงเหลือถูกปรับปรุงแล้วในระบบ</div>' +
                            '</div>';
                        if (hasExhausted) {
                            quotaHtml += '<div class="alert alert-warning d-flex gap-2 align-items-center py-2 px-3 mt-2" style="font-size:0.82rem;">' +
                                '<i class="ri ri-error-warning-line flex-shrink-0" style="font-size:1.1rem;"></i>' +
                                '<div>⚠️ มีเอกสารที่หมดโควตาแล้ว — กรุณาตรวจสอบและขอเพิ่มโควตาจากเจ้าหน้าที่กรมประมง</div>' +
                                '</div>';
                        }
                        quotaSection.innerHTML = quotaHtml;
                    } catch (e) { /* ignore parse error */ }
                }
            }

            detailModal.show();
        });
    });

    // 2.10(4): Export Excel — ส่งออกรายการหนังสือรับรองตนเอง
    var btnExportSelfDecl = document.getElementById('btnExportSelfDecl');
    if (btnExportSelfDecl) {
        btnExportSelfDecl.addEventListener('click', function (e) {
            e.preventDefault();
            // TODO: เรียก API /Officer/ExportSelfDeclExcel
            alert('TODO: ส่งออกรายการหนังสือรับรองตนเองเป็น Excel\n(จะ export ตามเงื่อนไข filter ที่เลือกไว้)');
        });
    }

    // 2.10(4): Export Excel — ส่งออก RMBS2/RMBS1/P2/P1
    var btnDoExportRmbs = document.getElementById('btnDoExportRmbs');
    if (btnDoExportRmbs) {
        btnDoExportRmbs.addEventListener('click', function () {
            var selected = [];
            ['exportChkRmbs2', 'exportChkRmbs1', 'exportChkP2', 'exportChkP1'].forEach(function (id) {
                var chk = document.getElementById(id);
                if (chk && chk.checked) selected.push(chk.value);
            });
            if (selected.length === 0) {
                alert('กรุณาเลือกประเภทเอกสารอย่างน้อย 1 ประเภท');
                return;
            }
            var dateFrom  = (document.getElementById('exportDateFrom') || {}).value || '';
            var dateTo    = (document.getElementById('exportDateTo') || {}).value || '';
            var quotaSt   = (document.getElementById('exportQuotaStatus') || {}).value || '';
            var sdFilter  = ((document.getElementById('exportSdFilter') || {}).value || '').trim();
            // TODO: เรียก API /Officer/ExportRmbsExcel?types=RMBS2,RMBS1&dateFrom=...&dateTo=...&quotaStatus=...&sdFilter=...
            alert('TODO: ส่งออก Excel ประเภท: ' + selected.join(', ') +
                '\nวันที่ออก: ' + (dateFrom || 'ทั้งหมด') + ' — ' + (dateTo || 'ทั้งหมด') +
                '\nสถานะโควตา: ' + (quotaSt || 'ทั้งหมด') +
                '\nSD Filter: ' + (sdFilter || 'ทั้งหมด'));
        });
    }
});
</script>
}

