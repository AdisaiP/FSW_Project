                                    <i class="ri ri-file-pdf-line text-secondary"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="sdTableEmpty" class="d-none">
                    <td colspan="12" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@* ============================================================ *@
@*  Hidden detail / batch data (read by JS for modal)           *@
@* ============================================================ *@
@foreach (var d in declarations)
{
    var pct2 = d.WeightKg > 0 ? (int)Math.Round(d.UsedWeightKg / d.WeightKg * 100) : 0;
    var docHasMeasure = d.Batches.Any(b => measureBatches.Contains(b.BatchNo));
    var docMeasureCountryList = string.Join(", ", d.Batches
        .Where(b => measureBatches.Contains(b.BatchNo))
        .Select(b => measureCountries[b.BatchNo]).Distinct());
    var docIuuFail = iuuFailDocs.Contains(d.DocNo);
    var docOtherCond = otherCondDocs.ContainsKey(d.DocNo) ? otherCondDocs[d.DocNo] : "";
    <div id="detail-@d.DocNo" class="d-none"
         data-docno="@d.DocNo"
         data-company="@d.CompanyName"
         data-certtype="@d.CertType"
         data-hscode="@d.HsCode"
         data-product="@d.ProductDesc"
         data-species="@d.Species"
         data-sourcecountry="@d.SourceCountry"
         data-estcode="@d.EstablishmentCode"
         data-issuedat="@d.IssuedAt.ToString("dd/MM/yyyy")"
         data-expiresat="@d.ExpiresAt.ToString("dd/MM/yyyy")"
         data-weighttotal="@((int)d.WeightKg)"
         data-weightused="@((int)d.UsedWeightKg)"
         data-weightremain="@((int)d.RemainingKg)"
         data-hasmeasure="@docHasMeasure.ToString().ToLower()"
         data-measurecountry="@docMeasureCountryList"
         data-iuufail="@docIuuFail.ToString().ToLower()"
         data-othercond="@docOtherCond"></div>

    @* 2.10(3): Quota data for JS *@
    @if (quotaRows.ContainsKey(d.DocNo))
    {
        <div id="quota-template-@d.DocNo" class="d-none" data-quota='@Html.Raw(
            "[" + string.Join(",", quotaRows[d.DocNo].Select(q =>
                $"{{\"type\":\"{q.Type}\",\"docno\":\"{q.DocNo}\",\"orig\":{q.OrigKg},\"deduct\":{q.DeductKg},\"remain\":{q.RemainKg}}}")) + "]"
        )'></div>
    }

    <div id="batch-template-@d.DocNo" class="d-none">
        @foreach (var b in d.Batches)
        {
            <div class="batch-card mb-3">
                <div class="batch-card-header d-flex align-items-center justify-content-between">
                    <span><i class="ri ri-box-3-line me-1 text-primary"></i>@b.BatchNo</span>
                    <div class="d-flex align-items-center gap-2">
                        @if (measureBatches.Contains(b.BatchNo)) {
                            <span class="badge bg-danger" style="font-size:0.65rem;">ติดมาตรการ @measureCountries[b.BatchNo] ❌</span>
                        } else {
                            <span class="badge bg-label-success" style="font-size:0.65rem;">ไม่ติดมาตรการ ✅</span>
                        }
                        <small class="text-muted">วันที่ผลิต: @b.LotDate.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
                <div class="batch-card-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <table class="table table-sm mb-0 source-detail-table">
                                <tbody>
                                    <tr>
                                        <th>วัตถุดิบ</th>
                                        <td>@b.RawMaterial</td>
                                    </tr>
                                    <tr>
                                        <th>น้ำหนักวัตถุดิบ</th>
                                        <td>@b.WeightKg.ToString("N0") กก.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div>
                                <div class="mb-2">
                                    <span class="text-muted small d-block mb-1">เอกสารการนำเข้า / ควบคุมวัตถุดิบ</span>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a href="#" class="link-chip link-chip-rmbs2" title="ระบบ RMBS2 (ใบรับรองนำเข้า)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> RMBS2: @b.Rmbs2No
                                        </a>
                                        <a href="#" class="link-chip link-chip-rmbs1" title="ระบบ RMBS1 (ควบคุมปริมาณวัตถุดิบ)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> RMBS1: @b.Rmbs1No
                                        </a>
                                    </div>
                                </div>
                                <div>
                                    <span class="text-muted small d-block mb-1">เอกสารการผลิต / ผลิตภัณฑ์</span>
                                    <div class="d-flex flex-wrap gap-1">
                                        <a href="#" class="link-chip link-chip-p2" title="เอกสาร P2 (แบบรายงานการผลิต)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> P2: @b.P2No
                                        </a>
                                        <a href="#" class="link-chip link-chip-p1" title="เอกสาร P1 (แบบรายงานผลิตภัณฑ์)" data-bs-toggle="tooltip">
                                            <i class="ri ri-links-line"></i> P1: @b.P1No
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* 2.10(1): Traceability section *@
                    <div class="mt-3 pt-3 border-top">
                        <div class="small fw-semibold text-muted mb-2">
                            <i class="ri ri-map-pin-2-line me-1 text-primary"></i>Traceability — แหล่งที่มาสัตว์น้ำนำเข้า
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-2" style="font-size:0.71rem;">
                                <thead class="table-light text-center">
                                    <tr>
                                        <th>เลขที่ RMBS2</th>
                                        <th>เลขที่ RMBS1</th>
                                        <th>เลขที่ P2</th>
                                        <th>เลขที่ P1</th>
                                        <th>รุ่นการผลิต</th>
                                        <th>น้ำหนัก (กก.)</th>
                                        <th>สถานะมาตรการ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr @Html.Raw(measureBatches.Contains(b.BatchNo) ? "class=\"table-danger\"" : "")>
                                        <td class="text-nowrap"><span class="link-chip link-chip-rmbs2" style="cursor:default;">@b.Rmbs2No</span></td>
                                        <td class="text-nowrap"><span class="link-chip link-chip-rmbs1" style="cursor:default;">@b.Rmbs1No</span></td>
                                        <td class="text-nowrap"><span class="link-chip link-chip-p2" style="cursor:default;">@b.P2No</span></td>
                                        <td class="text-nowrap"><span class="link-chip link-chip-p1" style="cursor:default;">@b.P1No</span></td>
                                        <td class="text-nowrap">@b.BatchNo<br /><span class="text-muted" style="font-size:0.65rem;">@b.LotDate.ToString("dd/MM/yyyy")</span></td>
                                        <td class="text-end text-nowrap">@b.WeightKg.ToString("N0")</td>
                                        <td class="text-center text-nowrap">
                                            @if (measureBatches.Contains(b.BatchNo)) {
                                                <span class="badge bg-danger"
                                                      data-bs-toggle="tooltip"
                                                      title="RMBS1 นี้ติดมาตรการประเทศ @measureCountries[b.BatchNo] — ไม่สามารถขอหนังสือรับรองตนเองเพื่อส่งออกไปยัง @measureCountries[b.BatchNo] ได้"
                                                      style="font-size:0.63rem;">ติดมาตรการ @measureCountries[b.BatchNo] ❌</span>
                                            } else {
                                                <span class="badge bg-label-success" style="font-size:0.63rem;">ปกติ ✅</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="#" class="btn btn-sm" style="font-size:0.72rem;border:1px solid #6f42c1;color:#6f42c1;background:#f3eeff;"
                               onclick="alert('mockup — นำทางไปยังรายละเอียด RMBS2: @b.Rmbs2No');return false;">
                                <i class="ri ri-external-link-line me-1"></i>ดูรายละเอียด RMBS2 →
                            </a>
                            <a href="#" class="btn btn-sm btn-outline-primary" style="font-size:0.72rem;"
                               onclick="alert('mockup — นำทางไปยังรายละเอียด RMBS1: @b.Rmbs1No');return false;">
                                <i class="ri ri-external-link-line me-1"></i>ดูรายละเอียด RMBS1 →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

