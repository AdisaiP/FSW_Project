                        </td>
                        <td class="text-center">@d.HsCode</td>
                        <td>
                            <div>@d.ProductDesc</div>
                            <small class="text-muted">@d.Species</small>
                        </td>
                        <td>@d.SourceCountry</td>
                        <td>
                            <div class="weight-bar-wrap">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-semibold">@d.WeightKg.ToString("N0")</span>
                                    <span class="text-muted">@(pct)%</span>
                                </div>
                                <div class="weight-bar">
                                    <div class="weight-bar-fill @barColor" style="width:@(pct)%"></div>
                                </div>
                                <div class="d-flex justify-content-between" style="font-size:0.68rem;">
                                    <span class="text-muted">ใช้ @d.UsedWeightKg.ToString("N0")</span>
                                    <span class="@(d.RemainingKg==0?"text-danger":d.RemainingKg<d.WeightKg*0.2m?"text-warning":"text-success") fw-bold">คงเหลือ @d.RemainingKg.ToString("N0")</span>
                                </div>
                            </div>
                        </td>
                        <td>@d.IssuedAt.ToString("dd/MM/yyyy")</td>
                        <td>@d.ExpiresAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <span class="badge rounded-pill @d.StatusClass">@d.StatusText</span>
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
