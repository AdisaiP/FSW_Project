                        <option value="มหาสมุทรอินเดีย">มหาสมุทรอินเดีย</option>
                        <option value="มหาสมุทรแปซิฟิก">มหาสมุทรแปซิฟิก</option>
                        <option value="อ่าวไทย">อ่าวไทย</option>
                        <option value="ทะเลอันดามัน">ทะเลอันดามัน</option>
                        <option value="ไทย">ไทย (เพาะเลี้ยง)</option>
                        <option value="เวียดนาม">เวียดนาม</option>
                    </select>
                </div>
            </div>
        </div>
