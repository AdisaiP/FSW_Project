                <label class="form-label small fw-semibold">รายละเอียดที่ต้องแก้ไข <span class="text-danger">*</span></label>
                <textarea id="notifyCorrectRemark" class="form-control" rows="4"
                    placeholder="ระบุรายละเอียดข้อมูลที่ผู้ประกอบการต้องแก้ไข เช่น ข้อมูลน้ำหนักไม่ตรง, เอกสารแนบไม่ครบ..."></textarea>
                <div class="invalid-feedback" id="notifyCorrectRemarkError">กรุณาระบุรายละเอียดที่ต้องแก้ไข</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmNotifyCorrect" class="btn btn-warning">
                    <i class="ri ri-send-plane-line me-1"></i> ส่งแจ้งเตือนกลับผู้ประกอบการ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: ยืนยันการอนุมัติ ==================== -->
<div class="modal fade" id="modalConfirmApprove" tabindex="-1" aria-labelledby="modalConfirmApproveLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalConfirmApproveLabel">
                     ยืนยันการอนุมัติ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="mb-1">คุณต้องการ <strong class="text-success">อนุมัติ</strong> เอกสาร RMBS1 หมายเลข</p>
                <p class="fw-semibold text-primary mb-3">10611280211800000561</p>
                <div class="alert alert-success d-flex gap-2 py-2 mb-3">
                    <i class="ri ri-information-line mt-1 flex-shrink-0"></i>
                    <span class="small">การอนุมัติจะเปลี่ยนสถานะเอกสารเป็น "อนุมัติแล้ว" และแจ้งผลให้ผู้ประกอบการทราบทันที</span>
                </div>
                <div class="mb-0">
                    <label class="form-label small fw-semibold">หมายเหตุการอนุมัติ (ผู้อนุมัติ)</label>
                    <textarea id="approveRemark" class="form-control" rows="2" placeholder="ระบุหมายเหตุเพิ่มเติม (ไม่บังคับ)"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmApprove" class="btn btn-success">
                    <i class="ri ri-checkbox-circle-line me-1"></i> ยืนยันอนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: ออกเอกสาร RMBS1:PS อัตโนมัติ ==================== -->
<div class="modal fade" id="modalAutoIssuePs" tabindex="-1" aria-labelledby="modalAutoIssuePsLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="modalAutoIssuePsLabel">
                    <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติและออกเอกสารอัตโนมัติสำเร็จ
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-success mb-3 d-flex gap-2">
                    <i class="ri ri-file-check-line fs-5 mt-1 flex-shrink-0"></i>
                    <div>
                        <div class="fw-semibold">✅ ระบบออกเลขที่เอกสาร RMBS1:PS อัตโนมัติแล้ว</div>
                        <div class="small text-muted mt-1">เลขที่เอกสาร: <span class="fw-semibold text-success">10611280211800000561</span></div>
                        <div class="small text-muted">วันที่ออก: <span class="fw-semibold" id="modalAutoIssueDateText">—</span> &nbsp;|&nbsp; เวลา: <span class="fw-semibold" id="modalAutoIssueTimeText">—</span> น.</div>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge bg-success fs-6 px-3 py-2"><i class="ri ri-checkbox-circle-line me-1"></i>ออกเลขที่อัตโนมัติ ✅</span>
                </div>
                <div class="small text-muted mb-0">
                    ผลการอนุมัติถูกบันทึกเรียบร้อย และระบบพร้อมแสดงเอกสารสำหรับการตรวจสอบ/พิมพ์
                </div>
            </div>
            <div class="modal-footer">
                <a href="@Url.Action("IndexAdjustRMBS1PS", "ImportAdjustment")" class="btn btn-outline-primary">
                    <i class="ri ri-eye-line me-1"></i> ดูเอกสาร
                </a>
                <button type="button" id="btnPrintAutoIssuedDoc" class="btn btn-success">
                    <i class="ri ri-printer-line me-1"></i> พิมพ์
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: ยืนยันการไม่อนุมัติ ==================== -->
<div class="modal fade" id="modalConfirmReject" tabindex="-1" aria-labelledby="modalConfirmRejectLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalConfirmRejectLabel">
                     ยืนยันการไม่อนุมัติ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="mb-1">คุณต้องการ <strong class="text-danger">ไม่อนุมัติ</strong> เอกสาร RMBS1 หมายเลข</p>
                <p class="fw-semibold text-primary mb-2">10611280211800000561</p>
                <label class="form-label small fw-semibold">เหตุผลการไม่อนุมัติ <span class="text-danger">*</span></label>
                <textarea id="rejectRemark" class="form-control" rows="3" placeholder="ระบุเหตุผลการไม่อนุมัติ..." readonly></textarea>
                <div class="invalid-feedback" id="rejectRemarkError">กรุณาระบุเหตุผลการไม่อนุมัติ</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmReject" class="btn btn-danger">
                    <i class="ri ri-close-circle-line me-1"></i> ยืนยันไม่อนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {

        var btnApprove = document.getElementById('btnApproveRequest');
        var btnReject  = document.getElementById('btnRejectRequest');
        var btnSaveDraft = document.getElementById('btnSaveDraft');
        var btnNotifyCorrect = document.getElementById('btnNotifyCorrect');
        var btnSendToApprover = document.getElementById('btnSendToApprover');

        // ── ส่งให้ผู้อนุมัติ ──
        btnSendToApprover.addEventListener('click', function () {
            var selected = document.querySelector('input[name="decisionResult"]:checked');
            if (!selected) {
                document.getElementById('decisionResultError').classList.remove('d-none');
                document.getElementById('cardDecisionOfficer').scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }
            document.getElementById('decisionResultError').classList.add('d-none');
            var labelMap = { approve: 'สนับสนุนอนุมัติ ✔', reject: 'ไม่อนุมัติ ✖', condition: 'มีเงื่อนไข ⚠' };
            document.getElementById('sendApproverDecisionText').textContent = labelMap[selected.value] || selected.value;
            new bootstrap.Modal(document.getElementById('modalSendToApprover')).show();
        });

        document.getElementById('btnConfirmSendToApprover').addEventListener('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('modalSendToApprover')).hide();
            var banner = document.querySelector('.alert[role="alert"] span');
            if (banner) {
                banner.innerHTML = '<strong>ส่งให้ผู้อนุมัติแล้ว 📨</strong> — รอผู้อนุมัติพิจารณาคำขอนี้';
                var alertEl = document.querySelector('.alert[role="alert"]');
                alertEl.className = 'alert alert-primary d-flex align-items-center gap-2 mb-4';
                alertEl.querySelector('i').className = 'ri ri-send-plane-line fs-5';
            }
            showToast('ส่งผลการพิจารณาให้ผู้อนุมัติเรียบร้อยแล้ว', 'info');
        });

        // ── IUU lock: ล็อก radio "สนับสนุนอนุมัติ" ──
        document.querySelectorAll('input[name="decisionResult"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                document.getElementById('decisionResultError').classList.add('d-none');
            });
        });

        // ── บันทึกร่าง ──
        btnSaveDraft.addEventListener('click', function () {
            showToast('บันทึกร่างเรียบร้อยแล้ว', 'info');
        });

        // ── แจ้งแก้ไข ──
        btnNotifyCorrect.addEventListener('click', function () {
            var el = document.getElementById('notifyCorrectRemark');
            el.classList.remove('is-invalid');
            el.value = '';
            new bootstrap.Modal(document.getElementById('modalNotifyCorrect')).show();
        });

        document.getElementById('btnConfirmNotifyCorrect').addEventListener('click', function () {
            var el = document.getElementById('notifyCorrectRemark');
            if (!el.value.trim()) {
                el.classList.add('is-invalid');
                el.focus();
                return;
            }
            bootstrap.Modal.getInstance(document.getElementById('modalNotifyCorrect')).hide();
            // อัปเดต status banner เป็น "ส่งกลับแก้ไข"
            var banner = document.querySelector('.alert[role="alert"] span');
            if (banner) {
                banner.innerHTML = '<strong>ส่งกลับแก้ไข ⚠️</strong> — แจ้งเตือนไปยังผู้ประกอบการแล้ว รอการแก้ไขจากผู้ประกอบการ';
                var alertEl = document.querySelector('.alert[role="alert"]');
                alertEl.className = 'alert alert-warning d-flex align-items-center gap-2 mb-4';
                alertEl.querySelector('i').className = 'ri ri-reply-line fs-5';
            }
            showToast('ส่งแจ้งแก้ไขกลับผู้ประกอบการเรียบร้อยแล้ว', 'warning');
        });

        document.getElementById('notifyCorrectRemark').addEventListener('input', function () {
            if (this.value.trim()) this.classList.remove('is-invalid');
        });

        // ── อนุมัติ ──
        btnApprove.addEventListener('click', function () {
            new bootstrap.Modal(document.getElementById('modalConfirmApprove')).show();
        });

        document.getElementById('btnConfirmApprove').addEventListener('click', function () {
            // TODO: submit form or call API
            // Set issued date/time (mockup: current date/time)
            var now = new Date();
            var dd = String(now.getDate()).padStart(2,'0');
            var mm = String(now.getMonth()+1).padStart(2,'0');
            var yyyy = now.getFullYear() + 543; // Buddhist era
            var hh = String(now.getHours()).padStart(2,'0');
            var min = String(now.getMinutes()).padStart(2,'0');
            var dateStr = dd + '/' + mm + '/' + yyyy;
            var timeStr = hh + ':' + min;
            // Update modal date/time spans
            document.getElementById('modalAutoIssueDateText').textContent = dateStr;
            document.getElementById('modalAutoIssueTimeText').textContent = timeStr;
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmApprove')).hide();
            showToast('อนุมัติเอกสารเรียบร้อยแล้ว', 'success');
            new bootstrap.Modal(document.getElementById('modalAutoIssuePs')).show();
            // Show persistent auto-issue banner on page
            document.getElementById('bannerAutoIssueDate').textContent = dateStr;
            document.getElementById('bannerAutoIssueTime').textContent = timeStr;
            var banner = document.getElementById('bannerAutoIssue');
            banner.classList.remove('d-none');
            // Update status banner
            var statusBanner = document.querySelector('.alert[role="alert"]:not(#bannerAutoIssue)');
            if (statusBanner) {
                statusBanner.className = 'alert alert-success d-flex align-items-center gap-2 mb-2';
                statusBanner.querySelector('i').className = 'ri ri-checkbox-circle-line fs-5';
                statusBanner.querySelector('span').innerHTML = '<strong>อนุมัติแล้ว ✅</strong> — เอกสาร RMBS1:PS ออกเลขที่อัตโนมัติแล้ว';
            }
        });

        // ── ไม่อนุมัติ ──
        btnReject.addEventListener('click', function () {
            var rejectEl = document.getElementById('rejectRemark');
            rejectEl.classList.remove('is-invalid');
            rejectEl.value = '';
            new bootstrap.Modal(document.getElementById('modalConfirmReject')).show();
        });

        document.getElementById('btnConfirmReject').addEventListener('click', function () {
            var rejectEl = document.getElementById('rejectRemark');
            if (!rejectEl.value.trim()) {
                rejectEl.classList.add('is-invalid');
                rejectEl.focus();
                return;
            }
            // TODO: submit form or call API
            bootstrap.Modal.getInstance(document.getElementById('modalConfirmReject')).hide();
            showToast('ไม่อนุมัติเอกสารเรียบร้อยแล้ว', 'danger');
        });

        document.getElementById('rejectRemark').addEventListener('input', function () {
            if (this.value.trim()) this.classList.remove('is-invalid');
        });

        document.getElementById('btnPrintAutoIssuedDoc').addEventListener('click', function () {
            alert('สั่งพิมพ์เอกสาร RMBS1:PS เรียบร้อย (mockup)');
        });

        // ── Override card (ผู้อนุมัติ) ──
        document.getElementById('btnEnableOverride').addEventListener('click', function () {
            document.getElementById('overrideReadonly').classList.add('d-none');
            document.getElementById('overrideEdit').classList.remove('d-none');
            this.classList.add('d-none');
        });

        document.getElementById('btnCancelOverride').addEventListener('click', function () {
            document.getElementById('overrideEdit').classList.add('d-none');
            document.getElementById('overrideReadonly').classList.remove('d-none');
            document.getElementById('btnEnableOverride').classList.remove('d-none');
        });

        document.getElementById('btnSaveOverride').addEventListener('click', function () {
            var remark = document.getElementById('overrideRemark');
            if (!remark.value.trim()) {
                remark.classList.add('is-invalid');
                remark.focus();
                return;
            }
            remark.classList.remove('is-invalid');
            // Update readonly display with new value
            var selected = document.querySelector('input[name="overrideResult"]:checked');
            var labelMap = { approve: '<span class="badge bg-label-success me-2">✔ อนุมัติ</span>', reject: '<span class="badge bg-label-danger me-2">✖ ไม่อนุมัติ</span>', condition: '<span class="badge bg-label-warning me-2">⚠ มีเงื่อนไข</span>' };
            var readonlyFields = document.querySelectorAll('#overrideReadonly .field-display');
            if (readonlyFields[0] && selected) readonlyFields[0].innerHTML = labelMap[selected.value] || selected.value;
            if (readonlyFields[2]) readonlyFields[2].textContent = remark.value;
            document.getElementById('overrideEdit').classList.add('d-none');
            document.getElementById('overrideReadonly').classList.remove('d-none');
            document.getElementById('btnEnableOverride').classList.remove('d-none');
            showToast('บันทึกผลการพิจารณา (override) เรียบร้อยแล้ว', 'success');
        });

        document.getElementById('overrideRemark').addEventListener('input', function () {
            if (this.value.trim()) this.classList.remove('is-invalid');
        });

        // ── Sanitary Lock ──
        // "ทุกประเทศ" ToggleAll
        document.getElementById('lockAll').addEventListener('change', function () {
            document.querySelectorAll('.sanitary-country').forEach(function (cb) {
                if (cb.id !== 'lockAll') cb.checked = false;
            });
        });
        document.querySelectorAll('.sanitary-country:not(#lockAll)').forEach(function (cb) {
            cb.addEventListener('change', function () {
                if (this.checked) document.getElementById('lockAll').checked = false;
            });
        });

        document.getElementById('btnSaveSanitaryLock').addEventListener('click', function () {
            var checked = Array.from(document.querySelectorAll('.sanitary-country:checked'));
            if (checked.length === 0) {
                document.getElementById('sanitaryLockError').classList.remove('d-none');
                return;
            }
            document.getElementById('sanitaryLockError').classList.add('d-none');
            var names = checked.map(function (cb) { return cb.value; }).join(', ');
            document.getElementById('sanitaryLockSummary').textContent = names;
            document.getElementById('sanitaryLockForm').classList.add('d-none');
            document.getElementById('sanitaryLockSaved').classList.remove('d-none');
            document.getElementById('badgeSanitaryLocked').classList.remove('d-none');
            showToast('ล็อกมาตรการสุขอนามัยเรียบร้อยแล้ว — แจ้งผู้ประกอบการแล้ว', 'info');
        });

        document.getElementById('btnEditSanitaryLock').addEventListener('click', function () {
            document.getElementById('sanitaryLockSaved').classList.add('d-none');
            document.getElementById('sanitaryLockForm').classList.remove('d-none');
        });

        // ── (ค) Import Details Edit Toggle ──
        document.getElementById('btnEditImportDetails').addEventListener('click', function () {
            document.getElementById('importDetailsReadonly').classList.add('d-none');
            document.getElementById('importDetailsForm').classList.remove('d-none');
        });
        document.getElementById('btnCancelImportEdit').addEventListener('click', function () {
            document.getElementById('importDetailsForm').classList.add('d-none');
            document.getElementById('importDetailsReadonly').classList.remove('d-none');
        });
        document.getElementById('btnSaveImportDetails').addEventListener('click', function () {
            document.getElementById('importDetailsForm').classList.add('d-none');
            document.getElementById('importDetailsReadonly').classList.remove('d-none');
            showToast('บันทึกรายละเอียดการนำเข้าเรียบร้อยแล้ว', 'success');
        });
        document.getElementById('btnAttachImportEvidence').addEventListener('click', function () {
            showToast('ฟังก์ชันแนบหลักฐาน — TODO: implement file upload', 'info');
        });

        // ── Toast helper ──
        function showToast(msg, type) {
            var bg = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : type === 'warning' ? 'bg-warning' : 'bg-info';
            var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-close-circle-line' : type === 'warning' ? 'ri-reply-line' : 'ri-information-line';
            var toastEl = document.createElement('div');
            toastEl.className = 'position-fixed bottom-0 end-0 p-3' ;
            toastEl.style.zIndex = 9999;
            toastEl.innerHTML =
                '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
                '  <div class="d-flex">' +
                '    <div class="toast-body d-flex align-items-center gap-2">' +
                '      <i class="ri ' + icon + ' fs-5"></i> ' + msg +
                '    </div>' +
                '    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '  </div>' +
                '</div>';
            document.body.appendChild(toastEl);
            setTimeout(function () { toastEl.remove(); }, 3500);
        }

    });
</script>
}
