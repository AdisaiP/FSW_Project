@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // flatpickr with Thai Buddhist Era for date inputs
        ['filterDraftDateFrom', 'filterDraftDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) return;
            flatpickr(el, {
                dateFormat: 'd/m/Y',
                allowInput: true,
                formatDate: function (date) {
                    var d = date.getDate().toString().padStart(2, '0');
                    var m = (date.getMonth() + 1).toString().padStart(2, '0');
                    var y = date.getFullYear() + 543;
                    return d + '/' + m + '/' + y;
                },
                parseDate: function (str) {
                    var parts = str.split('/');
                    if (parts.length < 3) return null;
                    var year = parseInt(parts[2], 10);
                    if (year > 2500) year -= 543;
                    return new Date(year, parseInt(parts[1], 10) - 1, parseInt(parts[0], 10));
                }
            });
        });

        // ── 2.7(3): Filter with 9 criteria ────────────────────────
        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var day   = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year  = parseInt(parts[2], 10);
            if (year > 2500) year -= 543;
            var hours   = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed  = new Date(year, month, day, hours, minutes, seconds);
            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certType   = (document.getElementById('filterCertType').value || '').trim();
            var status     = (document.getElementById('filterStatus').value || '').trim();
            var reqNo      = (document.getElementById('filterReqNo')?.value || '').trim().toLowerCase();
            var estab      = (document.getElementById('filterEstab')?.value || '').trim().toLowerCase();
            var factory    = (document.getElementById('filterFactory')?.value || '').trim().toLowerCase();
            var product    = (document.getElementById('filterProduct')?.value || '').trim().toLowerCase();
            var country    = (document.getElementById('filterCountry')?.value || '').trim().toLowerCase();
            var receivedNo = (document.getElementById('filterReceivedNo')?.value || '').trim().toLowerCase();
            var fromDate   = parseDateInput(document.getElementById('filterDraftDateFrom')?.value, false);
            var toDate     = parseDateInput(document.getElementById('filterDraftDateTo')?.value, true);
            var exclude    = document.getElementById('filterDateExclude')?.checked || false;

            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var certTypeMatch   = !certType   || (row.dataset.certtype    || '') === certType;
                var statusMatch     = !status     || (row.dataset.status      || '') === status;
                var reqNoMatch      = !reqNo      || (row.dataset.reqno       || '').includes(reqNo);
                var estabMatch      = !estab      || (row.dataset.estab       || '').includes(estab);
                var factoryMatch    = !factory    || (row.dataset.factory     || '').includes(factory);
                var productMatch    = !product    || (row.dataset.product     || '').includes(product);
                var countryMatch    = !country    || (row.dataset.country     || '').includes(country);
                var receivedNoMatch = !receivedNo || (row.dataset.receivedno  || '').includes(receivedNo);

                var dateMatch = true;
                if (fromDate || toDate) {
                    var rowDate = new Date(row.dataset.draftDate || '');
                    if (!isNaN(rowDate.getTime())) {
                        var inRange = (!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate);
                        dateMatch = exclude ? !inRange : inRange;
                    }
                }

                var visible = certTypeMatch && statusMatch && reqNoMatch && estabMatch
                           && factoryMatch && productMatch && countryMatch && receivedNoMatch && dateMatch;
                row.classList.toggle('d-none', !visible);
                if (visible) visibleCount++;
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterCertType').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterDateExclude')?.addEventListener('change', filterRows);

        // Enter key on any filter input triggers search
        document.querySelectorAll('#filterCertType, #filterStatus, #filterReqNo, #filterEstab, #filterFactory, #filterProduct, #filterCountry, #filterReceivedNo, #filterDraftDateFrom, #filterDraftDateTo').forEach(function (el) {
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });

        document.getElementById('btnResetRequests').addEventListener('click', function () {
            ['filterCertType','filterStatus','filterReqNo','filterEstab','filterFactory',
             'filterProduct','filterCountry','filterReceivedNo','filterDraftDateFrom','filterDraftDateTo'
            ].forEach(function (id) {
                var el = document.getElementById(id);
                if (el) el.value = '';
            });
            var chk = document.getElementById('filterDateExclude');
            if (chk) chk.checked = false;
            // collapse advanced panel
            var adv = document.getElementById('advancedSearch');
            if (adv && adv.classList.contains('show')) {
                var bsInst = bootstrap.Collapse.getInstance(adv);
                if (bsInst) bsInst.hide();
            }
            filterRows();
        });
    });
</script>
}

