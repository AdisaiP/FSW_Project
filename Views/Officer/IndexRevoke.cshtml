        <div>
            <h5 class="card-title mb-1">ค้นหาคำขอยกเลิก</h5>
            <p class="text-muted small mb-0">ค้นหาจากประเภทใบรับรอง / สถานะ หรือเปิด "ค้นหาขั้นสูง" สำหรับเงื่อนไขเพิ่มเติม</p>
        </div>
        @* 2.7(3): ปุ่มสร้างคำขอยกเลิก *@
        <button type="button" class="btn btn-primary" id="btnCreateRevokeRequest"
                onclick="alert('TODO: สร้างคำขอยกเลิก (เจ้าหน้าที่)')">
            <i class="ri ri-add-line me-1"></i>สร้างคำขอยกเลิก (เจ้าหน้าที่)
        </button>
    </div>
    <div class="card-body pb-2">
        @* --- แถวหลัก: ประเภท + สถานะ + ปุ่ม --- *@
        <div class="row g-3 align-items-end mb-3">
            <div class="col-md-4 col-lg-3">
                <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="NMD">NMD — ใบรับรองสัตว์น้ำไม่แปรรูป</option>
                    <option value="PS">PS — ใบรับรองการแปรรูปสัตว์น้ำ</option>
                    <option value="PST">PST — ใบรับรองการแปรรูป (ไทย)</option>
                    <option value="NMDT">NMDT — ใบรับรองไม่แปรรูป (ไทย)</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติ">อนุมัติ ✅</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ ❌</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                    <option value="ฉบับร่าง">ฉบับร่าง</option>
                </select>
            </div>
            <div class="col-auto d-flex align-items-end gap-2">
                <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square filter-action-buttons" title="ค้นหา">
                    <i class="ri ri-search-line"></i>
                </button>
                <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square filter-action-buttons">
                    <i class="ri ri-refresh-line"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        data-bs-toggle="collapse" data-bs-target="#advancedSearch" aria-expanded="false">
                    <i class="ri ri-equalizer-line me-1"></i>ค้นหาขั้นสูง
                </button>
            </div>
        </div>

        @* --- ค้นหาขั้นสูง (Collapsible) --- *@
        <div class="collapse" id="advancedSearch">
            <hr class="my-2" />
            <div class="row g-3 align-items-end pb-2">
                <div class="col-md-4 col-lg-3">
                    <label for="filterReqNo" class="form-label small">เลขที่คำขอ</label>
                    <input type="text" id="filterReqNo" class="form-control form-control-sm" placeholder="เลขที่คำขอ" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterEstab" class="form-label small">ชื่อสถานประกอบการ</label>
                    <input type="text" id="filterEstab" class="form-control form-control-sm" placeholder="ชื่อสถานประกอบการ" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterFactory" class="form-label small">เลขทะเบียนโรงงาน</label>
                    <input type="text" id="filterFactory" class="form-control form-control-sm" placeholder="เลขทะเบียนโรงงาน" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterProduct" class="form-label small">ชื่อสินค้า</label>
                    <input type="text" id="filterProduct" class="form-control form-control-sm" placeholder="ชื่อสินค้า" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterCountry" class="form-label small">ประเทศปลายทาง</label>
                    <input type="text" id="filterCountry" class="form-control form-control-sm" placeholder="ประเทศปลายทาง" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterReceivedNo" class="form-label small">เลขที่รับคำขอ</label>
                    <input type="text" id="filterReceivedNo" class="form-control form-control-sm" placeholder="เลขที่รับคำขอ" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterDraftDateFrom" class="form-label small">วันที่ยื่น (ตั้งแต่)</label>
                    <input type="text" id="filterDraftDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label for="filterDraftDateTo" class="form-label small">ถึงวันที่</label>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="text" id="filterDraftDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                        <div class="form-check mb-0 flex-shrink-0">
                            <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                            <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอยกเลิกใบรับรอง</h5>
            <p class="text-muted small mb-0">รายการคำขอยกเลิกใบรับรอง NMD / PS / PST / NMDT ทั้งหมด @totalRequestCount รายการ</p>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:180px;">เลขที่คำขอ</th>
                    <th style="width:4.5rem;">ประเภท</th>
                    <th style="min-width:180px;">สถานประกอบการ</th>
                    <th style="min-width:140px;">สินค้า / ประเทศ</th>
                    <th>เรื่อง</th>
                    <th style="min-width:120px;">วันที่ยื่น</th>
                    <th style="min-width:140px;">เลขที่รับคำขอ</th>
                    <th style="width:7rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey"
                        data-certtype="@request.CertificateKey"
                        data-status="@request.StatusText"
                        data-draft-date="@request.TransactionAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-reqno="@request.RequestNumber.ToLower()"
                        data-estab="@request.EstablishmentName.ToLower()"
                        data-factory="@request.FactoryRegNo.ToLower()"
                        data-product="@request.ProductName.ToLower()"
                        data-country="@request.DestinationCountry.ToLower()"
                        data-receivedno="@request.ReceivedNo.ToLower()">
                        <td>
                            <span class="fw-semibold text-primary d-block mb-1">@request.RequestNumber</span>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                                @* ReceivedNo แสดงใน column เลขที่รับคำขอ แล้ว (2.7(5)) *@
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge @request.CertTypeBadge">@request.CertificateKey</span>
                        </td>
                        <td class="small">
                            <span class="fw-semibold d-block">@request.EstablishmentName</span>
                            <span class="text-muted" style="font-size:0.72rem;">@request.FactoryRegNo</span>
                        </td>
                        <td class="small">
                            <span class="d-block">@request.ProductName</span>
                            <span class="text-muted" style="font-size:0.72rem;">@request.DestinationCountry</span>
                        </td>
                        <td class="small">@request.Subject</td>
                        <td class="text-center small text-nowrap">
                            @{ var beYear = request.TransactionAt.Year + 543; }
                            @request.TransactionAt.ToString("dd/MM/")@beYear<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm"))</span>
                        </td>
                        @* 2.7(5): เลขที่รับคำขอ dedicated column *@
                        <td class="text-center small">
                            @if (!string.IsNullOrEmpty(request.ReceivedNo))
                            {
                                <span class="fw-semibold text-success d-block">
                                    <i class="ri ri-inbox-archive-line me-1"></i>@request.ReceivedNo
                                </span>
                            }
                            else if (request.StatusText == "รออนุมัติ")
                            {
                                <span class="badge bg-label-warning">
                                    <i class="ri ri-time-line me-1"></i>รอลงทะเบียน
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                @{ var isProcessingType = request.CertificateKey == "PS" || request.CertificateKey == "PST"; }
                                @if (request.StatusText == "รออนุมัติ" || request.StatusText == "ฉบับร่าง")
                                {
                                    <a href="@Url.Action("ReviewRevoke", "Officer")"
                                       class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                    @* 2.7(3): ปุ่มแก้ไข/ลบ *@
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary" data-bs-toggle="tooltip" title="แก้ไข"
                                            onclick="alert('TODO: แก้ไขคำขอยกเลิก @request.RequestNumber')">
                                        <i class="ri ri-edit-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" data-bs-toggle="tooltip" title="ลบ"
                                            onclick="if(confirm('ยืนยันลบคำขอยกเลิก @request.RequestNumber ?')) alert('TODO: ลบ')">
                                        <i class="ri ri-delete-bin-line"></i>
                                    </button>
                                    @if (request.StatusText == "รออนุมัติ")
                                    {
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-success" data-bs-toggle="tooltip" title="อนุมัติ"
                                                onclick="if(confirm('ยืนยันอนุมัติคำขอยกเลิก @request.RequestNumber ?')) alert('TODO: อนุมัติ')">
                                            <i class="ri ri-checkbox-circle-line text-success"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-danger" data-bs-toggle="tooltip" title="ไม่อนุมัติ"
                                                onclick="if(confirm('ยืนยันไม่อนุมัติคำขอยกเลิก @request.RequestNumber ?')) alert('TODO: ไม่อนุมัติ')">
                                            <i class="ri ri-close-circle-line text-danger"></i>
                                        </button>
                                    }
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ไม่อนุมัติ")
                                {
                                    <a href="@Url.Action("ReviewRevoke", "Officer")"
                                       class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                }
                                @if (request.StatusText == "ยกเลิก")
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="8" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>