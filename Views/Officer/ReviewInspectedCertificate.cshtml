    // ปริมาณน้ำหนัก
    var requestedWeightKg   = 15000m;
    var inspectedWeightKg   = 14850m; // น้ำหนักที่ผ่านตรวจปล่อย (อาจน้อยกว่าที่ขอ)

    // ข้อมูลสินค้า
    var productDesc     = "CANNED TUNA IN OIL";
    var hsCode          = "1604.14";
    var destCountry     = "ญี่ปุ่น";
    var destCountryCode = "JAPAN";
    var refCertNo       = ""; // เลขที่ใบรับรองอ้างอิง (กรณี PS อ้างอิง Declaration)

    var destPort        = "Port of Osaka, Japan";
    var packageDesc     = "Cartons × 600 cases, 24.75 kg/case";

    // 2.9(2): Role-based access control (mock)
    // เปลี่ยน currentViewRole เพื่อดูมุมมองต่าง role
    var currentViewRole = "other"; // "owner" | "other" | "กตส"
    var viewerAgencyName = "กรมศุลกากร";
    var canViewEvidence = currentViewRole == "owner";  // Tab หลักฐานประกอบ — เฉพาะเจ้าของข้อมูล
    var canEdit = currentViewRole == "owner";
