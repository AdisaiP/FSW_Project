@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section PageStyles {
<style>
    .review-insp-section { font-size: 0.83rem; }
    .review-insp-section .form-label { font-weight: 600; font-size: 0.78rem; margin-bottom: 0.2rem; color: #444; }
    .review-insp-section .form-control-plaintext { font-size: 0.83rem; padding: 0.25rem 0; }
