    var requestedAtStr  = "15/04/2569";
    var receivedAtStr   = "16/04/2569";
    var issuedAtStr     = "20/04/2569";
    var expiredAtStr    = "19/04/2570";

    // ข้อมูลตรวจปล่อย (ด่านตรวจประมง)
