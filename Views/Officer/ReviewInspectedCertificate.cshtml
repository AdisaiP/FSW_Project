    }
</style>
}

@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ── Tooltip ──
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    }

    // ── Issue date validation: ≥ วันโหลดสินค้า AND ≤ วันส่งออก ──
    var LOADING_DATE    = '2026-04-21'; // yyyy-MM-dd
    var EXPORT_DATE     = '2026-04-22';

    var issueDateInput  = document.getElementById('inputIssueDate');
    var alertBefore     = document.getElementById('alertIssueDateBefore');
    var alertAfter      = document.getElementById('alertIssueDateAfter');
    var alertOk         = document.getElementById('alertIssueDateOk');

    if (issueDateInput) {
        flatpickr(issueDateInput, {
            dateFormat: 'd/m/Y',
            allowInput: true,
            onChange: validateIssueDate
        });
    }

    function parseLocalDate(str) {
        if (!str) return null;
        var p = str.split('/');
        if (p.length === 3) {
            var yr = parseInt(p[2]); if (yr > 2500) yr -= 543;
            return new Date(yr, parseInt(p[1]) - 1, parseInt(p[0]));
        }
        return new Date(str); // ISO
    }

    function validateIssueDate() {
        var val   = issueDateInput.value;
        var dt    = parseLocalDate(val);
        var dLoad = parseLocalDate(LOADING_DATE.split('-').reverse().join('/'));
        var dExp  = parseLocalDate(EXPORT_DATE.split('-').reverse().join('/'));
        alertBefore.classList.add('d-none');
        alertAfter.classList.add('d-none');
        alertOk.classList.add('d-none');
        if (!val || !dt) return;
        if (dt < dLoad) {
            alertBefore.classList.remove('d-none');
        } else if (dt > dExp) {
            alertAfter.classList.remove('d-none');
        } else {
            alertOk.classList.remove('d-none');
        }
    }

    // ── น้ำหนักตรวจปล่อย — อัปเดต progress bar + badge ──
    var MAX_WEIGHT      = @requestedWeightKg;
    var weightInput     = document.getElementById('inputInspectedWeight');
    var weightBar       = document.getElementById('weightBarFill');
    var weightPctLabel  = document.getElementById('weightPctLabel');
    var weightExceed    = document.getElementById('alertWeightExceed');
    var weightOk        = document.getElementById('alertWeightOk');

    function updateWeightBar() {
        if (!weightInput) return;
        var val = parseFloat(weightInput.value) || 0;
        var pct = Math.min((val / MAX_WEIGHT) * 100, 100);
        if (weightBar) { weightBar.style.width = pct + '%'; weightBar.style.background = val > MAX_WEIGHT ? '#dc3545' : ''; }
        if (weightPctLabel) weightPctLabel.textContent = val.toLocaleString('th-TH', {minimumFractionDigits:2,maximumFractionDigits:2}) + ' กก. (' + pct.toFixed(1) + '%)';
        if (weightExceed) weightExceed.classList.toggle('d-none', val <= MAX_WEIGHT);
        if (weightOk) weightOk.classList.toggle('d-none', val > MAX_WEIGHT || val <= 0);
    }
    if (weightInput) {
        weightInput.addEventListener('input', updateWeightBar);
        updateWeightBar();
    }

    // ── ปุ่มบันทึกน้ำหนัก ──
    var btnSaveWeight = document.getElementById('btnSaveWeight');
    if (btnSaveWeight) {
        btnSaveWeight.addEventListener('click', function () {
            var val = parseFloat(weightInput.value) || 0;
            if (val <= 0) { alert('กรุณาระบุน้ำหนักที่ถูกต้อง'); return; }
            if (val > MAX_WEIGHT) { alert('น้ำหนักเกินกว่าที่ขอ'); return; }
            document.getElementById('savedWeightMsg').classList.remove('d-none');
            setTimeout(function () { document.getElementById('savedWeightMsg').classList.add('d-none'); }, 3000);
            // TODO: submit form or call API — update inspected weight
        });
    }

    // ── Modal ออกใบรับรอง — Original/Copy toggle ──
    var CERT_TITLES = { PS: 'Processing Statement', NMD: 'Non-Manipulation Document' };
    document.querySelectorAll('input[name="issueCopyType"]').forEach(function (r) {
        r.addEventListener('change', function () {
            var isCopy = this.value === 'copy';
            document.getElementById('issueCopyCountWrap').classList.toggle('d-none', !isCopy);
            var label = isCopy ? 'COPY' : 'ORIGINAL';
            document.getElementById('issueCopyBadge').textContent = label;
            document.getElementById('issueCopyBadge').className = isCopy ? 'badge bg-label-secondary ms-1' : 'badge bg-label-success ms-1';
        });
    });

    // Download PDF mockup
    document.querySelectorAll('.btn-download-cert-pdf').forEach(function (btn) {
        btn.addEventListener('click', function () {
            alert('mockup — ระบบจริงจะสร้างไฟล์ PDF/A-3 และดาวน์โหลดอัตโนมัติ');
            // TODO: call API /api/certificate/download-pdf
        });
    });

    // ── แจ้งแก้ไข ──
    var btnConfirmNotify = document.getElementById('btnConfirmNotify');
    if (btnConfirmNotify) {
        btnConfirmNotify.addEventListener('click', function () {
            var reason = document.getElementById('notifyReason').value.trim();
            if (!reason) { alert('กรุณาระบุเหตุผลการแจ้งแก้ไข'); return; }
            document.getElementById('notifySuccessMsg').classList.remove('d-none');
            this.disabled = true;
            // TODO: submit form or call API
        });
    }
});
</script>
}

@* ──────────────── Content ──────────────── *@
<h4 class="mb-1">รายละเอียดใบรับรองที่ผ่านตรวจปล่อย</h4>
<p class="mb-1 text-muted">ตรวจสอบข้อมูลใบรับรอง ปรับน้ำหนักตามตรวจปล่อย และออกใบรับรองฉบับจริง</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="@Url.Action("IndexSearchCertificate","Officer")" class="text-primary fw-semibold">ค้นหาใบรับรอง</a></li>
