@{
    ViewData["Title"] = "รายละเอียดใบรับรองที่ผ่านตรวจปล่อย";

    // ── Mock data — ในระบบจริงรับจาก Model ──
    var certNo          = "PS-2026-00401";
    var certType        = "PS"; // PS | NMD
    var certTypeFull    = "Processing Statement (PS)";
    var requestNo       = "10611080326000401";
    var receiptNo       = "รบ. 2026-00401";
    var statusText      = "ผ่านตรวจปล่อยแล้ว";
    var statusClass     = "bg-label-success";
    var statusIcon      = "ri-shield-check-line";

    // คำขอ / บริษัท
    var companyName     = "บริษัท สยาม มารีน ฟู้ดส์ จำกัด";
    var companyBranch   = "สำนักงานใหญ่";
    var factoryRegNo    = "TH-1-6100-10-401/22";
    var contactPerson   = "นางสาวสมหญิง มีสุข";
    var contactTel      = "02-123-4567";
    var issuedByName    = "นายสมชาย ใจดี";

