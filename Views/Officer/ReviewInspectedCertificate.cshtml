    <div class="card-body py-3">
        <div class="row align-items-center g-3">
            <div class="col-auto">
                <span class="badge @statusClass rounded-pill px-3 py-2 fs-6">
                    <i class="ri @statusIcon me-1"></i>@statusText
                </span>
            </div>
            <div class="col">
                <div class="d-flex flex-wrap gap-4 small">
                    <div>
                        <span class="text-muted">เลขที่ใบรับรอง:</span>
                        <span class="fw-semibold ms-1">@certNo</span>
                        <span class="badge bg-label-info ms-1">@certType</span>
                    </div>
                    <div>
                        <span class="text-muted">เลขที่คำขอ:</span>
                        <span class="fw-semibold ms-1">@requestNo</span>
                    </div>
                    <div>
                        <span class="text-muted">เลขที่รับคำขอ:</span>
                        <span class="fw-semibold ms-1">@receiptNo</span>
                    </div>
                    <div>
                        <span class="text-muted">ผู้ออก:</span>
                        <span class="fw-semibold ms-1">@issuedByName</span>
                    </div>
                    <div>
                        <span class="text-muted">วันที่ออก:</span>
                        <span class="fw-semibold ms-1">@issuedAtStr</span>
                    </div>
                    <div>
                        <span class="text-muted">วันหมดอายุ:</span>
                        <span class="fw-semibold ms-1">@expiredAtStr</span>
                    </div>
                </div>
            </div>
            <div class="col-auto no-print">
                @if (canEdit)
                {
                    <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalIssueCert">
                        <i class="ri ri-award-line me-1"></i>ออกใบรับรอง Original/Copy
                    </button>
                    <button class="btn btn-outline-warning btn-sm ms-1" data-bs-toggle="modal" data-bs-target="#modalNotifyFix">
                        <i class="ri ri-error-warning-line me-1"></i>แจ้งแก้ไข
                    </button>
                }
                else
                {
                    <span class="badge bg-label-secondary px-3 py-2">
                        <i class="ri ri-eye-line me-1"></i>ดูเท่านั้น (readonly)
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 review-insp-section">

    <!-- ════════════ COL LEFT ════════════ -->
    <div class="col-lg-7">

        <!-- ── Section 1: ข้อมูลสถานประกอบการ ── -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="section-heading">1. ข้อมูลสถานประกอบการ</div>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">ชื่อสถานประกอบการ</label>
                        <div class="form-control-plaintext fw-semibold">@companyName (@companyBranch)</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">เลขทะเบียนโรงงาน</label>
                        <div class="form-control-plaintext"><span class="badge bg-label-secondary">@factoryRegNo</span></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ผู้ติดต่อ</label>
                        <div class="form-control-plaintext">@contactPerson &nbsp;<a href="tel:@contactTel" class="text-muted small">@contactTel</a></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ประเภทใบรับรอง</label>
                        <div class="form-control-plaintext">@certTypeFull</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 2: ข้อมูลสินค้า ── -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="section-heading">2. ข้อมูลสินค้า / ผลิตภัณฑ์</div>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">ชื่อสินค้า / รายละเอียด</label>
                        <div class="form-control-plaintext fw-semibold">@productDesc</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">HS Code</label>
                        <div class="form-control-plaintext"><span class="badge bg-label-secondary rounded-pill">@hsCode</span></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ประเทศปลายทาง</label>
                        <div class="form-control-plaintext">@destCountry <span class="text-muted small">(@destCountryCode)</span></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ท่าเรือปลายทาง</label>
                        <div class="form-control-plaintext">@destPort</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ชื่อเรือ / ยานพาหนะ</label>
                        <div class="form-control-plaintext fw-semibold"><i class="ri ri-ship-2-line me-1 text-primary"></i>@vesselName</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">รายละเอียดบรรจุภัณฑ์</label>
                        <div class="form-control-plaintext text-muted">@packageDesc</div>
                    </div>
                    @if (!string.IsNullOrEmpty(refCertNo)) {
                        <div class="col-12">
                            <label class="form-label">เลขที่ใบรับรองอ้างอิง (Declaration)</label>
                            <div class="form-control-plaintext"><a href="#" class="text-primary fw-semibold">@refCertNo</a></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ── Section 3: ข้อมูลตรวจปล่อย (ด่านตรวจประมง) ── -->
        <div class="card mb-4 border-primary" style="border-width:2px!important;">
            <div class="card-header py-2 d-flex align-items-center gap-2" style="background:#f0f7ff;">
                <i class="ri ri-shield-check-line text-primary"></i>
                <span class="fw-semibold">3. ข้อมูลตรวจปล่อย (ด่านตรวจประมง)</span>
                <a href="#" class="btn btn-outline-primary btn-sm ms-auto no-print" style="font-size:0.75rem;">
                    <i class="ri ri-external-link-line me-1"></i>ดูสถานะตรวจปล่อย ด่านตรวจประมง →
                </a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <!-- ด่านตรวจ -->
                    <div class="col-md-6">
                        <label class="form-label">ด่านตรวจปล่อย</label>
                        <div class="form-control-plaintext fw-semibold">
                            <i class="ri ri-map-pin-2-line me-1 text-primary"></i>@inspectionPort
                        </div>
                    </div>
                    <!-- วันที่โหลดสินค้า -->
                    <div class="col-md-3">
                        <label class="form-label">วันที่โหลดสินค้า</label>
                        <div class="form-control-plaintext">@loadingDateStr</div>
                    </div>
                    <!-- วันที่ส่งออก -->
                    <div class="col-md-3">
                        <label class="form-label">วันที่ส่งออก</label>
                        <div class="form-control-plaintext">@exportDateStr</div>
                    </div>
                    <!-- วันที่ตรวจปล่อย -->
                    <div class="col-md-4">
                        <label class="form-label">วันที่ตรวจปล่อย (ด่านตรวจ)</label>
                        <div class="form-control-plaintext">
                            <span class="badge bg-label-success px-3 py-2">
                                <i class="ri ri-calendar-check-line me-1"></i>@inspectionDateStr
                            </span>
                        </div>
                    </div>
                    <!-- Issue Date (คำนวณ = วันที่ตรวจปล่อย, แก้ไขได้) -->
                    <div class="col-md-4">
                        <label class="form-label">
                            Issue Date
                            <span class="badge bg-label-secondary ms-1" style="font-size:0.65rem;">คำนวณอัตโนมัติ</span>
                        </label>
                        <input type="text" class="form-control form-control-sm" id="inputIssueDate"
                               value="@issueDateStr" placeholder="วว/ดด/ปปปป" />
                        <div class="mt-1">
                            <div id="alertIssueDateBefore" class="d-none">
                                <span class="text-danger small">
                                    <i class="ri ri-error-warning-line me-1"></i>⛔ Issue date ก่อนวันโหลดสินค้า (@loadingDateStr) — ไม่ถูกต้อง
                                </span>
                            </div>
                            <div id="alertIssueDateAfter" class="d-none">
                                <span class="text-danger small">
                                    <i class="ri ri-error-warning-line me-1"></i>⛔ Issue date หลังวันส่งออก (@exportDateStr) — ไม่ถูกต้อง
                                </span>
                            </div>
                            <div id="alertIssueDateOk" class="d-none">
                                <span class="text-success small">
                                    <i class="ri ri-checkbox-circle-line me-1"></i>Issue date ถูกต้อง ✅
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- สถานะตรวจปล่อย -->
                    <div class="col-md-4">
                        <label class="form-label">สถานะตรวจปล่อย</label>
                        <div class="mt-1">
                            <span class="badge bg-label-success px-3 py-2">
                                <i class="ri ri-shield-check-line me-1"></i>ผ่านการตรวจปล่อยแล้ว ✅
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 4: ปรับปริมาณน้ำหนักตามตรวจปล่อย ── -->
        <div class="card mb-4">
            <div class="card-header py-2 d-flex align-items-center gap-2" style="background:#f8f9fc;">
                <i class="ri ri-scales-3-line text-success"></i>
                <span class="fw-semibold">4. ปรับปริมาณน้ำหนักตามตรวจปล่อย</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">น้ำหนักที่ขอตามใบรับรอง (กก.)</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control bg-light"
                                   value="@requestedWeightKg.ToString("N2")" readonly />
                            <span class="input-group-text">กก.</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">
                            น้ำหนักที่ผ่านตรวจปล่อย (กก.)
                            <span class="text-muted small fw-normal">(≤ น้ำหนักที่ขอ)</span>
                        </label>
                        <div class="input-group input-group-sm">
                            <input type="number" class="form-control" id="inputInspectedWeight"
                                   value="@inspectedWeightKg.ToString("F2")"
                                   min="0.01" max="@requestedWeightKg" step="0.01" />
                            <span class="input-group-text">กก.</span>
                            <button class="btn btn-outline-success btn-sm" type="button" id="btnSaveWeight"
                                    data-bs-toggle="tooltip" title="บันทึกน้ำหนักปรับ">
                                <i class="ri ri-save-line"></i>
                            </button>
                        </div>
                        <div id="alertWeightExceed" class="d-none mt-1">
                            <span class="text-danger small">
                                <i class="ri ri-error-warning-line me-1"></i>⛔ น้ำหนักเกินกว่าที่ขอ (สูงสุด @requestedWeightKg.ToString("N0") กก.)
                            </span>
                        </div>
                        <div id="alertWeightOk" class="d-none mt-1">
                            <span class="text-success small">
                                <i class="ri ri-checkbox-circle-line me-1"></i>น้ำหนักถูกต้อง
                            </span>
                        </div>
                        <div id="savedWeightMsg" class="d-none mt-1">
                            <span class="text-success small fw-semibold">
                                <i class="ri ri-checkbox-double-line me-1"></i>บันทึกน้ำหนักเรียบร้อยแล้ว
                            </span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">% ที่ผ่านตรวจปล่อย</label>
                        <div class="mt-1">
                            <div class="weight-bar mb-1">
                                <div class="weight-bar-fill" id="weightBarFill"
                                     style="width:@((inspectedWeightKg/requestedWeightKg*100).ToString("F0"))%;"></div>
                            </div>
                            <small class="text-muted" id="weightPctLabel">
                                @inspectedWeightKg.ToString("N2") กก. (@((inspectedWeightKg / requestedWeightKg * 100).ToString("F1"))%)
                            </small>
                        </div>
                    </div>
                </div>
                <div class="mt-3 p-2 rounded" style="background:#f0fff4;border:1px solid #b7ebb7;font-size:0.78rem;">
                    <i class="ri ri-information-line text-success me-1"></i>
                    เมื่อบันทึกน้ำหนักตรวจปล่อย ระบบจะ<strong>ปรับปริมาณในใบรับรองอัตโนมัติ</strong>
                    และใช้น้ำหนักนี้สำหรับออกใบรับรองฉบับจริง
