@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "รีวิวคำขอสิทธิ์การเข้าใช้งาน";

  // Mock data
  var reqId = "ACC-2569-00001";
  var reqName = "นายสมชาย ใจดี";
  var reqDept = "บริษัท ทดสอบ จำกัด";
  var reqDate = "20/04/2569";
  var reqSystems = new[] { "ระบบตรวจสอบ RMBS1", "ระบบประกาศ PS/NoPS" };
  var reqReason = "ต้องการเข้าถึงระบบเพื่อดำเนินการตรวจสอบและออกเอกสาร RMBS1 สำหรับการส่งออกสินค้าไปต่างประเทศ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/&#64;form-validation/form-validation.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/&#64;form-validation/popular.js"></script>
<script src="~/vendor/libs/&#64;form-validation/bootstrap5.js"></script>
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .info-row { display:flex; gap:.5rem; margin-bottom:.5rem; }
  .info-label { font-weight:600; color:var(--dpim-blue); min-width:160px; font-size:.88rem; }
  .info-value { color:var(--bs-body-color); font-size:.88rem; }
  .decision-radio { display:none; }
  .decision-card {
    border:2px solid var(--bs-border-color); border-radius:10px;
    padding:1rem 1.25rem; cursor:pointer; transition:all .18s ease;
    text-align:center;
  }
  .decision-radio:checked + .decision-card { border-color:var(--dpim-blue); background:rgba(35,64,143,.05); }
  #decision-reject:checked + .decision-card { border-color:#dc3545; background:rgba(220,53,69,.05); }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; border-color:#369a3a; color:#fff; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Show/hide reason textarea
  document.querySelectorAll('input[name="decision"]').forEach(function (r) {
    r.addEventListener('change', function () {
      var reasonRow = document.getElementById('reasonRow');
      reasonRow.style.display = this.value === 'reject' ? '' : 'none';
    });
  });

  document.getElementById('btnSave').addEventListener('click', function () {
    var decision = document.querySelector('input[name="decision"]:checked');
    if (!decision) { alert('กรุณาเลือกผลการพิจารณา'); return; }
    var msg = decision.value === 'approve'
      ? 'อนุมัติคำขอสำเร็จ! ระบบจะส่งอีเมลแจ้งผลไปยังผู้ยื่นคำขอ'
      : 'ปฏิเสธคำขอแล้ว ระบบจะส่งอีเมลแจ้งเหตุผลไปยังผู้ยื่นคำขอ';
    alert(msg);
    window.location.href = '/Officer/AccessRequestList';
  });
});
</script>
}

@* ============================================================ *@
<div class="container-xxl flex-grow-1 container-p-y">

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb breadcrumb-style1 mb-4">
      <li class="breadcrumb-item"><a href="/">หน้าหลัก</a></li>
      <li class="breadcrumb-item"><a href="/Officer/AccessRequestList">รายการคำขอสิทธิ์</a></li>
      <li class="breadcrumb-item active">รีวิวคำขอ @reqId</li>
    </ol>
  </nav>

  <h4 class="page-title-dpim mb-4">รีวิวคำขอสิทธิ์ — @reqId</h4>

  <div class="row g-4">
    <!-- Left: ข้อมูลคำขอ -->
    <div class="col-lg-7">
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0"><i class="ri ri-user-line me-2" style="color:var(--dpim-blue);"></i>ข้อมูลผู้ยื่นคำขอ</h5>
        </div>
        <div class="card-body">
          <div class="info-row"><span class="info-label">ชื่อ-นามสกุล</span><span class="info-value">@reqName</span></div>
          <div class="info-row"><span class="info-label">หน่วยงาน</span><span class="info-value">@reqDept</span></div>
          <div class="info-row"><span class="info-label">วันที่ยื่น</span><span class="info-value">@reqDate</span></div>
          <div class="info-row">
            <span class="info-label">ระบบงานที่ขอ</span>
            <span class="info-value d-flex flex-wrap gap-1">
              @foreach (var s in reqSystems) {
                <span class="badge" style="background:#e8f0fe;color:#23408F;">@s</span>
              }
            </span>
          </div>
          <div class="mt-3">
            <div class="info-label mb-1">เหตุผลการขอ</div>
            <div class="p-3 rounded" style="background:var(--bs-gray-100);font-size:.88rem;">@reqReason</div>
          </div>
        </div>
      </div>

      <!-- เอกสารแนบ -->
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0"><i class="ri ri-attachment-line me-2" style="color:var(--dpim-blue);"></i>เอกสารแนบ</h5>
        </div>
        <div class="card-body">
          <div class="list-group list-group-flush">
            <div class="list-group-item d-flex align-items-center justify-content-between px-0">
              <div class="d-flex align-items-center gap-2">
                <i class="bx bxs-file-pdf text-danger" style="font-size:1.3rem;"></i>
                <span style="font-size:.88rem;">สำเนาบัตรประชาชน.pdf</span>
              </div>
              <a href="javascript:;" class="btn btn-sm btn-outline-secondary">
                <i class="ri ri-download-line me-1"></i>ดาวน์โหลด
              </a>
            </div>
            <div class="list-group-item d-flex align-items-center justify-content-between px-0">
              <div class="d-flex align-items-center gap-2">
                <i class="bx bxs-file-pdf text-danger" style="font-size:1.3rem;"></i>
                <span style="font-size:.88rem;">หนังสือรับรองบริษัท.pdf</span>
              </div>
              <a href="javascript:;" class="btn btn-sm btn-outline-secondary">
                <i class="ri ri-download-line me-1"></i>ดาวน์โหลด
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: ผลการพิจารณา -->
    <div class="col-lg-5">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0"><i class="ri ri-shield-check-line me-2" style="color:var(--dpim-blue);"></i>ผลการพิจารณา</h5>
        </div>
        <div class="card-body">
          <p class="text-muted mb-3" style="font-size:.85rem;">เลือกผลการพิจารณาและบันทึก</p>

          <div class="row g-3 mb-4">
            <div class="col-6">
              <input class="decision-radio" type="radio" id="decision-approve" name="decision" value="approve" />
              <label class="decision-card" for="decision-approve">
                <i class="ri ri-checkbox-circle-line mb-1" style="font-size:2rem;color:var(--dpim-green);display:block;"></i>
                <div class="fw-semibold" style="color:var(--dpim-green);">อนุมัติ</div>
              </label>
            </div>
            <div class="col-6">
              <input class="decision-radio" type="radio" id="decision-reject" name="decision" value="reject" />
              <label class="decision-card" for="decision-reject">
                <i class="ri ri-close-circle-line mb-1" style="font-size:2rem;color:#dc3545;display:block;"></i>
                <div class="fw-semibold text-danger">ปฏิเสธ</div>
              </label>
            </div>
          </div>

          <div id="reasonRow" style="display:none;" class="mb-4">
            <label class="form-label fw-semibold">เหตุผลการปฏิเสธ <span class="text-danger">*</span></label>
            <textarea class="form-control" name="rejectReason" rows="3"
                      placeholder="ระบุเหตุผลที่ชัดเจน เพื่อแจ้งให้ผู้ยื่นคำขอทราบ..."></textarea>
            <div class="form-text">ระบบจะส่งเหตุผลนี้ให้ผู้ยื่นคำขอทางอีเมลอัตโนมัติ</div>
          </div>

          <div class="alert" style="background:#fffde7;border:1px solid #f9a825;border-radius:8px;font-size:.82rem;">
            <i class="ri ri-information-line me-1" style="color:#f9a825;"></i>
            หลังบันทึก ระบบจะส่งอีเมลแจ้งผลการพิจารณาไปยัง <strong>@reqName</strong> โดยอัตโนมัติ
          </div>

          <div class="d-flex gap-2 mt-3">
            <a href="/Officer/AccessRequestList" class="btn btn-outline-secondary flex-fill">
              <i class="ri ri-arrow-left-line me-1"></i>ย้อนกลับ
            </a>
            <button type="button" id="btnSave" class="btn btn-dpim flex-fill">
              <i class="ri ri-save-line me-1"></i>บันทึกผล
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
