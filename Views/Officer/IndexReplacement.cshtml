    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-secondary"><i class="ri ri-file-paper-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">NMDT</p><h5 class="mb-0">@nmdtCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-warning"><i class="ri ri-mail-send-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">รออนุมัติ</p><h5 class="mb-0">@pendingCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-success"><i class="ri ri-checkbox-circle-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">อนุมัติ</p><h5 class="mb-0">@approvedCount</h5></div>
