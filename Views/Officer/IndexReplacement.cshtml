@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, { dateFormat: 'd/m/Y', allowInput: true });
        }
        if (toInput) {
            flatpickr(toInput, { dateFormat: 'd/m/Y', allowInput: true });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            // แปลง BE → CE ถ้า year > 2500
            if (year > 2500) year -= 543;
            var h = endOfDay ? 23 : 0, m = endOfDay ? 59 : 0, s = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, h, m, s);
            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        // 2.6(3): ค้นหาจาก 9 ฟิลด์
        function filterRows() {
            var certType      = (document.getElementById('filterCertType').value || '').trim();
            var reqNo         = (document.getElementById('filterReqNo').value || '').trim().toLowerCase();
            var status        = (document.getElementById('filterStatus').value || '').trim();
            var establishment = (document.getElementById('filterEstablishment') ? document.getElementById('filterEstablishment').value : '').trim().toLowerCase();
            var factoryReg    = (document.getElementById('filterFactoryReg') ? document.getElementById('filterFactoryReg').value : '').trim().toLowerCase();
            var product       = (document.getElementById('filterProduct') ? document.getElementById('filterProduct').value : '').trim().toLowerCase();
            var country       = (document.getElementById('filterCountry') ? document.getElementById('filterCountry').value : '').trim().toLowerCase();
            var receivedNo    = (document.getElementById('filterReceivedNo') ? document.getElementById('filterReceivedNo').value : '').trim().toLowerCase();
            var fromDate      = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate        = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var excludeRange  = document.getElementById('filterDateExclude').checked;

            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowCert    = row.dataset.certificate || '';
                var rowStatus  = row.dataset.status || '';
                var rowDate    = new Date(row.dataset.draftDate || '');
                var rowReqNo   = row.dataset.reqno || '';
                var rowEstab   = row.dataset.establishment || '';
                var rowFactory = row.dataset.factory || '';
                var rowProduct = row.dataset.product || '';
                var rowCountry = row.dataset.country || '';
                var rowRecvNo  = row.dataset.receivedno || '';

                var certMatch    = !certType    || rowCert === certType;
                var statusMatch  = !status      || rowStatus === status;
                var reqNoMatch   = !reqNo       || rowReqNo.includes(reqNo);
                var estabMatch   = !establishment || rowEstab.includes(establishment);
                var factoryMatch = !factoryReg  || rowFactory.includes(factoryReg);
                var productMatch = !product     || rowProduct.includes(product);
                var countryMatch = !country     || rowCountry.includes(country);
                var recvNoMatch  = !receivedNo  || rowRecvNo.includes(receivedNo);

                var dateMatch;
                if (!fromDate && !toDate) {
                    dateMatch = true;
                } else if (excludeRange) {
                    var inRange = (!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate);
                    dateMatch = !inRange;
                } else {
                    dateMatch = (!fromDate || rowDate >= fromDate) && (!toDate || rowDate <= toDate);
                }

                var isVisible = certMatch && statusMatch && reqNoMatch && estabMatch && factoryMatch && productMatch && countryMatch && recvNoMatch && dateMatch;
                row.classList.toggle('d-none', !isVisible);
                if (isVisible) visibleCount++;
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        // Event listeners — all filter fields
        var filterIds = ['filterCertType', 'filterReqNo', 'filterStatus',
                         'filterEstablishment', 'filterFactoryReg', 'filterProduct',
                         'filterCountry', 'filterReceivedNo',
                         'filterDraftDateFrom', 'filterDraftDateTo'];
        filterIds.forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('change', filterRows);
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });
        document.getElementById('filterDateExclude').addEventListener('change', filterRows);
        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);

        document.getElementById('btnResetRequests').addEventListener('click', function () {
            filterIds.forEach(function (id) {
                var el = document.getElementById(id);
                if (el) el.value = '';
            });
            document.getElementById('filterDateExclude').checked = false;
            filterRows();
        });

        // 2.6(3): CRUD — Cancel modal: ใส่ data-reqno ในชื่อ modal
        var modalCancelEl = document.getElementById('modalCancelRequest');
        if (modalCancelEl) {
            modalCancelEl.addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                var reqNo = btn ? btn.getAttribute('data-reqno') : '';
                document.getElementById('cancelRequestReqNo').textContent = reqNo;
                document.getElementById('cancelRequestReason').value = '';
                document.getElementById('cancelRequestReason').classList.remove('is-invalid');
            });
            document.getElementById('btnConfirmCancel').addEventListener('click', function () {
                var reason = document.getElementById('cancelRequestReason').value.trim();
                if (!reason) {
                    document.getElementById('cancelRequestReason').classList.add('is-invalid');
                    return;
                }
                document.getElementById('cancelRequestReason').classList.remove('is-invalid');
                bootstrap.Modal.getInstance(modalCancelEl).hide();
                // TODO: ส่ง API ยกเลิกคำขอ
                alert('TODO: ยกเลิกคำขอ ' + document.getElementById('cancelRequestReqNo').textContent + '\nเหตุผล: ' + reason);
            });
        }

        // 2.6(3): CRUD — Delete modal
        var modalDeleteEl = document.getElementById('modalDeleteRequest');
        if (modalDeleteEl) {
            modalDeleteEl.addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                var reqNo = btn ? btn.getAttribute('data-reqno') : '';
                document.getElementById('deleteRequestReqNo').textContent = reqNo;
            });
            document.getElementById('btnConfirmDelete').addEventListener('click', function () {
                var reqNo = document.getElementById('deleteRequestReqNo').textContent;
                bootstrap.Modal.getInstance(modalDeleteEl).hide();
                // TODO: ส่ง API ลบคำขอ
                alert('TODO: ลบคำขอ ' + reqNo);
            });
        }
    });
</script>
}

