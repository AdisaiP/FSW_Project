    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-danger"><i class="ri ri-close-circle-line ri-22px"></i></span></div>
