    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-primary"><i class="ri ri-file-list-3-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">คำขอทั้งหมด</p><h5 class="mb-0">@totalRequestCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-primary"><i class="ri ri-file-paper-2-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">PS</p><h5 class="mb-0">@psCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0"><span class="avatar-initial rounded bg-label-info"><i class="ri ri-file-paper-2-line ri-22px"></i></span></div>
                <div><p class="mb-0 small text-muted">PST</p><h5 class="mb-0">@pstCount</h5></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="avatar flex-shrink-0" style="background:rgba(123,31,162,0.15);border-radius:0.375rem;"><span class="avatar-initial rounded" style="background:rgba(123,31,162,0.15);"><i class="ri ri-file-paper-line ri-22px" style="color:#7b1fa2;"></i></span></div>
                <div><p class="mb-0 small text-muted">NMD</p><h5 class="mb-0">@nmdCount</h5></div>
