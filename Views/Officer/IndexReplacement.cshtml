</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ตัวกรองการค้นหา</h5>
            <p class="text-muted small mb-0">
                ค้นหาจาก: ประเภทใบรับรอง / เลขที่คำขอ / สถานะ /
                <span class="text-primary" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#collapseAdvancedFilter">
                    ชื่อสถานประกอบการ / เลขทะเบียนโรงงาน / ชื่อสินค้า / ประเทศปลายทาง / วันที่ยื่น / เลขที่รับคำขอ
                </span>
            </p>
        </div>
        <button class="btn btn-sm btn-outline-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#collapseAdvancedFilter" aria-expanded="false" aria-controls="collapseAdvancedFilter">
            <i class="ri ri-filter-3-line me-1"></i>ค้นหาขั้นสูง
        </button>
    </div>
    <div class="card-body">
        <!-- แถวหลัก: ประเภท / เลขที่คำขอ / สถานะ + ปุ่ม -->
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                <select id="filterCertType" class="form-select">
                    <option value="">ทั้งหมด (4 ประเภท)</option>
                    <option value="PS">PS — ใบรับรองการแปรรูปสัตว์น้ำ</option>
                    <option value="PST">PST — ใบรับรองการแปรรูปสัตว์น้ำ (ไทย)</option>
                    <option value="NMD">NMD — ใบรับรองสัตว์น้ำไม่แปรรูป</option>
                    <option value="NMDT">NMDT — ใบรับรองสัตว์น้ำไม่แปรรูป (ไทย)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="filterReqNo" class="form-label">เลขที่คำขอ</label>
                <input type="text" id="filterReqNo" class="form-control" placeholder="REP821B...">
            </div>
            <div class="col-md-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="ฉบับร่าง">ฉบับร่าง</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติ">อนุมัติ</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                    <option value="ยกเลิก">ยกเลิก</option>
                </select>
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square" title="รีเซ็ต">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- ค้นหาขั้นสูง (collapsible) -->
        <div class="collapse mt-3" id="collapseAdvancedFilter">
            <hr class="mb-3 mt-0" />
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="filterEstablishment" class="form-label">ชื่อสถานประกอบการ</label>
                    <input type="text" id="filterEstablishment" class="form-control" placeholder="บริษัท...">
                </div>
                <div class="col-md-3">
                    <label for="filterFactoryReg" class="form-label">เลขทะเบียนโรงงาน</label>
                    <input type="text" id="filterFactoryReg" class="form-control" placeholder="0105548...">
                </div>
                <div class="col-md-2">
                    <label for="filterProduct" class="form-label">ชื่อสินค้า</label>
                    <input type="text" id="filterProduct" class="form-control" placeholder="ปลา / กุ้ง...">
                </div>
                <div class="col-md-3">
                    <label for="filterCountry" class="form-label">ประเทศปลายทาง</label>
                    <input type="text" id="filterCountry" class="form-control" placeholder="ญี่ปุ่น / EU...">
                </div>
            </div>
            <div class="row g-3 align-items-end mt-0">
                <div class="col-md-3">
                    <label for="filterDraftDateFrom" class="form-label">วันที่ยื่น (ตั้งแต่)</label>
                    <input type="text" id="filterDraftDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
                </div>
                <div class="col-md-3">
                    <label for="filterDraftDateTo" class="form-label">วันที่ยื่น (ถึง)</label>
                    <input type="text" id="filterDraftDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
                </div>
                <div class="col-auto">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="filterDateExclude" />
                        <label class="form-check-label small" for="filterDateExclude">ไม่อยู่ในช่วง</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <label for="filterReceivedNo" class="form-label">เลขที่รับคำขอ</label>
                    <input type="text" id="filterReceivedNo" class="form-control" placeholder="รบ.2569-...">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอใบรับรองทดแทนฉบับเก่า</h5>
            <p class="text-muted small mb-0">รายการคำขอใบรับรองทดแทนสำหรับใบรับรองสูญหายหรือชำรุดเสียหาย</p>
        </div>
        <button type="button" class="btn btn-primary"
                onclick="alert('TODO: สร้างคำขอใหม่')">
            <i class="ri ri-add-line me-1"></i>สร้างคำขอใหม่
        </button>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:180px;">เลขที่คำขอ</th>
                    <th style="width:5rem;">ประเภท</th>
                    <th style="min-width:175px;">ใบรับรอง</th>
                    <th style="min-width:155px;">เลขที่ใบรับรองเดิม</th>
                    <th style="min-width:175px;">สถานประกอบการ</th>
                    <th style="min-width:130px;">สินค้า / ปลายทาง</th>
                    <th>เหตุผลการขอ</th>
                    <th style="min-width:130px;">วันที่ยื่น</th>
                    <th style="width:9rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    <tr data-certificate="@request.CertificateKey"
                        data-status="@request.StatusText"
                        data-draft-date="@request.TransactionAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-reqno="@request.RequestNumber.ToLower()"
                        data-establishment="@request.EstablishmentName.ToLower()"
                        data-factory="@request.FactoryRegNo.ToLower()"
                        data-product="@request.ProductName.ToLower()"
                        data-country="@request.DestinationCountry.ToLower()"
                        data-receivedno="@request.ReceivedNo.ToLower()">
                        <td>
                            <span class="fw-semibold text-primary d-block mb-1">@request.RequestNumber</span>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                                @if (!string.IsNullOrEmpty(request.ReceivedNo))
                                {
                                    <div class="d-flex align-items-center gap-1 small text-muted">
                                        <i class="ri ri-inbox-archive-line" style="font-size:0.75rem;"></i>
                                        <span>เลขรับ: @request.ReceivedNo</span>
                                    </div>
                                }
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge @request.CertTypeBadge">@request.CertificateKey</span>
                        </td>
                        <td class="small">@request.CertificateName</td>
                        <td class="text-center">
                            <span class="fw-semibold text-secondary">@request.OriginalCertNumber</span>
                        </td>
                        <td class="small">
                            <span class="fw-semibold d-block">@request.EstablishmentName</span>
                            <span class="text-muted" style="font-size:0.72rem;">@request.FactoryRegNo</span>
                        </td>
                        <td class="small">
                            <span class="d-block">@request.ProductName</span>
                            <span class="text-muted" style="font-size:0.72rem;">@request.DestinationCountry</span>
                        </td>
                        <td class="small">@request.ReplacementReason</td>
                        <td class="text-center small text-nowrap">
                            @{
                                var beYear = request.TransactionAt.Year + 543;
                            }
                            @request.TransactionAt.ToString("dd/MM/")@beYear<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm"))</span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                @if (request.StatusText == "ฉบับร่าง")
                                {
                                    <a href="@(request.CertificateKey == "PS" || request.CertificateKey == "PST" ? Url.Action("ReviewReplacementProcessing", "Officer") : Url.Action("ReviewReplacementDeclaration", "Officer"))"
                                       class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary" data-bs-toggle="tooltip" title="แก้ไข"
                                            onclick="alert('TODO: แก้ไขคำขอ @request.RequestNumber')">
                                        <i class="ri ri-edit-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#modalCancelRequest"
                                            data-reqno="@request.RequestNumber" title="ยกเลิก">
                                        <i class="ri ri-close-circle-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#modalDeleteRequest"
                                            data-reqno="@request.RequestNumber" title="ลบ">
                                        <i class="ri ri-delete-bin-line"></i>
                                    </button>
                                }
                                @if (request.StatusText == "รออนุมัติ")
                                {
                                    <a href="@(request.CertificateKey == "PS" || request.CertificateKey == "PST" ? Url.Action("ReviewReplacementProcessing", "Officer") : Url.Action("ReviewReplacementDeclaration", "Officer"))"
                                       class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" data-bs-toggle="tooltip" title="อนุมัติ"
                                            onclick="if(confirm('ยืนยันอนุมัติคำขอ @request.RequestNumber ?')) alert('TODO: อนุมัติ')">
                                        <i class="ri ri-checkbox-circle-line text-success"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" data-bs-toggle="tooltip" title="ไม่อนุมัติ"
                                            onclick="if(confirm('ยืนยันไม่อนุมัติคำขอ @request.RequestNumber ?')) alert('TODO: ไม่อนุมัติ')">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#modalCancelRequest"
                                            data-reqno="@request.RequestNumber" title="ยกเลิก">
                                        <i class="ri ri-forbid-line"></i>
                                    </button>
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ไม่อนุมัติ" || request.StatusText == "ยกเลิก")
                                {
                                    <a href="@(request.CertificateKey == "PS" || request.CertificateKey == "PST" ? Url.Action("ReviewReplacementProcessing", "Officer") : Url.Action("ReviewReplacementDeclaration", "Officer"))"
                                       class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                    @* 2.6(8): badge พิมพ์ใบรับรองทดแทนแล้ว เฉพาะอนุมัติ *@
                                    @if (request.StatusText == "อนุมัติ")
                                    {
                                        <span class="badge bg-label-success px-2 py-1" data-bs-toggle="tooltip"
                                              title="พิมพ์ใบรับรองทดแทนแล้ว (PDF/A-3)">
                                            <i class="ri ri-printer-line me-1"></i>พิมพ์แล้ว ✅
                                        </span>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@* 2.6(3): Modal ยืนยันยกเลิกคำขอ *@
<div class="modal fade" id="modalCancelRequest" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ri ri-close-circle-line me-2 text-warning"></i>ยืนยันยกเลิกคำขอ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">คุณต้องการยกเลิกคำขอ <strong id="cancelRequestReqNo"></strong> ใช่หรือไม่?</p>
                <div class="mb-3">
                    <label for="cancelRequestReason" class="form-label">เหตุผลการยกเลิก <span class="text-danger">*</span></label>
                    <textarea id="cancelRequestReason" class="form-control" rows="3"
                              placeholder="ระบุเหตุผลการยกเลิก..."></textarea>
                    <div class="invalid-feedback">กรุณาระบุเหตุผลการยกเลิก</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
                <button type="button" id="btnConfirmCancel" class="btn btn-warning">
                    <i class="ri ri-close-circle-line me-1"></i>ยืนยันยกเลิก
                </button>
            </div>
        </div>
    </div>
</div>

@* 2.6(3): Modal ยืนยันลบคำขอ *@
<div class="modal fade" id="modalDeleteRequest" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ri ri-delete-bin-line me-2 text-danger"></i>ยืนยันลบคำขอ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
                    <i class="ri ri-error-warning-line mt-1 flex-shrink-0"></i>
                    <div>
                        <strong>คำเตือน:</strong> การลบข้อมูลไม่สามารถกู้คืนได้
                    </div>
                </div>
                <p>คุณต้องการลบคำขอ <strong id="deleteRequestReqNo"></strong> ออกจากระบบถาวรหรือไม่?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmDelete" class="btn btn-danger">
                    <i class="ri ri-delete-bin-line me-1"></i>ลบถาวร
                </button>
            </div>
        </div>
    </div>
</div>
