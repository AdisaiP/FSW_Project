                        <div class="input-group input-group-sm">
                            <input type="number" class="form-control" id="modalApprovedYield" value="@requestedYield.ToString("F1")" step="0.1" min="0" max="100" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label small">%Tolerance ที่อนุมัติ</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">±</span>
                            <input type="number" class="form-control" id="modalApprovedTolerance" value="@tolerance.ToString("F1")" step="0.5" min="0" max="10" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>
                <label class="form-label small">หมายเหตุ (ไม่บังคับ)</label>
                <textarea id="approveRemark" class="form-control" rows="2" placeholder="ระบุหมายเหตุ"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmApprove" class="btn btn-success">
                    <i class="ri ri-checkbox-circle-line me-1"></i> ยืนยันอนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: ไม่อนุมัติ ==================== -->
<div class="modal fade" id="modalReject" tabindex="-1" aria-labelledby="modalRejectLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalRejectLabel">
                    <i class="ri ri-close-circle-line me-1 text-danger"></i> ยืนยันไม่อนุมัติ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small">เหตุผลการไม่อนุมัติ <span class="text-danger">*</span></label>
                <textarea id="rejectReason" class="form-control" rows="3" placeholder="ระบุเหตุผล..."></textarea>
                <div id="rejectReasonError" class="text-danger small d-none mt-1">กรุณาระบุเหตุผล</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmReject" class="btn btn-danger">
                    <i class="ri ri-close-circle-line me-1"></i> ยืนยันไม่อนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: ส่งคืนแก้ไข ==================== -->
<div class="modal fade" id="modalReturn" tabindex="-1" aria-labelledby="modalReturnLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" id="modalReturnLabel">
                    <i class="ri ri-reply-line me-1 text-warning"></i> ส่งคืนให้แก้ไข
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small">รายละเอียดที่ต้องแก้ไข <span class="text-danger">*</span></label>
                <textarea id="returnDetail" class="form-control" rows="3" placeholder="ระบุสิ่งที่ต้องแก้ไข..."></textarea>
                <div id="returnDetailError" class="text-danger small d-none mt-1">กรุณาระบุรายละเอียด</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" id="btnConfirmReturn" class="btn btn-warning">
                    <i class="ri ri-send-plane-line me-1"></i> ส่งแจ้งกลับ
                </button>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    // Tooltips
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el, { trigger: 'hover' });
    });

    function showToast(msg, type) {
        var bg   = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : type === 'warning' ? 'bg-warning' : 'bg-info';
        var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-close-circle-line' : 'ri-error-warning-line';
        var el = document.createElement('div');
        el.className = 'position-fixed bottom-0 end-0 p-3'; el.style.zIndex = 9999;
        el.innerHTML = '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
            '<div class="d-flex"><div class="toast-body d-flex align-items-center gap-2">' +
            '<i class="ri ' + icon + ' fs-5"></i> ' + msg + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
            '</div></div>';
        document.body.appendChild(el); setTimeout(function () { el.remove(); }, 4000);
    }

    function setBanner(type, title, sub) {
        var banner = document.getElementById('statusBanner');
        var icons = { approved: 'ri-checkbox-circle-fill text-success', rejected: 'ri-close-circle-fill text-danger', returned: 'ri-reply-fill text-warning', pending: 'ri-time-line text-warning', suspended: 'ri-pause-circle-fill text-warning' };
        banner.className = 'review-banner ' + type + ' mb-4 d-flex align-items-center gap-3';
        banner.innerHTML = '<i class="ri ' + icons[type] + ' fs-4"></i><div><div class="fw-semibold">' + title + '</div><div class="small text-muted">' + sub + '</div></div>';
    }

    function addHistory(title, desc, type, time) {
        var li = document.createElement('li');
        if (type) li.className = type;
        li.innerHTML = '<div class="d-flex justify-content-between align-items-start">' +
            '<div><div class="fw-semibold small">' + title + '</div>' +
            '<div class="text-muted small">' + desc + '</div>' +
            '<div class="text-muted small">ผู้ดำเนินการ: น.ส.สมใจ พิจารณ์ (เจ้าหน้าที่)</div></div>' +
            '<span class="badge bg-label-secondary text-nowrap ms-3">' + time + '</span></div>';
        var list = document.getElementById('historyList');
        list.appendChild(li);
        list.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    // ── Approve ──
    document.getElementById('btnConfirmApprove').addEventListener('click', function () {
        var yld = document.getElementById('modalApprovedYield').value;
        var tol = document.getElementById('modalApprovedTolerance').value;
        bootstrap.Modal.getInstance(document.getElementById('modalApprove')).hide();
        showToast('อนุมัติ %Yield เรียบร้อยแล้ว — %Yield: ' + yld + '% ±' + tol + '%', 'success');
        setBanner('approved', 'อนุมัติแล้ว', '%Yield ที่อนุมัติ: ' + yld + '% &nbsp;|&nbsp; Tolerance: ±' + tol + '%');
        document.getElementById('approvedYieldDisplay').textContent = yld + '%';
        document.getElementById('approvedToleranceDisplay').textContent = '±' + tol + '%';
        document.getElementById('decisionResultBanner').classList.remove('d-none');
        var now = new Date(); var ts = ('0'+now.getDate()).slice(-2)+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+(now.getFullYear()+543)+' '+ ('0'+now.getHours()).slice(-2)+':'+ ('0'+now.getMinutes()).slice(-2);
        addHistory('อนุมัติ %Yield เรียบร้อยแล้ว', '%Yield ที่อนุมัติ: ' + yld + '% &nbsp;±' + tol + '% &nbsp;| มีผลถึง: 30/04/2570', 'success', ts);
    });

    // ── Reject ──
    document.getElementById('btnConfirmReject').addEventListener('click', function () {
        var reason = document.getElementById('rejectReason').value.trim();
        if (!reason) { document.getElementById('rejectReasonError').classList.remove('d-none'); return; }
        document.getElementById('rejectReasonError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalReject')).hide();
        showToast('ไม่อนุมัติ %Yield เรียบร้อยแล้ว', 'danger');
        setBanner('rejected', 'ไม่อนุมัติ', 'เหตุผล: ' + reason.substring(0, 60) + (reason.length > 60 ? '...' : ''));
        var now = new Date(); var ts = ('0'+now.getDate()).slice(-2)+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+(now.getFullYear()+543)+' '+ ('0'+now.getHours()).slice(-2)+':'+ ('0'+now.getMinutes()).slice(-2);
        addHistory('ไม่อนุมัติ %Yield', 'เหตุผล: ' + reason.substring(0, 80), 'danger', ts);
    });

    // ── Return ──
    document.getElementById('btnConfirmReturn').addEventListener('click', function () {
        var detail = document.getElementById('returnDetail').value.trim();
        if (!detail) { document.getElementById('returnDetailError').classList.remove('d-none'); return; }
        document.getElementById('returnDetailError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalReturn')).hide();
        showToast('ส่งคืนแก้ไขเรียบร้อยแล้ว', 'warning');
        setBanner('returned', 'ส่งคืนแก้ไข', 'รอผู้ประกอบการแก้ไขและส่งกลับมาใหม่');
        var now = new Date(); var ts = ('0'+now.getDate()).slice(-2)+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+(now.getFullYear()+543)+' '+ ('0'+now.getHours()).slice(-2)+':'+ ('0'+now.getMinutes()).slice(-2);
        addHistory('ส่งคืนเพื่อแก้ไข', 'รายละเอียด: ' + detail.substring(0, 80), 'warning', ts);
    });

    // ── Suspend ──
    document.getElementById('btnConfirmSuspend').addEventListener('click', function () {
        var reason = document.getElementById('reviewSuspendReason').value.trim();
        if (!reason) { document.getElementById('reviewSuspendReasonError').classList.remove('d-none'); return; }
        document.getElementById('reviewSuspendReasonError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalSuspend')).hide();
        showToast('ระงับ %Yield เรียบร้อยแล้ว', 'warning');
        setBanner('suspended', 'ระงับ 🚫', 'เหตุผล: ' + reason.substring(0, 60) + (reason.length > 60 ? '...' : ''));
        var now = new Date(); var ts = ('0'+now.getDate()).slice(-2)+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+(now.getFullYear()+543)+' '+ ('0'+now.getHours()).slice(-2)+':'+ ('0'+now.getMinutes()).slice(-2);
        addHistory('ระงับ %Yield', 'เหตุผล: ' + reason.substring(0, 80), 'warning', ts);
    });

    // ── New Yield Request ──
    document.getElementById('newYieldDropzone').addEventListener('click', function () {
        document.getElementById('newYieldFile').click();
    });
    document.getElementById('newYieldFile').addEventListener('change', function () {
        var lbl = document.getElementById('newYieldFileLabel');
        if (this.files.length > 0) {
            lbl.textContent = 'ไฟล์: ' + this.files[0].name;
            lbl.classList.remove('d-none');
        }
    });
    document.getElementById('btnSubmitNewYieldRequest').addEventListener('click', function () {
        var reason = document.getElementById('newYieldReason').value.trim();
        if (!reason) { document.getElementById('newYieldReasonError').classList.remove('d-none'); return; }
        document.getElementById('newYieldReasonError').classList.add('d-none');
        var newYld = document.getElementById('newYieldValue').value;
        bootstrap.Modal.getInstance(document.getElementById('modalNewYieldRequest')).hide();
        showToast('สร้างคำขอแก้ไข %Yield ใหม่เรียบร้อย — แจ้งเตือนเจ้าหน้าที่แล้ว', 'warning');
        var now = new Date();
        var ts = ('0'+now.getDate()).slice(-2)+'/'+(now.getMonth()+1).toString().padStart(2,'0')+'/'+(now.getFullYear()+543)+' '+('0'+now.getHours()).slice(-2)+':'+('0'+now.getMinutes()).slice(-2);
        addHistory('สร้างคำขอแก้ไข %Yield ใหม่', 'YLD ใหม่: ' + newYld + '% | เหตุผล: ' + reason.substring(0, 60) + ' — แจ้งเตือนเจ้าหน้าที่แล้ว', 'danger', ts);
        // TODO: submit new yield change request to API
    });

    // ─── Print Yield Form ───
    document.getElementById('btnPrintYield').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalPrintYield')).hide();
        setTimeout(function () { window.print(); }, 300);
    });
    document.getElementById('btnDownloadPdf').addEventListener('click', function () {
        // TODO: generate and download PDF via server API
        alert('TODO: ดาวน์โหลด PDF — เชื่อมต่อ API สร้างเอกสาร PDF จริง');
    });
});
</script>
}
