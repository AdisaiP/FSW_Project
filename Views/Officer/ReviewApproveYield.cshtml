@{
    ViewData["Title"] = "พิจารณาอนุมัติ %Yield";

    // ── Mockup data ──
    string requestNo      = "YLD-2026-00201";
    string companyName    = "บริษัท สยาม มารีน ฟู้ดส์ จำกัด";
    string companyReg     = "0105535012345";
    string certType       = "DOF รับรองโรงงาน (ทูน่า/ปลาเนื้อขาว)";
    string areaResponsible= "กองตรวจสอบคุณภาพสินค้าประมง (กตส.)";
    string requestTypeText= "คำขอใหม่";
    string requestTypeClass="bg-label-primary";
    string rawMaterialType= "วัตถุดิบนำเข้า";
    decimal previousYield = 70.0m;
    decimal requestedYield= 72.5m;
    decimal tolerance     = 2.0m;
    decimal approvedYield = 72.5m;          // last approved yield
    decimal calculatedYield = 65.2m;        // system-calculated actual yield
    decimal deviationPct  = 7.3m;           // abs deviation
    bool    isOverTolerance = true;          // 7.3 > 2.0 → over tolerance
    string  effectiveDateFrom = "01/05/2569";
    string  effectiveDateTo   = "30/04/2570";
    string submittedDate  = "18 เมษายน 2569  เวลา 09:00 น.";
    string statusText     = "รออนุมัติ";
    string statusClass    = "bg-label-warning";
}

@section PageStyles {
<style>
    .field-display {
        font-size: 0.875rem;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.375rem;
        padding: 0.4375rem 0.875rem;
        min-height: 2.375rem;
        display: flex;
        align-items: center;
        word-break: break-word;
    }
    .field-display.text-end   { justify-content: flex-end; }
    .field-display.text-center { justify-content: center; }
    .form-label.small { font-size: 0.8rem; font-weight: 500; margin-bottom: 0.25rem; }

    .decision-card { border: 2px solid var(--bs-primary); }
    .decision-card .card-header { background: rgba(var(--bs-primary-rgb), .08); }

    .review-banner { border-left: 4px solid; padding: 1rem 1.25rem; border-radius: 0.5rem; }
    .review-banner.pending  { border-color: #fd7e14; background: rgba(253,126,20,.06); }
    .review-banner.approved { border-color: #28a745; background: rgba(40,167,69,.06); }
    .review-banner.rejected { border-color: #dc3545; background: rgba(220,53,69,.06); }
    .review-banner.returned { border-color: #ffc107; background: rgba(255,193,7,.06); }
    .review-banner.suspended { border-color: #fd7e14; background: rgba(253,126,20,.08); }

    .history-timeline { list-style: none; padding-left: 0; position: relative; }
    .history-timeline::before { content: ''; position: absolute; left: 1rem; top: 0; bottom: 0; width: 2px; background: var(--bs-border-color); }
    .history-timeline li { position: relative; padding-left: 2.5rem; margin-bottom: 1.2rem; }
    .history-timeline li::before { content: ''; position: absolute; left: 0.55rem; top: 0.3rem; width: 0.9rem; height: 0.9rem; border-radius: 50%; background: var(--bs-primary); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--bs-primary); }
    .history-timeline li.success::before { background: #28a745; box-shadow: 0 0 0 2px #28a745; }
    .history-timeline li.warning::before { background: #ffc107; box-shadow: 0 0 0 2px #ffc107; }
    .history-timeline li.danger::before  { background: #dc3545; box-shadow: 0 0 0 2px #dc3545; }

    .yield-diff-up   { color: #28a745; font-weight: 600; }
    .yield-diff-down { color: #dc3545; font-weight: 600; }

    /* ─── Print ─── */
    @@media print {
        body * { visibility: hidden !important; }
        #printYieldArea, #printYieldArea * { visibility: visible !important; }
        #printYieldArea { position: absolute; left: 0; top: 0; width: 100%; padding: 24px; font-size: 11pt; }
        .modal-backdrop { display: none !important; }
    }
    .print-form-header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 16px; }
    .print-form-table th, .print-form-table td { border: 1px solid #999; padding: 5px 8px; font-size: 0.82rem; }
    .print-form-table { border-collapse: collapse; width: 100%; }
    .sign-box { border: 1px solid #999; min-height: 70px; border-radius: 4px; }
</style>
}

@* ===== Content ===== *@
<div class="d-flex align-items-center flex-wrap gap-2 mb-1">
    <h4 class="mb-0">พิจารณาอนุมัติ %Yield</h4>
</div>
<p class="mb-1 text-muted">ตรวจสอบและพิจารณาอนุมัติคำขอ %Yield ของสถานประกอบการ ครอบคลุมวัตถุดิบทุกประเภท และกำหนดค่าการยอมรับ (%Tolerance)</p>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="@Url.Action("IndexApproveYield","Officer")" class="text-primary fw-semibold">อนุมัติ %Yield</a></li>
        <li class="breadcrumb-item active text-secondary">@requestNo</li>
    </ol>
</nav>

<!-- ─── Status Banner ─── -->
<div class="review-banner pending mb-4 d-flex align-items-center gap-3" id="statusBanner">
    <i class="ri ri-time-line fs-4 text-warning"></i>
    <div>
        <div class="fw-semibold">รออนุมัติ</div>
        <div class="small text-muted">คำขอนี้รอการพิจารณา — <span class="badge @requestTypeClass">@requestTypeText</span> <span class="badge bg-label-secondary ms-1">@rawMaterialType</span></div>
    </div>
</div>

<!-- ─── Header Meta ─── -->
<div class="row g-2 mb-4">
    <div class="col-12 col-md-4">
        <div class="small text-muted">เลขที่คำขอ</div>
        <div class="fw-semibold text-primary">@requestNo</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">ผู้ประกอบการ</div>
        <div class="fw-semibold">@companyName</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">วันที่ยื่นคำขอ</div>
        <div class="fw-semibold">@submittedDate</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">ประเภทคำขอ</div>
        <div><span class="badge @requestTypeClass">@requestTypeText</span></div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">ประเภทวัตถุดิบ</div>
        <div><span class="badge bg-label-secondary">@rawMaterialType</span></div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">สถานะ</div>
        <div><span class="badge @statusClass">@statusText</span></div>
    </div>
</div>

<!-- ─── Action Buttons ─── -->
<div class="d-flex flex-wrap gap-2 mb-4" id="actionBar">
    <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalApprove">
        <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติ
    </button>
    <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modalReject">
        <i class="ri ri-close-circle-line me-1"></i> ไม่อนุมัติ
    </button>
    <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#modalReturn">
        <i class="ri ri-reply-line me-1"></i> ส่งคืนแก้ไข
    </button>
    <button type="button" class="btn btn-outline-warning btn-sm" data-bs-toggle="modal" data-bs-target="#modalSuspend">
        <i class="ri ri-pause-circle-line me-1"></i> ระงับ
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modalPrintYield">
        <i class="ri ri-printer-line me-1"></i> พิมพ์ฟอร์ม %Yield
    </button>
    <a href="@Url.Action("IndexApproveYield","Officer")" class="btn btn-outline-secondary btn-sm ms-auto">
        <i class="ri ri-arrow-left-line me-1"></i> กลับรายการ
    </a>
</div>

<!-- ─── Tabs ─── -->
<ul class="nav nav-tabs mb-4" id="yieldTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab1-tab" data-bs-toggle="tab" data-bs-target="#tab1" type="button" role="tab">
            <i class="ri ri-file-list-3-line me-1"></i> รายละเอียดคำขอ
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab2-tab" data-bs-toggle="tab" data-bs-target="#tab2" type="button" role="tab">
            <i class="ri ri-attachment-line me-1"></i> หลักฐานประกอบ
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab3-tab" data-bs-toggle="tab" data-bs-target="#tab3" type="button" role="tab">
            <i class="ri ri-scales-line me-1"></i> ผลการพิจารณา
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab4-tab" data-bs-toggle="tab" data-bs-target="#tab4" type="button" role="tab">
            <i class="ri ri-history-line me-1"></i> ประวัติการดำเนินการ
        </button>
    </li>
</ul>

<div class="tab-content" id="yieldTabsContent">

    <!-- ============================================================ -->
    <!-- TAB 1: รายละเอียดคำขอ -->
    <!-- ============================================================ -->
    <div class="tab-pane fade show active" id="tab1" role="tabpanel">

        <!-- ── ข้อมูลสถานประกอบการ ── -->
        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 fw-semibold small">
                <i class="ri ri-building-line me-1 text-primary"></i> ข้อมูลสถานประกอบการ
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small">ชื่อสถานประกอบการ</label>
                        <div class="field-display fw-semibold">@companyName</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">เลขทะเบียน</label>
                        <div class="field-display">@companyReg</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">ประเภทรับรอง DOF</label>
                        <div class="field-display"><span class="badge bg-label-primary">ในรับรอง DOF</span></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">ประเภทสินค้าที่รับรอง</label>
                        <div class="field-display">@certType</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">พื้นที่รับผิดชอบ</label>
                        <div class="field-display">@areaResponsible</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── รายละเอียดคำขอ %Yield ── -->
        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 fw-semibold small">
                <i class="ri ri-percent-line me-1 text-warning"></i> รายละเอียดคำขอ %Yield
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label class="form-label small">ประเภทคำขอ</label>
                        <div class="field-display"><span class="badge @requestTypeClass">@requestTypeText</span></div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">ประเภทวัตถุดิบ</label>
                        <div class="field-display"><span class="badge bg-label-secondary">@rawMaterialType</span></div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">%Yield เดิม</label>
                        <div class="field-display text-center fw-semibold text-muted">@previousYield.ToString("F1")%</div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">%Yield ที่ขอ</label>
                        <div class="field-display text-center fw-bold text-primary">@requestedYield.ToString("F1")%
                            <span class="yield-diff-up ms-1 small">(+@((requestedYield - previousYield).ToString("F1"))%)</span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">%Tolerance ที่กำหนด</label>
                        <div class="field-display text-center">
                            <input type="number" class="form-control form-control-sm text-center" id="toleranceInput" value="@tolerance.ToString("F1")" step="0.5" min="0" max="10" style="max-width:80px;" />
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label small">เหตุผลการขอเปลี่ยนแปลง</label>
                    <div class="field-display" style="min-height:3rem;align-items:flex-start;padding-top:.5rem;">
                        ข้อมูลเชิงเทคนิคการผลิตเปลี่ยนแปลงตามฤดูกาล ทำให้ %Yield เฉลี่ยเพิ่มขึ้นจาก 70.0% เป็น 72.5% จากการปรับปรุงกระบวนการผลิตรุ่น 2566
                    </div>
                </div>
            </div>
        </div>

        <!-- ── ตาราง %Yield รายผลิตภัณฑ์ ── -->
        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 fw-semibold small">
                <i class="ri ri-table-line me-1 text-success"></i> %Yield รายผลิตภัณฑ์ที่ขอ
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0" style="font-size:0.78rem;">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>รหัสผลิตภัณฑ์</th>
                                <th>ชื่อผลิตภัณฑ์</th>
                                <th>ประเภทวัตถุดิบ</th>
                                <th class="text-center">%Yield เดิม</th>
                                <th class="text-center">%Yield ขอ</th>
                                <th class="text-center">%Tolerance ขอ</th>
                                <th class="text-center">ช่วงที่ยอมรับ</th>
                                <th class="text-center">ผลตรวจสอบ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td>3AASNNBELNNPP</td>
                                <td>CANNED O LIGHTMEAT SHREDDED IN TABASCO</td>
                                <td><span class="badge bg-label-secondary">วัตถุดิบนำเข้า</span></td>
                                <td class="text-center text-muted">70.0%</td>
                                <td class="text-center fw-bold text-primary">72.5%</td>
                                <td class="text-center">±2.0%</td>
                                <td class="text-center small">70.5% – 74.5%</td>
                                <td class="text-center"><span class="badge bg-label-warning">รอพิจารณา</span></td>
                            </tr>
                            <tr>
                                <td>2</td>
                                <td>3AASNNBELNNKK</td>
                                <td>CANNED O SLICE IN XO SAUCE</td>
                                <td><span class="badge bg-label-secondary">วัตถุดิบนำเข้า</span></td>
                                <td class="text-center text-muted">68.5%</td>
                                <td class="text-center fw-bold text-primary">71.0%</td>
                                <td class="text-center">±2.0%</td>
                                <td class="text-center small">69.0% – 73.0%</td>
                                <td class="text-center"><span class="badge bg-label-warning">รอพิจารณา</span></td>
                            </tr>
                            <tr>
                                <td>3</td>
                                <td>3BAASLIGHTMEAT</td>
                                <td>CANNED TUNA LIGHTMEAT IN BRINE (EU)</td>
                                <td><span class="badge bg-label-info">ผลิตภัณฑ์แปรรูปเบื้องต้น</span></td>
                                <td class="text-center text-muted">74.0%</td>
                                <td class="text-center fw-bold text-primary">74.0%</td>
                                <td class="text-center">±2.5%</td>
                                <td class="text-center small">71.5% – 76.5%</td>
                                <td class="text-center"><span class="badge bg-label-warning">รอพิจารณา</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ── ผลการตรวจสอบ %Yield (vs คำนวณจริง) ── -->
        <div class="card shadow-sm mb-3" id="yieldCheckSection">
            <div class="card-header py-2 fw-semibold small">
                <i class="ri ri-bar-chart-line me-1 text-danger"></i> ผลการตรวจสอบ %Yield เทียบ %Yield อนุมัติ vs คำนวณจากระบบ
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-4">
                        <div class="p-3 rounded border text-center">
                            <div class="text-muted small mb-1">%Yield อนุมัติ (อ้างอิง)</div>
                            <div class="fw-bold fs-4 text-success">@approvedYield.ToString("F1")%</div>
                            <div class="text-muted small">ช่วงวันที่มีผล: @effectiveDateFrom – @effectiveDateTo</div>
                            <div class="text-muted small mt-1">Tolerance: ±@tolerance.ToString("F1")%</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="p-3 rounded border text-center">
                            <div class="text-muted small mb-1">%Yield จากการคำนวณจริง (ล่าสุด)</div>
                            <div class="fw-bold fs-4 @(isOverTolerance ? "text-danger" : "text-success")">@calculatedYield.ToString("F1")%</div>
                            <div class="text-muted small">คำนวณ ณ 24/04/2569 14:30 น.</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="p-3 rounded border text-center">
                            <div class="text-muted small mb-1">เบี่ยงเบนจากค่าอ้างอิง</div>
                            <div class="fw-bold fs-4 @(isOverTolerance ? "text-danger" : "text-success")">@deviationPct.ToString("F1")%</div>
                            @if (isOverTolerance)
                            {
                                <span class="badge bg-label-danger">เกินค่า Tolerance ❌</span>
                            }
                            else
                            {
                                <span class="badge bg-label-success">อยู่ในเกณฑ์ ✅</span>
                            }
                        </div>
                    </div>
                </div>

                @if (isOverTolerance)
                {
                <div class="alert alert-danger d-flex gap-3 py-3 mb-3">
                    <i class="ri ri-error-warning-fill fs-4 flex-shrink-0 mt-1"></i>
                    <div>
                        <div class="fw-semibold">⛔ %Yield เบี่ยงเบนเกินกำหนด — ระบบไม่สามารถบันทึกข้อมูลการผลิตได้</div>
                        <div class="small mt-1">%Yield คำนวณจริง (@calculatedYield.ToString("F1")%) เบี่ยงเบนจากค่าอนุมัติ (@approvedYield.ToString("F1")%) เกิน Tolerance (±@tolerance.ToString("F1")%)
                            — กรุณายื่นคำขอแก้ไข %Yield ใหม่ หรือติดต่อเจ้าหน้าที่ผู้รับผิดชอบ</div>
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#modalNewYieldRequest">
                                <i class="ri ri-add-circle-line me-1"></i> 📝 สร้างคำขอแก้ไข %Yield ใหม่
                            </button>
                        </div>
                    </div>
                </div>
                }
                else
                {
                <div class="alert alert-success d-flex gap-2 py-2 mb-3 small">
                    <i class="ri ri-checkbox-circle-line mt-1 flex-shrink-0"></i>
                    <span>%Yield จากการคำนวณจริงอยู่ในเกณฑ์ Tolerance — สามารถบันทึกข้อมูลการผลิตได้ตามปกติ</span>
                </div>
                }
            </div>
        </div>

    </div><!-- /tab1 -->
    <!-- ============================================================ -->
    <div class="tab-pane fade" id="tab2" role="tabpanel">
        <div class="card shadow-sm">
            <div class="card-header py-2 fw-semibold small">
                <i class="ri ri-attachment-line me-1 text-primary"></i> หลักฐานประกอบคำขอ
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0" style="font-size:0.78rem;">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>ชื่อไฟล์</th>
                                <th>ประเภทหลักฐาน</th>
                                <th class="text-center">ขนาด</th>
                                <th class="text-center">วันที่แนบ</th>
                                <th class="text-center">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td>
                                <td><i class="ri ri-file-excel-line text-success me-1"></i> yield_calculation_2566.xlsx</td>
                                <td>ตารางคำนวณ %Yield จากการผลิตจริง</td>
                                <td class="text-center">380 KB</td>
                                <td class="text-center">18/04/2569</td>
