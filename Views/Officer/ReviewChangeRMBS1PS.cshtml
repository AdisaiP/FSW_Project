@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    // Tooltips
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el, { trigger: 'hover' });
    });

    function showReviewToast(msg, type) {
        var bg   = type === 'success' ? 'bg-success' : type === 'danger' ? 'bg-danger' : type === 'warning' ? 'bg-warning' : 'bg-info';
        var icon = type === 'success' ? 'ri-checkbox-circle-line' : type === 'danger' ? 'ri-close-circle-line' : 'ri-error-warning-line';
        var toastEl = document.createElement('div');
        toastEl.className = 'position-fixed bottom-0 end-0 p-3';
        toastEl.style.zIndex = 9999;
        toastEl.innerHTML =
            '<div class="toast show align-items-center text-white ' + bg + ' border-0" role="alert">' +
            '  <div class="d-flex">' +
            '    <div class="toast-body d-flex align-items-center gap-2">' +
            '      <i class="ri ' + icon + ' fs-5"></i> ' + msg +
            '    </div>' +
            '    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
            '  </div>' +
            '</div>';
        document.body.appendChild(toastEl);
        setTimeout(function () { toastEl.remove(); }, 4000);
    }

    // Save draft
    document.getElementById('btnSaveDraft').addEventListener('click', function () {
        showReviewToast('บันทึกร่างคำขอเปลี่ยนแปลงเรียบร้อยแล้ว', 'info');
    });

    // Send to approver
    document.getElementById('btnConfirmSendToApprover').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalSendToApprover')).hide();
        showReviewToast('ส่งคำขอให้ผู้อนุมัติเรียบร้อยแล้ว', 'success');
        // Update status banner
        var banner = document.getElementById('statusBanner');
        banner.className = 'review-banner pending mb-4 d-flex align-items-center gap-3';
        banner.innerHTML =
            '<i class="ri ri-send-plane-fill fs-4 text-primary"></i>' +
            '<div><div class="fw-semibold">ส่งให้ผู้อนุมัติแล้ว</div>' +
            '<div class="small text-muted">รอผู้อนุมัติพิจารณา</div></div>';
    });

    // Approve
    document.getElementById('btnConfirmApprove').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalConfirmApprove')).hide();
        showReviewToast('อนุมัติคำขอเปลี่ยนแปลงเรียบร้อยแล้ว — ระบบดำเนินการเปลี่ยนแปลงข้อมูลแล้ว', 'success');
        document.getElementById('approvedResultBanner').classList.remove('d-none');
        // Update status banner
        var banner = document.getElementById('statusBanner');
        banner.className = 'review-banner approved mb-4 d-flex align-items-center gap-3';
        banner.innerHTML =
            '<i class="ri ri-checkbox-circle-fill fs-4 text-success"></i>' +
            '<div><div class="fw-semibold">อนุมัติแล้ว</div>' +
            '<div class="small text-muted">ผู้อนุมัติได้อนุมัติคำขอเปลี่ยนแปลงนี้แล้ว</div></div>';
    });

    // Reject
    document.getElementById('btnConfirmReject').addEventListener('click', function () {
        var reason = document.getElementById('rejectReason').value.trim();
        if (!reason) {
            document.getElementById('rejectReasonError').classList.remove('d-none');
            return;
        }
        document.getElementById('rejectReasonError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalConfirmReject')).hide();
        showReviewToast('ไม่อนุมัติคำขอเปลี่ยนแปลงเรียบร้อยแล้ว', 'danger');
        var banner = document.getElementById('statusBanner');
        banner.className = 'review-banner rejected mb-4 d-flex align-items-center gap-3';
        banner.innerHTML =
            '<i class="ri ri-close-circle-fill fs-4 text-danger"></i>' +
            '<div><div class="fw-semibold">ไม่อนุมัติ</div>' +
            '<div class="small text-muted">ผู้อนุมัติไม่อนุมัติคำขอเปลี่ยนแปลงนี้</div></div>';
    });

    // Notify correct
    document.getElementById('btnConfirmNotifyCorrect').addEventListener('click', function () {
        var detail = document.getElementById('correctDetail').value.trim();
        if (!detail) {
            document.getElementById('correctDetailError').classList.remove('d-none');
            return;
        }
        document.getElementById('correctDetailError').classList.add('d-none');
        bootstrap.Modal.getInstance(document.getElementById('modalNotifyCorrect')).hide();
        showReviewToast('แจ้งให้แก้ไขเรียบร้อยแล้ว', 'warning');
    });

    // Upload area mock
    document.getElementById('uploadArea').addEventListener('click', function () {
        showReviewToast('ฟังก์ชันแนบไฟล์ — TODO: implement file upload', 'info');
    });
    document.getElementById('btnAddAttachment').addEventListener('click', function () {
        showReviewToast('ฟังก์ชันแนบไฟล์ — TODO: implement file upload', 'info');
    });
});
</script>
}
