@{
    ViewData["Title"] = "พิจารณาคำขอเปลี่ยนแปลง RMBS1:PS";

    string changeRequestNo = "CHG-PS-2561-0001";
    string rmbs1OldNo      = "10611280211800000560";
    string changeType      = "เปลี่ยนผลการพิจารณา";
    string operatorName    = "Alpha Office Automation Co., Ltd. (สาขา 00001)";
    string submittedDate   = "5 ตุลาคม 2561  เวลา 09:30 น.";
    string statusText      = "รออนุมัติ";
    string statusClass     = "bg-label-warning";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
}

@section PageStyles {
<style>
    .field-display {
        font-size: 0.875rem;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.375rem;
        padding: 0.4375rem 0.875rem;
        min-height: 2.375rem;
        display: flex;
        align-items: center;
        word-break: break-word;
    }
    .field-display.text-end   { justify-content: flex-end; }
    .field-display.text-center { justify-content: center; }
    .form-label.small { font-size: 0.8rem; font-weight: 500; margin-bottom: 0.25rem; }

    .review-banner {
        border-left: 4px solid;
        padding: 1rem 1.25rem;
        border-radius: 0.5rem;
    }
    .review-banner.pending  { border-color: #fd7e14; background: rgba(253,126,20,.06); }
    .review-banner.approved { border-color: #28a745; background: rgba(40,167,69,.06); }
    .review-banner.rejected { border-color: #dc3545; background: rgba(220,53,69,.06); }

    .decision-card { border: 2px solid var(--bs-primary); }
    .decision-card .card-header { background: rgba(var(--bs-primary-rgb), .08); }

    .history-timeline { list-style: none; padding-left: 0; position: relative; }
    .history-timeline::before { content: ''; position: absolute; left: 1rem; top: 0; bottom: 0; width: 2px; background: var(--bs-border-color); }
    .history-timeline li { position: relative; padding-left: 2.5rem; margin-bottom: 1.2rem; }
    .history-timeline li::before { content: ''; position: absolute; left: 0.55rem; top: 0.3rem; width: 0.9rem; height: 0.9rem; border-radius: 50%; background: var(--bs-primary); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--bs-primary); }
    .history-timeline li.success::before { background: #28a745; box-shadow: 0 0 0 2px #28a745; }
    .history-timeline li.warning::before { background: #ffc107; box-shadow: 0 0 0 2px #ffc107; }
    .history-timeline li.danger::before  { background: #dc3545; box-shadow: 0 0 0 2px #dc3545; }
</style>
}

@* ===== Content ===== *@
<div class="d-flex align-items-center flex-wrap gap-2 mb-1">
    <h4 class="mb-0">พิจารณาคำขอเปลี่ยนแปลง RMBS1:PS</h4>
    <span class="badge bg-label-success ms-1">ผู้อนุมัติ 🔑</span>
</div>
<p class="mb-1 text-muted">ตรวจสอบและพิจารณาคำขอเปลี่ยนแปลงผลการพิจารณา / ยกเลิกการออกเอกสาร RMBS1:PS กรณีที่ออกใบรับรองไปแล้ว</p>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="@Url.Action("IndexRMBS1PS", "Officer")" class="text-primary fw-semibold">พิจารณา RMBS1 สถานะ PS / NoPS</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("IndexChangeRMBS1PS", "Officer")" class="text-primary fw-semibold">คำขอเปลี่ยนแปลง / ยกเลิก</a></li>
        <li class="breadcrumb-item active text-secondary">@changeRequestNo</li>
    </ol>
</nav>

<!-- ─── Status Banner ─── -->
<div class="review-banner pending mb-4 d-flex align-items-center gap-3" id="statusBanner">
    <i class="ri ri-time-line fs-4 text-warning"></i>
    <div>
        <div class="fw-semibold">รออนุมัติ</div>
        <div class="small text-muted">คำขอนี้รอการพิจารณาจากผู้อนุมัติ — <span class="badge bg-label-primary">@changeType</span></div>
    </div>
</div>

<!-- ─── Header Meta ─── -->
<div class="row g-2 mb-4">
    <div class="col-12 col-md-4">
        <div class="small text-muted">เลขที่คำขอเปลี่ยนแปลง</div>
        <div class="fw-semibold">@changeRequestNo</div>
    </div>
    <div class="col-12 col-md-4">
