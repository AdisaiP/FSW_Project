    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">วันที่ยื่นคำขอ</div>
        <div class="fw-semibold">@submittedDate</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">ผู้ประกอบการ</div>
        <div class="fw-semibold">@operatorName</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">ประเภทการเปลี่ยนแปลง</div>
        <div><span class="badge bg-label-primary">@changeType</span></div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">สถานะ</div>
        <div><span class="badge @statusClass">@statusText</span></div>
    </div>
</div>

<!-- ─── Action Buttons (Draft/Pending state) ─── -->
<div class="d-flex flex-wrap gap-2 mb-4" id="actionBar">
    <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSaveDraft">
        <i class="ri ri-save-line me-1"></i> บันทึกร่าง
    </button>
    <button type="button" class="btn btn-primary btn-sm" id="btnSendToApprover" data-bs-toggle="modal" data-bs-target="#modalSendToApprover">
        <i class="ri ri-send-plane-line me-1"></i> ส่งให้ผู้อนุมัติ
    </button>
    <button type="button" class="btn btn-success btn-sm" id="btnApprove" data-bs-toggle="modal" data-bs-target="#modalConfirmApprove">
        <i class="ri ri-checkbox-circle-line me-1"></i> อนุมัติคำขอ
    </button>
    <button type="button" class="btn btn-danger btn-sm" id="btnReject" data-bs-toggle="modal" data-bs-target="#modalConfirmReject">
        <i class="ri ri-close-circle-line me-1"></i> ไม่อนุมัติ
    </button>
    <button type="button" class="btn btn-outline-warning btn-sm" id="btnNotifyCorrect" data-bs-toggle="modal" data-bs-target="#modalNotifyCorrect">
        <i class="ri ri-edit-line me-1"></i> แจ้งให้แก้ไข
