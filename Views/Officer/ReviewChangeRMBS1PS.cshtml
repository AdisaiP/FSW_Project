                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">วันออกเอกสาร</label>
                                <div class="field-display">17/08/2561</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">ประเภทสัตว์น้ำ</label>
                                <div class="field-display">ปลาทูน่าอัลบาคอร์ ทั้งตัว แช่แข็ง</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">ปริมาณที่อนุมัติ (กก.)</label>
                                <div class="field-display text-end">240,000.00</div>
                            </div>
                            <div class="col-md-4">
