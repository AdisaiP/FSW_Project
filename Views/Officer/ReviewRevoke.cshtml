                            <h6 class="mb-0 fw-semibold">ประวัติการดำเนินการ</h6>
                        </div>
                        <ul class="timeline mb-0" style="list-style:none; padding-left:1rem; border-left:2px solid #dee2e6;">
                            <li class="mb-3 ps-3 position-relative">
                                <span class="position-absolute start-0 translate-middle badge rounded-circle bg-success" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                <div class="small text-muted">21/04/2569 09:10</div>
                                <div class="fw-semibold small">ผู้ประกอบการยื่นคำขอยกเลิก</div>
                                <div class="small text-muted">ผู้ดำเนินการ: ผู้เข้าใช้ระบบ</div>
                            </li>
                            @* 2.7(8): ประวัติข้อมูลตรวจปล่อยจากด่านฯ *@
                            @if (hasInspectionData)
                            {
                                <li class="mb-3 ps-3 position-relative">
                                    <span class="position-absolute start-0 translate-middle badge rounded-circle bg-info" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                    <div class="small text-muted">@inspectionDate 08:45</div>
                                    <div class="fw-semibold small">
                                        รับข้อมูลตรวจปล่อยจากด่านตรวจประมง
                                        <span class="badge bg-label-success ms-1">ผ่านตรวจปล่อย ✅</span>
                                    </div>
                                    <div class="small text-muted">@inspectionPort — @inspectionRefNo</div>
                                </li>
                            }
                            @if (isRegistered)
                            {
                                <li class="mb-3 ps-3 position-relative">
                                    <span class="position-absolute start-0 translate-middle badge rounded-circle bg-info" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                    <div class="small text-muted">21/04/2569 10:30</div>
                                    <div class="fw-semibold small">ลงทะเบียนรับคำขอยกเลิก — <span class="text-success">@receivedNo</span></div>
                                    <div class="small text-muted">ผู้ดำเนินการ: เจ้าหน้าที่กรมประมง</div>
                                </li>
                            }
                            @if (requestStatus == "อนุมัติ")
                            {
                                <li class="mb-3 ps-3 position-relative">
                                    <span class="position-absolute start-0 translate-middle badge rounded-circle bg-success" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                    <div class="small text-muted">21/04/2569 14:00</div>
                                    <div class="fw-semibold small">อนุมัติยกเลิกใบรับรอง</div>
                                    <div class="small text-muted">ผู้ดำเนินการ: นายสมชาย มีสุข</div>
                                </li>
                                <li class="mb-3 ps-3 position-relative">
                                    <span class="position-absolute start-0 translate-middle badge rounded-circle bg-primary" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                    <div class="small text-muted">21/04/2569 14:00</div>
                                    <div class="fw-semibold small">
                                        คืนน้ำหนัก/โควตาอัตโนมัติสำเร็จ
                                        <span class="revoke-badge-auto ms-1">✅ คืน @returnWeight.ToString("N2") กก.</span>
                                    </div>
                                    <div class="small text-muted">ระบบดำเนินการอัตโนมัติ</div>
                                </li>
                                @* 2.7(7): HC คืนในประวัติ *@
                                @if (hasHcRef)
                                {
                                    <li class="mb-3 ps-3 position-relative">
                                        <span class="position-absolute start-0 translate-middle badge rounded-circle bg-danger" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                        <div class="small text-muted">21/04/2569 14:00</div>
                                        <div class="fw-semibold small">
                                            คืน Health Certificate อัตโนมัติ
                                            <span class="badge bg-label-success ms-1">HC @hcRefNo พร้อมใช้งาน ✅</span>
                                        </div>
                                        <div class="small text-muted">ระบบดำเนินการอัตโนมัติ</div>
                                    </li>
                                }
                                @* 2.7(9): แจ้งยกเลิกไปด่านตรวจประมงในประวัติ *@
                                @if (notifiedToPort)
                                {
                                    <li class="mb-3 ps-3 position-relative">
                                        <span class="position-absolute start-0 translate-middle badge rounded-circle bg-info" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                        <div class="small text-muted">@notifyPortDate</div>
                                        <div class="fw-semibold small">
                                            แจ้งยกเลิกใบรับรองไปยังด่านตรวจประมงอัตโนมัติ
                                            <span class="badge bg-label-info ms-1">แจ้งแล้ว ✅</span>
                                        </div>
                                        <div class="small text-muted">@notifyPortName — อ้างอิง: @notifyPortRefNo</div>
                                    </li>
                                }
                            }
                            else if (requestStatus == "ไม่อนุมัติ")
                            {
                                <li class="mb-3 ps-3 position-relative">
                                    <span class="position-absolute start-0 translate-middle badge rounded-circle bg-danger" style="left:-0.05rem!important;top:0.15rem;width:0.75rem;height:0.75rem;padding:0;"></span>
                                    <div class="small text-muted">21/04/2569 14:00</div>
                                    <div class="fw-semibold small">ไม่อนุมัติคำขอยกเลิก</div>
                                    <div class="small text-muted">ผู้ดำเนินการ: นายสมชาย มีสุข</div>
                                </li>
                            }
                        </ul>
                    </div>
                </div><!-- /tab-history -->

            </div><!-- /tab-content -->
        </div><!-- /nav-align-top -->
    </div>
</div>

@section PageStyles {
<style>
    .cert-type-nmd {
        background-color: rgba(123,31,162,0.15);
        color: #7b1fa2;
    }
    .quota-table th, .quota-table td { padding: 0.5rem 0.75rem; vertical-align: middle; font-size: 0.83rem; }
    .quota-table .col-before  { color: #6e7985; }
    .quota-table .col-returned { color: #198754; font-weight: 600; }
    .quota-table .col-after   { color: #0d6efd; font-weight: 700; }
    .revoke-badge-auto {
        background-color: rgba(25,135,84,0.12);
        color: #198754;
        border: 1px solid rgba(25,135,84,0.25);
        padding: 0.3rem 0.7rem;
        border-radius: 0.45rem;
        font-size: 0.78rem;
        font-weight: 600;
    }
</style>
}

@section PageScripts {
<script>
    // 2.7(5): ลงทะเบียนรับคำขอยกเลิก
    function confirmRegister() {
        var receivedNo = document.getElementById('generatedReceivedNo').value;
        var note = document.getElementById('registerNote').value;
        // TODO: POST to server
        var modal = bootstrap.Modal.getInstance(document.getElementById('modalRegisterRevoke'));
        if (modal) modal.hide();
        alert('✅ ลงทะเบียนรับคำขอยกเลิกสำเร็จ\nเลขที่รับคำขอ: ' + receivedNo + '\nหมายเหตุ: ' + (note || '(ไม่มี)'));
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Set today's date in Thai BE
        var today = new Date();
        var day   = today.getDate().toString().padStart(2, '0');
        var month = (today.getMonth() + 1).toString().padStart(2, '0');
        var year  = today.getFullYear() + 543;
        var el = document.getElementById('registerDate');
        if (el) el.value = day + '/' + month + '/' + year;

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (e) {
                new bootstrap.Tooltip(e);
            });
        }
    });
</script>
}
