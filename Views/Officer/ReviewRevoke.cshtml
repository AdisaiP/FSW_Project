                                <i class="ri ri-information-line fs-5"></i>
                                <span>การคืนน้ำหนัก/โควตาจะดำเนินการอัตโนมัติหลังจากอนุมัติคำขอยกเลิก</span>
                            </div>
                        }

                        <!-- ตาราง ก่อน/หลังยกเลิก -->
                        <div class="card mb-4">
                            <div class="card-header d-flex align-items-center gap-2">
                                <i class="ri ri-table-line text-primary"></i>
                                <h6 class="mb-0 fw-semibold">ผลการคืนน้ำหนักและโควตา — ก่อน/หลังยกเลิกใบรับรอง</h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle mb-0 quota-table">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th style="min-width:260px;">รายการ</th>
                                            <th style="min-width:120px;">ก่อนยกเลิก (กก.)</th>
                                            <th style="min-width:120px;">ที่คืนกลับ (กก.)</th>
                                            <th style="min-width:120px;">หลังยกเลิก (กก.)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in quotaRows)
                                        {
                                            <tr>
                                                <td>@row.Label</td>
                                                <td class="text-end col-before">@row.Before.ToString("N2")</td>
                                                <td class="text-end col-returned">
                                                    @if (requestStatus == "อนุมัติ")
                                                    {
                                                        <span>+@row.Returned.ToString("N2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">(ยังไม่ได้คืน)</span>
                                                    }
                                                </td>
                                                <td class="text-end col-after">
                                                    @if (requestStatus == "อนุมัติ")
                                                    {
                                                        @row.After.ToString("N2")
                                                    }
