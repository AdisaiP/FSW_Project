@{
    ViewData["Title"] = "พิจารณาคำขอยกเลิกใบรับรอง";

    // ── Mock variables ──────────────────────────────────────────────────
    var requestStatus = "อนุมัติ"; // mock: รออนุมัติ | อนุมัติ | ไม่อนุมัติ
    var isReadOnly = requestStatus != "รออนุมัติ";

    var requestNumber   = "10611180232800201";
    var certNo          = "NMD-2569-HC821B211301";
    var certType        = "NMD";
    var certTypeName    = "ใบรับรองสัตว์น้ำไม่แปรรูป (NMD)";
    var establishment   = "บริษัท สยาม โปรเซสซิ่ง จำกัด";
    var taxId           = "0105548054321";
    var productName     = "กุ้งแช่แข็ง";
    var destination     = "ญี่ปุ่น";
    var revokeReason    = "ข้อมูลไม่ถูกต้อง";
    var submittedDate   = "21/04/2569 (09:10)";
    var receivedNo      = requestStatus == "อนุมัติ" ? "รบ-ยก.2569-00201" : "";
    var isRegistered    = !string.IsNullOrEmpty(receivedNo);

    // 2.7(4): quota/weight return data (mock)
    var returnWeight = 500.0m; // กก. ที่คืนกลับ
    var quotaReturned = 500.0m;

    // 2.7(7): Health Certificate ที่อ้างอิง (สำหรับ NMD/PS ที่ผูกกับ HC)
    var hasHcRef    = certType == "NMD" || certType == "PS";
    var hcRefNo     = "HC821B211301";
    var hcIssuedDate = "10/04/2569";
    var hcStatus    = requestStatus == "อนุมัติ" ? "พร้อมใช้งาน" : "ถูกใช้งานโดยใบรับรองนี้";

    // 2.7(8): ข้อมูลตรวจปล่อยจากด่านตรวจประมง
    var hasInspectionData  = true;  // mock: มีข้อมูลตรวจปล่อยจากด่านฯ
    var inspectionPort     = "ด่านตรวจประมงท่าเรือแหลมฉบัง";
    var inspectionDate     = "18/04/2569";
    var inspectionRefNo    = "TP-2569-LC-00823";
    var inspectionOfficer  = "เจ้าหน้าที่ประมง สุรีย์ มั่นคง";
    var inspectionWeight   = "500.00 กก.";
    var inspectionResult   = "ผ่านการตรวจปล่อย";

    // 2.7(9): แจ้งยกเลิกไปด่านตรวจประมง (ส่งข้อมูลออก)
    var notifiedToPort     = requestStatus == "อนุมัติ";  // แจ้งอัตโนมัติหลังอนุมัติ
    var notifyPortRefNo    = "NT-YK-2569-LC-00201";       // เลขที่แจ้งยกเลิก
    var notifyPortDate     = "21/04/2569 14:05";
    var notifyPortName     = "ด่านตรวจประมงท่าเรือแหลมฉบัง";

    // ก่อน / คืนกลับ / หลัง (หน่วย: กก.)
    var quotaRows = new[]
    {
        new { Label = "น้ำหนักปริมาณสัตว์น้ำที่โรงงานรับซื้อ-ขาย (คงเหลือ)",       Before = 1250.00m,  Returned = 500.00m, After = 1750.00m  },
        new { Label = "โควตาสัตว์น้ำที่รับซื้อ (คงเหลือ)",                          Before = 3400.00m,  Returned = 500.00m, After = 3900.00m  },
        new { Label = "ปริมาณ/โควตาสัตว์น้ำที่รับซื้อ ณ วันที่ CC/SCC มา (คงเหลือ)", Before = 2100.00m, Returned = 500.00m, After = 2600.00m  },
        new { Label = "โควตา ณ วันที่ CC/SCC มา (คงเหลือ)",                         Before = 1800.00m,  Returned = 500.00m, After = 2300.00m  },
        new { Label = "โควตาและปริมาณตามเอกสารแหล่งที่มาสัตว์น้ำนำเข้า",           Before = 4200.00m,  Returned = 500.00m, After = 4700.00m  },
    };
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageStyles {
<style>
    .quota-table th, .quota-table td { padding: 0.5rem 0.75rem; vertical-align: middle; font-size: 0.83rem; }
    .quota-table .col-before  { color: #6e7985; }
    .quota-table .col-returned { color: #198754; font-weight: 600; }
    .quota-table .col-after   { color: #0d6efd; font-weight: 700; }
    .revoke-badge-auto {
        background-color: rgba(25,135,84,0.12);
        color: #198754;
        border: 1px solid rgba(25,135,84,0.25);
        padding: 0.35rem 0.8rem;
        border-radius: 0.5rem;
        font-size: 0.8rem;
        font-weight: 600;
    }
</style>
}

@* ************** Content ************** *@
<h4 class="mb-1">พิจารณาคำขอยกเลิกใบรับรอง</h4>
<p class="mb-1">พิจารณาคำขอยกเลิกและผลการคืนน้ำหนัก/โควตาอัตโนมัติ</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexRevoke", "Officer")" class="text-primary fw-semibold">พิจารณายกเลิกใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active text-secondary">@requestNumber</li>
    </ol>
</nav>

<!-- Status Banner -->
@if (requestStatus == "อนุมัติ")
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="ri ri-checkbox-circle-line fs-5"></i>
        <div>
            <strong>อนุมัติยกเลิกแล้ว</strong> — ใบรับรอง @certNo ถูกยกเลิกเรียบร้อย
            <span class="ms-2 revoke-badge-auto">
                <i class="ri ri-arrow-go-back-line me-1"></i>คืนน้ำหนัก/โควตาอัตโนมัติแล้ว ✅
            </span>
        </div>
    </div>
    @* 2.7(4): alert ผลการคืนอัตโนมัติ *@
    <div class="alert alert-success border border-success bg-success bg-opacity-10 d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="ri ri-checkbox-circle-fill text-success fs-5 flex-shrink-0"></i>
        <span>
            ✅ ยกเลิกใบรับรอง <strong>@certNo</strong> แล้ว —
            คืนน้ำหนัก <strong>@returnWeight.ToString("N2") กก.</strong>
            และโควตา <strong>@quotaReturned.ToString("N2") กก.</strong> อัตโนมัติ
        </span>
    </div>
    @* 2.7(7): alert ผลการคืน HC *@
    @if (hasHcRef)
    {
        <div class="alert alert-success border border-success bg-success bg-opacity-10 d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="ri ri-heart-pulse-line text-success fs-5 flex-shrink-0"></i>
            <span>
                ✅ คืน HC <strong class="font-monospace">@hcRefNo</strong> เรียบร้อยแล้ว —
                สามารถนำไปใช้อ้างอิงในใบรับรองอื่นได้
            </span>
        </div>
    }
    @* 2.7(9): badge แจ้งยกเลิกไปด่านตรวจประมง *@
    <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i class="ri ri-ship-2-line text-info fs-5 flex-shrink-0"></i>
            <div>
                <span class="badge bg-info text-white me-2">
                    <i class="ri ri-send-plane-line me-1"></i>แจ้งยกเลิกไปด่านตรวจประมงแล้ว ✅
                </span>
                <span class="small text-muted">@notifyPortName — เลขที่แจ้ง: @notifyPortRefNo (@notifyPortDate)</span>
            </div>
        </div>
        <a href="#" class="btn btn-outline-info btn-sm flex-shrink-0"
           onclick="alert('TODO: ดูสถานะด่านตรวจปล่อย @notifyPortRefNo'); return false;">
            <i class="ri ri-external-link-line me-1"></i>ดูสถานะด่านตรวจปล่อย →
        </a>
    </div>
}
else if (requestStatus == "ไม่อนุมัติ")
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-close-circle-line fs-5"></i>
        <span><strong>ไม่อนุมัติ</strong> — คำขอยกเลิกนี้ถูกปฏิเสธ กรุณาดูเหตุผลในส่วนผลการพิจารณา</span>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-time-line fs-5"></i>
        <span><strong>รออนุมัติ</strong> — คำขอยกเลิกนี้รอการพิจารณาจากเจ้าหน้าที่</span>
    </div>
}

<!-- Request Info Header -->
<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <div>
        <span class="text-muted small">เลขที่คำขอ</span>
        <div class="fw-bold text-primary fs-6">@requestNumber</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">ประเภทใบรับรอง</span>
        <div class="fw-bold"><span class="badge cert-type-nmd">@certType</span> @certTypeName</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">เลขที่ใบรับรอง</span>
        <div class="fw-bold">@certNo</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">ผู้ประกอบการ</span>
        <div class="fw-bold">@establishment</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">วันที่ยื่นคำขอ</span>
        <div class="fw-bold">@submittedDate</div>
    </div>
    @if (isRegistered)
    {
        <div class="vr d-none d-md-block"></div>
        <div>
            <span class="text-muted small">เลขที่รับคำขอ</span>
            <div class="fw-bold text-success"><i class="ri ri-inbox-archive-line me-1"></i>@receivedNo</div>
        </div>
    }
    else
    {
        <div class="vr d-none d-md-block"></div>
        <div>
            <span class="text-muted small">เลขที่รับคำขอ</span>
            <div><span class="badge bg-label-warning"><i class="ri ri-time-line me-1"></i>ยังไม่ลงทะเบียน</span></div>
        </div>
    }
</div>

<!-- Action Bar (รออนุมัติ only) -->
@if (!isReadOnly)
{
    <div class="d-flex gap-2 mb-4 flex-wrap">
        @if (!isRegistered)
        {
            <button type="button" class="btn btn-outline-secondary" id="btnRegister"
                    data-bs-toggle="modal" data-bs-target="#modalRegisterRevoke">
                <i class="ri ri-inbox-archive-line me-1"></i>ลงทะเบียนรับคำขอยกเลิก
            </button>
        }
        else
        {
            <span class="btn btn-outline-success disabled">
                <i class="ri ri-inbox-archive-line me-1"></i>ลงทะเบียนแล้ว: @receivedNo
            </span>
        }
        <button type="button" class="btn btn-success" id="btnApprove"
                onclick="if(confirm('ยืนยันอนุมัติคำขอยกเลิก @requestNumber ?')) alert('TODO: อนุมัติ')">
            <i class="ri ri-checkbox-circle-line me-1"></i>อนุมัติยกเลิก
        </button>
        <button type="button" class="btn btn-danger" id="btnReject"
                onclick="if(confirm('ยืนยันไม่อนุมัติคำขอยกเลิก @requestNumber ?')) alert('TODO: ไม่อนุมัติ')">
            <i class="ri ri-close-circle-line me-1"></i>ไม่อนุมัติ
        </button>
    </div>
}

@* 2.7(5): Modal ลงทะเบียนรับคำขอยกเลิก *@
<div class="modal fade" id="modalRegisterRevoke" tabindex="-1" aria-labelledby="modalRegisterRevokeLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRegisterRevokeLabel">
                    <i class="ri ri-inbox-archive-line me-2 text-primary"></i>ลงทะเบียนรับคำขอยกเลิก
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
                    <i class="ri ri-information-line fs-5"></i>
                    <span>ระบบจะสร้างเลขที่รับคำขออัตโนมัติและบันทึกวันที่รับคำขอ</span>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">เลขที่รับคำขอ (อัตโนมัติ)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="ri ri-barcode-line"></i></span>
                            <input type="text" class="form-control bg-light fw-bold text-success"
                                   id="generatedReceivedNo" value="รบ-ยก.2569-00208" readonly />
                        </div>
                        <div class="form-text">เลขที่รับคำขอที่ระบบสร้างให้อัตโนมัติตามลำดับ</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">เลขที่คำขอ</label>
                        <input type="text" class="form-control bg-light" value="@requestNumber" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">วันที่รับคำขอ</label>
                        <input type="text" class="form-control bg-light" id="registerDate" value="28/04/2569" readonly />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">ผู้รับคำขอ</label>
                        <input type="text" class="form-control bg-light" value="นายสมชาย มีสุข (เจ้าหน้าที่กรมประมง)" readonly />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">หมายเหตุ</label>
                        <textarea class="form-control" rows="2" id="registerNote" placeholder="หมายเหตุเพิ่มเติม (ถ้ามี)"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-primary" id="btnConfirmRegister"
                        onclick="confirmRegister()">
                    <i class="ri ri-save-line me-1"></i>ยืนยันลงทะเบียน
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="row">
    <div class="col-12">
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                            data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i>รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                            data-bs-target="#tab-quota" aria-controls="tab-quota" aria-selected="false">
                        <i class="ri ri-arrow-go-back-line me-1"></i>ผลการคืนน้ำหนัก/โควตา
                        @if (requestStatus == "อนุมัติ")
                        {
                            <span class="badge bg-success rounded-pill ms-1" style="font-size:0.62rem;">✅ คืนแล้ว</span>
                            @if (hasHcRef)
                            {
                                <span class="badge bg-danger rounded-pill ms-1" style="font-size:0.62rem;">HC คืนแล้ว</span>
                            }
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                            data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i>หลักฐานประกอบ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                            data-bs-target="#tab-review" aria-controls="tab-review" aria-selected="false">
                        <i class="ri ri-shield-check-line me-1"></i>ผลการพิจารณา
                        @if (requestStatus == "รออนุมัติ")
                        {
                            <span class="badge bg-warning rounded-pill ms-1" style="font-size:0.65rem;">รอ</span>
                        }
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                            data-bs-target="#tab-history" aria-controls="tab-history" aria-selected="false">
                        <i class="ri ri-history-line me-1"></i>ประวัติการดำเนินการ
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <!-- ===== TAB 1: รายละเอียดคำขอ ===== -->
                <div id="tab-detail" class="tab-pane fade show active" role="tabpanel">
                    <div class="accordion accordion-custom-button" id="accordionRevokeDetail">

                        <!-- ─── ข้อมูลใบรับรองที่ต้องการยกเลิก ─── -->
                        <div class="accordion-item active">
                            <h2 class="accordion-header">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseRevokeInfo" aria-expanded="true">
                                    <i class="icon-base ri ri-file-close-line me-2"></i>ข้อมูลใบรับรองที่ต้องการยกเลิก
                                </button>
                            </h2>
                            <div id="collapseRevokeInfo" class="accordion-collapse collapse show">
                                <div class="accordion-body">
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@establishment (@taxId)" readonly />
                                                <label>ผู้ประกอบการ</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@taxId" readonly />
                                                <label>เลขประจำตัวผู้เสียภาษี</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@certTypeName" readonly />
                                                <label>ประเภทใบรับรอง</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@certNo" readonly />
                                                <label>เลขที่ใบรับรอง</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@productName" readonly />
                                                <label>ชื่อสินค้า</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="@destination" readonly />
                                                <label>ประเทศปลายทาง</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="500.00 กก." readonly />
                                                <label>น้ำหนักสุทธิในใบรับรอง</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-floating form-floating-outline">
                                                <input type="text" class="form-control bg-light" value="15/04/2569" readonly />
                                                <label>วันที่ออกใบรับรอง</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ─── เหตุผลการขอยกเลิก ─── -->
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button type="button" class="accordion-button collapsed" data-bs-toggle="collapse"
                                        data-bs-target="#collapseRevokeReason" aria-expanded="false">
