                                @if (!isReadOnly)
                                {
                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                            onclick="document.querySelectorAll('.rmbs-check').forEach(c=>c.checked=true)">
                                        <i class="ri ri-checkbox-multiple-line me-1"></i>เลือกทั้งหมด
                                    </button>
                                }
