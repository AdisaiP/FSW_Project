                                                            <td>@totalOrig.ToString("N3")</td>
                                                            <td class="text-success">@totalRet.ToString("N3")</td>
                                                            <td class="@(totalRem > 0 ? "text-warning" : "text-muted")">@totalRem.ToString("N3")</td>
                                                            <td></td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
