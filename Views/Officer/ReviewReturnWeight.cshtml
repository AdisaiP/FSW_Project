    {
        new { OrigNo = "RMBS2-2569-OC-00881", NewNo = "RMBS2-2569-OC-00881-RET", Rmbs1OrigNo = "RMBS1-2569-OC-01105", Rmbs1NewNo = "RMBS1-2569-OC-01105-RET", Batch = "OCP-2569-B001", Weight = 1000.0m },
