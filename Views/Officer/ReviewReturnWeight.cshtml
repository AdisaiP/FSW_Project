                @* 2.8(15): Section ตรวจสอบมาตรการ *@
                @{
                    var tradeMeasurePass = true;      // มาตรการประเทศคู่ค้า
                    var fisheryCheckPass = true;      // เงื่อนไขด่านตรวจประมง
                    var exportIntentPass = true;      // ความประสงค์ส่งออก
                    var iuuMeasurePass = true;        // มาตรการสุขอนามัย (IUU)
                    var allMeasurePass = tradeMeasurePass && fisheryCheckPass && exportIntentPass && iuuMeasurePass;
                }
                <div class="card border @(allMeasurePass ? "border-success" : "border-danger") border-opacity-50 mb-3">
                    <div class="card-header d-flex align-items-center justify-content-between py-2 @(allMeasurePass ? "bg-success" : "bg-danger") bg-opacity-10">
                        <span class="fw-semibold @(allMeasurePass ? "text-success" : "text-danger")">
                            <i class="ri ri-shield-check-line me-1"></i>ตรวจสอบมาตรการ / เงื่อนไข
                        </span>
                        @if (allMeasurePass)
                        {
                            <span class="badge bg-success px-3"><i class="ri ri-checkbox-circle-line me-1"></i>ผ่านทุกเงื่อนไข ✅</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3"><i class="ri ri-close-circle-line me-1"></i>พบเงื่อนไขที่ไม่ผ่าน</span>
                        }
                    </div>
                    <div class="card-body pb-2">
                        <div class="row g-3">
                            @* มาตรการประเทศคู่ค้า *@
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3 p-3 rounded border @(tradeMeasurePass ? "border-success bg-success bg-opacity-10" : "border-danger bg-danger bg-opacity-10")">
                                    <i class="ri @(tradeMeasurePass ? "ri-earth-line text-success" : "ri-earth-line text-danger") fs-4 flex-shrink-0 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small mb-1">มาตรการประเทศคู่ค้า</div>
                                        @if (tradeMeasurePass)
                                        {
                                            <span class="badge bg-success">ผ่าน ✅</span>
                                            <div class="text-muted small mt-1">ไม่มีมาตรการห้ามนำเข้าจากประเทศคู่ค้า</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">ติดมาตรการ ❌</span>
                                            <div class="text-danger small mt-1">ประเทศปลายทางมีมาตรการพิเศษ — กรุณาตรวจสอบก่อนอนุมัติ</div>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* เงื่อนไขด่านตรวจประมง *@
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3 p-3 rounded border @(fisheryCheckPass ? "border-success bg-success bg-opacity-10" : "border-danger bg-danger bg-opacity-10")">
                                    <i class="ri @(fisheryCheckPass ? "ri-ship-line text-success" : "ri-ship-line text-danger") fs-4 flex-shrink-0 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small mb-1">เงื่อนไขด่านตรวจประมง</div>
                                        @if (fisheryCheckPass)
                                        {
                                            <span class="badge bg-success">ผ่าน ✅</span>
                                            <div class="text-muted small mt-1">ไม่ติดเงื่อนไขด่านตรวจประมง</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">ติดเงื่อนไข ❌</span>
                                            <div class="text-danger small mt-1">พบเงื่อนไขที่ด่านตรวจประมง — กรุณาติดต่อด่านที่เกี่ยวข้อง</div>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* ความประสงค์ส่งออก *@
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3 p-3 rounded border @(exportIntentPass ? "border-success bg-success bg-opacity-10" : "border-warning bg-warning bg-opacity-10")">
                                    <i class="ri @(exportIntentPass ? "ri-truck-line text-success" : "ri-truck-line text-warning") fs-4 flex-shrink-0 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small mb-1">ความประสงค์ส่งออก</div>
                                        @if (exportIntentPass)
                                        {
                                            <span class="badge bg-success">ผ่าน ✅</span>
                                            <div class="text-muted small mt-1">ความประสงค์ส่งออกสอดคล้องกับเงื่อนไขคำขอ</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">ไม่ตรงเงื่อนไข ❌</span>
                                            <div class="text-warning-emphasis small mt-1">ความประสงค์ส่งออกไม่ตรงกับเงื่อนไขที่กำหนด</div>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* มาตรการสุขอนามัย (IUU) *@
                            <div class="col-md-6">
                                <div class="d-flex align-items-start gap-3 p-3 rounded border @(iuuMeasurePass ? "border-success bg-success bg-opacity-10" : "border-danger bg-danger bg-opacity-10")">
                                    <i class="ri @(iuuMeasurePass ? "ri-health-book-line text-success" : "ri-health-book-line text-danger") fs-4 flex-shrink-0 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small mb-1">มาตรการสุขอนามัย (IUU)</div>
                                        @if (iuuMeasurePass)
                                        {
                                            <span class="badge bg-success">ผ่าน ✅</span>
                                            <div class="text-muted small mt-1">ไม่พบรายการ IUU / ไม่ติดมาตรการสุขอนามัย</div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">IUU ❌</span>
                                            <div class="text-danger small mt-1">พบรายการ IUU หรือติดมาตรการสุขอนามัย — กรุณาตรวจสอบ</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!allMeasurePass)
                        {
                            <div class="alert alert-danger d-flex align-items-center gap-2 mt-3 mb-0">
                                <i class="ri ri-error-warning-line fs-5 flex-shrink-0"></i>
                                <div>พบเงื่อนไขที่ไม่ผ่านการตรวจสอบ — กรุณาแก้ไขก่อนดำเนินการอนุมัติ</div>
                            </div>
                        }
                    </div>
                </div>
