    // mock: "destroy" | "export" | "domestic"
    var returnPurpose         = "export";
    var returnScope           = "ทั้งหมด";   // "ทั้งหมด" | "บางส่วน"
    var returnWeightAmount    = 1750.0m;

    // 2.8(6): RMBS2/RMBS1/P2/P1 ที่เกี่ยวข้อง (mock หลายใบรับรอง)
    var rmbs2Rows = new[]
    {
        new { CertNo = "ใบรับรอง 1", Rmbs2No = "RMBS2-2569-OC-00881", Rmbs1No = "RMBS1-2569-OC-01105",
              Batch = "OCP-2569-B001", WeightOrig = 1000.0m, WeightReturn = 1000.0m,
