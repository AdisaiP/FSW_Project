                                {
                                    <span class="badge bg-success">โหลดแล้ว ✅</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">ยังไม่ได้โหลด</span>
                                }
                            </div>
                            @if (!dataAutoLoaded)
                            {
                                <button type="button" class="btn btn-primary btn-sm"
                                        onclick="alert('TODO: โหลดข้อมูลตั้งต้นอัตโนมัติจากระบบ'); return false;">
                                    <i class="ri ri-refresh-line me-1"></i>โหลดข้อมูลตั้งต้นอัตโนมัติ
                                </button>
                            }
                        </div>
                        <div class="card-body py-3">
                            <div class="row g-3">
                                @* ผลการพิจารณาอนุมัติ *@
