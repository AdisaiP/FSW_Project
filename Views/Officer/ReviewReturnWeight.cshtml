                                var headingId  = $"headingRmbs{certIdx}";
                                <div class="accordion-item mb-2">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button type="button" class="accordion-button @(certIdx > 1 ? "collapsed" : "")"
                                                data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                                aria-expanded="@(certIdx == 1 ? "true" : "false")"
                                                aria-controls="@collapseId">
                                            <i class="icon-base ri ri-file-2-line me-2"></i>
                                            @cert
                                            <span class="ms-2 badge @(allFull ? "bg-label-success" : "bg-label-warning")">
                                                @(allFull ? "คืนทั้งหมด" : "คืนบางส่วน")
                                            </span>
                                            <span class="ms-2 badge bg-label-secondary small">@certRows.Length รุ่น</span>
                                        </button>
                                    </h2>
                                    <div id="@collapseId" class="accordion-collapse collapse @(certIdx == 1 ? "show" : "")"
                                         aria-labelledby="@headingId" data-bs-parent="#accordionRmbs">
