@{
    ViewData["Title"] = "พิจารณาคืนนํ้าหนักสินค้าส่งคืน";

    var returnWeightStatus = "อยู่ระหว่างดำเนินการ"; // mock: อยู่ระหว่างดำเนินการ | อนุมัติให้คืนน้ำหนัก | อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข | ไม่อนุมัติให้คืนน้ำหนัก | ยกเลิก
    var isReadOnly = returnWeightStatus != "อยู่ระหว่างดำเนินการ";

    // 2.8(1): แหล่งข้อมูลตั้งต้น (เชื่อมโยงจากระบบอื่น)
    var sourceImportPermitNo  = "23501100116100110";               // ใบอนุญาตนำเข้า
    var sourceApprovalRefNo   = "อนุมัติ-RW-2569-00099";           // ผลการพิจารณาอนุมัติ (pre-fill)
    var sourceApprovalDate    = "19/04/2569";
    var hasImd                = true;                               // พบเอกสาร IMD หรือไม่
    var imdRefNo              = "IMD-2569-LC-04821";               // เลขที่เอกสาร IMD
