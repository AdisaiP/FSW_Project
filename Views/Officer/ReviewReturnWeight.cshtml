                        </div>

                        <div class="accordion accordion-custom-button" id="accordionRmbs">
                            @{ var certIdx = 0; }
                            @foreach (var cert in certGroups)
                            {
                                certIdx++;
                                var certRows  = rmbs2Rows.Where(r => r.CertNo == cert).ToArray();
                                var totalOrig = certRows.Sum(r => r.WeightOrig);
                                var totalRet  = certRows.Sum(r => r.WeightReturn);
                                var totalRem  = certRows.Sum(r => r.WeightRemain);
                                var allFull   = certRows.All(r => r.ReturnMode == "ทั้งหมด");
