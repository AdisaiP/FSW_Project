        document.addEventListener('DOMContentLoaded', function () {

            // Flatpickr
            document.querySelectorAll('.flatpickr-date').forEach(function (el) {
                if (el && !el._flatpickr) {
                    flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
                }
            });

            // Tooltips
            if (window.bootstrap && bootstrap.Tooltip) {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                    new bootstrap.Tooltip(el);
                });
            }

            // 2.8(5): toggle วัตถุประสงค์ section
            window.onReturnPurposeChange = function (value) {
                var secDestroy = document.getElementById('sectionDestroy');
                var secReturn  = document.getElementById('sectionReturnWeight');
                var btnExport  = document.getElementById('btnSectionExport');
                var btnDomestic = document.getElementById('btnSectionDomestic');
                if (!secDestroy || !secReturn) return;
                secDestroy.classList.toggle('d-none', value !== 'destroy');
                secReturn.classList.toggle('d-none', value === 'destroy');
                if (btnExport)  btnExport.classList.toggle('d-none', value !== 'export');
                if (btnDomestic) btnDomestic.classList.toggle('d-none', value !== 'domestic');
            };

            // 2.8(3): toggle เสนอลงนาม section
            var btnToggleSign = document.getElementById('btnToggleSign');
            if (btnToggleSign) {
                btnToggleSign.addEventListener('click', function () {
                    var sec = document.getElementById('sectionSubmitSign');
                    if (sec) { sec.classList.toggle('d-none'); }
                });
            }

            // 2.8(3): ยืนยันเสนอลงนาม
            var btnConfirmSign = document.getElementById('btnConfirmSign');
            if (btnConfirmSign) {
                btnConfirmSign.addEventListener('click', function () {
                    var signer = document.getElementById('selectSigner');
                    if (!signer || !signer.value) {
                        alert('กรุณาเลือกผู้ลงนามก่อนดำเนินการ');
                        signer && signer.focus();
                        return;
                    }
                    if (confirm('ยืนยันการเสนอให้ "' + signer.options[signer.selectedIndex].text + '" ลงนาม?')) {
                        alert('TODO: เสนอลงนามเรียบร้อย');
                    }
                });
            }

            // 2.8(3): Modal อนุมัติ
            var btnConfirmApprove = document.getElementById('btnConfirmApprove');
            if (btnConfirmApprove) {
                btnConfirmApprove.addEventListener('click', function () {
                    if (confirm('ยืนยันการอนุมัติให้คืนน้ำหนักสินค้าส่งคืนคำขอนี้?')) {
                        alert('TODO: บันทึกผลการอนุมัติให้คืนน้ำหนักเรียบร้อย');
                        bootstrap.Modal.getInstance(document.getElementById('modalApprove')).hide();
                    }
                });
            }

            // 2.8(3): Modal อนุมัติแบบมีเงื่อนไข
            var btnConfirmApproveCondition = document.getElementById('btnConfirmApproveCondition');
            if (btnConfirmApproveCondition) {
                btnConfirmApproveCondition.addEventListener('click', function () {
                    var condition = document.getElementById('approveConditionText');
                    if (!condition || condition.value.trim() === '') {
                        alert('กรุณาระบุเงื่อนไขประกอบการอนุมัติแบบมีเงื่อนไข');
                        condition && condition.focus();
                        return;
                    }
                    if (confirm('ยืนยันการอนุมัติแบบมีเงื่อนไขสำหรับคำขอนี้?')) {
                        alert('TODO: บันทึกผลการอนุมัติแบบมีเงื่อนไขเรียบร้อย');
                        bootstrap.Modal.getInstance(document.getElementById('modalApproveCondition')).hide();
                    }
                });
            }

            // 2.8(3): Modal ไม่อนุมัติ
            var btnConfirmReject = document.getElementById('btnConfirmReject');
            if (btnConfirmReject) {
                btnConfirmReject.addEventListener('click', function () {
                    var reason = document.getElementById('rejectReason');
                    if (!reason || reason.value.trim() === '') {
                        alert('กรุณาระบุเหตุผลการปฏิเสธก่อนดำเนินการ');
                        reason && reason.focus();
                        return;
                    }
                    if (confirm('ยืนยันการไม่อนุมัติให้คืนน้ำหนักสำหรับคำขอนี้?')) {
                        alert('TODO: บันทึกผลการไม่อนุมัติเรียบร้อย');
                        bootstrap.Modal.getInstance(document.getElementById('modalReject')).hide();
                    }
                });
            }

            // 2.8(3): Modal แจ้งแก้ไขข้อมูล
            var btnConfirmRequestEdit = document.getElementById('btnConfirmRequestEdit');
            if (btnConfirmRequestEdit) {
                btnConfirmRequestEdit.addEventListener('click', function () {
                    var detail = document.getElementById('editRequestDetail');
                    if (!detail || detail.value.trim() === '') {
                        alert('กรุณาระบุรายละเอียดที่ต้องการให้แก้ไขก่อนดำเนินการ');
                        detail && detail.focus();
                        return;
                    }
                    if (confirm('ยืนยันการแจ้งให้ผู้ประกอบการแก้ไขข้อมูล?')) {
                        alert('TODO: แจ้งแก้ไขข้อมูลเรียบร้อย');
                        bootstrap.Modal.getInstance(document.getElementById('modalRequestEdit')).hide();
                    }
                });
            }

            // 2.8(14): ส่งข้อมูลเศษเหลือไประบบปลาป่น
            window.submitScrapData = function () {
                var wt = document.getElementById('scrapWeightInput');
                var tp = document.getElementById('scrapTypeSelect');
                if (!wt || !wt.value || parseFloat(wt.value) <= 0) {
                    alert('กรุณาระบุน้ำหนักเศษเหลือให้ถูกต้อง (มากกว่า 0)');
                    wt && wt.focus();
                    return;
                }
                if (!tp || !tp.value) {
                    alert('กรุณาเลือกประเภทเศษเหลือ');
                    tp && tp.focus();
                    return;
                }
                var typeName = tp.options[tp.selectedIndex].text;
                if (confirm('ยืนยันการส่งข้อมูลเศษเหลือ "' + typeName + '" น้ำหนัก ' + parseFloat(wt.value).toFixed(3) + ' กก. ไประบบออกหนังสือรับรองปลาป่น?')) {
                    alert('TODO: ส่งข้อมูลเศษเหลือเรียบร้อย — ระบบออกหนังสือรับรองปลาป่นรับข้อมูลแล้ว');
                }
            };

        });
    </script>
}
