                                        <label class="form-label text-muted small mb-1">ผู้พิจารณา</label>
                                        <div class="fw-semibold">@resultOfficer</div>
                                        <div class="text-muted small">@resultOfficerDept</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted small mb-1">น้ำหนักที่คืนจริง (กก.)</label>
                                        @if (resultWeight > 0)
                                        {
                                            <div class="fw-semibold text-success fs-5">@resultWeight.ToString("N3") <span class="fs-6 text-muted fw-normal">กก.</span></div>
                                        }
                                        else
                                        {
                                            <div class="text-muted">— ไม่มีการคืนน้ำหนัก</div>
                                        }
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label text-muted small mb-1">หมายเหตุ / เหตุผลประกอบ</label>
                                        <div class="alert alert-light mb-0 py-2">@resultRemark</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* รายการที่อนุมัติแล้ว *@
                        @if (returnWeightStatus == "อนุมัติให้คืนน้ำหนัก" || returnWeightStatus == "อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข")
                        {
                            <h6 class="fw-semibold mb-3"><i class="ri ri-list-check-2 me-1 text-success"></i>รายการที่อนุมัติให้คืนน้ำหนัก</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle small mb-0">
                                    <thead class="table-light text-center">
                                        <tr>
                                            <th>#</th>
                                            <th>สินค้าประมง</th>
                                            <th>น้ำหนักที่คืน (กก.)</th>
                                            <th>RMBS2/P2</th>
                                            <th>สถานะ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="text-center text-muted">1</td>
                                            <td>ปลาทูน่าตาโต ทั้งตัว แช่แข็ง<br /><span class="text-muted small">0303.44.00 000/KGM</span></td>
                                            <td class="text-end fw-semibold text-success">@(returnWeightStatus == "อนุมัติให้คืนน้ำหนัก" ? "1,000.000" : "800.000")</td>
                                            <td class="font-monospace small text-nowrap">RMBS2-2569-OC-00881-RET</td>
                                            <td class="text-center"><span class="badge bg-success">คืนแล้ว ✅</span></td>
                                        </tr>
                                        @if (returnWeightStatus == "อนุมัติให้คืนน้ำหนัก")
                                        {
                                            <tr>
                                                <td class="text-center text-muted">2</td>
                                                <td>ปลาแซลมอน ทั้งตัว แช่แข็ง<br /><span class="text-muted small">0303.89.90 000/KGM</span></td>
                                                <td class="text-end fw-semibold text-success">750.000</td>
                                                <td class="font-monospace small text-nowrap">RMBS2-2569-OC-00882-RET</td>
                                                <td class="text-center"><span class="badge bg-success">คืนแล้ว ✅</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light fw-semibold text-end small">
                                        <tr>
                                            <td colspan="2" class="text-end">รวมน้ำหนักที่คืนจริง</td>
                                            <td class="text-success">@resultWeight.ToString("N3") กก.</td>
                                            <td colspan="2"></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                    }

                    @* 2.8(16): เชื่อมโยงผลการพิจารณาไปยังด่านตรวจประมง *@
                    @{
                        var sentToFisheryCheck = returnWeightStatus == "อนุมัติให้คืนน้ำหนัก" || returnWeightStatus == "อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข";
                        var fisheryCheckSentDate = "21/04/2569 (14:35)";
                        var fisheryCheckStationName = "ด่านตรวจประมงท่าเรือแหลมฉบัง";
                        var fisheryCheckRefNo = "FC-LINK-2569-00219";
                    }
                    @if (hasResult)
                    {
                        <div class="card border @(sentToFisheryCheck ? "border-success" : "border-secondary") border-opacity-50 mt-4">
                            <div class="card-header d-flex align-items-center justify-content-between py-2 @(sentToFisheryCheck ? "bg-success" : "bg-secondary") bg-opacity-10">
                                <span class="fw-semibold @(sentToFisheryCheck ? "text-success" : "text-muted")">
                                    <i class="ri ri-radar-line me-1"></i>การเชื่อมโยงผลการพิจารณาไปยังด่านตรวจประมง
                                </span>
                                @if (sentToFisheryCheck)
                                {
                                    <span class="badge bg-success px-3">
                                        <i class="ri ri-checkbox-circle-line me-1"></i>ส่งผลการพิจารณาไปยังด่านตรวจประมงแล้ว ✅
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary px-3">ไม่ส่งข้อมูล (ไม่อนุมัติ)</span>
                                }
                            </div>
                            <div class="card-body">
                                @if (sentToFisheryCheck)
                                {
                                    <div class="row g-3 mb-3">
                                        <div class="col-md-4">
                                            <div class="text-muted small mb-1">ด่านตรวจประมงปลายทาง</div>
                                            <div class="fw-semibold">@fisheryCheckStationName</div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-muted small mb-1">เลขที่อ้างอิงการส่งข้อมูล</div>
                                            <div class="fw-semibold font-monospace">@fisheryCheckRefNo</div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-muted small mb-1">วันที่/เวลาที่ส่ง</div>
                                            <div class="fw-semibold">@fisheryCheckSentDate</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                        <div class="alert alert-success d-flex align-items-center gap-2 mb-0 py-2 flex-grow-1">
                                            <i class="ri ri-checkbox-circle-line flex-shrink-0"></i>
                                            <span class="small">ส่งผลการพิจารณาคืนน้ำหนัก <strong>@returnWeightAmount.ToString("N3") กก.</strong> ไปยัง <strong>@fisheryCheckStationName</strong> เรียบร้อยแล้ว — ด่านตรวจรับข้อมูลแล้ว</span>
                                        </div>
                                        <a href="#" class="btn btn-sm btn-outline-success text-nowrap"
                                           onclick="alert('TODO: เปิดหน้าสถานะด่านตรวจประมง @fisheryCheckStationName'); return false;">
                                            <i class="ri ri-external-link-line me-1"></i>ดูสถานะด่านตรวจประมง →
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-secondary d-flex align-items-center gap-2 mb-0">
                                        <i class="ri ri-information-line fs-5 flex-shrink-0"></i>
                                        <div class="small">ไม่ส่งข้อมูลไปยังด่านตรวจประมง เนื่องจากผลการพิจารณาเป็น <strong>@returnWeightStatus</strong></div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @* /2.8(16) *@
                </div>
                @* /TAB 5 *@

            </div><!-- /tab-content -->
        </div><!-- /nav-align-top -->

        <!-- Action Buttons / Action Bar -->
        @* 2.8(3): Action bar เต็ม (เมื่อสถานะ อยู่ระหว่างดำเนินการ) *@
        @if (!isReadOnly)
        {
            <div class="card border border-warning border-opacity-50 mt-4">
                <div class="card-header bg-warning bg-opacity-10 py-2">
                    <span class="fw-semibold text-warning-emphasis"><i class="ri ri-tools-line me-1"></i>การดำเนินการ (เจ้าหน้าที่)</span>
                </div>
                <div class="card-body d-flex flex-wrap gap-2 align-items-center">
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalApprove">
                        <i class="ri ri-checkbox-circle-line me-1"></i>อนุมัติให้คืนน้ำหนัก
                    </button>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalApproveCondition">
                        <i class="ri ri-check-double-line me-1"></i>อนุมัติแบบมีเงื่อนไข
                    </button>
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalReject">
                        <i class="ri ri-close-circle-line me-1"></i>ไม่อนุมัติ
                    </button>
                    <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#modalRequestEdit">
                        <i class="ri ri-edit-2-line me-1"></i>แจ้งแก้ไขข้อมูล
                    </button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-outline-secondary" id="btnToggleSign">
                        <i class="ri ri-pen-nib-line me-1"></i>เสนอลงนาม
                    </button>
                </div>
            </div>

            @* 2.8(3): section เสนอลงนาม *@
            <div id="sectionSubmitSign" class="card border border-secondary border-opacity-50 mt-3 d-none">
                <div class="card-header py-2 bg-secondary bg-opacity-10">
                    <span class="fw-semibold"><i class="ri ri-pen-nib-line me-1"></i>เสนอลงนาม</span>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label">ผู้ลงนาม <span class="text-danger">*</span></label>
                            <select class="form-select" id="selectSigner">
                                <option value="">-- เลือกผู้ลงนาม --</option>
                                <option value="1">นายสมชาย มีสุข (ผู้อำนวยการกอง)</option>
                                <option value="2">นางสาวสุดา รักดี (รองผู้อำนวยการ)</option>
                                <option value="3">นายวิชัย ใจดี (ผู้เชี่ยวชาญ)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">หมายเหตุ</label>
                            <input type="text" class="form-control" id="signRemark" placeholder="ระบุหมายเหตุ (ถ้ามี)" />
                        </div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-secondary w-100" id="btnConfirmSign">
                                <i class="ri ri-send-plane-line me-1"></i>เสนอให้ลงนาม
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end gap-2 mt-3">
            @* 2.8(13): ปุ่มพิมพ์ฟอร์มคืนน้ำหนัก (PDF) เฉพาะสถานะอนุมัติ *@
            @if (returnWeightStatus == "อนุมัติให้คืนน้ำหนัก" || returnWeightStatus == "อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข")
            {
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalPrintReturnWeight">
                    <i class="ri ri-file-pdf-line me-1"></i>พิมพ์ฟอร์มคืนน้ำหนัก (PDF)
                </button>
            }
            <a href="@Url.Action("IndexReturnWeight", "Officer")" class="btn btn-outline-secondary">
                <i class="ri ri-arrow-left-line me-1"></i> กลับรายการ
            </a>
        </div>

    </div><!-- /col -->
</div><!-- /row -->

@* 2.8(3): Modals *@
<!-- Modal: อนุมัติให้คืนน้ำหนัก -->
<div class="modal fade" id="modalApprove" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success bg-opacity-10">
                <h5 class="modal-title"><i class="ri ri-checkbox-circle-line text-success me-2"></i>อนุมัติให้คืนน้ำหนัก</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">หมายเหตุ / เงื่อนไขการอนุมัติ</label>
                    <textarea class="form-control" id="approveRemark" rows="3" placeholder="ระบุหมายเหตุ (ถ้ามี)"></textarea>
                </div>
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0">
                    <i class="ri ri-information-line"></i>
                    <span class="small">เมื่อยืนยัน ระบบจะอนุมัติและดำเนินการคืนน้ำหนัก/โควตาอัตโนมัติ</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-success" id="btnConfirmApprove">
                    <i class="ri ri-checkbox-circle-line me-1"></i>ยืนยันอนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: อนุมัติแบบมีเงื่อนไข -->
<div class="modal fade" id="modalApproveCondition" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary bg-opacity-10">
                <h5 class="modal-title"><i class="ri ri-check-double-line text-primary me-2"></i>อนุมัติแบบมีเงื่อนไข</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">เงื่อนไขประกอบการอนุมัติ <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="approveConditionText" rows="3" placeholder="ระบุเงื่อนไขที่ผู้ประกอบการต้องปฏิบัติ"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">หมายเหตุ</label>
                    <textarea class="form-control" id="approveConditionRemark" rows="2" placeholder="ระบุหมายเหตุ (ถ้ามี)"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-primary" id="btnConfirmApproveCondition">
                    <i class="ri ri-check-double-line me-1"></i>ยืนยันอนุมัติแบบมีเงื่อนไข
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: ไม่อนุมัติ -->
<div class="modal fade" id="modalReject" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger bg-opacity-10">
                <h5 class="modal-title"><i class="ri ri-close-circle-line text-danger me-2"></i>ไม่อนุมัติให้คืนน้ำหนัก</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">เหตุผลการปฏิเสธ <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="rejectReason" rows="3" placeholder="ระบุเหตุผลที่ไม่อนุมัติ"></textarea>
                </div>
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-0">
                    <i class="ri ri-alert-line"></i>
                    <span class="small">การไม่อนุมัติจะแจ้งกลับไปยังผู้ประกอบการ</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-danger" id="btnConfirmReject">
                    <i class="ri ri-close-circle-line me-1"></i>ยืนยันไม่อนุมัติ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: แจ้งแก้ไขข้อมูล -->
<div class="modal fade" id="modalRequestEdit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning bg-opacity-10">
                <h5 class="modal-title"><i class="ri ri-edit-2-line text-warning me-2"></i>แจ้งแก้ไขข้อมูล</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">รายละเอียดที่ต้องแก้ไข <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="editRequestDetail" rows="4" placeholder="ระบุรายละเอียดข้อมูลที่ต้องการให้ผู้ประกอบการแก้ไข"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">แนบหลักฐานประกอบ (ถ้ามี)</label>
                    <input type="file" class="form-control" id="editRequestFile" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                    <div class="form-text">รองรับไฟล์ PDF, JPG, PNG, DOC, DOCX</div>
                </div>
                <div class="mb-0">
                    <label class="form-label">หมายเหตุ</label>
                    <textarea class="form-control" id="editRequestRemark" rows="2" placeholder="ระบุหมายเหตุเพิ่มเติม (ถ้ามี)"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-warning" id="btnConfirmRequestEdit">
                    <i class="ri ri-send-plane-line me-1"></i>แจ้งให้แก้ไข
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: คัดลอก RMBS2/P2 → ตั้งต้นสินค้าส่งคืน -->
<div class="modal fade" id="modalCopyRmbs" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary bg-opacity-10">
                <h5 class="modal-title"><i class="ri ri-file-copy-line text-primary me-2"></i>สำเนาฐานข้อมูล RMBS2/P2 → ตั้งต้นสินค้าส่งคืน</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info mb-3">
                    <i class="ri ri-shield-check-line me-2"></i>
                    ระบบจะ<strong>สำเนา</strong>ฐานข้อมูลต่อไปนี้เป็น <strong>RMBS2/RMBS1/P2/P1 สินค้าส่งคืน</strong><br />
                    โดยไม่กระทบข้อมูลต้นฉบับ และจะสร้างรายการใหม่แบบอิสระ
                </div>
                <div class="table-responsive mb-3">
                    <table class="table table-bordered align-middle small mb-0">
                        <thead class="table-light text-center">
                            <tr>
                                <th>#</th>
                                <th>RMBS2/P2 ต้นฉบับ</th>
                                <th>RMBS1/P1 ต้นฉบับ</th>
                                <th>รุ่นการผลิต</th>
                                <th>น้ำหนัก (กก.)</th>
                                <th>จะสร้างเป็น</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var modalIdx = 0; }
                            @foreach (var row in rmbs2Rows)
                            {
                                modalIdx++;
                                <tr>
                                    <td class="text-center text-muted">@modalIdx</td>
                                    <td class="font-monospace small text-nowrap">@row.Rmbs2No</td>
                                    <td class="font-monospace small text-muted text-nowrap">@row.Rmbs1No</td>
                                    <td class="text-nowrap">@row.Batch</td>
                                    <td class="text-end">@row.WeightReturn.ToString("N3")</td>
                                    <td><span class="badge bg-label-primary">RMBS2 สินค้าส่งคืน</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mb-0">
                    <label class="form-label">หมายเหตุ (ถ้ามี)</label>
                    <input type="text" class="form-control" id="copyRmbsRemark" placeholder="ระบุหมายเหตุเพิ่มเติม" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
