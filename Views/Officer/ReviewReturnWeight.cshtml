                                                <table class="table table-bordered align-middle mb-0 small">
                                                    <thead class="table-light text-center">
                                                        <tr>
                                                            @if (!isReadOnly)
                                                            {
                                                                <th style="width:2.5rem;"><input type="checkbox" class="form-check-input"
                                                                    onchange="this.closest('table').querySelectorAll('.rmbs-check').forEach(c=>c.checked=this.checked)" /></th>
                                                            }
                                                            <th>RMBS2/P2 เลขที่</th>
                                                            <th>RMBS1/P1 เลขที่</th>
                                                            <th>รุ่นการผลิต</th>
                                                            <th>น้ำหนักเดิม (กก.)</th>
                                                            <th>น้ำหนักที่คืน (กก.)</th>
                                                            <th>คงเหลือ (กก.)</th>
                                                            <th>ประเภทการคืน</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var row in certRows)
                                                        {
                                                            <tr>
                                                                @if (!isReadOnly)
                                                                {
                                                                    <td class="text-center">
                                                                        <input type="checkbox" class="form-check-input rmbs-check" checked />
                                                                    </td>
                                                                }
                                                                <td class="font-monospace fw-semibold small text-nowrap">@row.Rmbs2No</td>
                                                                <td class="font-monospace small text-nowrap text-muted">@row.Rmbs1No</td>
                                                                <td class="text-nowrap">@row.Batch</td>
                                                                <td class="text-end">@row.WeightOrig.ToString("N3")</td>
                                                                <td class="text-end text-success fw-semibold">@row.WeightReturn.ToString("N3")</td>
                                                                <td class="text-end @(row.WeightRemain > 0 ? "text-warning" : "text-muted")">@row.WeightRemain.ToString("N3")</td>
                                                                <td class="text-center">
                                                                    <span class="badge @(row.ReturnMode == "ทั้งหมด" ? "bg-label-success" : "bg-label-warning")">
                                                                        @row.ReturnMode
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        }
