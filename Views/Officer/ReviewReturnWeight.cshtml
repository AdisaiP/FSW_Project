        new { CertNo = "ใบรับรอง 2", Rmbs2No = "RMBS2-2569-OC-00895", Rmbs1No = "RMBS1-2569-OC-01120",
              Batch = "OCP-2569-B003", WeightOrig = 500.0m, WeightReturn = 250.0m,
              WeightRemain = 250.0m, ReturnMode = "บางส่วน" },
    };
    var certGroups = rmbs2Rows.Select(r => r.CertNo).Distinct().ToArray();

    // 2.8(8): mock สถานะการสำเนา RMBS2/P2 → ตั้งต้นสินค้าส่งคืน
    var copyDone = returnWeightStatus == "อนุมัติให้คืนน้ำหนัก"
               || returnWeightStatus == "อนุมัติให้คืนน้ำหนักแบบมีเงื่อนไข";
