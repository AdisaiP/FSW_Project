                                    <div class="d-flex align-items-start gap-2">
                                        <i class="ri ri-checkbox-circle-fill text-success mt-1 flex-shrink-0"></i>
                                        <div>
                                            <div class="small text-muted">ผลการพิจารณาอนุมัติ</div>
                                            <span class="badge bg-label-success me-1">ดึงข้อมูลแล้ว ✅</span>
                                            <div class="small fw-semibold font-monospace">@sourceApprovalRefNo</div>
                                            <div class="small text-muted">วันที่อนุมัติ: @sourceApprovalDate</div>
                                        </div>
                                    </div>
                                </div>
                                @* ใบอนุญาตนำเข้า *@
