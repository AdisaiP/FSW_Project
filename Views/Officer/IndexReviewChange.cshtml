                        <td>
                            <span class="fw-semibold text-primary d-block mb-1">@request.RequestNumber</span>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @request.StatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.RequestedByClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.RequestedByIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>ขอโดย: @request.RequestedByText</span>
                                </div>
                                <div class="small text-muted text-truncate" style="max-width:220px;" title="@request.EstablishmentName">
                                    <i class="ri ri-building-line me-1"></i>@request.EstablishmentName
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge @request.CertTypeBadge fs-6 px-2 py-1">@request.CertTypeCode</span>
                        </td>
                        <td class="small">@request.CertificateName</td>
                        <td class="small">@request.Subject</td>
                        <td class="text-center small text-nowrap">
                            @request.TransactionAt.ToString("dd/MM/yyyy")<br />
                            <span class="text-muted">(@request.TransactionAt.ToString("HH:mm:ss"))</span>
                        </td>
                        <td class="text-center small text-nowrap">
                            @if (!string.IsNullOrEmpty(request.ReceivedNo))
                            {
                                <span class="fw-semibold">@request.ReceivedNo</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (request.StatusText == "รออนุมัติ")
                                {
                                    <a href="@Url.Action("ReviewUpdateCertificate", "Officer")" class="btn btn-sm btn-icon btn-outline-primary" data-bs-toggle="tooltip" title="พิจารณา">
                                        <i class="ri ri-shield-check-line"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-edit-request" data-bs-toggle="tooltip" title="แก้ไข" data-request-no="@request.RequestNumber">
                                        <i class="ri ri-edit-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-delete-request" data-bs-toggle="tooltip" title="ลบคำขอ" data-request-no="@request.RequestNumber">
                                        <i class="ri ri-delete-bin-line"></i>
                                    </button>
                                }
                                @if (request.StatusText == "อนุมัติ" || request.StatusText == "ไม่อนุมัติ")
                                {
                                    <a href="@Url.Action("ReviewUpdateCertificate", "Officer")" class="btn btn-sm btn-icon btn-outline-secondary" data-bs-toggle="tooltip" title="ดูรายละเอียด">
                                        <i class="ri ri-eye-line"></i>
                                    </a>
                                }
                                @if (request.StatusText == "ยกเลิก")
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="7" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>