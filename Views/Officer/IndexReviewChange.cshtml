@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (toInput) {
            flatpickr(toInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            // รองรับปี พ.ศ. (ปี > 2500)
            if (year > 2500) {
                year -= 543;
            }
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function contains(haystack, needle) {
            if (!needle) return true;
            return haystack.toLowerCase().indexOf(needle.toLowerCase()) !== -1;
        }

        function filterRows() {
            var certType       = (document.getElementById('filterCertType').value || '').trim();
            var status         = (document.getElementById('filterStatus').value || '').trim();
            var fromDate       = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate         = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            var excludeRange   = document.getElementById('filterDateExclude').checked;
            // ค้นหาขั้นสูง
            var filterReqNo    = (document.getElementById('filterRequestNo').value || '').trim();
            var filterRecvNo   = (document.getElementById('filterReceivedNo').value || '').trim();
            var filterEstab    = (document.getElementById('filterEstablishment').value || '').trim();
            var filterRegNo    = (document.getElementById('filterRegNo').value || '').trim();
            var filterProduct  = (document.getElementById('filterProduct').value || '').trim();
            var filterCountry  = (document.getElementById('filterCountry').value || '').trim();

            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowCertType    = row.dataset.certtype || '';
                var rowStatus      = row.dataset.status || '';
                var rowDraftDate   = new Date(row.dataset.draftDate || '');
                var rowRequestNo   = row.dataset.requestNo || '';
                var rowReceivedNo  = row.dataset.receivedNo || '';
                var rowEstab       = row.dataset.establishment || '';
                var rowRegNo       = row.dataset.regNo || '';
                var rowProduct     = row.dataset.product || '';
                var rowCountry     = row.dataset.country || '';

                var certTypeMatch = !certType || rowCertType === certType;
                var statusMatch   = !status || rowStatus === status;
                var dateMatch;
                if (!fromDate && !toDate) {
                    dateMatch = true;
                } else if (excludeRange) {
                    var inRange = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                    dateMatch = !inRange;
                } else {
                    dateMatch = (!fromDate || rowDraftDate >= fromDate) && (!toDate || rowDraftDate <= toDate);
                }
                var advMatch = contains(rowRequestNo, filterReqNo)
                    && contains(rowReceivedNo, filterRecvNo)
                    && contains(rowEstab, filterEstab)
                    && contains(rowRegNo, filterRegNo)
                    && contains(rowProduct, filterProduct)
                    && contains(rowCountry, filterCountry);

                var isVisible = certTypeMatch && statusMatch && dateMatch && advMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

        // ปุ่มสร้างคำขอเปลี่ยนแปลง (เจ้าหน้าที่)
        document.getElementById('btnCreateRequest').addEventListener('click', function () {
            // TODO: นำทางไปหน้าสร้างคำขอเปลี่ยนแปลง หรือเปิด modal
            alert('สร้างคำขอเปลี่ยนแปลงใบรับรอง (เจ้าหน้าที่) — TODO: เปิดฟอร์มสร้างคำขอ');
        });

        // ปุ่มแก้ไขคำขอ (เฉพาะสถานะ รออนุมัติ)
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-edit-request');
            if (btn) {
                var reqNo = btn.dataset.requestNo || '';
                // TODO: นำทางไปหน้าแก้ไขคำขอ หรือเปิด modal
                alert('แก้ไขคำขอ: ' + reqNo + '\n— TODO: เปิดฟอร์มแก้ไข');
            }
        });

        // ปุ่มลบคำขอ (เฉพาะสถานะ รออนุมัติ)
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-delete-request');
            if (btn) {
                var reqNo = btn.dataset.requestNo || '';
                if (confirm('ยืนยันการลบคำขอ: ' + reqNo + '\nการดำเนินการนี้ไม่สามารถย้อนกลับได้')) {
                    // TODO: เรียก API ลบคำขอ
                    alert('ลบคำขอสำเร็จ (mockup): ' + reqNo);
                }
            }
        });

        // Event listeners หลัก
        document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
        document.getElementById('filterCertType').addEventListener('change', filterRows);
        document.getElementById('filterStatus').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateFrom').addEventListener('change', filterRows);
        document.getElementById('filterDraftDateTo').addEventListener('change', filterRows);
        document.getElementById('filterDateExclude').addEventListener('change', filterRows);

        // Event listeners ค้นหาขั้นสูง — กด Enter ทุกช่อง
        ['filterCertType','filterStatus','filterDraftDateFrom','filterDraftDateTo',
         'filterRequestNo','filterReceivedNo','filterEstablishment','filterRegNo','filterProduct','filterCountry'
        ].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        filterRows();
                    }
                });
            }
        });

        document.getElementById('btnResetRequests').addEventListener('click', function () {
            document.getElementById('filterCertType').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterDraftDateFrom').value = '';
            document.getElementById('filterDraftDateTo').value = '';
            document.getElementById('filterDateExclude').checked = false;
            document.getElementById('filterRequestNo').value = '';
            document.getElementById('filterReceivedNo').value = '';
            document.getElementById('filterEstablishment').value = '';
            document.getElementById('filterRegNo').value = '';
            document.getElementById('filterProduct').value = '';
            document.getElementById('filterCountry').value = '';
            filterRows();
        });
    });
</script>
}

