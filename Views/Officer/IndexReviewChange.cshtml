            RegistrationNo = "ปผ-2569-0021",
            ProductName = "กุ้งมังกรสด (Live Lobster)",
            CountryName = "จีน",
            ReceivedNo = "RCV-6904-DT2"
        }
    };

    var totalRequestCount = requests.Length;
    var psCount    = requests.Count(r => r.CertTypeCode == "PS");
    var pstCount   = requests.Count(r => r.CertTypeCode == "PST");
    var nmdCount   = requests.Count(r => r.CertTypeCode == "NMD");
    var nmdtCount  = requests.Count(r => r.CertTypeCode == "NMDT");
    var pendingCount   = requests.Count(r => r.StatusText == "รออนุมัติ");
    var approvedCount  = requests.Count(r => r.StatusText == "อนุมัติ");
    var rejectedCount  = requests.Count(r => r.StatusText == "ไม่อนุมัติ");
    var cancelledCount = requests.Count(r => r.StatusText == "ยกเลิก");
}

