@{
    ViewData["Title"] = "พิจารณาคำขอเปลี่ยนแปลงใบรับรองฯ";

    var requestNumber = "10611180131800118";
    var reviewStatus = "รออนุมัติ"; // mock: รออนุมัติ | อนุมัติ | ไม่อนุมัติ | ยกเลิก
    var isReadOnly = reviewStatus != "รออนุมัติ";

    // 2.5(1): สถานะการเชื่อมโยงกับระบบภายนอก
    // mock: "not_linked" | "linked_external" | "declared_to_customer"
    var linkStatus = "not_linked";
    var isLocked = linkStatus != "not_linked";

    // 2.5(4): ลงทะเบียนรับคำขอ
    // mock: "" = ยังไม่ลงทะเบียน | ค่าใดๆ = ลงทะเบียนแล้ว
    var receivedNo = ""; // TODO: จะออกเลขอัตโนมัติเมื่อลงทะเบียน
    var isRegistered = !string.IsNullOrEmpty(receivedNo);

    // 2.5(6): ประเภทการแก้ไข & เงื่อนไขตรวจปล่อย
    // mock: true = แก้ไขน้ำหนักส่งออก | false = แก้ไขรายละเอียดอื่น
    var isWeightChange = true;
    // mock: true = ผู้ประกอบการยกเลิกตรวจปล่อยแล้ว | false = ยังไม่ยกเลิก
    var inspectionCancelled = false;
    // mock: เชื่อมโยงด่านตรวจปล่อยอัตโนมัติหลังอนุมัติ
    var isLinkedToStation = reviewStatus == "อนุมัติ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@* ************** Content ************** *@
<h4 class="mb-1">พิจารณาคำขอเปลี่ยนแปลงใบรับรองฯ</h4>
<p class="mb-1">ตรวจสอบและพิจารณาคำขอเปลี่ยนแปลงใบรับรองการแปรรูปสัตว์นํ้า (PS) และใบรับรองไม่แปรรูปสัตว์นํ้า (Declaration)</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a>
        </li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexReviewChange", "Officer")" class="text-primary fw-semibold">พิจารณาเปลี่ยนแปลงใบรับรอง</a>
        </li>
        <li class="breadcrumb-item active text-secondary">@requestNumber</li>
    </ol>
</nav>

<!-- Status Banner -->
@if (reviewStatus == "อนุมัติ")
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-checkbox-circle-line fs-5"></i>
        <span><strong>อนุมัติ</strong> — คำขอนี้ได้รับการอนุมัติเรียบร้อยแล้ว</span>
    </div>
}
else if (reviewStatus == "ไม่อนุมัติ")
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-close-circle-line fs-5"></i>
        <span><strong>ไม่อนุมัติ</strong> — คำขอนี้ถูกปฏิเสธ กรุณาดูเหตุผลในส่วนผลการพิจารณา</span>
    </div>
}
else if (reviewStatus == "ยกเลิก")
{
    <div class="alert alert-secondary d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-forbid-line fs-5"></i>
        <span><strong>ยกเลิก</strong> — คำขอนี้ถูกยกเลิกแล้ว</span>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="ri ri-time-line fs-5"></i>
        <span><strong>รออนุมัติ</strong> — คำขอนี้รอการพิจารณาจากเจ้าหน้าที่</span>
    </div>
}

<!-- Request Info Badge -->
<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <div>
        <span class="text-muted small">เลขที่คำขอ</span>
        <div class="fw-bold text-primary fs-6">@requestNumber</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">ใบรับรอง</span>
        <div class="fw-bold">ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">ผู้ประกอบการ</span>
        <div class="fw-bold">Alpha Office Automation Co., Ltd.</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">วันที่ยื่นคำขอ</span>
        <div class="fw-bold">20/04/2569 (16:53:46)</div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">เลขที่รับคำขอ</span>
        <div>
            @if (isRegistered)
            {
                <span class="fw-bold text-primary">@receivedNo</span>
            }
            else
            {
                <span class="badge bg-label-warning"><i class="ri ri-time-line me-1"></i>ยังไม่ลงทะเบียน</span>
            }
        </div>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div>
        <span class="text-muted small">สถานะ</span>
        <div>
            @if (reviewStatus == "อนุมัติ")
            {
                <span class="badge bg-label-success"><i class="ri ri-checkbox-circle-line me-1"></i>@reviewStatus</span>
            }
            else if (reviewStatus == "ไม่อนุมัติ")
            {
                <span class="badge bg-label-danger"><i class="ri ri-close-circle-line me-1"></i>@reviewStatus</span>
            }
            else if (reviewStatus == "ยกเลิก")
            {
                <span class="badge bg-label-secondary"><i class="ri ri-forbid-line me-1"></i>@reviewStatus</span>
            }
            else
            {
                <span class="badge bg-label-warning"><i class="ri ri-mail-send-line me-1"></i>@reviewStatus</span>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">

        @* ─── 2.5(1): Lock alert — เชื่อมโยงระบบภายนอกแล้ว ─── *@
        @if (isLocked)
        {
            <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
                <i class="ri ri-lock-2-line fs-4 flex-shrink-0 mt-1"></i>
                <div>
                    <div class="fw-bold mb-1">⛔ ไม่สามารถดำเนินการขอเปลี่ยนแปลงได้</div>
                    <div>
                        ใบรับรองเลขที่ <strong>@requestNumber</strong>
                        @if (linkStatus == "linked_external")
                        {
                            @:ถูก<strong>เชื่อมโยง/แลกเปลี่ยน/ส่งต่อข้อมูล</strong>ไปยังระบบภายนอกแล้ว
                        }
                        else
                        {
                            @:ถูก<strong>สำแดงกับลูกค้า</strong>แล้ว
                        }
                        — การแก้ไขใบรับรองทำได้เฉพาะกรณียังไม่มีการเชื่อมโยงกับระบบภายนอก
                        และยังไม่ได้สำแดงใบรับรองกับลูกค้าเท่านั้น
                    </div>
                </div>
            </div>
        }

        <!-- ===== Tabs ===== -->
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-production" aria-controls="tab-production" aria-selected="false">
                        <i class="ri ri-list-check-3 me-1"></i> รายการข้อมูลการผลิต
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-history" aria-controls="tab-history" aria-selected="false">
                        <i class="ri ri-history-line me-1"></i> ประวัติการดำเนินการ
                    </button>
                </li>

            </ul>

            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
                <div id="tab-detail" class="tab-pane fade show active" role="tabpanel">

                    <!-- ===== Accordion: ส่วนหัว ===== -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionHeader">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingHeader">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseHeaderContent" aria-expanded="true"
                                    aria-controls="collapseHeaderContent">
                                    <i class="icon-base ri ri-file-list-line me-2"></i>
                                    รายละเอียดประเภทเอกสารส่วนหัว
                                </button>
                            </h2>
                            <div id="collapseHeaderContent" class="accordion-collapse collapse show"
                                aria-labelledby="headingHeader">
                                <div class="accordion-body p-0">

                                    <!-- รายละเอียด -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-information-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">รายละเอียด</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-8">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light"
                                                        value="Alpha Office Automation Co., Ltd. (สาขา 00001)" readonly />
                                                    <label>ผู้ประกอบการ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light"
                                                        value="0105539133390" readonly />
                                                    <label>เลขประจำตัวผู้เสียภาษี</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light"
                                                        value="ใบรับรองการแปรรูปสัตว์น้ำ (Processing Statement)" readonly />
                                                    <label>ใบรับรอง</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light"
                                                        value="10611180131800118" readonly />
                                                    <label>เลขที่ใบรับรอง</label>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light"
                                                        value="ปกติ" readonly />
                                                    <label>สถานะใบรับรอง</label>
                                                </div>
                                            </div>
                                            @* ─── 2.5(5): ค้นหาใบรับรองต้นฉบับ ─── *@
                                            <div class="col-md-3 d-flex align-items-center">
                                                <button type="button" class="btn btn-outline-primary w-100" id="btnSearchOriginalCert" data-bs-toggle="modal" data-bs-target="#modalSearchOriginalCert">
                                                    <i class="ri ri-search-line me-1"></i>ค้นหาใบรับรองต้นฉบับ
                                                </button>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label d-block mb-2">ประเภทการขอเปลี่ยนแปลง</label>
                                                <div class="border rounded p-3 bg-light">
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input" type="radio" name="changeRequestType"
                                                            id="changeRequestEdit" value="edit" checked disabled />
                                                        <label class="form-check-label text-muted" for="changeRequestEdit">
                                                            ขอเปลี่ยนแปลงข้อมูลใบรับรองการทำอิเล็กทรอนิกส์แบบไร้กระดาษ (Paperless)
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="changeRequestType"
                                                            id="changeRequestCancel" value="cancel" disabled />
                                                        <label class="form-check-label text-muted" for="changeRequestCancel">
                                                            ยกเลิกใบรับรองการทำอิเล็กทรอนิกส์แบบไร้กระดาษ (Paperless)
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">รายละเอียด</label>
                                                <textarea class="form-control bg-light" rows="4" readonly>ขอเปลี่ยนแปลงข้อมูลผู้ส่งออกและวันที่ส่งออก เนื่องจากมีการแก้ไขข้อมูลตามที่ตรวจพบ</textarea>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">ไฟล์แนบ</label>
                                                <div class="border rounded p-3 bg-light">
                                                    <a href="#" class="badge bg-label-secondary text-decoration-none">
                                                        <i class="ri ri-file-pdf-line me-1"></i>change_request_doc.pdf
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ─── 2.5(6): ประเภทการแก้ไข & เงื่อนไขตรวจปล่อย ─── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-warning rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-scales-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ประเภทการแก้ไข & เงื่อนไขตรวจปล่อย</h6>
                                        </div>
                                        <div class="row g-3">

                                            @* Radio: ประเภทการแก้ไขข้อมูล *@
                                            <div class="col-12">
                                                <label class="form-label d-block mb-2">ประเภทการแก้ไขข้อมูล</label>
                                                <div class="border rounded p-3 @(isReadOnly ? "bg-light" : "")">
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input" type="radio" name="editWeightType"
                                                            id="editWeightYes" value="weight"
                                                            @(isWeightChange ? "checked" : "")
                                                            @(isReadOnly ? "disabled" : "") />
                                                        <label class="form-check-label @(isReadOnly ? "text-muted" : "")" for="editWeightYes">
                                                            <strong>แก้ไขน้ำหนักส่งออก</strong>
                                                            <span class="text-danger small ms-1">— ผู้ประกอบการต้องลบ/ยกเลิกการตรวจปล่อยก่อน</span>
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="editWeightType"
                                                            id="editWeightNo" value="other"
                                                            @(!isWeightChange ? "checked" : "")
                                                            @(isReadOnly ? "disabled" : "") />
                                                        <label class="form-check-label @(isReadOnly ? "text-muted" : "")" for="editWeightNo">
                                                            <strong>แก้ไขรายละเอียดอื่น</strong> (ไม่แก้ไขน้ำหนัก)
                                                            <span class="text-success small ms-1">— ระบบปรับอัตโนมัติ ไม่ต้องขอตรวจปล่อยใหม่</span>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>

                                            @* เงื่อนไขตามประเภทการแก้ไข *@
                                            <div class="col-12" id="sectionWeightCondition">
                                                @if (isWeightChange)
                                                {
                                                    <div class="alert alert-warning d-flex align-items-start gap-3 mb-3" role="alert">
                                                        <i class="ri ri-alert-line fs-5 mt-1 flex-shrink-0"></i>
                                                        <div>
                                                            <div class="fw-semibold mb-1">⚠️ กรณีแก้ไขน้ำหนักส่งออก</div>
                                                            <div class="small">ผู้ประกอบการต้องลบ/ยกเลิกการตรวจปล่อยจากด่านตรวจประมงก่อนสร้างคำขอเปลี่ยนแปลง
                                                            หากยังไม่ยกเลิก ระบบจะไม่อนุมัติคำขอเปลี่ยนแปลงนี้</div>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex align-items-center flex-wrap gap-3">
                                                        <span class="small text-muted text-nowrap">สถานะการตรวจปล่อย:</span>
                                                        @if (inspectionCancelled)
                                                        {
                                                            <span class="badge bg-success fs-6 px-3 py-2">
                                                                <i class="ri ri-checkbox-circle-line me-1"></i>ยกเลิกตรวจปล่อยแล้ว ✅
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger fs-6 px-3 py-2">
                                                                <i class="ri ri-close-circle-line me-1"></i>ยังไม่ยกเลิกตรวจปล่อย ❌
                                                            </span>
                                                            <span class="small text-danger">กรุณาแจ้งให้ผู้ประกอบการยกเลิกการตรวจปล่อยก่อน</span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex align-items-center flex-wrap gap-3">
                                                        <span class="badge bg-success fs-6 px-3 py-2">
                                                            <i class="ri ri-magic-line me-1"></i>ระบบปรับอัตโนมัติ ✅ ไม่ต้องขอตรวจปล่อยใหม่
                                                        </span>
                                                        <span class="small text-muted">ระบบจะปรับข้อมูลใบรับรองอัตโนมัติหลังอนุมัติคำขอเปลี่ยนแปลง</span>
                                                    </div>
                                                }
                                            </div>

                                            @* เชื่อมโยงไปด่านตรวจปล่อย *@
                                            <div class="col-12">
                                                <div class="d-flex align-items-center flex-wrap gap-3">
                                                    <span class="small text-muted text-nowrap">การเชื่อมโยงด่านตรวจปล่อย:</span>
                                                    @if (isLinkedToStation)
                                                    {
                                                        <span class="badge bg-primary fs-6 px-3 py-2">
                                                            <i class="ri ri-links-line me-1"></i>เชื่อมโยงไปด่านตรวจปล่อยแล้ว ✅
                                                        </span>
                                                        <a href="#" class="btn btn-outline-primary btn-sm">
                                                            <i class="ri ri-external-link-line me-1"></i>ดูด่านตรวจปล่อย
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-label-secondary fs-6 px-3 py-2">
                                                            <i class="ri ri-link-unlink-m me-1"></i>ยังไม่เชื่อมโยงด่านตรวจปล่อย
                                                        </span>
                                                        <span class="small text-muted">จะเชื่อมโยงอัตโนมัติหลังอนุมัติคำขอเปลี่ยนแปลง</span>
                                                    }
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <!-- /2.5(6) -->

                                    <!-- ผู้ผ่านพิธีการ / ผู้รับมอบอำนาจ -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-user-star-line fs-5"></i>
                                            </span>
