@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {

        // Flatpickr
        document.querySelectorAll('.flatpickr-date').forEach(function (el) {
            if (el && !el._flatpickr) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true, locale: { firstDayOfWeek: 1 } });
            }
        });

        // Tooltips
        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // Toggle sub-rows (RMBS1 expand/collapse)
        document.querySelectorAll('.btn-toggle-sub').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var target = this.dataset.target;
                var sub = document.getElementById(target);
                var icon = this.querySelector('i');
                if (sub) {
                    if (sub.classList.contains('d-none')) {
                        sub.classList.remove('d-none');
                        icon.classList.remove('ri-arrow-right-s-line');
                        icon.classList.add('ri-arrow-down-s-line');
                    } else {
                        sub.classList.add('d-none');
                        icon.classList.remove('ri-arrow-down-s-line');
                        icon.classList.add('ri-arrow-right-s-line');
                    }
                }
            });
        });

        // 2.5(5): Modal ค้นหาใบรับรองต้นฉบับ
        function modalFilterRows() {
            var certType   = (document.getElementById('modalFilterCertType').value || '').trim();
            var certNo     = (document.getElementById('modalFilterCertNo').value || '').trim().toLowerCase();
            var receivedNo = (document.getElementById('modalFilterReceivedNo').value || '').trim().toLowerCase();
            var estab      = (document.getElementById('modalFilterEstab').value || '').trim().toLowerCase();
            var regNo      = (document.getElementById('modalFilterRegNo').value || '').trim().toLowerCase();
            var product    = (document.getElementById('modalFilterProduct').value || '').trim().toLowerCase();
            var country    = (document.getElementById('modalFilterCountry').value || '').trim().toLowerCase();
            var status     = (document.getElementById('modalFilterStatus').value || '').trim();

            var rows = document.querySelectorAll('.modal-cert-row');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var match =
                    (!certType   || row.dataset.certType === certType) &&
                    (!certNo     || row.dataset.certNo.toLowerCase().indexOf(certNo) !== -1) &&
                    (!receivedNo || row.dataset.receivedNo.toLowerCase().indexOf(receivedNo) !== -1) &&
                    (!estab      || row.dataset.estab.toLowerCase().indexOf(estab) !== -1) &&
                    (!regNo      || true) &&
                    (!product    || row.dataset.product.toLowerCase().indexOf(product) !== -1) &&
                    (!country    || row.dataset.country.toLowerCase().indexOf(country) !== -1) &&
                    (!status     || row.dataset.certStatus === status);

                row.classList.toggle('d-none', !match);
                if (match) visibleCount++;
            });

            var emptyEl = document.getElementById('modalSearchEmpty');
            if (emptyEl) emptyEl.classList.toggle('d-none', visibleCount !== 0);
        }

        var btnModalSearch = document.getElementById('btnModalSearch');
        if (btnModalSearch) {
            btnModalSearch.addEventListener('click', modalFilterRows);
        }
        var btnModalReset = document.getElementById('btnModalReset');
        if (btnModalReset) {
            btnModalReset.addEventListener('click', function () {
                ['modalFilterCertType','modalFilterCertNo','modalFilterReceivedNo',
                 'modalFilterEstab','modalFilterRegNo','modalFilterProduct',
                 'modalFilterCountry','modalFilterStatus','modalFilterDateFrom','modalFilterDateTo'
                ].forEach(function (id) {
                    var el = document.getElementById(id);
                    if (el) el.value = '';
                });
                modalFilterRows();
            });
        }

        // เลือกใบรับรองจาก modal → กรอกเลขที่ใบรับรองในฟอร์ม
        document.querySelectorAll('.btn-select-cert').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var certNo = this.dataset.certNo || '';
                // TODO: ส่งค่า certNo กลับไปยังฟอร์มหรือ state ที่ต้องการ
                alert('เลือกใบรับรอง: ' + certNo + '\n— TODO: อัปเดตฟอร์มด้วยข้อมูลใบรับรองนี้');
            });
        });

        // Enter ใน modal search fields
        ['modalFilterCertNo','modalFilterReceivedNo','modalFilterEstab','modalFilterRegNo',
         'modalFilterProduct','modalFilterCountry'
        ].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') { e.preventDefault(); modalFilterRows(); }
                });
            }
        });

        // 2.5(7): Modal พิมพ์ใบรับรอง (ฉบับแก้ไข)
        var printTypeOriginal = document.getElementById('printTypeOriginal');
        var printTypeCopy     = document.getElementById('printTypeCopy');
        var copySetsSection   = document.getElementById('copySetsSection');
        var copySetsCount     = document.getElementById('copySetsCount');
        var btnCopySetsUp     = document.getElementById('btnCopySetsUp');
        var btnCopySetsDown   = document.getElementById('btnCopySetsDown');

        function toggleCopySets() {
            if (!copySetsSection) return;
            copySetsSection.style.display = (printTypeCopy && printTypeCopy.checked) ? '' : 'none';
        }
        if (printTypeOriginal) printTypeOriginal.addEventListener('change', toggleCopySets);
        if (printTypeCopy)     printTypeCopy.addEventListener('change', toggleCopySets);

        if (btnCopySetsUp) btnCopySetsUp.addEventListener('click', function () {
            if (!copySetsCount) return;
            var v = parseInt(copySetsCount.value, 10) || 1;
            if (v < 10) copySetsCount.value = v + 1;
        });
        if (btnCopySetsDown) btnCopySetsDown.addEventListener('click', function () {
            if (!copySetsCount) return;
            var v = parseInt(copySetsCount.value, 10) || 1;
            if (v > 1) copySetsCount.value = v - 1;
        });

        var btnPrintCert = document.getElementById('btnPrintCert');
        if (btnPrintCert) {
            btnPrintCert.addEventListener('click', function () {
                var type  = (printTypeCopy && printTypeCopy.checked) ? 'Copy' : 'Original';
                var sets  = (copySetsCount ? parseInt(copySetsCount.value, 10) : 1) || 1;
                var label = type === 'Copy' ? ' (สำเนา ' + sets + ' ชุด)' : ' (ต้นฉบับ)';
                // TODO: window.print() จริงให้ใช้ print stylesheet แยก
                alert('🖨️ สั่งพิมพ์ใบรับรองฉบับแก้ไข' + label + '\n— TODO: เปิด print preview พร้อม stylesheet');
            });
        }

        var btnDownloadPdfA3 = document.getElementById('btnDownloadPdfA3');
        if (btnDownloadPdfA3) {
            btnDownloadPdfA3.addEventListener('click', function () {
                // TODO: เรียก API สร้างและดาวน์โหลดไฟล์ PDF/A-3
                alert('📄 ดาวน์โหลด PDF/A-3 ใบรับรองเลขที่ 10611180131800118 (ฉบับแก้ไข ครั้งที่ 1)\n— TODO: เรียก API /Officer/DownloadCertPdf');
            });
        }

        // 2.5(6): live toggle ประเภทการแก้ไข & เงื่อนไขตรวจปล่อย
        var editWeightYes = document.getElementById('editWeightYes');
        var editWeightNo  = document.getElementById('editWeightNo');
        var sectionWeightCondition = document.getElementById('sectionWeightCondition');
        function renderWeightCondition(isWeight) {
            if (!sectionWeightCondition) return;
            if (isWeight) {
                sectionWeightCondition.innerHTML =
                    '<div class="alert alert-warning d-flex align-items-start gap-3 mb-3" role="alert">' +
                    '  <i class="ri ri-alert-line fs-5 mt-1 flex-shrink-0"></i>' +
                    '  <div><div class="fw-semibold mb-1">⚠️ กรณีแก้ไขน้ำหนักส่งออก</div>' +
                    '    <div class="small">ผู้ประกอบการต้องลบ/ยกเลิกการตรวจปล่อยจากด่านตรวจประมงก่อนสร้างคำขอเปลี่ยนแปลง หากยังไม่ยกเลิก ระบบจะไม่อนุมัติคำขอเปลี่ยนแปลงนี้</div>' +
                    '  </div></div>' +
                    '<div class="d-flex align-items-center flex-wrap gap-3">' +
                    '  <span class="small text-muted text-nowrap">สถานะการตรวจปล่อย:</span>' +
                    '  <span class="badge bg-danger fs-6 px-3 py-2"><i class="ri ri-close-circle-line me-1"></i>ยังไม่ยกเลิกตรวจปล่อย ❌</span>' +
                    '  <span class="small text-danger">กรุณาแจ้งให้ผู้ประกอบการยกเลิกการตรวจปล่อยก่อน</span>' +
                    '</div>';
            } else {
                sectionWeightCondition.innerHTML =
                    '<div class="d-flex align-items-center flex-wrap gap-3">' +
                    '  <span class="badge bg-success fs-6 px-3 py-2"><i class="ri ri-magic-line me-1"></i>ระบบปรับอัตโนมัติ ✅ ไม่ต้องขอตรวจปล่อยใหม่</span>' +
                    '  <span class="small text-muted">ระบบจะปรับข้อมูลใบรับรองอัตโนมัติหลังอนุมัติคำขอเปลี่ยนแปลง</span>' +
                    '</div>';
            }
        }
        if (editWeightYes) editWeightYes.addEventListener('change', function () { renderWeightCondition(true); });
        if (editWeightNo)  editWeightNo.addEventListener('change',  function () { renderWeightCondition(false); });

        var btnCancel = document.getElementById('btnCancelRequest');
        if (btnCancel) {
            btnCancel.addEventListener('click', function () {
                if (confirm('ยืนยันการยกเลิกคำขอเปลี่ยนแปลงใบรับรองนี้?')) {
                    alert('บันทึกการยกเลิกเรียบร้อย');
                }
            });
        }

        // 2.5(4): ลงทะเบียนรับคำขอ — ออกเลขที่รับคำขออัตโนมัติ
        var btnRegister = document.getElementById('btnRegisterRequest');
        if (btnRegister) {
            btnRegister.addEventListener('click', function () {
                if (confirm('ยืนยันการลงทะเบียนรับคำขอเปลี่ยนแปลงใบรับรอง\nเลขที่คำขอ: ' + '@requestNumber' + '\n\nระบบจะออกเลขที่รับคำขออัตโนมัติให้')) {
                    // TODO: เรียก API ลงทะเบียนรับคำขอ และรับเลขที่กลับมา
                    var generatedNo = 'รบ-ปค. 2026-00045';
                    alert('✅ รับคำขอเปลี่ยนแปลงแล้ว\nเลขที่รับคำขอ: ' + generatedNo);
                    // Reload page (mockup — จริงๆ จะ re-render ด้วยข้อมูลใหม่)
                    // location.reload();
                }
            });
        }

        var btnApprove = document.getElementById('btnApproveRequest');
        if (btnApprove) {
            btnApprove.addEventListener('click', function () {
                if (confirm('ยืนยันการอนุมัติคำขอเปลี่ยนแปลงใบรับรองนี้?')) {
                    alert('บันทึกผลการอนุมัติเรียบร้อย');
                }
            });
        }

        var btnReject = document.getElementById('btnRejectRequest');
        if (btnReject) {
            btnReject.addEventListener('click', function () {
                if (confirm('ยืนยันการไม่อนุมัติคำขอเปลี่ยนแปลงใบรับรองนี้?')) {
                    alert('บันทึกผลการไม่อนุมัติเรียบร้อย');
                }
            });
        }
    });
</script>
}
