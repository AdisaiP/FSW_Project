            function getChecked() {
                return Array.from(document.querySelectorAll('.check-propose-row:checked'));
            }

            function updateBar() {
                var checked = getChecked();
                var n = checked.length;
                stickyBar.classList.toggle('hidden', n === 0);
                countBadge.textContent = n;
                countBtn.textContent   = n;
                document.getElementById('proposeConfirmCount').textContent = n;
                document.getElementById('proposeListCount').textContent    = n;
                namesLabel.textContent = checked.map(function (c) {
                    return c.dataset.hcno || c.value;
                }).join(', ');
                // sync checkAll indeterminate
                var allBoxes = document.querySelectorAll('.check-propose-row');
                checkAll.indeterminate = n > 0 && n < allBoxes.length;
                checkAll.checked = n === allBoxes.length && n > 0;
                // populate modal list
                populateProposeList(checked);
            }

            function populateProposeList(checked) {
                var tbody = document.getElementById('proposeListBody');
                if (!tbody) return;
                if (checked.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-2">— ยังไม่มีรายการที่เลือก —</td></tr>';
                    return;
                }
                tbody.innerHTML = checked.map(function (c, i) {
                    return '<tr>'
                        + '<td class="text-center">' + (i + 1) + '</td>'
                        + '<td>' + (c.dataset.certname || '—') + '</td>'
                        + '<td class="text-center">' + (c.dataset.hcno || '—') + '</td>'
                        + '<td><span class="badge bg-label-primary" style="font-size:0.65rem;">'
                        + (c.dataset.signer || '— ยังไม่กำหนด') + '</span></td>'
                        + '<td class="text-center">'
                        + '<button type="button" class="btn btn-icon btn-sm btn-outline-danger btn-remove-propose-row" data-val="' + c.value + '">'
                        + '<i class="ri ri-close-line"></i></button>'
                        + '</td>'
                        + '</tr>';
                }).join('');
                // Remove row handler
                tbody.querySelectorAll('.btn-remove-propose-row').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var cb = document.querySelector('.check-propose-row[value="' + this.dataset.val + '"]');
                        if (cb) { cb.checked = false; updateBar(); }
                    });
                });
            }

            // Checkbox change events
            document.querySelectorAll('.check-propose-row').forEach(function (cb) {
                cb.addEventListener('change', updateBar);
            });

            // Select all
            if (checkAll) {
                checkAll.addEventListener('change', function () {
                    document.querySelectorAll('.check-propose-row').forEach(function (cb) {
                        cb.checked = checkAll.checked;
                    });
                    updateBar();
                });
            }

            // Clear button
            var btnClear = document.getElementById('btnClearPropose');
            if (btnClear) {
                btnClear.addEventListener('click', function () {
                    document.querySelectorAll('.check-propose-row').forEach(function (cb) { cb.checked = false; });
                    updateBar();
                });
            }

