                        + '<span class="badge ' + h.actionClass + ' rounded-circle d-flex align-items-center justify-content-center" style="width:2rem;height:2rem;"><i class="ri ' + icon + '"></i></span>'
                        + (isLast ? '' : '<div class="flex-grow-1 border-start border-2 border-light mt-1" style="min-height:2.5rem;"></div>')
                        + '</div>'
                        + '<div class="pt-1">'
                        + '<div class="fw-semibold">' + h.actionText + '</div>'
                        + '<div class="text-muted small">' + h.date + ' ' + h.time + ' น. — ' + h.actor + ' <span class="badge bg-label-secondary ms-1" style="font-size:0.6rem;">' + h.role + '</span></div>'
