        // ─── 2.4(22): Export Excel / พิมพ์ ───
        (function () {
            // Collect all row data from the preview table
            function getExportRows(scope) {
                var rows = document.querySelectorAll('#tblExportPreview tbody tr.export-row');
                return Array.from(rows).filter(function (row) {
                    if (scope === 'all')     return true;
                    if (scope === 'pending') return row.dataset.status === 'pending';
                    if (scope === 'approved')return row.dataset.status === 'approved';
                    if (scope === 'ready')   return row.dataset.ready  === 'ready';
                    return true;
                });
            }

            // Column index map (0-based, matching <th> order)
            var COL_IDS = ['col_no','col_certno','col_type','col_est','col_product','col_country','col_date','col_status','col_signer'];
            var COL_HEADERS = ['#','เลขที่ใบรับรอง / HC No.','ประเภท','สถานประกอบการ','สินค้า','ประเทศ','วันที่ยื่นคำขอ','สถานะ','ผู้ลงนาม'];

            // Filter scope → update count badge + hide/show table rows
            function applyScope() {
                var scope = document.querySelector('input[name="exportScope"]:checked').value;
                var rows = document.querySelectorAll('#tblExportPreview tbody tr.export-row');
                var vis = 0;
                rows.forEach(function (row) {
                    var show = scope === 'all'
                        || (scope === 'pending'  && row.dataset.status === 'pending')
                        || (scope === 'approved' && row.dataset.status === 'approved')
                        || (scope === 'ready'    && row.dataset.ready  === 'ready');
                    row.classList.toggle('d-none', !show);
                    if (show) vis++;
                });
                var badge = document.getElementById('exportRowCount');
                if (badge) badge.textContent = 'แสดง ' + vis + ' รายการ';
            }

            document.querySelectorAll('input[name="exportScope"]').forEach(function (radio) {
                radio.addEventListener('change', applyScope);
            });

            // Export CSV
            document.getElementById('btnExportCSV').addEventListener('click', function () {
                var scope = document.querySelector('input[name="exportScope"]:checked').value;
                var colFlags = COL_IDS.map(function (id) {
                    var el = document.getElementById(id);
                    return el ? el.checked : true;
                });

                // Build headers
                var headerRow = COL_HEADERS.filter(function (_, i) { return colFlags[i]; });
                var lines = [headerRow.map(csvEscape).join(',')];

                // Build data rows
                var rows = getExportRows(scope);
                rows.forEach(function (row) {
                    var cells = row.querySelectorAll('td');
                    var rowData = [];
                    cells.forEach(function (td, i) {
                        if (!colFlags[i]) return;
                        // Extract text cleanly (strip badges, multiple divs → join with space)
                        var text = Array.from(td.querySelectorAll('div, span')).map(function (el) {
                            return el.textContent.trim();
                        }).filter(Boolean).join(' ');
                        if (!text) text = td.textContent.trim();
                        rowData.push(csvEscape(text.replace(/\s+/g, ' ').trim()));
                    });
                    lines.push(rowData.join(','));
                });

                var BOM = '\uFEFF'; // UTF-8 BOM for Thai in Excel
                var csvContent = BOM + lines.join('\r\n');
                var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                var url  = URL.createObjectURL(blob);
                var a    = document.createElement('a');
                a.href     = url;
                a.download = 'รายการใบรับรอง_' + todayStr() + '.csv';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                // TODO: submit form or call API — export actual data from server
            });

            // Print preview
            document.getElementById('btnPrintPreview').addEventListener('click', function () {
                var scope = document.querySelector('input[name="exportScope"]:checked').value;
                var rows = getExportRows(scope);

                var tbl = '<table border="1" cellpadding="4" cellspacing="0" style="border-collapse:collapse;font-size:11pt;width:100%;">'
                    + '<thead><tr style="background:#1a5276;color:#fff;">'
                    + '<th>#</th><th>เลขที่ใบรับรอง / HC No.</th><th>ประเภท</th>'
                    + '<th>สถานประกอบการ</th><th>สินค้า</th><th>ประเทศ</th>'
                    + '<th>วันที่ยื่นคำขอ</th><th>สถานะ</th><th>ผู้ลงนาม</th>'
                    + '</tr></thead><tbody>';

                rows.forEach(function (row) {
                    var cells = row.querySelectorAll('td');
                    tbl += '<tr>';
                    cells.forEach(function (td) {
                        var text = Array.from(td.querySelectorAll('div,span')).map(function (el) { return el.textContent.trim(); }).filter(Boolean).join(' ');
                        if (!text) text = td.textContent.trim();
                        tbl += '<td>' + escapeHtml(text.replace(/\s+/g,' ').trim()) + '</td>';
                    });
                    tbl += '</tr>';
                });
                tbl += '</tbody></table>';

                var win = window.open('', '_blank', 'width=1100,height=700');
                win.document.write(
                    '<!DOCTYPE html><html><head><meta charset="utf-8">'
                    + '<title>รายการใบรับรอง — กรมประมง</title>'
                    + '<style>body{font-family:\'Sarabun\',sans-serif;padding:1.5rem;}h2{font-size:14pt;margin-bottom:0.5rem;}p{font-size:9pt;color:#666;margin:0 0 1rem;}@@media print{button{display:none;}}</style>'
                    + '</head><body>'
                    + '<h2>รายการใบรับรอง Processing Statement / NMD</h2>'
                    + '<p>พิมพ์เมื่อ: ' + todayStr() + ' &nbsp;|&nbsp; จำนวน: ' + rows.length + ' รายการ</p>'
                    + tbl
                    + '<br/><button onclick="window.print();" style="padding:0.4rem 1.2rem;background:#1a5276;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:10pt;">พิมพ์</button>'
                    + '</body></html>'
                );
                win.document.close();
                // TODO: submit form or call API — print with server-rendered PDF
            });

            function csvEscape(str) {
                str = (str || '').toString().replace(/"/g, '""');
                return '"' + str + '"';
            }
            function escapeHtml(str) {
                return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            }
            function todayStr() {
                var d = new Date();
                return d.getDate().toString().padStart(2,'0') + '-'
                     + (d.getMonth()+1).toString().padStart(2,'0') + '-'
                     + (d.getFullYear()+543);
            }
        })();

