                                '<strong>⛔ HC ซ้ำ — ห้ามใช้!</strong>' +
                                '</div>' +
                                '<div>HC <code class="text-danger fw-bold">' + val.trim() + '</code> ถูกใช้ในใบรับรอง <strong>' + found.certNo + '</strong> แล้ว</div>' +
                                '<div class="mt-1 text-muted small">' +
                                'ประเภท: ' + found.type + ' &nbsp;|&nbsp; ' +
                                'ผู้ประกอบการ: ' + found.company + '<br>' +
                                'ประเทศ: ' + found.country + ' &nbsp;|&nbsp; สถานะ: <strong>' + found.issuedStatus + '</strong>' +
                                '</div>' +
                                '<div class="mt-1 small fw-semibold text-danger">กรุณาตรวจสอบเลขที่ HC หรือยกเลิกคำขอเดิมก่อน</div>' +
                                '</div>';
                        } else {
                            // Warn — same HC in non-approved request
                            alertBox.innerHTML =
                                '<div class="alert alert-warning py-2 px-3 mb-0" style="font-size:.82rem;border-left:4px solid #ffc107;">' +
                                '<div class="d-flex align-items-center gap-2 mb-1">' +
                                '<i class="ri ri-error-warning-line fs-5 text-warning flex-shrink-0"></i>' +
                                '<strong>⚠️ HC นี้อยู่ในระหว่างดำเนินการ</strong>' +
                                '</div>' +
                                '<div>HC <code class="text-warning fw-bold">' + val.trim() + '</code> กำลังถูกใช้ในคำขอ <strong>' + found.certNo + '</strong> (สถานะ: ' + found.issuedStatus + ')</div>' +
                                '<div class="text-muted small mt-1">ผู้ประกอบการ: ' + found.company + ' &nbsp;|&nbsp; ประเทศ: ' + found.country + '</div>' +
                                '<div class="mt-1 small">สามารถยื่นได้ แต่กรุณาตรวจสอบความถูกต้องก่อน</div>' +
                                '</div>';
                        }
                        alertBox.style.display = '';
                    } else {
                        // Not found — HC is available
                        hcInput.classList.add('is-valid');
                        okIcon.style.display = '';
                    }
                }, 150);
            }

            hcInput.addEventListener('input', function () { checkHcDuplicate(this.value); });
            hcInput.addEventListener('change', function () { checkHcDuplicate(this.value); });

            // Re-expose check function for submit button
            window._checkHcBeforeSubmit = function () {
                if (!hcInput.value.trim()) return true; // HC is optional
                return !isDuplicate;
            };
        })();

        // ─── Create request modal: save draft / save as / submit ───
        document.getElementById('btnSaveDraft').addEventListener('click', function () {
            // TODO: submit form or call API — save as draft
            bootstrap.Modal.getInstance(document.getElementById('modalCreateRequest')).hide();
            alert('บันทึกร่างเรียบร้อยแล้ว (TODO: เชื่อมต่อ API)');
        });
        document.getElementById('btnSaveAs').addEventListener('click', function () {
            // TODO: submit form or call API — save as new request
            alert('บันทึกเป็นคำขอใหม่ (Save as) — (TODO: เชื่อมต่อ API)');
        });
        document.getElementById('btnSubmitNewRequest').addEventListener('click', function () {
            var certType = document.getElementById('newCertType').value;
            var establishment = document.getElementById('newEstablishment').value.trim();
            if (!certType || !establishment) { alert('กรุณากรอกข้อมูลที่จำเป็น (ประเภทใบรับรอง / ผู้ประกอบการ)'); return; }
            // 2.4(29): block if HC is duplicate with issued cert
            if (window._checkHcBeforeSubmit && !window._checkHcBeforeSubmit()) {
                alert('⛔ ไม่สามารถยื่นคำขอได้\nเลขที่ HC ซ้ำกับใบรับรองที่ออกแล้ว\nกรุณาตรวจสอบและแก้ไขเลขที่ HC ก่อน');
                // Switch to tab ข้อมูลคำขอ
                document.querySelector('[data-bs-target="#createTabInfo"]').click();
                document.getElementById('newHcNo').focus();
                return;
            }
            bootstrap.Modal.getInstance(document.getElementById('modalCreateRequest')).hide();
            // TODO: submit form or call API — submit new certificate request
            alert('ยื่นคำขอเรียบร้อย (TODO: เชื่อมต่อ API)');
        });
    });
</script>
}

