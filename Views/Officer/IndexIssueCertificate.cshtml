                <tr>
                    <th style="width:32px;" class="text-center">
                        <input type="checkbox" id="checkAllPropose" class="form-check-input"
                               data-bs-toggle="tooltip" title="เลือกทั้งหมดที่จัดทำแล้ว รอเสนอลงนาม" />
                    </th>
                    <th style="width:32px;" class="text-center">
                        <input type="checkbox" id="checkAllSign" class="form-check-input"
                               data-bs-toggle="tooltip" title="เลือกทั้งหมดที่รอลงนาม (Multi-sign)" />
                    </th>
                    <th>ใบรับรอง</th>
                    <th>Health Certificate Number</th>
                    <th>HS Code</th>
                    <th>Country</th>
                    <th>Fishery Products</th>
                    <th>ผู้ประกอบการโรงงาน</th>
                    <th>เลขที่รับคำขอ</th>
                    <th>วันที่ยื่นคำขอ</th>
                    <th>เลขที่ใบรับรอง</th>
                    <th>สถานะการพิจารณา</th>
                    <th>การดำเนินการ</th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    var exportDt = exportDates.GetValueOrDefault(request.RowNo, System.DateTime.MaxValue);
                    var daysToExport = (int)(exportDt - today).TotalDays;
                    var isNearExport = daysToExport >= 0 && daysToExport <= alertThresholdDays;
                    <tr data-certificate="@request.CertificateKey" data-status="@request.StatusKey"
                        data-submitted-date="@request.SubmittedAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-export-date="@exportDt.ToString("yyyy-MM-dd")"
                        data-establishment="@request.Establishment.ToLower()"
                        data-fishery="@request.FisheryProducts.ToLower()"
                        data-country="@request.Country"
                        data-hcno="@request.HealthCertificateNumber.ToLower()"
                        data-receipt="@(receiptNos.GetValueOrDefault(request.RowNo, "").ToLower())"
                        @(isNearExport ? "class=\"table-warning\"" : "")>

                        <!-- Checkbox: เสนอลงนาม (2.4(20)) -->
                        <td class="text-center" style="width:32px;">
                            @if (prepareStatuses.ContainsKey(request.RowNo))
                            {
                                <input type="checkbox" class="form-check-input check-propose-row"
                                       value="@request.RowNo"
                                       data-certname="@request.CertificateName"
                                       data-hcno="@request.HealthCertificateNumber"
                                       data-signer="@(signerNames.GetValueOrDefault(request.RowNo,""))"
                                       data-bs-toggle="tooltip" title="เลือกเพื่อเสนอลงนาม" />
                            }
                        </td>

                        <!-- Checkbox: ลงนาม Multi-sign (2.4(23)) -->
                        <td class="text-center" style="width:32px;">
                            @if (waitingSignStatuses.ContainsKey(request.RowNo))
                            {
                                <input type="checkbox" class="form-check-input check-sign-row"
                                       value="@request.RowNo"
                                       data-certname="@request.CertificateName"
                                       data-hcno="@request.HealthCertificateNumber"
                                       data-signer="@(waitingSignerNames.GetValueOrDefault(request.RowNo,""))"
                                       data-bs-toggle="tooltip" title="เลือกเพื่อลงนาม (Multi-sign)" />
                            }
                        </td>

                        <td>
                            @{
                                var certBadgeClass = request.CertificateKey switch {
                                    "processing" => "bg-label-primary",
                                    "pst"        => "bg-label-info",
                                    "nmd"        => "bg-label-purple",
                                    "nmdt"       => "bg-label-secondary",
                                    _            => "bg-label-warning"
                                };
                                var certBadgeLabel = request.CertificateKey switch {
                                    "processing" => "PS",
                                    "pst"        => "PST",
                                    "nmd"        => "NMD",
                                    "nmdt"       => "NMDT",
                                    _            => "DECL"
                                };
                            }
                            <span class="badge @certBadgeClass me-1" style="font-size:0.7rem;">@certBadgeLabel</span>
                            <a href="@request.DetailUrl" class="fw-semibold text-primary d-inline-block">@request.CertificateName</a>
                            <div class="signature-indicator d-flex align-items-center gap-1 mt-1 text-muted">
                                @if (request.SignedElectronically)
                                {
                                    <span class="badge rounded-circle bg-label-success">
                                        <i class="ri ri-check-line"></i>
                                    </span>
                                    <span>ลงลายมือชื่ออิเล็กทรอนิกส์แล้ว</span>
                                }
                                else
                                {
                                    <span class="badge rounded-circle bg-label-danger">
                                        <i class="ri ri-close-line"></i>
                                    </span>
                                    <span>ยังไม่ลงลายมือชื่ออิเล็กทรอนิกส์</span>
                                }
                            </div>
                        </td>
                        <td>@request.HealthCertificateNumber</td>
                        <td class="text-center">@request.HsCode</td>
                        <td>@request.Country</td>
                        <td>@request.FisheryProducts</td>
                        <td>@request.Establishment</td>
                        <td class="text-center" style="white-space:nowrap;">
                            @{
                                var rno = receiptNos.GetValueOrDefault(request.RowNo, "");
                            }
                            @if (!string.IsNullOrEmpty(rno))
                            {
                                <span class="badge bg-label-primary d-block mb-1" style="font-size:0.68rem;">@rno</span>
                                <span class="badge bg-label-success" style="font-size:0.65rem;"><i class="ri ri-checkbox-circle-line me-1"></i>รับคำขอแล้ว &#x2705;</span>
                            }
                            else if (request.StatusKey != "draft")
                            {
                                <span class="text-muted small">— ยังไม่ลงทะเบียน</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>@request.SubmittedAt.ToString("dd/MM/yyyy HH:mm:ss")
                            <div class="mt-1 small text-muted">
                                <i class="ri ri-ship-line me-1" style="font-size:0.75rem;"></i>
                                ส่งออก: @exportDt.ToString("dd/MM/yyyy")
                            </div>
                            @if (isNearExport)
                            {
                                <span class="badge bg-label-warning mt-1 d-inline-block" style="font-size:0.68rem;">
                                    ⚠️ ส่งออกใน @(daysToExport == 0 ? "วันนี้!" : daysToExport + " วัน")
                                </span>
                            }
                        </td>
                        @{
                            var issuedNo = issuedCertNos.GetValueOrDefault(request.RowNo, "");
                        }
                        <td class="text-center" style="white-space:nowrap;">
                            @if (!string.IsNullOrEmpty(issuedNo))
                            {
                                <span class="badge bg-label-success d-block mb-1" style="font-size:0.68rem;">
                                    <i class="ri ri-award-line me-1"></i>@issuedNo
                                </span>
                                <span class="badge bg-label-info" style="font-size:0.62rem;">
                                    <i class="ri ri-checkbox-circle-line me-1"></i>ออกอัตโนมัติ ✅
                                </span>
                            }
                            else if (request.StatusKey == "approved")
                            {
                                <span class="text-muted small">— รอออกเลข</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill @request.StatusClass">@request.StatusText</span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                @if (waitingSignStatuses.ContainsKey(request.RowNo))
                                {
                                    var wsigner = waitingSignerNames.GetValueOrDefault(request.RowNo, "— ยังไม่กำหนด");
                                    <div class="w-100 mb-1 d-flex flex-column align-items-start gap-1">
                                        <span class="badge bg-label-success" style="font-size:0.62rem;max-width:130px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@wsigner">
                                            <i class="ri ri-pen-nib-line me-1"></i>@wsigner
                                        </span>
                                        <div class="d-flex gap-1">
                                            <button type="button" class="btn btn-sm btn-success btn-do-sign"
                                                    style="font-size:0.7rem;padding:0.12rem 0.45rem;"
                                                    data-bs-toggle="tooltip" title="ลงนามใบรับรองนี้"
                                                    data-rowno="@request.RowNo"
                                                    data-certname="@request.CertificateName"
                                                    data-hcno="@request.HealthCertificateNumber"
                                                    data-signer="@wsigner">
                                                <i class="ri ri-pen-nib-line me-1"></i>ลงนาม
                                            </button>
                                            <button type="button" class="btn btn-sm btn-warning btn-forward-sign"
                                                    style="font-size:0.7rem;padding:0.12rem 0.35rem;"
                                                    data-bs-toggle="tooltip" title="ส่งต่อผู้ลงนามแทน"
                                                    data-rowno="@request.RowNo"
                                                    data-certname="@request.CertificateName"
                                                    data-hcno="@request.HealthCertificateNumber"
                                                    data-signer="@wsigner">
                                                <i class="ri ri-share-forward-line"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (prepareStatuses.ContainsKey(request.RowNo))
                                {
                                    var signer = signerNames.GetValueOrDefault(request.RowNo, "— ยังไม่กำหนด");
                                    <div class="w-100 mb-1 d-flex flex-column align-items-start gap-1">
                                        <span class="badge bg-label-primary" style="font-size:0.62rem;max-width:120px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@signer">
                                            <i class="ri ri-user-star-line me-1"></i>@signer
                                        </span>
                                        <div class="d-flex gap-1">
                                            <button type="button" class="btn btn-sm btn-primary btn-propose-sign"
                                                    style="font-size:0.7rem;padding:0.12rem 0.45rem;"
                                                    data-bs-toggle="tooltip" title="เสนอลงนาม"
                                                    data-rowno="@request.RowNo"
                                                    data-certname="@request.CertificateName"
                                                    data-hcno="@request.HealthCertificateNumber"
                                                    data-signer="@signer">
                                                <i class="ri ri-send-plane-line me-1"></i>เสนอลงนาม
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary btn-change-signer"
                                                    style="font-size:0.7rem;padding:0.12rem 0.35rem;"
                                                    data-bs-toggle="tooltip" title="เปลี่ยนผู้ลงนาม"
                                                    data-rowno="@request.RowNo"
                                                    data-certname="@request.CertificateName"
                                                    data-signer="@signer">
                                                <i class="ri ri-user-shared-line"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (request.StatusKey == "pending" && !receiptNos.ContainsKey(request.RowNo))
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary btn-register-req"
                                        title="ลงทะเบียนรับคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ลงทะเบียนรับคำขอ"
                                        data-rowno="@request.RowNo" data-certname="@request.CertificateName">
                                        <i class="ri ri-file-add-line text-primary"></i>
                                    </button>
                                }
                                @if ((request.StatusKey == "pending" || request.StatusKey == "reviewing") && !receiptNos.ContainsKey(request.RowNo))
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-notify-fix"
                                        title="แจ้งแก้ไขผู้ประกอบการ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="แจ้งแก้ไข"
                                        data-rowno="@request.RowNo" data-certname="@request.CertificateName"
                                        data-establishment="@request.Establishment">
                                        <i class="ri ri-error-warning-line text-warning"></i>
                                    </button>
                                }
                                <a href="@request.DetailUrl" class="btn btn-sm btn-icon btn-outline-info" title="ดูรายละเอียดคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ดูรายละเอียดคำขอ">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary btn-view-history"
                                        title="ดูประวัติการดำเนินการ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ดูประวัติ"
                                        data-rowno="@request.RowNo"
                                        data-certname="@request.CertificateName"
                                        data-hcno="@request.HealthCertificateNumber"
                                        data-status="@request.StatusText"
                                        data-establishment="@request.Establishment"
                                        data-detail-url="@request.DetailUrl#tab-history">
                                    <i class="ri ri-history-line"></i>
                                </button>
                                @if (request.AllowApprove)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" title="อนุมัติออกใบรับรอง" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="อนุมัติออกใบรับรอง">
                                        <i class="ri ri-check-line text-success"></i>
                                    </button>
                                }
                                @if (request.AllowReturn)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning" title="ส่งกลับแก้ไข" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ส่งกลับแก้ไข">
                                        <i class="ri ri-arrow-go-back-line text-warning"></i>
                                    </button>
                                }
                                @if (request.AllowReject)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ปฏิเสธคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ปฏิเสธคำขอ">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                }
                                @if (request.AllowPrint)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary btn-print-cert"
                                        title="พิมพ์ใบรับรอง" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="พิมพ์ใบรับรอง"
                                        data-rowno="@request.RowNo"
                                        data-certname="@request.CertificateName"
                                        data-hcno="@request.HealthCertificateNumber"
                                        data-fishery="@request.FisheryProducts"
                                        data-country="@request.Country"
                                        data-status="@request.StatusText"
                                        data-certno="@(issuedCertNos.ContainsKey(request.RowNo) ? issuedCertNos[request.RowNo] : "")"
                                        data-submitted="@request.SubmittedAt.ToString("dd/MM/yyyy")">
                                        <i class="ri ri-printer-line text-primary"></i>
                                    </button>
                                    @if (issuedCertNos.ContainsKey(request.RowNo))
                                    {
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-show-qr"
                                            title="QR Code ตรวจสอบออนไลน์" data-bs-toggle="tooltip" data-bs-placement="top"
                                            aria-label="แสดง QR Code"
                                            data-certno="@issuedCertNos[request.RowNo]"
                                            data-certname="@request.CertificateName"
                                            data-hcno="@request.HealthCertificateNumber"
                                            data-fishery="@request.FisheryProducts"
                                            data-country="@request.Country"
                                            data-status="@request.StatusText"
                                            data-submitted="@request.SubmittedAt.ToString("dd/MM/yyyy")">
                                            <i class="ri ri-qr-code-line text-info"></i>
                                        </button>
                                    }
                                }
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-print-draft"
                                    title="พิมพ์ร่างคำขอ (Draft)" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="พิมพ์ร่างคำขอ"
                                    data-rowno="@request.RowNo"
                                    data-certname="@request.CertificateName"
                                    data-hcno="@request.HealthCertificateNumber"
                                    data-fishery="@request.FisheryProducts"
                                    data-country="@request.Country"
                                    data-status="@request.StatusText"
                                    data-submitted="@request.SubmittedAt.ToString("dd/MM/yyyy")">
                                    <i class="ri ri-file-pdf-line text-danger"></i>
                                </button>
                                @if (request.StatusKey == "draft" || request.StatusKey == "pending")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary btn-edit-req" title="แก้ไขคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="แก้ไขคำขอ"
                                        data-rowno="@request.RowNo" data-certname="@request.CertificateName">
                                        <i class="ri ri-edit-line"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-cancel-req" title="ยกเลิกคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ยกเลิกคำขอ"
                                        data-rowno="@request.RowNo">
                                        <i class="ri ri-forbid-line text-warning"></i>
                                    </button>
                                }
                                @if (request.StatusKey == "draft")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-delete-req" title="ลบคำขอ" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ลบคำขอ"
                                        data-rowno="@request.RowNo">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                                @* 2.4(34): แก้ไขใบรับรองที่ออกแล้ว (สถานะ approved ที่ยังไม่ผ่านตรวจปล่อย) *@
                                @if (request.StatusKey == "approved")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-warning btn-edit-issued-cert"
                                        title="แก้ไขใบรับรองที่ออกแล้ว" data-bs-toggle="tooltip" data-bs-placement="top"
                                        aria-label="แก้ไขใบรับรอง"
                                        data-rowno="@request.RowNo"
                                        data-certname="@request.CertificateName"
                                        data-hcno="@request.HealthCertificateNumber"
                                        data-fishery="@request.FisheryProducts"
                                        data-country="@request.Country"
                                        data-certno="@(issuedCertNos.ContainsKey(request.RowNo) ? issuedCertNos[request.RowNo] : "")"
                                        data-submitted="@request.SubmittedAt.ToString("dd/MM/yyyy")">
                                        <i class="ri ri-edit-line text-dark"></i>
                                    </button>
                                }
                                @if (!request.SignedElectronically)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-esign-req" title="ลงลายเซ็นอิเล็กทรอนิกส์" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ลงลายเซ็น"
                                        data-rowno="@request.RowNo" data-bs-target="#modalESign" data-bs-toggle2="modal">
                                        <i class="ri ri-pen-nib-line text-info"></i>
                                    </button>
                                }
                                @if (receiptNos.ContainsKey(request.RowNo) && request.StatusKey != "approved" && request.StatusKey != "rejected")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-revert-status"
                                        title="ถอยสถานะกลับ (ก่อนรับคำขอ)" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="ถอยสถานะ"
                                        data-rowno="@request.RowNo" data-certname="@request.CertificateName"
                                        data-receiptno="@(receiptNos.GetValueOrDefault(request.RowNo, ""))">
                                        <i class="ri ri-arrow-go-back-line text-danger"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="13" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== Sticky Action Bar: เสนอลงนาม (2.4(20)) ==================== -->
<div class="sticky-propose-bar hidden" id="stickyProposeBar">
    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6" id="stickyProposeCount">0</span>
    <span class="fw-semibold">ใบที่เลือก</span>
    <span class="text-white-50 small d-none d-md-inline" id="stickyProposeNames" style="max-width:380px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
    <div class="ms-auto d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-light btn-sm" id="btnBulkChangeSigner">
            <i class="ri ri-user-shared-line me-1"></i>เปลี่ยนผู้ลงนาม
        </button>
        <button type="button" class="btn btn-warning btn-sm" id="btnBulkProposeSign"
                data-bs-toggle="modal" data-bs-target="#modalProposeSign">
            <i class="ri ri-send-plane-line me-1"></i>เสนอลงนาม <span id="stickyProposeCountBtn">0</span> ใบ
        </button>
        <button type="button" class="btn btn-outline-light btn-sm" id="btnClearPropose">
            <i class="ri ri-close-line"></i>
        </button>
    </div>
</div>

<!-- ==================== Sticky Action Bar: ลงนาม Multi-sign (2.4(23)) ==================== -->
<div class="sticky-sign-bar hidden" id="stickySignBar">
    <span class="badge bg-success rounded-pill px-3 py-2 fs-6" id="stickySignCount">0</span>
    <span class="fw-semibold">ใบที่เลือกลงนาม</span>
    <span class="text-white-50 small d-none d-md-inline" id="stickySignNames"
          style="max-width:380px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
    <div class="ms-auto d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-warning btn-sm" id="btnBulkSign"
                data-bs-toggle="modal" data-bs-target="#modalMultiSign">
            <i class="ri ri-pen-nib-line me-1"></i>ลงนามทั้งหมดที่เลือก <span id="stickySignCountBtn">0</span> ใบ
        </button>
        <button type="button" class="btn btn-outline-light btn-sm" id="btnClearSign">
            <i class="ri ri-close-line"></i>
        </button>
    </div>
</div>

<!-- ==================== Modal: ลงนามหลายฉบับ Multi-sign (2.4(23)) ==================== -->
<div class="modal fade" id="modalMultiSign" tabindex="-1" aria-labelledby="modalMultiSignLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMultiSignLabel">
                    <i class="ri ri-pen-nib-line me-1 text-success"></i>ลงนามหลายฉบับในครั้งเดียว
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <!-- Info banner -->
                <div class="alert alert-success d-flex align-items-center gap-2 py-2 small mb-3" role="alert">
                    <i class="ri ri-pen-nib-line fs-5 flex-shrink-0"></i>
                    <div>
                        กำลังดำเนินการลงนาม <strong><span id="multiSignCountDisplay">0</span> ฉบับ</strong>
