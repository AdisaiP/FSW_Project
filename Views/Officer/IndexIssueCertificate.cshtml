            function applyModalFilter() {
                var act = (document.getElementById('histModalFilterAction').value || '').toLowerCase();
                var txt = (document.getElementById('histModalFilterText').value || '').trim().toLowerCase();
                var actPattern = act ? (ACT_MAP[act] || act) : '';
                var rows = document.querySelectorAll('#histModalTableBody tr[data-action-key]');
                rows.forEach(function (row) {
                    var rowAct    = row.dataset.actionKey || '';
                    var rowActor  = row.dataset.actor     || '';
                    var rowDetail = row.dataset.detail    || '';
                    var actMatch  = !actPattern || actPattern.split('|').some(function (p) { return rowAct.includes(p); });
                    var txtMatch  = !txt || rowActor.includes(txt) || rowDetail.includes(txt);
                    row.classList.toggle('d-none', !(actMatch && txtMatch));
                });
                var tlItems = document.querySelectorAll('#histModalViewTimeline [data-action-key]');
                tlItems.forEach(function (item) {
                    var rowAct    = item.dataset.actionKey || '';
                    var rowActor  = item.dataset.actor     || '';
                    var rowDetail = item.dataset.detail    || '';
                    var actMatch  = !actPattern || actPattern.split('|').some(function (p) { return rowAct.includes(p); });
