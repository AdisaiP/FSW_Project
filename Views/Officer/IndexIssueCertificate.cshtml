                    if (sel && this.dataset.signer) sel.value = this.dataset.signer;
                    document.getElementById('proposeSuccessMsg').classList.add('d-none');
                    document.getElementById('btnConfirmProposeSign').disabled = false;
                    new bootstrap.Modal(document.getElementById('modalProposeSign')).show();
