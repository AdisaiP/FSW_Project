@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var fromInput = document.getElementById('filterDraftDateFrom');
        var toInput = document.getElementById('filterDraftDateTo');

        if (fromInput) {
            flatpickr(fromInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (toInput) {
            flatpickr(toInput, {
                dateFormat: 'd/m/Y',
                allowInput: true
            });
        }

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                new bootstrap.Tooltip(element);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) {
                return null;
            }

            var parts = value.split('/');
            if (parts.length !== 3) {
                return null;
            }

            var day = parseInt(parts[0], 10);
            var month = parseInt(parts[1], 10) - 1;
            var year = parseInt(parts[2], 10);
            var hours = endOfDay ? 23 : 0;
            var minutes = endOfDay ? 59 : 0;
            var seconds = endOfDay ? 59 : 0;
            var parsed = new Date(year, month, day, hours, minutes, seconds);

            return Number.isNaN(parsed.getTime()) ? null : parsed;
        }

        function filterRows() {
            var certificate = (document.getElementById('filterCertificate').value || '').trim();
            var status = (document.getElementById('filterStatus').value || '').trim();
            var fromDate = parseDateInput(document.getElementById('filterDraftDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDraftDateTo').value, true);
            // Export date filter
            var exportFromVal = document.getElementById('filterExportDateFrom').value;
            var exportToVal = document.getElementById('filterExportDateTo').value;
            var exportFromDate = exportFromVal ? new Date(exportFromVal + 'T00:00:00') : null;
            var exportToDate = exportToVal ? new Date(exportToVal + 'T23:59:59') : null;
            // Advanced
            var requestNo = (document.getElementById('filterRequestNo').value || '').trim().toLowerCase();
            var establishment = (document.getElementById('filterEstablishment').value || '').trim().toLowerCase();
            var regNo = (document.getElementById('filterRegNo').value || '').trim().toLowerCase();
            var fishery = (document.getElementById('filterFishery').value || '').trim().toLowerCase();
            var country = (document.getElementById('filterCountry').value || '').trim();
            var receiptNo = (document.getElementById('filterReceiptNo').value || '').trim().toLowerCase();
            var hcNo = (document.getElementById('filterHcNo').value || '').trim().toLowerCase();

            var rows = document.querySelectorAll('#requestTableBody tr[data-certificate]');
            var visibleCount = 0;

            rows.forEach(function (row) {
                var rowCertificate = row.dataset.certificate || '';
                var rowStatus = row.dataset.status || '';
                var rowDraftDate = new Date(row.dataset.submittedDate || '');
                var rowExportDate = row.dataset.exportDate ? new Date(row.dataset.exportDate + 'T00:00:00') : null;
                var rowEstablishment = (row.dataset.establishment || '').toLowerCase();
                var rowFishery = (row.dataset.fishery || '').toLowerCase();
                var rowCountry = row.dataset.country || '';
                var rowHcno = (row.dataset.hcno || '').toLowerCase();
                var rowReceipt = (row.dataset.receipt || '').toLowerCase();

                var certificateMatch = !certificate || rowCertificate === certificate;
                var statusMatch = !status || rowStatus === status;
                var fromMatch = !fromDate || rowDraftDate >= fromDate;
                var toMatch = !toDate || rowDraftDate <= toDate;
                var exportFromMatch = !exportFromDate || !rowExportDate || rowExportDate >= exportFromDate;
                var exportToMatch = !exportToDate || !rowExportDate || rowExportDate <= exportToDate;
                var reqNoMatch = !requestNo;
                var establishMatch = !establishment || rowEstablishment.includes(establishment);
                var regNoMatch = !regNo;
                var fisheryMatch = !fishery || rowFishery.includes(fishery);
                var countryMatch = !country || rowCountry === country;
                var receiptMatch = !receiptNo || rowReceipt.includes(receiptNo);
                var hcMatch = !hcNo || rowHcno.includes(hcNo);

                var isVisible = certificateMatch && statusMatch && fromMatch && toMatch
                    && exportFromMatch && exportToMatch
                    && reqNoMatch && establishMatch && regNoMatch
                    && fisheryMatch && countryMatch && receiptMatch && hcMatch;

                row.classList.toggle('d-none', !isVisible);
                if (isVisible) {
                    visibleCount += 1;
                }
            });

            document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
        }

