        // ─── 2.4(23): Multi-signature ลงนามหลายฉบับ ───
        (function () {
            var signBar       = document.getElementById('stickySignBar');
            var signCountEl   = document.getElementById('stickySignCount');
            var signCountBtnEl= document.getElementById('stickySignCountBtn');
            var signNamesEl   = document.getElementById('stickySignNames');
            var checkAllSign  = document.getElementById('checkAllSign');
            var signClearBtn  = document.getElementById('btnClearSign');
            var confirmBtn    = document.getElementById('btnConfirmMultiSign');
            var confirmChk    = document.getElementById('multiSignConfirmChk');

            function getCheckedSignRows() {
                return Array.from(document.querySelectorAll('.check-sign-row:checked'));
            }

            function updateSignBar() {
                var checked = getCheckedSignRows();
                var n = checked.length;
                signCountEl.textContent    = n;
                signCountBtnEl.textContent = n;
                if (n > 0) {
                    signBar.classList.remove('hidden');
                    var names = checked.map(function (cb) {
                        return cb.dataset.hcno;
                    }).join(', ');
                    signNamesEl.textContent = names;
                } else {
                    signBar.classList.add('hidden');
                }
            }

            // Select all sign checkboxes
            if (checkAllSign) {
                checkAllSign.addEventListener('change', function () {
                    document.querySelectorAll('.check-sign-row').forEach(function (cb) {
                        cb.checked = checkAllSign.checked;
                    });
                    updateSignBar();
                });
            }

            // Individual sign checkboxes
            document.addEventListener('change', function (e) {
                if (e.target.classList.contains('check-sign-row')) {
                    updateSignBar();
                    if (checkAllSign) {
                        var all  = document.querySelectorAll('.check-sign-row');
                        var chk  = document.querySelectorAll('.check-sign-row:checked');
                        checkAllSign.indeterminate = chk.length > 0 && chk.length < all.length;
                        checkAllSign.checked       = chk.length === all.length && all.length > 0;
                    }
                }
            });

            // Clear sign selection
            if (signClearBtn) {
                signClearBtn.addEventListener('click', function () {
                    document.querySelectorAll('.check-sign-row').forEach(function (cb) { cb.checked = false; });
                    if (checkAllSign) { checkAllSign.checked = false; checkAllSign.indeterminate = false; }
                    updateSignBar();
                });
            }

            // Single-row "ลงนาม" button → check its checkbox and open modal
            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.btn-do-sign');
                if (!btn) return;
                var rowno = btn.dataset.rowno;
                var cb = document.querySelector('.check-sign-row[value="' + rowno + '"]');
                if (cb) { cb.checked = true; updateSignBar(); }
                populateSignList();
                new bootstrap.Modal(document.getElementById('modalMultiSign')).show();
            });

            // Bulk sign button → populate modal
            var bulkSignBtn = document.getElementById('btnBulkSign');
            if (bulkSignBtn) {
                bulkSignBtn.addEventListener('click', function () {
                    populateSignList();
                });
            }

            function populateSignList() {
                var checked = getCheckedSignRows();
                var n = checked.length;
                document.getElementById('multiSignCountDisplay').textContent  = n;
                document.getElementById('multiSignConfirmCount').textContent  = n;

                var tbody = document.getElementById('multiSignList');
                tbody.innerHTML = '';
