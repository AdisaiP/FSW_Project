            document.querySelectorAll('.btn-propose-sign').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    // Make sure this row checkbox is checked
                    var rowCb = document.querySelector('.check-propose-row[value="' + this.dataset.rowno + '"]');
                    if (rowCb && !rowCb.checked) {
                        rowCb.checked = true;
                        updateBar();
