                        + '<td class="text-center"><span class="badge ' + h.actionClass + '" style="font-size:0.65rem;">' + h.actionText + '</span></td>'
                        + '<td>' + h.detail + '</td>'
                        + '<td class="text-muted small">' + (h.remark || '—') + '</td>'
                        + '</tr>';
                }).join('');
            }

            function buildTimeline(data) {
                return data.map(function (h, i) {
                    var isLast = i === data.length - 1;
                    var icon = ICON_MAP[h.actionKey] || 'ri-checkbox-circle-line';
                    return '<div class="d-flex gap-3 ' + (isLast ? 'mb-2' : 'mb-4') + '" data-action-key="' + h.actionKey + '" data-actor="' + h.actor.toLowerCase() + '" data-detail="' + h.detail.toLowerCase() + '">'
