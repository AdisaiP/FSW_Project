@section VendorScripts {
    <script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var fromInput = document.getElementById('filterDocumentDateFrom');
            var toInput = document.getElementById('filterDocumentDateTo');

            if (fromInput) {
                flatpickr(fromInput, {
                    dateFormat: 'd/m/Y',
                    allowInput: true
                });
            }

            if (toInput) {
                flatpickr(toInput, {
                    dateFormat: 'd/m/Y',
                    allowInput: true
                });
            }

            if (window.bootstrap && bootstrap.Tooltip) {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (element) {
                    new bootstrap.Tooltip(element);
                });
            }

            function parseDateInput(value, endOfDay) {
                if (!value) {
                    return null;
                }

                var parts = value.split('/');
                if (parts.length !== 3) {
                    return null;
                }

                var day = parseInt(parts[0], 10);
                var month = parseInt(parts[1], 10) - 1;
                var year = parseInt(parts[2], 10);
                var hours = endOfDay ? 23 : 0;
                var minutes = endOfDay ? 59 : 0;
                var seconds = endOfDay ? 59 : 0;
                var parsed = new Date(year, month, day, hours, minutes, seconds);

                return Number.isNaN(parsed.getTime()) ? null : parsed;
            }

            function filterRows() {
                var documentNumber = (document.getElementById('filterDocumentNumber').value || '').trim().toLowerCase();
                var importPermitNumber = (document.getElementById('filterImportPermit').value || '').trim().toLowerCase();
                var seizureNumber = (document.getElementById('filterSeizure').value || '').trim().toLowerCase();
                var status = (document.getElementById('filterReturnWeightStatus').value || '').trim();
                var fromDate = parseDateInput(document.getElementById('filterDocumentDateFrom').value, false);
                var toDate = parseDateInput(document.getElementById('filterDocumentDateTo').value, true);
                var excludeRange = document.getElementById('filterDateExclude').checked;
                // 2.8(11): ค้นหาขั้นสูง
                var certType = (document.getElementById('filterCertType').value || '').trim();
                var certNo = (document.getElementById('filterCertNo').value || '').trim().toLowerCase();
                var operatorName = (document.getElementById('filterOperatorName').value || '').trim().toLowerCase();
                var factoryReg = (document.getElementById('filterFactoryReg').value || '').trim().toLowerCase();
                var product = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
                var destination = (document.getElementById('filterDestination').value || '').trim();
                var receiptNo = (document.getElementById('filterReceiptNo').value || '').trim().toLowerCase();

                var rows = document.querySelectorAll('#requestTableBody tr[data-doc-number]');
                var visibleCount = 0;

                rows.forEach(function (row) {
                    var rowDocumentNumber = (row.dataset.docNumber || '').toLowerCase();
                    var rowImportPermit = (row.dataset.importPermit || '').toLowerCase();
                    var rowSeizureNumber = (row.dataset.seizureNumber || '').toLowerCase();
                    var rowStatus = row.dataset.returnWeightStatus || '';
                    var rowDocumentDate = new Date(row.dataset.docDate || '');
                    var rowCertType = row.dataset.certType || '';
                    var rowCertNo = (row.dataset.certNo || '').toLowerCase();
                    var rowOperatorName = (row.dataset.operatorName || '').toLowerCase();
                    var rowFactoryReg = (row.dataset.factoryReg || '').toLowerCase();
                    var rowProduct = (row.dataset.product || '').toLowerCase();
                    var rowDestination = row.dataset.destination || '';
                    var rowReceiptNo = (row.dataset.receiptNo || '').toLowerCase();

                    var documentMatch = !documentNumber || rowDocumentNumber.indexOf(documentNumber) >= 0 || rowReceiptNo.indexOf(documentNumber) >= 0;
                    var importPermitMatch = !importPermitNumber || rowImportPermit.indexOf(importPermitNumber) >= 0;
                    var seizureMatch = !seizureNumber || rowSeizureNumber.indexOf(seizureNumber) >= 0;
                    var statusMatch = !status || rowStatus === status;
                    var certTypeMatch = !certType || rowCertType === certType;
                    var certNoMatch = !certNo || rowCertNo.indexOf(certNo) >= 0;
                    var operatorMatch = !operatorName || rowOperatorName.indexOf(operatorName) >= 0;
                    var factoryMatch = !factoryReg || rowFactoryReg.indexOf(factoryReg) >= 0;
                    var productMatch = !product || rowProduct.indexOf(product) >= 0;
                    var destinationMatch = !destination || rowDestination === destination;
                    var receiptMatch = !receiptNo || rowReceiptNo.indexOf(receiptNo) >= 0;
                    var dateMatch;
                    if (!fromDate && !toDate) {
                        dateMatch = true;
                    } else if (excludeRange) {
                        var inRange = (!fromDate || rowDocumentDate >= fromDate) && (!toDate || rowDocumentDate <= toDate);
                        dateMatch = !inRange;
                    } else {
                        dateMatch = (!fromDate || rowDocumentDate >= fromDate) && (!toDate || rowDocumentDate <= toDate);
                    }
                    var isVisible = documentMatch && importPermitMatch && seizureMatch && statusMatch && dateMatch
                                 && certTypeMatch && certNoMatch && operatorMatch && factoryMatch && productMatch && destinationMatch && receiptMatch;

                    row.classList.toggle('d-none', !isVisible);
                    if (isVisible) {
                        visibleCount += 1;
                    }
                });

                document.getElementById('requestTableEmpty').classList.toggle('d-none', visibleCount !== 0);
            }

            document.getElementById('btnSearchRequests').addEventListener('click', filterRows);
            document.getElementById('filterReturnWeightStatus').addEventListener('change', filterRows);
            document.getElementById('filterDocumentDateFrom').addEventListener('change', filterRows);
            document.getElementById('filterDocumentDateTo').addEventListener('change', filterRows);
            document.getElementById('filterDateExclude').addEventListener('change', filterRows);
            document.getElementById('filterCertType').addEventListener('change', filterRows);
            document.getElementById('filterDestination').addEventListener('change', filterRows);
            document.querySelectorAll('#filterDocumentNumber, #filterImportPermit, #filterSeizure, #filterCertNo, #filterOperatorName, #filterFactoryReg, #filterProduct, #filterReceiptNo, #filterDocumentDateFrom, #filterDocumentDateTo').forEach(function (element) {
                element.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        filterRows();
                    }
                });
            });
            document.getElementById('btnResetRequests').addEventListener('click', function () {
                document.getElementById('filterDocumentNumber').value = '';
                document.getElementById('filterImportPermit').value = '';
                document.getElementById('filterSeizure').value = '';
                document.getElementById('filterReturnWeightStatus').value = '';
                document.getElementById('filterDocumentDateFrom').value = '';
                document.getElementById('filterDocumentDateTo').value = '';
                document.getElementById('filterDateExclude').checked = false;
                document.getElementById('filterCertType').value = '';
                document.getElementById('filterCertNo').value = '';
                document.getElementById('filterOperatorName').value = '';
                document.getElementById('filterFactoryReg').value = '';
                document.getElementById('filterProduct').value = '';
                document.getElementById('filterDestination').value = '';
                document.getElementById('filterReceiptNo').value = '';
                filterRows();
            });

            // 2.8(13): Export Excel mockup
            function exportToExcel() {
                var rows = document.querySelectorAll('#requestTableBody tr:not(.d-none)');
                if (rows.length === 0) {
                    alert('ไม่มีข้อมูลที่จะ Export');
                    return;
                }
                var headers = ['เลขที่เอกสาร', 'ผู้ประกอบการ', 'น้ำหนักที่คืน (กก.)', 'วัตถุประสงค์', 'สถานะ', 'วันที่ออกเอกสาร'];
                var lines = [headers.join('\t')];
                rows.forEach(function (row) {
                    var docNo = row.dataset.docNo || '';
                    var operator = row.dataset.operatorName || '';
                    var returnWt = row.dataset.returnWeight || '-';
                    var purpose = row.dataset.purpose || '-';
                    var status = (row.querySelector('.badge') || {}).textContent || '';
                    var docDate = row.dataset.docDate || '';
                    lines.push([docNo, operator, returnWt, purpose, status.trim(), docDate].join('\t'));
                });
                var content = '\uFEFF' + lines.join('\n');
                var blob = new Blob([content], { type: 'application/vnd.ms-excel;charset=utf-8' });
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                a.download = 'คำขอคืนน้ำหนัก_' + new Date().toLocaleDateString('th-TH') + '.xls';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }

        });
    </script>
}

