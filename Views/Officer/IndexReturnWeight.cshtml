            <div class="col-md-6 col-lg-3">
                <label for="filterDocumentDateFrom" class="form-label">วันที่ยื่นคำขอ (จาก)</label>
                <input type="text" id="filterDocumentDateFrom" class="form-control" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-6 col-lg-3">
                <label for="filterDocumentDateTo" class="form-label">ถึงวันที่</label>
                <input type="text" id="filterDocumentDateTo" class="form-control" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-auto d-flex flex-column justify-content-end">
                <div class="form-check mb-1">
                    <input class="form-check-input" type="checkbox" id="filterDateExclude">
                    <label class="form-check-label small" for="filterDateExclude">ยกเว้นช่วงวันที่</label>
                </div>
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearchRequests" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnResetRequests" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>

        @* ค้นหาขั้นสูง (2.8(11)) *@
        <div class="collapse mt-3 pt-3 border-top" id="advancedSearchCollapse">
            <div class="row g-3 align-items-end">
                <div class="col-md-6 col-lg-3">
                    <label for="filterCertType" class="form-label">ประเภทใบรับรอง</label>
                    <select id="filterCertType" class="form-select">
                        <option value="">-- ทุกประเภท --</option>
                        <option value="NMD">NMD — ใบรับรองสัตว์น้ำไม่แปรรูป</option>
                        <option value="HC">HC — ใบรับรองสุขอนามัย</option>
                        <option value="CC">CC — ใบรับรองการจับสัตว์น้ำ</option>
                        <option value="SCC">SCC — ใบรับรองการจับเสริม</option>
                    </select>
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterCertNo" class="form-label">เลขที่ใบรับรอง</label>
                    <input type="text" id="filterCertNo" class="form-control" placeholder="เช่น NMD-2569-OC-00551" />
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterOperatorName" class="form-label">ชื่อสถานประกอบการ</label>
                    <input type="text" id="filterOperatorName" class="form-control" placeholder="ระบุชื่อสถานประกอบการ" />
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterFactoryReg" class="form-label">เลขทะเบียนโรงงาน</label>
                    <input type="text" id="filterFactoryReg" class="form-control" placeholder="เช่น OPE-2569-001" />
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterProduct" class="form-label">ชื่อสินค้า</label>
                    <input type="text" id="filterProduct" class="form-control" placeholder="ระบุชื่อสินค้า" />
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterDestination" class="form-label">ประเทศปลายทาง</label>
                    <select id="filterDestination" class="form-select">
                        <option value="">-- ทุกประเทศ --</option>
                        <option value="ญี่ปุ่น">ญี่ปุ่น</option>
                        <option value="สหรัฐอเมริกา">สหรัฐอเมริกา</option>
                        <option value="สหภาพยุโรป">สหภาพยุโรป</option>
                        <option value="จีน">จีน</option>
                        <option value="เกาหลีใต้">เกาหลีใต้</option>
                        <option value="ออสเตรเลีย">ออสเตรเลีย</option>
                        <option value="แคนาดา">แคนาดา</option>
                    </select>
                </div>
                <div class="col-md-6 col-lg-3">
                    <label for="filterReceiptNo" class="form-label">เลขที่รับคำขอ</label>
                    <input type="text" id="filterReceiptNo" class="form-control" placeholder="เช่น รบ-คน.2569-00105" />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Results Table -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอพิจารณาคืนนํ้าหนักสินค้าส่งคืน</h5>
            <p class="text-muted small mb-0">แสดงรายการที่รอเจ้าหน้าที่พิจารณาอนุมัติการคืนนํ้าหนักสินค้าส่งคืน</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @* 2.8(13): ปุ่ม Export Excel *@
            <button type="button" class="btn btn-outline-success" id="btnExportExcel"
                    onclick="exportToExcel(); return false;">
                <i class="ri ri-file-excel-line me-1"></i>Export Excel
            </button>
            @* 2.8(2): ปุ่มสร้างคำขอคืนน้ำหนัก (เจ้าหน้าที่) *@
            <button type="button" class="btn btn-success"
                    onclick="alert('TODO: เปิดฟอร์มสร้างคำขอคืนน้ำหนักโดยเจ้าหน้าที่'); return false;">
                <i class="ri ri-add-line me-1"></i>สร้างคำขอคืนน้ำหนัก (เจ้าหน้าที่)
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 request-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="min-width:170px;">เลขที่เอกสาร</th>
                    <th style="min-width:130px;">วันที่ออกเอกสาร</th>
                    <th style="min-width:180px;">เลขที่ใบอนุญาตนำเข้า</th>
                    <th style="min-width:180px;">เลขที่ใบอายัดสินค้า</th>
                    <th style="min-width:220px;">ผู้ประกอบการ</th>
                    <th style="width:8rem;"></th>
                </tr>
            </thead>
            <tbody id="requestTableBody">
                @foreach (var request in requests)
                {
                    var documentStatusText = GetDocumentStatusText(request.ReturnWeightStatusText);
                    var documentStatusClass = GetStatusClassByText(documentStatusText);
                    var documentStatusIcon = GetStatusIconByText(documentStatusText);
                    var canApprove = request.ReturnWeightStatusText == "อยู่ระหว่างดำเนินการ";
                    var canCancel = request.ReturnWeightStatusText == "อยู่ระหว่างดำเนินการ";

                    <tr data-doc-number="@request.DocumentNumber" data-import-permit="@request.ImportPermitNumber"
                        data-seizure-number="@request.SeizureNumber"
                        data-return-weight-status="@request.ReturnWeightStatusText"
                        data-doc-date="@request.DocumentDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-cert-type="@request.CertType"
                        data-cert-no="@request.CertNo"
                        data-operator-name="@request.OperatorName"
                        data-factory-reg="@request.FactoryRegNo"
                        data-product="@request.ProductName"
                        data-destination="@request.Destination"
                        data-receipt-no="@request.ReceiptNo">
                        <td>
                            <a href="@Url.Action("ReviewReturnWeight", "Officer")"
                                   class="fw-semibold text-primary text-decoration-none d-block mb-1">
                                @request.DocumentNumber
                            </a>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @documentStatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0"
                                          style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @documentStatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะ: @documentStatusText</span>
                                </div>
                                <div class="d-flex align-items-center gap-1 small text-muted">
                                    <span class="badge @request.StatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0"
                                          style="width:1.15rem;height:1.15rem;padding:0;">
                                        <i class="ri @request.StatusIcon" style="font-size:0.6rem;"></i>
                                    </span>
                                    <span>สถานะขอคืนน้ำหนัก: @request.ReturnWeightStatusText</span>
                                </div>
                            </div>
                        </td>
                        <td class="text-center text-nowrap">@request.DocumentDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-nowrap">@request.ImportPermitNumber</td>
                        <td class="text-nowrap">@request.SeizureNumber</td>
                        <td>@request.OperatorName</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a href="@Url.Action("ReviewReturnWeight", "Officer")"
                                       class="btn btn-sm btn-icon btn-outline-info" data-bs-toggle="tooltip"
                                       title="ดูรายละเอียด">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                @if (canApprove)
                                {
                                    @* 2.8(2): ปุ่มแก้ไข *@
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                            data-bs-toggle="tooltip" title="แก้ไขคำขอ"
                                            onclick="alert('TODO: แก้ไขคำขอ @request.DocumentNumber')">
                                        <i class="ri ri-edit-line text-warning"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success"
                                            data-bs-toggle="tooltip" title="อนุมัติให้คืนน้ำหนัก">
                                        <i class="ri ri-check-line text-success"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary"
                                            data-bs-toggle="tooltip" title="อนุมัติแบบมีเงื่อนไข">
                                        <i class="ri ri-check-double-line text-primary"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                            data-bs-toggle="tooltip" title="ไม่อนุมัติให้คืนน้ำหนัก">
                                        <i class="ri ri-close-line text-danger"></i>
                                    </button>
                                    @* 2.8(2): ปุ่มลบ *@
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                            data-bs-toggle="tooltip" title="ลบคำขอ"
                                            onclick="if(confirm('ยืนยันการลบคำขอ @request.DocumentNumber ?')) alert('TODO: ลบคำขอ @request.DocumentNumber')">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                                @if (canCancel)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                            data-bs-toggle="tooltip" title="ยกเลิก">
                                        <i class="ri ri-forbid-line text-secondary"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="requestTableEmpty" class="d-none">
                    <td colspan="6" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>