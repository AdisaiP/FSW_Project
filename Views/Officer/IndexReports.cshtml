    var currentRunRc = null;

    // เปิด Run modal
    document.querySelectorAll('.btn-rpt-run').forEach(function(b) {
        b.addEventListener('click', function() {
            var rc    = this.dataset.rc;
            var rname = this.dataset.rname;
            currentRunRc = rc;
            document.getElementById('runRptName').textContent = rname;
            document.getElementById('runRptCode').textContent = rc;
            document.getElementById('runProgress').classList.add('d-none');
            document.getElementById('btnDoRunReport').disabled = false;
            // render params form
            var d = detailsMap[rc];
            var paramsHtml = '';
            if (d && d.params && d.params.length) {
                d.params.forEach(function(p) {
                    var req = p.req === 'บังคับ';
                    var inputHtml;
                    if (p.key === 'dateRange' || p.key.toLowerCase().includes('date') || p.key.toLowerCase().includes('month')) {
                        inputHtml = '<input type="text" class="form-control form-control-sm" id="rp_' + p.key + '" placeholder="' + p.sample + '">';
                    } else if (p.key === 'partnerCountry') {
                        inputHtml = '<select class="form-select form-select-sm" id="rp_' + p.key + '">' +
                            '<option value="">ทั้งหมด</option>' +
                            '<option value="JP">ญี่ปุ่น</option>' +
                            '<option value="EU">สหภาพยุโรป</option>' +
                            '<option value="US">สหรัฐอเมริกา</option>' +
                            '<option value="AU">ออสเตรเลีย</option>' +
                            '</select>';
                    } else if (p.key === 'status' || p.key === 'quotaStatus') {
                        inputHtml = '<select class="form-select form-select-sm" id="rp_' + p.key + '">' +
                            '<option value="">ทุกสถานะ</option>' +
                            '<option value="approved">อนุมัติ</option>' +
                            '<option value="rejected">ปฏิเสธ</option>' +
                            '<option value="pending">รอดำเนินการ</option>' +
                            '</select>';
                    } else {
                        inputHtml = '<input type="text" class="form-control form-control-sm" id="rp_' + p.key + '" placeholder="' + p.sample + '">';
                    }
                    paramsHtml += '<div class="col-12 col-sm-6">' +
                        '<label class="form-label small fw-semibold" for="rp_' + p.key + '">' + p.label + (req ? ' <span class="text-danger">*</span>' : '') + '</label>' +
                        inputHtml + '</div>';
                });
            } else {
                paramsHtml = '<div class="col-12"><p class="text-muted small mb-0">รายงานนี้ไม่มีพารามิเตอร์เพิ่มเติม</p></div>';
            }
            document.getElementById('runParamsForm').innerHTML = paramsHtml;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalRunReport')).show();
        });
    });

    // ปุ่ม สร้างรายงาน — simulate progress → open preview
    document.getElementById('btnDoRunReport').addEventListener('click', function() {
        var rc = currentRunRc;
        var btn = this;
        btn.disabled = true;
        var progressDiv = document.getElementById('runProgress');
        var bar = document.getElementById('runProgressBar');
        var txt = document.getElementById('runProgressText');
        progressDiv.classList.remove('d-none');
        var pct = 0;
        var steps = ['กำลังดึงข้อมูล...', 'กำลังประมวลผล...', 'กำลังจัดรูปแบบ...', 'เสร็จสิ้น ✅'];
        var stepIdx = 0;
        txt.textContent = steps[0];
        bar.style.width = '0%';
        var iv = setInterval(function() {
            pct += 25;
            bar.style.width = pct + '%';
            stepIdx = Math.min(Math.floor(pct / 25), steps.length - 1);
            txt.textContent = steps[stepIdx];
            if (pct >= 100) {
                clearInterval(iv);
                setTimeout(function() {
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalRunReport')).hide();
                    // เปิด preview modal
                    var rname = document.getElementById('runRptName').textContent;
                    document.getElementById('previewRptName').textContent = rname;
                    var pd = previewDataMap[rc];
                    if (pd) {
                        var thHtml = '<tr>' + pd.headers.map(function(h) { return '<th>' + h + '</th>'; }).join('') + '</tr>';
                        document.getElementById('previewTHead').innerHTML = thHtml;
                        var tbHtml = pd.rows.map(function(row) {
                            return '<tr>' + row.map(function(cell, ci) {
                                var cls = ci === 0 ? ' fw-semibold' : '';
                                return '<td class="' + cls + '">' + cell + '</td>';
                            }).join('') + '</tr>';
                        }).join('');
                        document.getElementById('previewTBody').innerHTML = tbHtml;
                        document.getElementById('previewRowCount').textContent = pd.rows.length + ' แถว (ตัวอย่าง)';
                    }
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalReportPreview')).show();
                }, 400);
            }
        }, 350);
    });

    // Export Excel ต่อแถว
    document.querySelectorAll('.btn-rpt-excel').forEach(function(b) {
        b.addEventListener('click', function() {
            // TODO: เรียก API /Officer/ExportReportExcel?rc=...
            alert('TODO: Export Excel — รายงาน ' + this.dataset.rc);
        });
    });

    // Export PDF ต่อแถว
    document.querySelectorAll('.btn-rpt-pdf').forEach(function(b) {
        b.addEventListener('click', function() {
            // TODO: เรียก API /Officer/ExportReportPdf?rc=...
            alert('TODO: Export PDF — รายงาน ' + this.dataset.rc);
        });
    });

    // ดาวน์โหลดจาก preview modal
    document.getElementById('btnPreviewExcel').addEventListener('click', function() {
        alert('TODO: ดาวน์โหลด Excel — ' + (document.getElementById('previewRptName').textContent || ''));
    });
    document.getElementById('btnPreviewPdf').addEventListener('click', function() {
        alert('TODO: ดาวน์โหลด PDF — ' + (document.getElementById('previewRptName').textContent || ''));
    });
});
</script>
