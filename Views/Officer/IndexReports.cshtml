<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการรายงาน</h5>
            <p class="text-muted small mb-0">สลับดูรายงาน Static และ Dynamic จากแท็บด้านล่าง</p>
        </div>
        <button type="button" class="btn btn-primary btn-sm"><i class="ri ri-add-line me-1"></i> เพิ่มรายงาน</button>
    </div>

    <div class="px-4 pt-3">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tabSt" type="button"><i class="ri ri-file-chart-line me-1"></i> Static Reports</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tabDy" type="button"><i class="ri ri-dashboard-3-line me-1"></i> Dynamic Reports</button>
            </li>
        </ul>
    </div>

    <div class="table-responsive p-1" id="secSt">
        <table class="table table-bordered align-middle mb-0 rpt-table">
            <thead class="text-center">
                <tr>
                    <th style="width:50px;">#</th>
                    <th>รหัสรายงาน</th>
                    <th>ชื่อรายงาน</th>
                    <th>หมวดหมู่</th>
                    <th>รูปแบบ</th>
                    <th>รอบรายงาน</th>
                    <th>รันล่าสุด</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="stTBody">
                @foreach (var r in staticReports)
                {
                    <tr data-rc="@r.ReportCode"
                        data-rname="@r.ReportName"
                        data-cat="@r.Category"
                        data-status="@r.StatusText"
                        data-scls="@r.StatusClass"
                        data-st="@($"{r.ReportCode} {r.ReportName} {r.Category} {r.OutputFormat} {r.OwnerUnit}")">
                        <td class="text-center text-muted">@r.RowNo</td>
                        <td class="fw-semibold text-primary">@r.ReportCode</td>
                        <td>
                            <div class="fw-semibold">@r.ReportName</div>
                            <div class="text-muted small">@r.OwnerUnit</div>
                        </td>
                        <td>@r.Category</td>
                        <td class="text-center">@r.OutputFormat</td>
                        <td class="text-center">@r.Frequency</td>
                        <td class="text-center">@r.LastRunAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center"><span class="badge rounded-pill @r.StatusClass">@r.StatusText</span></td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                @* 2.11(1): ดึงรายงาน / Export *@
                                <button type="button" class="btn btn-sm btn-icon btn-outline-primary btn-rpt-run" data-rc="@r.ReportCode" data-rname="@r.ReportName" title="ดึงรายงาน" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-play-circle-line text-primary"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-success btn-rpt-excel" data-rc="@r.ReportCode" title="Export Excel" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-file-excel-line text-success"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-rpt-pdf" data-rc="@r.ReportCode" title="Export PDF" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-file-pdf-line text-danger"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-rpt-detail" data-rc="@r.ReportCode" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="stEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="table-responsive p-1 d-none" id="secDy">
        <table class="table table-bordered align-middle mb-0 rpt-table">
            <thead class="text-center">
                <tr>
                    <th style="width:50px;">#</th>
                    <th>รหัสรายงาน</th>
                    <th>ชื่อรายงาน</th>
                    <th>หมวดหมู่</th>
                    <th>แหล่งข้อมูล</th>
                    <th>รอบ Refresh</th>
                    <th>Refresh ล่าสุด</th>
                    <th>สถานะ</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="dyTBody">
                @foreach (var r in dynamicReports)
                {
                    <tr data-rc="@r.ReportCode"
                        data-rname="@r.ReportName"
                        data-cat="@r.Category"
                        data-status="@r.StatusText"
                        data-scls="@r.StatusClass"
                        data-st="@($"{r.ReportCode} {r.ReportName} {r.Category} {r.DataSource} {r.OwnerUnit}")">
                        <td class="text-center text-muted">@r.RowNo</td>
                        <td class="fw-semibold text-primary">@r.ReportCode</td>
                        <td>
                            <div class="fw-semibold">@r.ReportName</div>
                            <div class="text-muted small">@r.OwnerUnit</div>
                        </td>
                        <td>@r.Category</td>
                        <td>@r.DataSource</td>
                        <td class="text-center">@r.RefreshPolicy</td>
                        <td class="text-center">@r.LastRefreshAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center"><span class="badge rounded-pill @r.StatusClass">@r.StatusText</span></td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                @* 2.11(1): ดึงรายงาน / Export *@
                                <button type="button" class="btn btn-sm btn-icon btn-outline-primary btn-rpt-run" data-rc="@r.ReportCode" data-rname="@r.ReportName" title="ดึงรายงาน" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-play-circle-line text-primary"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-success btn-rpt-excel" data-rc="@r.ReportCode" title="Export Excel" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-file-excel-line text-success"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-rpt-pdf" data-rc="@r.ReportCode" title="Export PDF" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-file-pdf-line text-danger"></i></button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-info btn-rpt-detail" data-rc="@r.ReportCode" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top"><i class="ri ri-eye-line text-info"></i></button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="dyEmpty" class="d-none">
                    <td colspan="9" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="rptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <span id="modalTitle">รายละเอียดรายงาน</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="nav-align-top nav-tabs-shadow">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabDetail" type="button"><i class="ri ri-file-list-2-line me-1"></i> ข้อมูลหลัก</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabParams" type="button"><i class="ri ri-settings-3-line me-1"></i> พารามิเตอร์</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabHist" type="button"><i class="ri ri-history-line me-1"></i> ประวัติการทำงาน</button></li>
                    </ul>
                    <div class="tab-content">
                        <div id="tabDetail" class="tab-pane fade show active">
                            <div class="accordion accordion-custom-button" id="rptAccordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#accInfo" type="button">
                                            <i class="icon-base ri ri-information-line me-2"></i> ข้อมูลรายงาน
                                        </button>
                                    </h2>
                                    <div id="accInfo" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-4"><div class="detail-kv"><span class="lbl">รหัสรายงาน</span><span class="val" id="dCode">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="lbl">ประเภทรายงาน</span><span class="val" id="dType">-</span></div></div>
                                                <div class="col-md-4"><div class="detail-kv"><span class="lbl">สถานะ</span><span class="val" id="dStatus">-</span></div></div>
                                                <div class="col-md-6"><div class="detail-kv"><span class="lbl">ชื่อรายงาน</span><span class="val" id="dName">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="lbl">หมวดหมู่</span><span class="val" id="dCat">-</span></div></div>
                                                <div class="col-md-3"><div class="detail-kv"><span class="lbl">เจ้าของรายงาน</span><span class="val" id="dOwner">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#accOps" type="button">
                                            <i class="icon-base ri ri-settings-4-line me-2"></i> การตั้งค่าและการดูแล
                                        </button>
                                    </h2>
                                    <div id="accOps" class="accordion-collapse collapse show">
                                        <div class="accordion-body">
                                            <div class="row g-3">
                                                <div class="col-md-6"><div class="detail-kv"><span class="lbl">วัตถุประสงค์</span><span class="val" id="dObj">-</span></div></div>
                                                <div class="col-md-2"><div class="detail-kv"><span class="lbl">อัปเดตโดย</span><span class="val" id="dBy">-</span></div></div>
                                                <div class="col-md-2"><div class="detail-kv"><span class="lbl">เวลาอัปเดต</span><span class="val" id="dAt">-</span></div></div>
                                                <div class="col-md-2"><div class="detail-kv"><span class="lbl">หมายเหตุ</span><span class="val" id="dNote">-</span></div></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="tabParams" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 rpt-table">
                                    <thead class="text-center">
                                        <tr><th style="width:50px;">#</th><th>Key</th><th>ชื่อพารามิเตอร์</th><th>บังคับ/ทางเลือก</th><th>ค่าเริ่มต้นตัวอย่าง</th></tr>
                                    </thead>
                                    <tbody id="paramTBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="tabHist" class="tab-pane fade">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-0 rpt-table">
                                    <thead class="text-center">
                                        <tr><th style="width:50px;">#</th><th>เวลา</th><th>กิจกรรม</th><th>ผู้ดำเนินการ</th><th>ผลลัพธ์</th></tr>
                                    </thead>
                                    <tbody id="histTBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class="ri ri-close-line me-1"></i> ปิด</button>
                <button type="button" class="btn btn-primary"><i class="ri ri-save-line me-1"></i> บันทึกข้อมูล</button>
            </div>
        </div>
    </div>
</div>

@* 2.11(1): Modal ตั้งค่าพารามิเตอร์รายงาน *@
<div class="modal fade" id="modalRunReport" tabindex="-1" aria-labelledby="modalRunReportLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRunReportLabel">
                    <i class="ri ri-play-circle-line me-2 text-primary"></i>ดึงรายงาน — <span id="runRptName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info d-flex gap-2 align-items-start py-2 px-3 mb-3" style="font-size:0.82rem;">
                    <i class="ri ri-information-line flex-shrink-0" style="font-size:1rem;margin-top:1px;"></i>
                    <div>กรุณากำหนดพารามิเตอร์ก่อนสร้างรายงาน ฟิลด์ที่มีเครื่องหมาย <span class="text-danger fw-bold">*</span> จำเป็นต้องกรอก</div>
                </div>

                <div class="mb-3">
                    <p class="fw-semibold mb-2 small"><i class="ri ri-settings-3-line me-1 text-muted"></i>รหัสรายงาน: <code id="runRptCode"></code></p>
                </div>

                <div id="runParamsForm" class="row g-3 mb-3"></div>

                <hr class="my-3" />

                @* รูปแบบผลลัพธ์ *@
                <div class="mb-3">
                    <label class="form-label fw-semibold small">รูปแบบผลลัพธ์</label>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="runOutputFmt" id="fmtPreview" value="preview" checked>
                            <label class="form-check-label" for="fmtPreview"><i class="ri ri-eye-line me-1 text-info"></i>ดูตัวอย่างก่อน</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="runOutputFmt" id="fmtExcel" value="excel">
                            <label class="form-check-label" for="fmtExcel"><i class="ri ri-file-excel-line me-1 text-success"></i>ส่งออก Excel ทันที</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="runOutputFmt" id="fmtPdf" value="pdf">
                            <label class="form-check-label" for="fmtPdf"><i class="ri ri-file-pdf-line me-1 text-danger"></i>ส่งออก PDF ทันที</label>
                        </div>
                    </div>
                </div>

                @* Progress bar (ซ่อน เริ่มต้น) *@
                <div id="runProgress" class="d-none">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="small text-muted" id="runProgressText">กำลังประมวลผล...</span>
                    </div>
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" id="runProgressBar" role="progressbar" style="width:0%"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ยกเลิก
                </button>
                <button type="button" class="btn btn-primary btn-sm" id="btnDoRunReport">
                    <i class="ri ri-play-circle-line me-1"></i>สร้างรายงาน
                </button>
            </div>
        </div>
    </div>
</div>

@* 2.11(1): Modal ตัวอย่างรายงาน (Preview) *@
<div class="modal fade" id="modalReportPreview" tabindex="-1" aria-labelledby="modalReportPreviewLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalReportPreviewLabel">
                    <i class="ri ri-table-line me-2 text-success"></i>ตัวอย่างรายงาน — <span id="previewRptName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                    <div>
                        <span class="badge bg-label-success me-1" style="font-size:0.75rem;"><i class="ri ri-checkbox-circle-line me-1"></i>สร้างรายงานสำเร็จ</span>
                        <span class="text-muted small" id="previewRowCount"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-success btn-sm" id="btnPreviewExcel">
                            <i class="ri ri-file-excel-line me-1"></i>ดาวน์โหลด Excel
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-sm" id="btnPreviewPdf">
                            <i class="ri ri-file-pdf-line me-1"></i>ดาวน์โหลด PDF
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0 rpt-table" id="previewTable">
                        <thead class="table-light text-center" id="previewTHead"></thead>
                        <tbody id="previewTBody"></tbody>
                    </table>
                </div>

                <p class="text-muted small mt-2 mb-0">
                    <i class="ri ri-information-line me-1"></i>แสดงข้อมูลตัวอย่าง (mockup) — ระบบจริงจะดึงข้อมูลจากฐานข้อมูลตามพารามิเตอร์ที่กำหนด
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i>ปิด
                </button>
            </div>
        </div>
    </div>
</div>
