    };

    var curType = 'static';

    function getRows() {
        return document.querySelectorAll(curType === 'static' ? '#stTBody tr[data-rc]' : '#dyTBody tr[data-rc]');
    }
    function getEmptyRow() {
        return document.getElementById(curType === 'static' ? 'stEmpty' : 'dyEmpty');
    }

    function filterRows() {
        var kw  = (document.getElementById('fKw').value  || '').trim().toLowerCase();
        var cat = (document.getElementById('fCat').value || '').trim();
        var st  = (document.getElementById('fSt').value  || '').trim();
        var visible = 0;
        getRows().forEach(function(r) {
            var show = (!kw  || r.dataset.st.toLowerCase().includes(kw)) &&
                       (!cat || r.dataset.cat    === cat) &&
                       (!st  || r.dataset.status === st);
            r.classList.toggle('d-none', !show);
            if (show) visible++;
        });
        getEmptyRow().classList.toggle('d-none', visible !== 0);
    }

    function renderParams(items) {
        if (!items || !items.length) return '<tr><td colspan="5" class="text-center text-muted py-3">ไม่พบพารามิเตอร์</td></tr>';
        return items.map(function(p, i) {
            var cls = p.req === 'บังคับ' ? 'bg-label-danger' : 'bg-label-secondary';
            return '<tr><td class="text-center text-muted">'+(i+1)+'</td><td><code>'+p.key+'</code></td><td>'+p.label+'</td><td class="text-center"><span class="badge rounded-pill '+cls+'">'+p.req+'</span></td><td>'+p.sample+'</td></tr>';
        }).join('');
    }

    function renderHistory(items) {
        if (!items || !items.length) return '<tr><td colspan="5" class="text-center text-muted py-3">ไม่พบประวัติ</td></tr>';
        return items.map(function(h, i) {
            var cls = h.result === 'สำเร็จ' ? 'bg-label-success' : 'bg-label-danger';
            return '<tr><td class="text-center text-muted">'+(i+1)+'</td><td>'+h.date+'</td><td>'+h.action+'</td><td>'+h.user+'</td><td class="text-center"><span class="badge rounded-pill '+cls+'">'+h.result+'</span></td></tr>';
        }).join('');
    }

    function openDetail(rc) {
        var d   = detailsMap[rc];
        var row = document.querySelector('tr[data-rc="'+rc+'"]');
        if (!d || !row) return;
        document.getElementById('modalTitle').textContent = row.dataset.rname;
        document.getElementById('dCode').textContent  = rc;
        document.getElementById('dName').textContent  = row.dataset.rname;
        document.getElementById('dType').textContent  = d.rtype === 'static' ? 'Static' : 'Dynamic';
        document.getElementById('dCat').textContent   = row.dataset.cat;
        document.getElementById('dOwner').textContent = d.owner;
        document.getElementById('dStatus').innerHTML  = '<span class="badge rounded-pill '+row.dataset.scls+'">'+row.dataset.status+'</span>';
        document.getElementById('dObj').textContent   = d.objective;
        document.getElementById('dBy').textContent    = d.updatedBy;
        document.getElementById('dAt').textContent    = d.updatedAt;
        document.getElementById('dNote').textContent  = d.note;
        document.getElementById('paramTBody').innerHTML = renderParams(d.params);
        document.getElementById('histTBody').innerHTML  = renderHistory(d.histories);
        bootstrap.Modal.getOrCreateInstance(document.getElementById('rptModal')).show();
    }

    function switchType(t) {
        curType = t;
        document.getElementById('tabSt').classList.toggle('active', t === 'static');
        document.getElementById('tabDy').classList.toggle('active', t === 'dynamic');
        document.getElementById('secSt').classList.toggle('d-none', t !== 'static');
        document.getElementById('secDy').classList.toggle('d-none', t !== 'dynamic');
        filterRows();
    }

    document.getElementById('tabSt').addEventListener('click', function() { switchType('static'); });
    document.getElementById('tabDy').addEventListener('click', function() { switchType('dynamic'); });
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function() {
        document.getElementById('fKw').value  = '';
        document.getElementById('fCat').value = '';
        document.getElementById('fSt').value  = '';
        filterRows();
    });
    ['fKw','fCat','fSt'].forEach(function(id) {
        var el = document.getElementById(id);
        el.addEventListener('change', filterRows);
        el.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); filterRows(); } });
    });
    document.querySelectorAll('.btn-rpt-detail').forEach(function(b) {
        b.addEventListener('click', function() { openDetail(this.dataset.rc); });
    });
    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) { new bootstrap.Tooltip(el); });
    }
    switchType('static');

