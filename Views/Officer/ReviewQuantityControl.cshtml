@{
    ViewData["Title"] = "รายละเอียดเอกสาร P1";

    // ── Mockup data ──
    string docNo          = "QC-2026-00303";
    string companyName    = "บริษัท โอเชียน ไพร์ม เอ็กซ์พอร์ต จำกัด";
    string companyReg     = "0205560012345";
    string certType       = "DOF รับรองโรงงาน (ปลาโอ)";
    string productName    = "ปลาโอสาแช่แข็ง";
