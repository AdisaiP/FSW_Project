                            <tr><td>1</td><td>L0</td><td>RMBS1</td><td>RMBS1-2569-00112</td><td>ปลาโอสา แช่แข็ง (นำเข้า)</td><td class="text-end">65,000.000</td><td>PT. Indo Fisheries International</td><td>15/03/2569</td><td>อนุมัติ</td></tr>
                            <tr><td>2</td><td>L1</td><td>IMD</td><td>IMD-2569-00112</td><td>ปลาโอสา แช่แข็ง</td><td class="text-end">65,000.000</td><td>@companyName</td><td>18/03/2569</td><td>อนุมัติ</td></tr>
                            <tr><td>3</td><td>L2</td><td>P1</td><td>@docNo</td><td>ปลาโอสา/ปลาโอ รวม 4 ผลิตภัณฑ์</td><td class="text-end">@p1Items.Sum(x => x.InputKg).ToString("N0")</td><td>@companyName</td><td>21/04/2569</td><td>@statusText</td></tr>
