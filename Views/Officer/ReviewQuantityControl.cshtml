        new { ProductCode="3CCOSA003", ProductName="ปลาโอสา (แช่แข็ง) 5kg",  InputKg=15000m, OutputKg=10500m, ActualYield=70.0m, ApprovedYield=66.0m, Deviation= 4.0m, IsOver=true  },
        new { ProductCode="3CCOTHR01", ProductName="ปลาโอ (อื่นๆ) แช่เย็น",    InputKg= 5000m, OutputKg= 3300m, ActualYield=66.0m, ApprovedYield=66.0m, Deviation= 0.0m, IsOver=false },
