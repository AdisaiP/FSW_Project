                                <tr><td>@pRow</td><td>L3</td><td>P2</td><td>@p2.P2No</td><td>@p2.ProductName</td><td class="text-end">@p2.WeightKg.ToString("N0")</td><td>@p2.Destination</td><td>@p2.P2Date</td><td>@p2.StatusText</td></tr>
