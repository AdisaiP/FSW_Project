        new { P2No="P2-2026-00402", ProductName="ปลาโอสา (แช่แข็ง) 1kg",  Destination="สหภาพยุโรป",  WeightKg=15500m, P2Date="22/04/2569", StatusText="รอตรวจสอบ",  StatusClass="bg-label-warning" },
        new { P2No="P2-2026-00403", ProductName="ปลาโอสา (แช่แข็ง) 5kg",  Destination="สหรัฐอเมริกา",WeightKg= 8200m, P2Date="23/04/2569", StatusText="อนุมัติแล้ว", StatusClass="bg-label-success" },
        new { P2No="P2-2026-00404", ProductName="ปลาโอ (อื่นๆ) แช่เย็น",   Destination="จีน",         WeightKg= 3300m, P2Date="23/04/2569", StatusText="อนุมัติแล้ว", StatusClass="bg-label-success" },
    };
}

@section PageStyles {
<style>
    .field-display {
        font-size: 0.875rem;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 0.375rem;
        padding: 0.4375rem 0.875rem;
        min-height: 2.375rem;
        display: flex;
        align-items: center;
        word-break: break-word;
    }
    .form-label.small { font-size: 0.8rem; font-weight: 500; margin-bottom: 0.25rem; }
    .review-banner { border-left: 4px solid; padding: 1rem 1.25rem; border-radius: 0.5rem; }
    .review-banner.deviation { border-color: #dc3545; background: rgba(220,53,69,.06); }
    .review-banner.approved  { border-color: #28a745; background: rgba(40,167,69,.06); }
    .history-timeline { list-style: none; padding-left: 0; position: relative; margin: 0; }
    .history-timeline::before { content: ''; position: absolute; left: 1rem; top: 0; bottom: 0; width: 2px; background: var(--bs-border-color); }
    .history-timeline li { position: relative; padding-left: 2.5rem; margin-bottom: 1.2rem; }
    .history-timeline li::before { content: ''; position: absolute; left: 0.55rem; top: 0.3rem; width: 0.9rem; height: 0.9rem; border-radius: 50%; background: var(--bs-primary); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--bs-primary); }
    .history-timeline li.success::before { background: #28a745; box-shadow: 0 0 0 2px #28a745; }
    .history-timeline li.warning::before { background: #ffc107; box-shadow: 0 0 0 2px #ffc107; }
    .history-timeline li.danger::before  { background: #dc3545; box-shadow: 0 0 0 2px #dc3545; }
    /* Tree Diagram */
    .tree-node-officer { transition: box-shadow .15s; }
    .tree-node-officer:hover { box-shadow: 0 2px 8px rgba(0,0,0,.12); }
    .tree-connector { color: #aaa; font-size: 1.3rem; line-height: 1; text-align: center; }
    /* Print */
    @@media print {
        body * { visibility: hidden !important; }
        #printP1Area, #printP1Area *, #printTreeArea, #printTreeArea *, #printMeasureArea, #printMeasureArea * { visibility: visible !important; }
        #printP1Area, #printTreeArea, #printMeasureArea { position: absolute; left: 0; top: 0; width: 100%; padding: 24px; font-size: 11pt; }
        .modal-backdrop { display: none !important; }
    }
    .print-form-header { text-align: center; border-bottom: 2px solid #333; padding-bottom: 8px; margin-bottom: 16px; }
    .print-form-table th, .print-form-table td { border: 1px solid #999; padding: 5px 8px; font-size: 0.82rem; }
    .print-form-table { border-collapse: collapse; width: 100%; }
    .sign-box { border: 1px solid #999; min-height: 70px; border-radius: 4px; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ─── Export buttons ───
    document.getElementById('btnExportExcel').addEventListener('click', function () {
        // TODO: export Excel via server API
        alert('TODO: Export Excel — เชื่อมต่อ API สร้างไฟล์ Excel จริง');
    });
    document.getElementById('btnExportPdf').addEventListener('click', function () {
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modalPrintP1')).show();
    });
    document.getElementById('btnPrintP1').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalPrintP1')).hide();
        setTimeout(function () { window.print(); }, 300);
    });
    document.getElementById('btnDownloadExcel2').addEventListener('click', function () {
        // TODO: download Excel via server API
        alert('TODO: Export Excel — เชื่อมต่อ API จริง');
    });

    // ─── Tree tab: Expand / Collapse all ───
    document.getElementById('btnExpandAll').addEventListener('click', function () {
        document.querySelectorAll('.tree-collapsible').forEach(function (el) { el.classList.remove('d-none'); });
    });
    document.getElementById('btnCollapseAll').addEventListener('click', function () {
        document.querySelectorAll('.tree-collapsible').forEach(function (el) { el.classList.add('d-none'); });
    });
    document.querySelectorAll('.btn-tree-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = document.getElementById(btn.dataset.treeTarget);
            if (target) {
                target.classList.toggle('d-none');
                var icon = btn.querySelector('i');
                if (icon) { icon.classList.toggle('ri-subtract-line'); icon.classList.toggle('ri-add-line'); }
            }
        });
    });

    // ─── Tree: Export Excel ───
    document.getElementById('btnTreeExportExcel').addEventListener('click', function () {
        // TODO: export supply-chain tree as Excel via server API
        alert('TODO: Export Excel ตลอดเส้นทาง — เชื่อมต่อ API จริง');
    });
    document.getElementById('btnTreeExportExcel2').addEventListener('click', function () {
        alert('TODO: Export Excel ตลอดเส้นทาง — เชื่อมต่อ API จริง');
    });

    // ─── Tree: Export PDF / Print ───
    document.getElementById('btnTreeExportPdf').addEventListener('click', function () {
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modalPrintTree')).show();
    });
    document.getElementById('btnPrintTree').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalPrintTree')).hide();
        setTimeout(function () { window.print(); }, 300);
    });

    // ─── Tab 5: มาตรการประเทศคู่ค้า & สุขอนามัย ───
    ['btnPrintMeasure', 'btnPrintMeasure2'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) {
            el.addEventListener('click', function () {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalPrintMeasure')).show();
            });
        }
    });
    document.getElementById('btnPrintMeasureModal').addEventListener('click', function () {
        bootstrap.Modal.getInstance(document.getElementById('modalPrintMeasure')).hide();
        setTimeout(function () { window.print(); }, 300);
    });
    document.getElementById('btnDownloadMeasurePdf').addEventListener('click', function () {
        // TODO: submit form or call API — download PDF มาตรการ
        alert('TODO: ดาวน์โหลด PDF มาตรการ — เชื่อมต่อ API จริง');
    });

    // ─── (ค) รายละเอียดการนำเข้า: toggle edit/view ───
    document.getElementById('btnEditImportDetail').addEventListener('click', function () {
        document.getElementById('importDetailView').style.display = 'none';
        document.getElementById('importDetailEdit').style.display = '';
    });
    document.getElementById('btnCancelImportDetail').addEventListener('click', function () {
        document.getElementById('importDetailEdit').style.display = 'none';
        document.getElementById('importDetailView').style.display = '';
    });
    document.getElementById('btnSaveImportDetail').addEventListener('click', function () {
        // Update view values from edit inputs
        var fields = ['placeDepart','dateDepart','lastPort','transport','dateArrival','storage'];
        fields.forEach(function(f) {
            var editEl = document.getElementById('edit-' + f);
            var viewEl = document.getElementById('val-' + f);
            if (editEl && viewEl) viewEl.textContent = editEl.value;
        });
        var remarkEl = document.getElementById('edit-remark');
        var remarkView = document.getElementById('val-remark');
        if (remarkEl && remarkView) remarkView.textContent = remarkEl.value;
        document.getElementById('importDetailEdit').style.display = 'none';
        document.getElementById('importDetailView').style.display = '';
        // TODO: submit form or call API — save import detail
    });
});
</script>
}

@* ===== Content ===== *@
<div class="d-flex align-items-center flex-wrap gap-2 mb-1">
    <h4 class="mb-0">รายละเอียดเอกสาร P1</h4>
</div>
<p class="mb-1 text-muted">ตรวจสอบรายละเอียดเอกสารควบคุมปริมาณสินค้า เอกสารที่ 1 รายผลิตภัณฑ์</p>

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="@Url.Action("IndexQuantityControl","Officer")" class="text-primary fw-semibold">ควบคุมปริมาณสินค้า (เอกสารที่ 1)</a></li>
        <li class="breadcrumb-item active text-secondary">@docNo</li>
    </ol>
</nav>

<!-- Status Banner -->
@if (statusText == "ค่าเบี่ยงเบน")
{
    <div class="review-banner deviation mb-4 d-flex align-items-center gap-3">
        <i class="ri ri-error-warning-line fs-4 text-danger"></i>
        <div>
            <div class="fw-semibold text-danger">ค่าเบี่ยงเบน — %Yield จริงเกินเกณฑ์ที่อนุมัติ</div>
            <div class="small text-muted">กรุณาตรวจสอบรายละเอียดและดำเนินการตามขั้นตอน</div>
        </div>
    </div>
}
else
{
    <div class="review-banner approved mb-4 d-flex align-items-center gap-3">
        <i class="ri ri-checkbox-circle-line fs-4 text-success"></i>
        <div>
            <div class="fw-semibold text-success">@statusText</div>
            <div class="small text-muted">เอกสารนี้ผ่านการตรวจสอบแล้ว</div>
        </div>
    </div>
}

<!-- Header Meta -->
<div class="row g-2 mb-4">
    <div class="col-12 col-md-4">
        <div class="small text-muted">เลขที่เอกสาร P1</div>
        <div class="fw-semibold text-primary">@docNo</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">บริษัท</div>
        <div class="fw-semibold">@companyName</div>
    </div>
    <div class="col-12 col-md-4">
        <div class="small text-muted">วันที่เอกสาร</div>
        <div class="fw-semibold">@docDate</div>
    </div>
</div>

<!-- Action Bar -->
<div class="d-flex flex-wrap gap-2 mb-4" id="actionBar">
    <button type="button" class="btn btn-outline-success btn-sm" id="btnExportExcel">
        <i class="ri ri-file-excel-line me-1"></i> Export Excel
    </button>
    <button type="button" class="btn btn-outline-danger btn-sm" id="btnExportPdf">
        <i class="ri ri-file-pdf-line me-1"></i> Export PDF / พิมพ์
    </button>
    <a href="@Url.Action("IndexQuantityControl","Officer")" class="btn btn-outline-secondary btn-sm ms-auto">
        <i class="ri ri-arrow-left-line me-1"></i> กลับรายการ
    </a>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item"><button class="nav-link active" id="tab1-tab" data-bs-toggle="tab" data-bs-target="#tab1" type="button" role="tab">
        <i class="ri ri-file-list-3-line me-1"></i> รายละเอียด P1
    </button></li>
    <li class="nav-item"><button class="nav-link" id="tab2-tab" data-bs-toggle="tab" data-bs-target="#tab2" type="button" role="tab">
        <i class="ri ri-file-copy-line me-1"></i> P2 (เอกสารลูก)
        <span class="badge bg-primary ms-1">@p2Items.Length</span>
    </button></li>
    <li class="nav-item"><button class="nav-link" id="tab3-tab" data-bs-toggle="tab" data-bs-target="#tab3" type="button" role="tab">
        <i class="ri ri-history-line me-1"></i> ประวัติการดำเนินการ
    </button></li>
    <li class="nav-item"><button class="nav-link" id="tab4-tab" data-bs-toggle="tab" data-bs-target="#tab4" type="button" role="tab">
        <i class="ri ri-node-tree me-1"></i> เส้นทางการซื้อขาย
        <span class="badge bg-info ms-1">Tree</span>
    </button></li>
    <li class="nav-item"><button class="nav-link" id="tab5-tab" data-bs-toggle="tab" data-bs-target="#tab5" type="button" role="tab">
        <i class="ri ri-shield-check-line me-1"></i> มาตรการประเทศคู่ค้า &amp; สุขอนามัย
        <span class="badge bg-warning text-dark ms-1">1</span>
    </button></li>
</ul>

<div class="tab-content">

<!-- ========================= Tab 1: P1 Detail ========================= -->
<div class="tab-pane fade show active" id="tab1" role="tabpanel">

    <!-- ข้อมูลสถานประกอบการ -->
    <div class="card mb-4">
        <div class="card-header"><h6 class="mb-0"><i class="ri ri-building-2-line me-1"></i> ข้อมูลสถานประกอบการ</h6></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label small">ชื่อสถานประกอบการ</label>
                    <div class="field-display">@companyName</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">เลขทะเบียนนิติบุคคล</label>
                    <div class="field-display">@companyReg</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">ประเภทใบรับรอง</label>
                    <div class="field-display">@certType</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">แหล่งวัตถุดิบ</label>
                    <div class="field-display">@rawMaterialSrc</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">ช่วงวันที่ผลิต</label>
                    <div class="field-display">@docPeriod</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">สถานะ</label>
                    <div class="field-display"><span class="badge @statusClass">@statusText</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ตาราง P1 รายผลิตภัณฑ์ -->
    <div class="card mb-4">
        <div class="card-header"><h6 class="mb-0"><i class="ri ri-table-line me-1"></i> รายละเอียด P1 รายผลิตภัณฑ์</h6></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:0.8rem;">
                <thead class="table-light">
                    <tr>
                        <th>รหัสสินค้า</th>
                        <th>ชื่อผลิตภัณฑ์</th>
                        <th class="text-end">น้ำหนักวัตถุดิบ (กก.)</th>
                        <th class="text-end">น้ำหนักผลผลิต (กก.)</th>
                        <th class="text-center">%Yield จริง</th>
                        <th class="text-center">%Yield อนุมัติ</th>
                        <th class="text-center">เบี่ยงเบน</th>
                        <th class="text-center">ผลการตรวจสอบ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in p1Items)
                    {
                        <tr>
                            <td class="text-muted small">@item.ProductCode</td>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td class="text-end">@item.InputKg.ToString("N0")</td>
                            <td class="text-end">@item.OutputKg.ToString("N0")</td>
                            <td class="text-center @(item.IsOver ? "text-danger fw-bold" : "")">@item.ActualYield.ToString("F1")%</td>
                            <td class="text-center">@item.ApprovedYield.ToString("F1")%</td>
                            <td class="text-center @(item.IsOver ? "text-danger fw-bold" : "text-success fw-bold")">
                                @(item.Deviation >= 0 ? "+" : "")@item.Deviation.ToString("F1")%
                            </td>
                            <td class="text-center">
                                @if (item.IsOver)
                                {
                                    <span class="badge bg-label-danger">ค่าเบี่ยงเบน ❌</span>
                                }
                                else
                                {
                                    <span class="badge bg-label-success">อยู่ในเกณฑ์ ✅</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light fw-semibold" style="font-size:0.8rem;">
                    <tr>
                        <td colspan="2">รวมทั้งหมด</td>
                        <td class="text-end">@p1Items.Sum(x => x.InputKg).ToString("N0")</td>
                        <td class="text-end">@p1Items.Sum(x => x.OutputKg).ToString("N0")</td>
                        <td class="text-center">@((p1Items.Sum(x => x.OutputKg) / p1Items.Sum(x => x.InputKg) * 100).ToString("F1"))%</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- ปุ่ม export ล่าง -->
    <div class="d-flex gap-2 mb-2">
        <button type="button" class="btn btn-outline-success btn-sm" id="btnDownloadExcel2">
            <i class="ri ri-file-excel-line me-1"></i> ดาวน์โหลด Excel
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modalPrintP1">
            <i class="ri ri-printer-line me-1"></i> พิมพ์ / PDF
        </button>
    </div>

    <!-- ========================= Accordion: การเชื่อมโยงข้อมูล P1/P2 ========================= -->
    <hr class="my-4">
    <h6 class="mb-3 fw-semibold"><i class="ri ri-links-line me-1 text-primary"></i>การเชื่อมโยงข้อมูล P1/P2 → หนังสือรับรองตนเอง</h6>
    <div class="accordion" id="accordionLinkData">

        <!-- (ก) ตัดโควตา -->
        <div class="accordion-item mb-2 border rounded">
            <h2 class="accordion-header" id="headingLinkA">
                <button class="accordion-button collapsed py-2" type="button"
                    data-bs-toggle="collapse" data-bs-target="#collapseLinkA"
                    aria-expanded="false" aria-controls="collapseLinkA" style="font-size:0.88rem;">
                    <i class="ri ri-scissors-cut-line me-2 text-primary"></i>
                    <strong>(ก)</strong>&nbsp;ข้อมูลตัดโควตา P1 / P2 → กระบวนงานหนังสือรับรองตนเอง
                    <span class="badge bg-label-success ms-2 small">ส่งอัตโนมัติ ✅</span>
                </button>
            </h2>
            <div id="collapseLinkA" class="accordion-collapse collapse" aria-labelledby="headingLinkA">
                <div class="accordion-body pt-2 pb-3" style="font-size:0.85rem;">
                    <div class="alert alert-success py-2 mb-3 small d-flex align-items-center gap-2">
                        <i class="ri ri-checkbox-circle-line text-success fs-5 flex-shrink-0"></i>
                        <span>ระบบส่งข้อมูลตัดโควตา P1 (<strong>@docNo</strong>) และ P2 รวม <strong>@p2Items.Length รายการ</strong>
                            ไปยังกระบวนงานหนังสือรับรองตนเองอัตโนมัติแล้ว</span>
                    </div>
                    <div class="row g-2 mb-3" style="font-size:0.82rem;">
                        <div class="col-sm-4">
                            <div class="border rounded p-2 bg-light text-center">
                                <div class="text-muted small">ปริมาณ P1 รวม (Input)</div>
                                <div class="fw-bold fs-6">@p1Items.Sum(x => x.InputKg).ToString("N0") KGM</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-2 bg-light text-center">
                                <div class="text-muted small">ปริมาณ P2 ส่งออกรวม</div>
                                <div class="fw-bold fs-6">@p2Items.Sum(x => x.WeightKg).ToString("N0") KGM</div>
                            </div>
                        </div>
