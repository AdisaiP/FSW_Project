        width: 48px; height: 48px; padding: 0;
        display: inline-flex; align-items: center; justify-content: center;
    }
</style>
}

@section PageScripts {
<script>
    // DOF Check mock data (2.14(4)) — result per reqNo
    // status: 'pass' | 'mismatch' | 'incomplete' | 'na'
    var dofCheckMap = {
        'REG-2026-00101': {
            status: 'mismatch',
            rows: [
                { label: 'ชื่อโรงงาน (EN)', system: 'New Seafood Trade Co., Ltd.', dof: 'New Seafood Trade Company Limited', match: false },
                { label: 'ที่อยู่ (EN)', system: '123/45 Rama II Rd., Bang Mot, Chom Thong, Bangkok 10150, Thailand', dof: '123/45 Rama II Rd., Bang Mot, Chom Thong, Bangkok 10150, Thailand', match: true },
                { label: 'หมายเลขรับรองโรงงาน', system: 'TH-EST-1041', dof: 'TH-EST-1041', match: true }
            ]
        },
        'REG-2026-00102': {
            status: 'incomplete',
            rows: [
                { label: 'ชื่อโรงงาน (EN)', system: 'Blue Fish Export Co., Ltd.', dof: 'Blue Fish Export Co., Ltd.', match: true },
                { label: 'ที่อยู่ (EN)', system: '— ไม่มีข้อมูล (ข้อมูลไม่ครบ) —', dof: '67 Sukhumvit Soi 101, Bangna, Bangkok 10260, Thailand', match: false },
                { label: 'หมายเลขรับรองโรงงาน', system: 'TH-EST-0921', dof: 'TH-EST-0921', match: true }
            ]
        },
        'REG-2026-00103': {
            status: 'mismatch',
            rows: [
                { label: 'ชื่อโรงงาน (EN)', system: 'Andaman 2 Processing Co., Ltd.', dof: 'Andaman 2 Processing Co., Ltd.', match: true },
                { label: 'ที่อยู่ (EN)', system: '88 M.3 Ratsada, Mueang Phuket, Phuket 83000, Thailand', dof: '88 Moo 3 Ratsada Sub-district, Muang District, Phuket 83000, Thailand', match: false },
                { label: 'หมายเลขรับรองโรงงาน', system: 'TH-EST-0644', dof: 'TH-EST-0644', match: true }
            ]
        },
        'REG-2026-00104': { status: 'na', rows: [] },
        'REG-2026-00099': {
            status: 'pass',
            rows: [
                { label: 'ชื่อโรงงาน (EN)', system: 'Siam Marine Foods Co., Ltd.', dof: 'Siam Marine Foods Co., Ltd.', match: true },
                { label: 'ที่อยู่ (EN)', system: '555 Sukhumvit Rd. km.29, Phra Khanong, Bangkok 10260, Thailand', dof: '555 Sukhumvit Rd. km.29, Phra Khanong, Bangkok 10260, Thailand', match: true },
                { label: 'หมายเลขรับรองโรงงาน', system: 'TH-EST-0828', dof: 'TH-EST-0828', match: true }
            ]
        },
        'REG-2026-00098': { status: 'na', rows: [] }
    };

document.addEventListener('DOMContentLoaded', function () {
    function filterRows() {
        var keyword = (document.getElementById('filterKeyword').value || '').trim().toLowerCase();
        var status = (document.getElementById('filterStatus').value || '').trim();
        var role = (document.getElementById('filterRole').value || '').trim();
        var rows = document.querySelectorAll('#regTableBody tr[data-id]');
        var count = 0;
        rows.forEach(function (row) {
            var text = (row.dataset.searchText || '').toLowerCase();
            var rowStatus = row.dataset.status || '';
            var rowRole = row.dataset.role || '';
            var show = (!keyword || text.includes(keyword)) && (!status || rowStatus === status) && (!role || rowRole === role);
            row.classList.toggle('d-none', !show);
            if (show) count++;
        });
        document.getElementById('regTableEmpty').classList.toggle('d-none', count !== 0);
    }
    document.getElementById('btnSearch').addEventListener('click', filterRows);
    document.getElementById('btnReset').addEventListener('click', function () {
        document.getElementById('filterKeyword').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterRole').value = '';
        filterRows();
    });
    document.getElementById('filterKeyword').addEventListener('keydown', function (e) { if (e.key === 'Enter') filterRows(); });
    document.getElementById('filterStatus').addEventListener('change', filterRows);
    document.getElementById('filterRole').addEventListener('change', filterRows);

    // Detail button (ข้อมูลผู้ประกอบการ — 2.14(1))
    // POA mock count map (2.14(3))
    var poaCountMap = {
        'REG-2026-00101': 2,
        'REG-2026-00102': 0,
        'REG-2026-00103': 0,
        'REG-2026-00104': 1,
        'REG-2026-00099': 2,
        'REG-2026-00098': 0
    };
    document.querySelectorAll('.btn-view-detail').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var rowId = this.dataset.row;
            var row = document.querySelector('#regTableBody tr[data-req-no="' + rowId + '"]');
            if (!row) return;

            var complete   = row.dataset.complete === 'true';
            var companyTH  = row.dataset.companyTh || '';
            var companyEN  = row.dataset.companyEn || '';
            var addressTH  = row.dataset.addressTh || '';
            var addressEN  = row.dataset.addressEn || '';
            var taxId      = row.dataset.taxId || '';
            var branchNo   = row.dataset.branchNo || '';
            var phoneCC    = row.dataset.phoneCC || '+66';
            var phone      = row.dataset.phone || '';
            var faxCC      = row.dataset.faxCC || '+66';
            var fax        = row.dataset.fax || '';

            // Header
            document.getElementById('dModalReqNo').textContent = row.dataset.reqNo;

            // Badge completeness
            var badgeEl = document.getElementById('dBadgeComplete');
            if (complete) {
                badgeEl.innerHTML = '<span class="badge bg-success px-3 py-2"><i class="ri ri-checkbox-circle-line me-1"></i>ข้อมูลผู้ประกอบการครบถ้วน ✅ — พร้อมนำส่งสู่ระบบออกใบรับรอง</span>';
            } else {
                badgeEl.innerHTML = '<span class="badge bg-label-warning px-3 py-2"><i class="ri ri-error-warning-line me-1"></i>ข้อมูลผู้ประกอบการไม่ครบถ้วน ⚠️ — กรุณาตรวจสอบก่อนอนุมัติ</span>';
            }

            // Tab badge
            var tabBadge = document.getElementById('dTabExporterBadge');
            tabBadge.innerHTML = complete
                ? '<span class="badge bg-success" style="font-size:0.6rem;">✅</span>'
                : '<span class="badge bg-warning" style="font-size:0.6rem;">⚠️</span>';

            // Tab 1: user info
            document.getElementById('dReqNo').textContent     = row.dataset.reqNo;
            document.getElementById('dFullName').textContent   = row.dataset.fullName;
            document.getElementById('dEmail').textContent      = row.dataset.email;
            document.getElementById('dOrg').textContent        = row.dataset.org;
            document.getElementById('dRole').textContent       = row.dataset.orgRole;
            document.getElementById('dSubmitted').textContent  = row.dataset.submitted;

            // Tab 2: exporter info
            document.getElementById('dCompanyTH').textContent  = companyTH  || '— ยังไม่ระบุ —';
            document.getElementById('dCompanyEN').textContent  = companyEN  || '— Not provided —';
            document.getElementById('dAddressTH').textContent  = addressTH  || '— ยังไม่ระบุ —';
            document.getElementById('dAddressEN').textContent  = addressEN  || '— Not provided —';
            document.getElementById('dTaxId').textContent      = taxId      || '— ยังไม่ระบุ —';
            document.getElementById('dBranchNo').textContent   = branchNo   || '— ยังไม่ระบุ —';
            document.getElementById('dPhoneCC').textContent    = phoneCC;
            document.getElementById('dPhone').textContent      = phone      || '— ยังไม่ระบุ —';
            document.getElementById('dFaxCC').textContent      = faxCC;
            document.getElementById('dFax').textContent        = fax        || '— ยังไม่ระบุ —';

            // Missing fields
            var missing = [];
            if (!companyEN)  missing.push('ชื่อบริษัท (EN)');
            if (!addressTH)  missing.push('ที่อยู่ (ไทย)');
            if (!addressEN)  missing.push('ที่อยู่ (EN)');
            if (!taxId)      missing.push('เลขผู้เสียภาษี');
            if (!branchNo)   missing.push('ลำดับสาขา');
            if (!phone)      missing.push('โทรศัพท์');

            var alertEl = document.getElementById('dMissingAlert');
            if (missing.length > 0 && !complete) {
                alertEl.classList.remove('d-none');
                document.getElementById('dMissingList').textContent = missing.join(', ');
            } else {
                alertEl.classList.add('d-none');
            }

            // Tab badge POA (2.14(3))
            var poaCount = poaCountMap[row.dataset.reqNo] || 0;
            var tabPoaBadge = document.getElementById('dTabPoaBadge');
            tabPoaBadge.innerHTML = poaCount > 0
                ? '<span class="badge bg-primary" style="font-size:0.6rem;">' + poaCount + '</span>'
                : '<span class="badge bg-label-secondary" style="font-size:0.6rem;">0</span>';
            // POA summary badge
            var poaSummary = document.getElementById('dPoaSummaryBadge');
            if (poaSummary) {
                poaSummary.innerHTML = poaCount > 0
                    ? '<span class="badge bg-label-primary px-3 py-2"><i class="ri ri-user-shared-line me-1"></i>มีผู้รับมอบอำนาจ ' + poaCount + ' คน</span>'
                    : '<span class="badge bg-label-secondary px-3 py-2"><i class="ri ri-user-shared-line me-1"></i>ยังไม่มีผู้รับมอบอำนาจ</span>';
            }

            // DOF Check Tab (2.14(4))
            var dofData  = dofCheckMap[row.dataset.reqNo] || { status: 'na', rows: [] };
            var dofStatus = dofData.status;

            // Reset visibility
            ['dDofMismatchAlert','dDofIncompleteAlert','dDofNaAlert','dDofCheckTableWrap'].forEach(function(id){
                document.getElementById(id).classList.add('d-none');
            });

            // Tab badge
            var dofBadge = document.getElementById('dTabDofBadge');
            var approveBtn = document.getElementById('dBtnApprove');
            if (dofStatus === 'pass') {
                dofBadge.innerHTML = '<span class="badge bg-success" style="font-size:0.6rem;">✅</span>';
                approveBtn.disabled = false;
            } else if (dofStatus === 'mismatch') {
                dofBadge.innerHTML = '<span class="badge bg-danger" style="font-size:0.6rem;">❌</span>';
                approveBtn.disabled = true;
                approveBtn.title = 'ไม่สามารถอนุมัติได้ — ข้อมูลไม่ตรง DOF List';
                document.getElementById('dDofMismatchAlert').classList.remove('d-none');
            } else if (dofStatus === 'incomplete') {
                dofBadge.innerHTML = '<span class="badge bg-warning" style="font-size:0.6rem;">⚠️</span>';
                approveBtn.disabled = true;
                approveBtn.title = 'ไม่สามารถอนุมัติได้ — ข้อมูลไม่ครบสำหรับตรวจสอบ DOF List';
                document.getElementById('dDofIncompleteAlert').classList.remove('d-none');
            } else {
                dofBadge.innerHTML = '<span class="badge bg-label-secondary" style="font-size:0.6rem;">N/A</span>';
                approveBtn.disabled = false;
                document.getElementById('dDofNaAlert').classList.remove('d-none');
            }

            // Comparison table
            var checkBadge = document.getElementById('dDofCheckBadge');
            if (dofStatus === 'pass') {
                checkBadge.innerHTML = '<span class="badge bg-success px-3 py-2 fs-6"><i class="ri ri-checkbox-circle-line me-1"></i>ตรวจสอบ DOF List ✅ — ข้อมูลตรงกันทุกรายการ</span>';
            } else if (dofStatus === 'na') {
                checkBadge.innerHTML = '<span class="badge bg-label-secondary px-3 py-2"><i class="ri ri-subtract-line me-1"></i>ไม่ใช้งาน DOF List สำหรับผู้ใช้ประเภทนี้</span>';
            } else if (dofStatus === 'mismatch') {
                checkBadge.innerHTML = '<span class="badge bg-danger px-3 py-2 fs-6"><i class="ri ri-error-warning-line me-1"></i>ข้อมูลไม่ตรง DOF List ❌ — ไม่สามารถอนุมัติได้</span>';
            } else {
                checkBadge.innerHTML = '<span class="badge bg-warning px-3 py-2"><i class="ri ri-error-warning-line me-1"></i>ข้อมูลไม่ครบ ⚠️ — ตรวจสอบ DOF List ไม่ได้ครบทุกรายการ</span>';
            }

            if (dofData.rows && dofData.rows.length > 0) {
                document.getElementById('dDofCheckTableWrap').classList.remove('d-none');
                var tbody = document.getElementById('dDofCheckTableBody');
                tbody.innerHTML = '';
                dofData.rows.forEach(function(r) {
                    var rowClass = r.match ? '' : 'table-danger';
                    var resultBadge = r.match
                        ? '<span class="badge bg-label-success">ตรงกัน ✅</span>'
                        : '<span class="badge bg-danger">ไม่ตรง ❌</span>';
                    var systemCellClass = r.match ? '' : 'text-danger fw-semibold';
                    tbody.innerHTML += '<tr class="' + rowClass + '">'
                        + '<td class="fw-semibold text-muted">' + r.label + '</td>'
                        + '<td class="' + systemCellClass + '">' + r.system + '</td>'
                        + '<td>' + r.dof + '</td>'
                        + '<td class="text-center">' + resultBadge + '</td>'
                        + '</tr>';
                });
            }

            new bootstrap.Modal(document.getElementById('detailRegModal')).show();
        });
    });

    // Approve button — open approval modal
    document.querySelectorAll('.btn-approve-reg').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var reqNo = this.dataset.reqNo;
            var fullName = this.dataset.fullName;
            var org = this.dataset.org;
            var reqRole = this.dataset.role;
            var reqAgency = this.dataset.agency || '';
            document.getElementById('approveModalReqNo').textContent = reqNo;
            document.getElementById('approveModalName').textContent = fullName;
            document.getElementById('approveModalOrg').textContent = org;
            // set role default from request
            document.getElementById('approveRoleAssign').value = (reqRole === 'เจ้าหน้าที่') ? 'เจ้าหน้าที่' : 'สมาชิก';
            document.getElementById('approveAgencyAssign').value = reqAgency;
            document.getElementById('approveOfficerSection').classList.toggle('d-none', reqRole !== 'เจ้าหน้าที่');
            document.getElementById('approveIsSignerToggle').checked = false;
            document.getElementById('approveIsApproverToggle').checked = false;
            document.querySelectorAll('.approve-specific-role').forEach(function(cb){ cb.checked = false; });
            document.getElementById('approveResponsibleArea').value = '';
            new bootstrap.Modal(document.getElementById('approveRegModal')).show();
        });
    });

    // Role select in approve modal toggles officer section
    document.getElementById('approveRoleAssign').addEventListener('change', function() {
        document.getElementById('approveOfficerSection').classList.toggle('d-none', this.value !== 'เจ้าหน้าที่');
    });

    // Reject button
    document.querySelectorAll('.btn-reject-reg').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('rejectModalReqNo').textContent = this.dataset.reqNo;
            document.getElementById('rejectModalName').textContent = this.dataset.fullName;
            document.getElementById('rejectReason').value = '';
            new bootstrap.Modal(document.getElementById('rejectRegModal')).show();
        });
    });

    if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { new bootstrap.Tooltip(el); });
    }
});
</script>
}

