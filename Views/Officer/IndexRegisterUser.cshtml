                            <option value="เจ้าหน้าที่">เจ้าหน้าที่ กตส./ศตส.</option>
                            <option value="ผู้ดูแลระบบ">ผู้ดูแลระบบ</option>
                        </select>
                    </div>
                    <!-- Section 2: หน่วยงานสังกัด -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">หน่วยงานสังกัด กตส./ศตส.</label>
                        <select id="approveAgencyAssign" class="form-select">
                            <option value="">— ไม่ระบุ (สมาชิกทั่วไป) —</option>
                            <option value="กตส.">กตส. (กองตรวจสอบสินค้าประมง)</option>
                            <option value="ศตส.เขต 1">ศตส. เขต 1 (สมุทรปราการ)</option>
                            <option value="ศตส.เขต 2">ศตส. เขต 2 (สงขลา)</option>
                            <option value="ศตส.เขต 3">ศตส. เขต 3 (ระยอง)</option>
                            <option value="ศตส.เขต 4">ศตส. เขต 4 (สมุทรสาคร)</option>
                            <option value="ศตส.เขต 5">ศตส. เขต 5 (สุราษฎร์ธานี)</option>
                            <option value="ศตส.เขต 6">ศตส. เขต 6 (ชลบุรี)</option>
                        </select>
                    </div>
                </div>

                <!-- Officer-only section -->
                <div id="approveOfficerSection" class="mt-4 d-none">
                    <hr class="my-2" />
                    <h6 class="fw-semibold mb-3 text-primary"><i class="ri ri-shield-user-line me-1"></i>การกำหนดสิทธิ์เจ้าหน้าที่</h6>

                    <!-- บทบาทพิเศษ -->
                    <label class="form-label fw-semibold">บทบาทพิเศษ</label>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleReceive" value="เจ้าหน้าที่รับเรื่อง">
                                <label class="form-check-label" for="approveRoleReceive">เจ้าหน้าที่รับเรื่อง</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleReview" value="เจ้าหน้าที่พิจารณา">
                                <label class="form-check-label" for="approveRoleReview">เจ้าหน้าที่พิจารณา</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleApproveRMBS" value="ผู้อนุมัติ RMBS1">
                                <label class="form-check-label" for="approveRoleApproveRMBS">ผู้อนุมัติ RMBS1</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleSigner" value="ผู้ลงนามใบรับรอง">
                                <label class="form-check-label" for="approveRoleSigner">ผู้ลงนามใบรับรอง</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleTrace" value="ผู้ตรวจสอบ Trace">
                                <label class="form-check-label" for="approveRoleTrace">ผู้ตรวจสอบ Trace</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input approve-specific-role" type="checkbox" id="approveRoleDOF" value="ผู้จัดการ DOF List">
                                <label class="form-check-label" for="approveRoleDOF">ผู้จัดการ DOF List</label>
                            </div>
                        </div>
                    </div>

                    <!-- พื้นที่รับผิดชอบ -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">พื้นที่รับผิดชอบ <small class="text-muted">(คั่นด้วยคอมมา)</small></label>
                        <input id="approveResponsibleArea" type="text" class="form-control"
                               placeholder="เช่น สมุทรปราการ, ชลบุรี, ระยอง" />
                        <div class="form-text">ระบุจังหวัด/พื้นที่ที่เจ้าหน้าที่รับผิดชอบ</div>
                    </div>

                    <!-- ผู้ลงนาม / ผู้อนุมัติ -->
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card bg-label-info border-0 p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold"><i class="ri ri-quill-pen-line me-1"></i>ผู้ลงนามใบรับรอง</div>
                                        <small class="text-muted">สามารถลงนามใบรับรองได้</small>
                                    </div>
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="approveIsSignerToggle" role="switch">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-label-warning border-0 p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold"><i class="ri ri-shield-check-line me-1"></i>ผู้อนุมัติ</div>
                                        <small class="text-muted">สามารถอนุมัติคำขอได้</small>
                                    </div>
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="approveIsApproverToggle" role="switch">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- หมายเหตุ -->
                <div class="mt-4">
                    <label class="form-label fw-semibold">หมายเหตุ / เหตุผลการอนุมัติ</label>
                    <textarea class="form-control" id="approveNote" rows="2"
                              placeholder="ระบุหมายเหตุ (ถ้ามี)"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-success">
                    <i class="ri ri-check-line me-1"></i>อนุมัติและบันทึก
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: ปฏิเสธคำขอลงทะเบียน -->
<div class="modal fade" id="rejectRegModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">ปฏิเสธคำขอลงทะเบียน</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-flex gap-2 py-2 mb-3">
                    <i class="ri ri-error-warning-line fs-5"></i>
                    <div>คำขอ <strong id="rejectModalReqNo">-</strong> ของ <strong id="rejectModalName">-</strong> จะถูกปฏิเสธ</div>
                </div>
                <label class="form-label fw-semibold">เหตุผลการปฏิเสธ <span class="text-danger">*</span></label>
                <textarea class="form-control" id="rejectReason" rows="3"
                          placeholder="ระบุเหตุผลในการปฏิเสธคำขอ..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-danger">
                    <i class="ri ri-close-circle-line me-1"></i>ยืนยันปฏิเสธ
                </button>
            </div>
        </div>
    </div>
</div>
