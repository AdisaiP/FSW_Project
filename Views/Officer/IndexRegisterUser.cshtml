<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="#" class="text-primary fw-semibold">เจ้าหน้าที่</a></li>
        <li class="breadcrumb-item active text-secondary">ลงทะเบียนผู้ใช้งาน</li>
    </ol>
</nav>

<!-- Summary Cards -->
<div class="row mb-6 g-6">
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@pendingRegistrations.Length</h5>
                        <small>คำขอทั้งหมด</small>
                    </div>
                    <span class="badge bg-label-primary rounded-circle p-2">
                        <i class="icon-base ri ri-user-settings-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@pendingCount</h5>
                        <small>รอตรวจสอบ</small>
                    </div>
                    <span class="badge bg-label-warning rounded-circle p-2">
                        <i class="icon-base ri ri-user-add-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@approvedCount</h5>
                        <small>อนุมัติแล้ว</small>
                    </div>
                    <span class="badge bg-label-success rounded-circle p-2">
                        <i class="icon-base ri ri-user-follow-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@officerCount</h5>
                        <small>เจ้าหน้าที่รออนุมัติ</small>
                    </div>
                    <span class="badge bg-label-info rounded-circle p-2">
                        <i class="icon-base ri ri-shield-user-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-@(dataCompleteCount == pendingRegistrations.Length ? "success" : "warning") border-2">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="content-left">
                        <h5 class="mb-1">@dataCompleteCount/@pendingRegistrations.Length</h5>
                        <small>ข้อมูลผู้ประกอบการครบถ้วน</small>
                    </div>
                    <span class="badge bg-label-@(dataCompleteCount == pendingRegistrations.Length ? "success" : "warning") rounded-circle p-2">
                        <i class="icon-base ri ri-building-2-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="card-title mb-1">ค้นหาคำขอลงทะเบียน</h5>
            <p class="text-muted small mb-0">ค้นหาตามชื่อ อีเมล องค์กร หรือสถานะคำขอ</p>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5 col-lg-5">
                <label for="filterKeyword" class="form-label">ค้นหา</label>
                <input id="filterKeyword" type="text" class="form-control" placeholder="ชื่อ / อีเมล / องค์กร" />
            </div>
            <div class="col-md-2 col-lg-2">
                <label for="filterRole" class="form-label">บทบาทที่ขอ</label>
                <select id="filterRole" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="สมาชิก">สมาชิก</option>
                    <option value="เจ้าหน้าที่">เจ้าหน้าที่ กตส./ศตส.</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-2">
                <label for="filterStatus" class="form-label">สถานะ</label>
                <select id="filterStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="รอตรวจสอบ">รอตรวจสอบ</option>
                    <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                    <option value="ปฏิเสธ">ปฏิเสธ</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-4">
                <div class="d-flex gap-2 filter-action-buttons">
                    <button type="button" id="btnSearch" class="btn btn-outline-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการขอลงทะเบียน</h5>
            <p class="text-muted small mb-0">แสดงคำขอลงทะเบียนผู้ใช้งานระบบใบรับรองสัตว์น้ำ</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-primary btn-sm">
                <i class="ri ri-user-add-line me-1"></i>สร้างบัญชีผู้ใช้
            </button>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered align-middle mb-0 reg-table-compact">
            <thead class="text-center">
                <tr>
                    <th style="width:50px">#</th>
                    <th>เลขที่คำขอ</th>
                    <th>ชื่อ-สกุล</th>
                    <th>อีเมล</th>
                    <th>องค์กร / หน่วยงาน</th>
                    <th>บทบาทที่ขอ</th>
                    <th>สังกัดที่ขอ</th>
                    <th>วันที่ยื่น</th>                    <th>ข้อมูลผู้ประกอบการ</th>                    <th>สถานะ</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody id="regTableBody">
                @foreach (var r in pendingRegistrations)
                {
                    <tr data-id="@r.ReqNo" data-status="@r.StatusText" data-role="@r.RequestedRole" data-search-text="@r.FullName.ToLower() @r.Email.ToLower() @r.Organization.ToLower()"
                        data-req-no="@r.ReqNo" data-full-name="@r.FullName" data-email="@r.Email"
                        data-org="@r.Organization" data-org-role="@r.RequestedRole" data-agency="@r.RequestedAgency"
                        data-submitted="@r.SubmittedAt.ToString("dd/MM/yyyy HH:mm")"
                        data-company-th="@r.CompanyNameTH" data-company-en="@r.CompanyNameEN"
                        data-address-th="@r.AddressTH" data-address-en="@r.AddressEN"
                        data-tax-id="@r.TaxId" data-branch-no="@r.BranchNo"
                        data-phone-cc="@r.PhoneCC" data-phone="@r.Phone"
                        data-fax-cc="@r.FaxCC" data-fax="@r.Fax"
                        data-complete="@r.DataComplete.ToString().ToLower()">
                        <td class="text-center text-muted">@r.RowNo</td>
                        <td><span class="fw-semibold text-primary">@r.ReqNo</span></td>
                        <td>@r.FullName</td>
                        <td>@r.Email</td>
                        <td>
                            @r.Organization
                            @if (!string.IsNullOrEmpty(r.RequestedAgency))
                            {
                                <br/><small class="text-muted"><i class="ri ri-government-line me-1"></i>@r.RequestedAgency</small>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill @(r.RequestedRole == "เจ้าหน้าที่" ? "bg-label-info" : "bg-label-secondary")">@r.RequestedRole</span>
                        </td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(r.RequestedAgency))
                            {
                                <span class="badge bg-label-primary">@r.RequestedAgency</span>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td>@r.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            @if (r.DataComplete)
                            {
                                <span class="badge bg-success">
                                    <i class="ri ri-checkbox-circle-line me-1"></i>ข้อมูลครบถ้วน ✅
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-label-warning">
                                    <i class="ri ri-error-warning-line me-1"></i>ข้อมูลไม่ครบ ⚠️
                                </span>
                            }
                        </td>
                        <td class="text-center"><span class="badge rounded-pill @r.StatusClass">@r.StatusText</span></td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <button class="btn btn-icon btn-sm btn-outline-info btn-view-detail"
                                        data-row="@r.ReqNo"
                                        data-bs-toggle="tooltip" title="ดูรายละเอียด (ข้อมูลผู้ประกอบการ)">
                                    <i class="ri ri-eye-line text-info"></i>
                                </button>
                                @if (r.StatusText == "รอตรวจสอบ")
                                {
                                    <button class="btn btn-icon btn-sm btn-outline-success btn-approve-reg"
                                            data-req-no="@r.ReqNo" data-full-name="@r.FullName"
                                            data-org="@r.Organization" data-role="@r.RequestedRole"
                                            data-agency="@r.RequestedAgency"
                                            data-bs-toggle="tooltip" title="อนุมัติ">
                                        <i class="ri ri-check-line text-success"></i>
                                    </button>
                                    <button class="btn btn-icon btn-sm btn-outline-danger btn-reject-reg"
                                            data-req-no="@r.ReqNo" data-full-name="@r.FullName"
                                            data-bs-toggle="tooltip" title="ปฏิเสธ">
                                        <i class="ri ri-close-line text-danger"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="regTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ======================================================
     Modal: รายละเอียดผู้ลงทะเบียน + ข้อมูลผู้ประกอบการ (TOR 2.14(1))
     ====================================================== -->
<div class="modal fade" id="detailRegModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="ri ri-file-user-line me-2"></i>
                    รายละเอียดคำขอลงทะเบียน — <span id="dModalReqNo">-</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pb-2">
                <!-- completeness badge -->
                <div id="dBadgeComplete" class="mb-3"></div>

                <!-- Tabs -->
                <ul class="nav nav-tabs mb-4" id="detailTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="tab-user-info" data-bs-toggle="tab" data-bs-target="#pane-user-info" type="button" role="tab">
                            <i class="ri ri-user-line me-1"></i>ข้อมูลผู้ใช้
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-exporter" data-bs-toggle="tab" data-bs-target="#pane-exporter" type="button" role="tab">
                            <i class="ri ri-building-2-line me-1"></i>ข้อมูลผู้ประกอบการ (Exporter)
                            <span id="dTabExporterBadge" class="ms-1"></span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-poa" data-bs-toggle="tab" data-bs-target="#pane-poa" type="button" role="tab">
                            <i class="ri ri-user-shared-line me-1"></i>ผู้รับมอบอำนาจ
                            <span id="dTabPoaBadge" class="ms-1"></span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-dof-check" data-bs-toggle="tab" data-bs-target="#pane-dof-check" type="button" role="tab">
                            <i class="ri ri-search-eye-line me-1"></i>ตรวจสอบ DOF List
                            <span id="dTabDofBadge" class="ms-1"></span>
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- Tab 1: ข้อมูลผู้ใช้ -->
                    <div class="tab-pane fade show active" id="pane-user-info" role="tabpanel">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">เลขที่คำขอ</label>
                                <div class="fw-semibold text-primary" id="dReqNo">-</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">ชื่อ-สกุล</label>
                                <div id="dFullName">-</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">อีเมล</label>
                                <div id="dEmail">-</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">องค์กร / หน่วยงาน</label>
                                <div id="dOrg">-</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">บทบาทที่ขอ</label>
                                <div id="dRole">-</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-muted small">วันที่ยื่นคำขอ</label>
                                <div id="dSubmitted">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Tab 2: ข้อมูลผู้ประกอบการ (Exporter) — TOR 2.14(1) -->
                    <div class="tab-pane fade" id="pane-exporter" role="tabpanel">
                        <div class="alert alert-info border-0 py-2 mb-4 small">
                            <i class="ri ri-information-line me-1"></i>
                            <strong>2.14(1)</strong> ข้อมูลนี้จะถูกนำส่งสู่ระบบออกใบรับรองสัตว์น้ำโดยอัตโนมัติหลังอนุมัติการลงทะเบียน
                        </div>

                        <!-- ชื่อบริษัท TH/EN -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    ชื่อบริษัท / ผู้ประกอบการ <span class="text-muted">(ไทย)</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="dCompanyTH" class="form-control-plaintext border rounded px-3 py-2 bg-light">-</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Company Name <span class="text-muted">(English)</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="dCompanyEN" class="form-control-plaintext border rounded px-3 py-2 bg-light">-</div>
                            </div>
                        </div>

                        <!-- ที่อยู่ TH/EN -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    ที่อยู่ <span class="text-muted">(ไทย)</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="dAddressTH" class="form-control-plaintext border rounded px-3 py-2 bg-light" style="min-height:56px;white-space:pre-wrap;">-</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Address <span class="text-muted">(English)</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="dAddressEN" class="form-control-plaintext border rounded px-3 py-2 bg-light" style="min-height:56px;white-space:pre-wrap;">-</div>
                            </div>
                        </div>

                        <!-- เลขผู้เสียภาษี + ลำดับสาขา -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    เลขประจำตัวผู้เสียภาษีอากร <span class="text-danger">*</span>
                                </label>
                                <div id="dTaxId" class="form-control-plaintext border rounded px-3 py-2 bg-light font-monospace">-</div>
                                <div class="form-text">13 หลัก (นิติบุคคล)</div>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold">
                                    ลำดับสาขา <span class="text-danger">*</span>
                                </label>
                                <div id="dBranchNo" class="form-control-plaintext border rounded px-3 py-2 bg-light font-monospace">-</div>
                                <div class="form-text">5 หลัก (00000 = สำนักงานใหญ่)</div>
                            </div>
                            <div class="col-md-6">
                                <div class="alert border-0 py-2 bg-label-secondary small mt-4">
                                    <i class="ri ri-information-line me-1"></i>
                                    สำนักงานใหญ่ = 00000 &nbsp;|&nbsp; สาขา 1 = 00001 &nbsp;|&nbsp; สาขา 2 = 00002
                                </div>
                            </div>
                        </div>

                        <!-- โทรศัพท์ + โทรสาร (พร้อมรหัสประเทศ) -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    โทรศัพท์ (พร้อมรหัสประเทศ) <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light fw-semibold" id="dPhoneCC" style="min-width:70px;">+66</span>
                                    <div id="dPhone" class="form-control bg-light py-2 px-3">-</div>
                                </div>
                                <div class="form-text">รหัสประเทศ + เบอร์โทรศัพท์ (เช่น +66 02-123-4567)</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    โทรสาร / Fax (พร้อมรหัสประเทศ)
                                    <span class="text-muted">(ถ้ามี)</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light fw-semibold" id="dFaxCC" style="min-width:70px;">+66</span>
                                    <div id="dFax" class="form-control bg-light py-2 px-3">-</div>
                                </div>
                                <div class="form-text">รหัสประเทศ + หมายเลขโทรสาร</div>
                            </div>
                        </div>

                        <!-- Missing fields alert -->
                        <div id="dMissingAlert" class="d-none">
                            <div class="alert alert-warning border-0 py-2 small">
                                <i class="ri ri-error-warning-line me-1"></i>
                                <strong>ข้อมูลไม่ครบถ้วน</strong> — ฟิลด์ที่ยังขาด:
                                <span id="dMissingList" class="fw-semibold text-danger"></span>
                                <br/>เจ้าหน้าที่ควรติดต่อผู้ประกอบการเพื่อขอข้อมูลเพิ่มเติมก่อนอนุมัติ
                            </div>
                        </div>

                        <!-- Edit hint -->
                        <div class="alert alert-secondary border-0 py-2 mt-3 small">
                            <i class="ri ri-edit-line me-1"></i>
                            <strong>หมายเหตุ:</strong> เจ้าหน้าที่สามารถแก้ไขข้อมูลผู้ประกอบการได้ใน Admin &gt; จัดการผู้ใช้
                            หลังอนุมัติการลงทะเบียนแล้ว &nbsp;|&nbsp;
                            ข้อมูลจะถูกนำส่งสู่ระบบออกใบรับรองโดยอัตโนมัติ
                        </div>
                    </div>

                    <!-- Tab 3: ผู้รับมอบอำนาจ — TOR 2.14(3) -->
                    <div class="tab-pane fade" id="pane-poa" role="tabpanel">
                        <div class="alert alert-info border-0 py-2 mb-3 small">
                            <i class="ri ri-information-line me-1"></i>
                            <strong>2.14(3)</strong> ผู้รับมอบอำนาจ (นิติบุคคลและบุคคลธรรมดา)
                            สามารถดำเนินการแทนผู้มอบอำนาจได้ทั้งหมดในระบบออกใบรับรองสัตว์น้ำ
                        </div>

                        <div class="d-flex align-items-center justify-content-between mb-3">
