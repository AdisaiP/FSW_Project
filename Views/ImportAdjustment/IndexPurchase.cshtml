@section VendorScripts {
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['filterDateFrom', 'filterDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var d = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10) - 1;
            var y = parseInt(parts[2], 10);
            var dt = new Date(y, m, d, endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
            return Number.isNaN(dt.getTime()) ? null : dt;
        }

        function filterRows() {
            var imdNo = (document.getElementById('filterImdNumber').value || '').trim().toLowerCase();
            var docType = (document.getElementById('filterDocType').value || '').trim();
            var statusVal = (document.getElementById('filterStatus').value || '').trim();
            var vessel = (document.getElementById('filterVessel').value || '').trim().toLowerCase();
            var gear = (document.getElementById('filterGear').value || '').trim().toLowerCase();
            var captain = (document.getElementById('filterCaptain').value || '').trim().toLowerCase();
            var ccNo = (document.getElementById('filterCcNumber').value || '').trim().toLowerCase();
            var product = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
            var allocation = (document.getElementById('filterAllocation').value || '').trim();
            var changeType = (document.getElementById('filterChangeType').value || '').trim();
            var fromDate = parseDateInput(document.getElementById('filterDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDateTo').value, true);

            var rows = document.querySelectorAll('#imdTableBody tr[data-row]');
            var visible = 0;

            rows.forEach(function (row) {
                var match =
                    (!imdNo || (row.dataset.imdNumber || '').toLowerCase().includes(imdNo)) &&
                    (!docType || row.dataset.docType === docType) &&
                    (!statusVal || row.dataset.status === statusVal) &&
                    (!vessel || (row.dataset.vessel || '').toLowerCase().includes(vessel)) &&
                    (!gear || (row.dataset.gear || '').toLowerCase().includes(gear)) &&
                    (!captain || (row.dataset.captain || '').toLowerCase().includes(captain)) &&
                    (!ccNo || (row.dataset.ccNumber || '').toLowerCase().includes(ccNo)) &&
                    (!product || (row.dataset.product || '').toLowerCase().includes(product)) &&
                    (!allocation || row.dataset.allocation === allocation) &&
                    (!changeType || row.dataset.changeType === changeType) &&
                    (!fromDate || new Date(row.dataset.txDate) >= fromDate) &&
                    (!toDate || new Date(row.dataset.txDate) <= toDate);

                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });

            document.getElementById('imdTableEmpty').classList.toggle('d-none', visible !== 0);
        }

        document.getElementById('btnSearch').addEventListener('click', filterRows);
        document.getElementById('btnReset').addEventListener('click', function () {
            ['filterImdNumber', 'filterVessel', 'filterGear', 'filterCaptain', 'filterCcNumber', 'filterProduct', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            ['filterDocType', 'filterStatus', 'filterAllocation', 'filterChangeType'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            filterRows();
        });

        ['filterDocType', 'filterStatus', 'filterAllocation', 'filterChangeType'].forEach(function (id) {
            document.getElementById(id).addEventListener('change', filterRows);
        });

        ['filterImdNumber', 'filterVessel', 'filterGear', 'filterCaptain', 'filterCcNumber', 'filterProduct', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
            document.getElementById(id).addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });
    });
</script>
}

@* ===== Content ===== *@
<h4 class="mb-1">ขออนุมัติปริมาณ (จับคู่ซื้อต่อ)</h4>
<p class="mb-1">แสดงรายการขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์นํ้านำเข้าซื้อต่อ</p>

<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexPurchase", "ImportAdjustment")" class="text-primary fw-semibold">ขออนุมัติปริมาณ
                (จับคู่ซื้อต่อ)</a>
        </li>
    </ol>
</nav>

<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">ค้นหารายการ</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <!-- Row 1 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterImdNumber" class="form-label filter-form-label">เลขที่ IMD</label>
                <input type="text" id="filterImdNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ IMD" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDocType" class="form-label filter-form-label">ประเภทเอกสารใช้ในการจับคู่</label>
                <select id="filterDocType" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="cc">CC</option>
                    <option value="scc">SCC</option>
                    <option value="other">Other Document</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label filter-form-label">สถานะ</label>
                <select id="filterStatus" class="form-select form-select-sm">
                    <option value="">-- เลือกข้อมูล --</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterVessel" class="form-label filter-form-label">ชื่อเรือประมง</label>
                <input type="text" id="filterVessel" class="form-control form-control-sm" placeholder="ระบุชื่อเรือประมง" />
            </div>
            <!-- Row 2 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterGear" class="form-label filter-form-label">ชื่อเครื่องมือที่ใช้จับ</label>
                <input type="text" id="filterGear" class="form-control form-control-sm" placeholder="ระบุชื่อเครื่องมือ" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCaptain" class="form-label filter-form-label">กัปตัน/ผู้ควบคุมเรือ</label>
                <input type="text" id="filterCaptain" class="form-control form-control-sm" placeholder="ระบุชื่อกัปตัน" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCcNumber" class="form-label filter-form-label">CC/SCC/OtherDocument Number</label>
                <input type="text" id="filterCcNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่เอกสาร" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterProduct" class="form-label filter-form-label">สินค้าประมง</label>
                <input type="text" id="filterProduct" class="form-control form-control-sm" placeholder="ระบุสินค้าประมง" />
            </div>
            <!-- Row 3 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterAllocation" class="form-label filter-form-label">รูปแบบการจัดสรร</label>
                <select id="filterAllocation" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="all">จัดสรรทั้งหมด</option>
                    <option value="partial">จัดสรรบางส่วน</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterChangeType" class="form-label filter-form-label">ประเภทการขอเปลี่ยนแปลง</label>
                <select id="filterChangeType" class="form-select form-select-sm">
                    <option value="">-- เลือกข้อมูล --</option>
                    <option value="change">ขอเปลี่ยนแปลง</option>
                    <option value="cancel">ขอยกเลิก</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDateFrom" class="form-label filter-form-label">วันที่ทำรายการ</label>
                <input type="text" id="filterDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDateTo" class="form-label filter-form-label">ถึง</label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="text" id="filterDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    <button type="button" id="btnSearch" class="btn btn-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการ IMD</h5>
            <p class="text-muted small mb-0">แสดงรายการขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์น้ำนำเข้าครั้งแรก</p>
        </div>
        <a href="@Url.Action("CreatePurchase", "ImportAdjustment")" class="btn btn-primary btn-sm">
            <i class="ri ri-add-line me-1"></i> สร้างคำขอ
        </a>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 imd-table">
            <thead class="text-center">
                <tr>
                    <th>วันที่</th>
                    <th style="min-width:300px;">เลขที่ IMD</th>
                    <th>เลขที่ CC</th>
                    <th>Validation date</th>
                    <th>ชื่อเรือประมง</th>
                    <th>ชื่อเครื่องมือ</th>
                    <th>Catch description</th>
                    <th>สินค้าประมง</th>
                    <th>ปริมาณสัตว์น้ำใน CC</th>
                    <th>ปริมาณสัตว์น้ำเข้าโรงงาน</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="imdTableBody">
                @foreach (var rec in imdRecords)
                {
                    <tr data-row="@rec.RowNo"
                        data-imd-number="@rec.ImdNumber"
                        data-doc-type="@rec.DocumentType"
                        data-status="@rec.StatusText"
                        data-vessel="@rec.VesselName"
                        data-gear="@rec.GearType"
                        data-captain=""
                        data-cc-number="@rec.CcNumber"
                        data-product="@rec.FisheryProducts"
                        data-allocation="all"
                        data-change-type=""
                        data-tx-date="@rec.TransactionDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="text-nowrap">@rec.TransactionDate.ToString("dd/MM/yyyy")<br /><small class="text-muted">(@rec.TransactionDate.ToString("HH:mm:ss"))</small></td>
                        <td>
                            @{
                                var docTypeLabel = rec.DocumentType == "cc" ? "เอกสาร CC" :
                                                   rec.DocumentType == "scc" ? "เอกสาร SCC" : "เอกสาร Other Document กรมประมงกำหนด";
                            }
                            <div class="fw-semibold">@rec.ImdNumber</div>
                            <div class="mt-1">
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-success rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-check-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">แหล่งที่มา :</span> ภายนอกระบบ [FSW]
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-info rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-building-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">ประเภทเอกสารที่ใช้จับคู่ :</span> @docTypeLabel
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-danger rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-warning-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">รูปแบบการจัดสรร :</span> First Come First Serve
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge bg-label-warning rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-list-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะ :</span> <span class="ms-1">@rec.StatusText</span>
                                </div>
                            </div>
                        </td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@rec.ValidationDate.ToString("dd/MM/yyyy")</td>
                        <td>@rec.VesselName</td>
                        <td>@rec.GearType</td>
                        <td>@rec.CatchDescription</td>
                        <td style="max-width:220px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyInCC.ToString("N2")</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <a href="@Url.Action("CreateIMD", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-pencil-line text-warning"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="คัดลอก" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-file-copy-line text-secondary"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบ" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-delete-bin-line text-danger"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="12" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
