        <i class="ri ri-file-list-3-line me-1"></i>ดูเอกสาร P1
    </a>
</div>

<!-- Table card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการขออนุมัติปริมาณ (จับคู่ซื้อต่อ)</h5>
            <p class="text-muted small mb-0">แสดงรายการขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์น้ำนำเข้าซื้อต่อ</p>
        </div>
        <a href="@Url.Action("CreatePurchase", "ImportAdjustment")" class="btn btn-primary btn-sm">
            <i class="ri ri-add-line me-1"></i> สร้างคำขอ
        </a>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 imd-table">
            <thead class="text-center">
                <tr>
                    <th>วันที่</th>
                    <th style="min-width:300px;">เลขที่ IMD</th>
                    <th>เลขที่ CC</th>
                    <th>Validation date</th>
                    <th>ชื่อเรือประมง</th>
                    <th>ชื่อเครื่องมือ</th>
                    <th>Catch description</th>
                    <th>สินค้าประมง</th>
                    <th>ปริมาณสัตว์น้ำใน CC</th>
                    <th>ปริมาณสัตว์น้ำเข้าโรงงาน</th>
                    <th>เลขที่ P1 (ผู้ซื้อ)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="imdTableBody">
                @foreach (var rec in imdRecords)
                {
                    <tr data-row="@rec.RowNo"
                        data-imd-number="@rec.ImdNumber"
                        data-doc-type="@rec.DocumentType"
                        data-status="@rec.StatusText"
                        data-vessel="@rec.VesselName"
                        data-gear="@rec.GearType"
                        data-captain=""
                        data-cc-number="@rec.CcNumber"
                        data-product="@rec.FisheryProducts"
                        data-allocation="all"
                        data-change-type=""
                        data-tx-date="@rec.TransactionDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="text-nowrap">@rec.TransactionDate.ToString("dd/MM/yyyy")<br /><small class="text-muted">(@rec.TransactionDate.ToString("HH:mm:ss"))</small></td>
                        <td>
                            @{
                                var docTypeLabel = rec.DocumentType == "cc" ? "เอกสาร CC" :
                                                   rec.DocumentType == "scc" ? "เอกสาร SCC" : "เอกสาร Other Document กรมประมงกำหนด";
                            }
                            <div class="fw-semibold">@rec.ImdNumber</div>
                            <div class="mt-1">
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-success rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-check-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">แหล่งที่มา :</span> ภายนอกระบบ [FSW]
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-info rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-building-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">ประเภทเอกสารที่ใช้จับคู่ :</span> @docTypeLabel
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-danger rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-warning-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">รูปแบบการจัดสรร :</span> First Come First Serve
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge bg-label-warning rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-list-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะ :</span> <span class="ms-1">@rec.StatusText</span>
                                </div>
                            </div>
                        </td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@rec.ValidationDate.ToString("dd/MM/yyyy")</td>
                        <td>@rec.VesselName</td>
                        <td>@rec.GearType</td>
                        <td>@rec.CatchDescription</td>
                        <td style="max-width:220px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyInCC.ToString("N2")</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <!-- เลขที่ P1 (ผู้ซื้อ) (TOR 1.6(5)) -->
                        <td class="text-nowrap">
                            @if (rec.P1BuyerNumber != "—")
                            {
                                <a href="@Url.Action("IndexP1", "ImportAdjustment")" class="text-success fw-semibold">
                                    @rec.P1BuyerNumber
                                </a>
                                <br />
                                <span class="badge bg-label-success" style="font-size:10px;">
                                    <i class="ri ri-robot-line me-1"></i>ออกอัตโนมัติ
                                </span>
                            }
                            else if (rec.BuyerConfirmStatus == "รอยืนยันรับซื้อ")
                            {
                                <span class="badge bg-label-warning" style="font-size:10px;">
                                    <i class="ri ri-time-line me-1"></i>รอยืนยัน
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <a href="@Url.Action("CreateIMD", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                @if (rec.BuyerConfirmStatus == "รอยืนยันรับซื้อ")
                                {
                                    <!-- ปุ่ม ยืนยันรับซื้อ (TOR 1.6(5)) -->
                                    <button type="button" class="btn btn-sm btn-outline-success"
                                        style="font-size:0.72rem;padding:2px 8px;"
                                        title="ยืนยันรับซื้อผลิตภัณฑ์และรับเลขที่ P1"
                                        onclick="showBuyerConfirmModal('@rec.ImdNumber', '@rec.FisheryProducts', '@rec.QtyEnteringFactory.ToString("N2")')">
                                        <i class="ri ri-check-double-line me-1"></i>ยืนยันรับซื้อ
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </button>
                                }
                                else if (rec.BuyerConfirmStatus == "รับซื้อแล้ว")
                                {
                                    <!-- รับซื้อแล้ว: ดู P1 -->
                                    <a href="@Url.Action("IndexP1", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-success" title="ดูเอกสาร P1" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-file-list-3-line text-success"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="คัดลอก" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="alert('คัดลอกรายการ (mockup)')">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </button>
                                    <a href="@Url.Action("CreateChangeRMBS1", "ImportAdjustment")"
                                        class="btn btn-sm btn-icon btn-outline-primary" title="ขอเปลี่ยนแปลงผลการพิจารณา" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-loop-right-line text-primary"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="คัดลอก" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning btn-cancel-purchase"
                                        title="ยกเลิกการซื้อขาย" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-forbid-2-line text-warning"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบ" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="13" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== Modal: ยืนยันยกเลิกการซื้อขาย ==================== -->
