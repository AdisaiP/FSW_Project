                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge @rec.CertificationStatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri @rec.CertificationStatusIcon" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะเอกสารรับรอง :</span> @rec.CertificationStatusText
                                </div>
                            </div>
                        </td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.TransactionDate)</td>
                        <td class="text-center">
                            <div>@rec.ImdNumber</div>
                            <div class="text-muted">(@ToThaiDate(rec.ValidationDate))</div>
                        </td>
                        <td>@rec.VesselName</td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.FishingStartDate)-<br />@ToThaiDate(rec.FishingEndDate)</td>
                        <td>@rec.GearType</td>
                        <td style="max-width:280px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <td class="text-center">
                            @{
                                var pct = rec.QtyEnteringFactory > 0 ? (rec.QtyEnteringFactory - 3700) / rec.QtyEnteringFactory * 100 : 100;
                                string quotaBadgeClass = pct > 10 ? "bg-success" : (pct > 0 ? "bg-warning" : "bg-danger");
                                string quotaBadgeIcon = pct > 10 ? "ri-checkbox-circle-line" : (pct > 0 ? "ri-alert-line" : "ri-close-circle-line");
                                string quotaBadgeText = pct > 10 ? "โควตาปกติ" : (pct > 0 ? "โควตาเหลือน้อย" : "โควตาหมด");
                            }
                            <span class="badge @quotaBadgeClass">
                                <i class="ri @quotaBadgeIcon me-1"></i>@quotaBadgeText
                            </span>
                            <div class="text-muted small mt-1">@(rec.QtyEnteringFactory > 0 ? $"{(rec.QtyEnteringFactory - 3700):N0} / {rec.QtyEnteringFactory:N0} กก." : "—")</div>
                        </td>
                        <td class="text-center">
                            <span class="badge @rec.StatusClass">@rec.StatusText</span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="@Url.Action("CreateAdjustRMBS1PS", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-primary me-1" title="แก้ไข">
                                <i class="ri ri-pencil-line"></i>
                            </a>
                            @if (rec.StatusText == "รออนุมัติ")
                            {
                                <button type="button" class="btn btn-sm btn-icon btn-outline-warning me-1" title="ยกเลิกคำขอ"
                                    onclick="if(confirm('ยืนยันยกเลิกคำขอ RMBS1:PS นี้?')) alert('ยกเลิกคำขอเรียบร้อย (mockup)')">
                                    <i class="ri ri-close-circle-line"></i>
                                </button>
                            }
                            @if (rec.StatusText == "อนุมัติแล้ว")
                            {
                                <button type="button" class="btn btn-sm btn-icon btn-outline-danger me-1 btn-ps-pdf"
                                    title="ดูเอกสาร RMBS1:PS"
                                    data-bs-toggle="modal" data-bs-target="#modalPsPdfPreview">
                                    <i class="ri ri-file-pdf-line"></i>
                                </button>
                            }
                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบ"
                                onclick="if(confirm('ต้องการลบรายการนี้?')) alert('ลบเรียบร้อย (mockup)')">
                                <i class="ri ri-delete-bin-line"></i>
                            </button>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="12" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== Modal: ดูเอกสาร RMBS1:PS (PDF Preview) ==================== -->
<div class="modal fade" id="modalPsPdfPreview" tabindex="-1" aria-labelledby="modalPsPdfPreviewLabel" aria-hidden="true">
