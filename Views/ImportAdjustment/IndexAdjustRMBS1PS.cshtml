                    <!-- Species table -->
                    <div style="margin-bottom:1rem;">
                        <div style="font-weight:700;margin-bottom:0.3rem;ชนิดสัตว์น้ำ">ชนิดสัตว์น้ำและปริมาณ:</div>
                        <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
                            <thead>
                                <tr style="background:#e8f5e9;">
                                    <th style="border:1px solid #aaa;padding:4px 8px;ชนิด">รหัส HS</th>
                                    <th style="border:1px solid #aaa;padding:4px 8px;">ชนิดสัตว์น้ำ</th>
                                    <th style="border:1px solid #aaa;padding:4px 8px;text-align:right;">ปริมาณ (KGM)</th>
                                    <th style="border:1px solid #aaa;padding:4px 8px;text-align:center;">หน่วย</th>
