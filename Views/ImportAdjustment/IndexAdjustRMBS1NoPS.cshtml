            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterImdNumber" class="form-label filter-form-label">เลขที่ IMD</label>
                <input type="text" id="filterImdNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ IMD" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterCcNumber" class="form-label filter-form-label">เลขที่ Catch Certificate</label>
                <input type="text" id="filterCcNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ Catch Certificate" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterVessel" class="form-label filter-form-label">ชื่อเรือประมง</label>
                <input type="text" id="filterVessel" class="form-control form-control-sm" placeholder="ระบุชื่อเรือประมง" />
            </div>
            <div class="col-md-6 col-xl-4">
                <label for="filterRegistrationNo" class="form-label filter-form-label">เลขทะเบียนเรือ</label>
                <input type="text" id="filterRegistrationNo" class="form-control form-control-sm" placeholder="ระบุเลขทะเบียนเรือ" />
            </div>
            <div class="col-12">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label filter-form-label">ช่วงวันที่บันทึก</label>
                        <input type="text" id="filterLogDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label for="filterLogDateTo" class="form-label filter-form-label">ถึงวันที่</label>
                        <input type="text" id="filterLogDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="form-check mb-1">
                            <input class="form-check-input" type="checkbox" id="filterLogDateExclude" />
                            <label class="form-check-label small" for="filterLogDateExclude">ไม่อยู่ในช่วง</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label filter-form-label">ช่วงเวลาทำการประมง</label>
                        <input type="text" id="filterFishingDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label for="filterFishingDateTo" class="form-label filter-form-label">ถึงวันที่</label>
                        <input type="text" id="filterFishingDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    </div>
                    <div class="col-auto">
                        <div class="range-actions">
                            <button type="button" id="btnSearch" class="btn btn-primary btn-square" title="ค้นหา">
                                <i class="ri ri-search-line"></i>
                            </button>
                            <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                                <i class="ri ri-refresh-line"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการการควบคุมปริมาณวัตถุดิบสัตว์นํ้านำเข้า (RMBS1:NoPS)</h5>
            <p class="text-muted small mb-0">แสดงรายการการควบคุมปริมาณวัตถุดิบสัตว์นํ้านำเข้า (RMBS1:NoPS)

</p>
        </div>
        <div>
            <a href="@Url.Action("CreateAdjustRMBS1NoPS", "ImportAdjustment", new { mode = "create" })" class="btn btn-primary btn-sm">
                <i class="ri ri-add-line me-1"></i> สร้างคำขอใหม่
            </a>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 imd-table">
            <thead class="text-center">
                <tr>
                    <th style="min-width:280px;">เลขที่ RMBS1</th>
                    <th>วันที่บันทึก</th>
                    <th style="min-width:160px;">เลขที่ IMD (วันที่)</th>
                    <th>ชื่อเรือประมง</th>
                    <th>เลขที่ Catch Certificate</th>
                    <th style="min-width:140px;">ช่วงเวลาทำการประมง</th>
                    <th>เครื่องมือทำการประมง</th>
                    <th style="min-width:280px;">ชนิดสัตว์น้ำ</th>
                    <th>ปริมาณสัตว์น้ำเข้าโรงงาน</th>
                    <th style="min-width:130px;">สถานะอนุมัติ</th>
                    <th style="min-width:130px;">จัดการ</th>
                </tr>
            </thead>
            <tbody id="imdTableBody">
                @foreach (var rec in imdRecords)
                {
                    <tr data-row="@rec.RowNo"
                        data-rmbs1-number="@rec.Rmbs1Number"
                        data-imd-number="@rec.ImdNumber"
                        data-doc-type="@rec.DocumentType"
                        data-status="@rec.StatusText"
                        data-vessel="@rec.VesselName"
                        data-registration-no="@rec.RegistrationNo"
                        data-fishing-start-date="@rec.FishingStartDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-fishing-end-date="@rec.FishingEndDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-gear="@rec.GearType"
                        data-captain=""
                        data-cc-number="@rec.CcNumber"
                        data-product="@rec.FisheryProducts"
                        data-allocation="all"
                        data-change-type=""
                        data-tx-date="@rec.TransactionDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td>
                            <a href="@Url.Action("CreateAdjustRMBS1NoPS", "ImportAdjustment", new { mode = "view", rmbs1No = rec.Rmbs1Number })" class="fw-semibold text-primary text-decoration-none">@rec.Rmbs1Number</a>
                            <div class="mt-1">
                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge @rec.CertificationStatusClass rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri @rec.CertificationStatusIcon" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะเอกสารรับรอง :</span> @rec.CertificationStatusText
                                </div>
                            </div>
                        </td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.TransactionDate)</td>
                        <td class="text-center">
                            <div>@rec.ImdNumber</div>
                            <div class="text-muted">(@ToThaiDate(rec.ValidationDate))</div>
                        </td>
                        <td>@rec.VesselName</td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@ToThaiDate(rec.FishingStartDate)-<br />@ToThaiDate(rec.FishingEndDate)</td>
                        <td>@rec.GearType</td>
                        <td style="max-width:280px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <td class="text-center">
                            @if (rec.StatusText == "อนุมัติแล้ว")
                            {
                                <span class="badge bg-success"><i class="ri ri-checkbox-circle-line me-1"></i>อนุมัติโดยระบบ</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="ri ri-time-line me-1"></i>@rec.StatusText</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-1">
                                <a href="@Url.Action("CreateAdjustRMBS1NoPS", "ImportAdjustment", new { mode = "view", rmbs1No = rec.Rmbs1Number })" class="btn btn-sm btn-icon btn-outline-primary" title="ดู">
                                    <i class="ri ri-eye-line"></i>
                                </a>
                                <a href="@Url.Action("CreateAdjustRMBS1NoPS", "ImportAdjustment", new { mode = "edit", rmbs1No = rec.Rmbs1Number })" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข">
                                    <i class="ri ri-pencil-line"></i>
                                </a>
                                @if (rec.StatusText == "อนุมัติแล้ว")
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-preview-pdf"
                                            title="พรีวิว PDF"
                                            data-rmbs1="@rec.Rmbs1Number"
                                            data-date="@rec.TransactionDate.ToString("dd/MM/yyyy")"
                                            data-bs-toggle="modal" data-bs-target="#modalPdfPreview">
                                        <i class="ri ri-file-pdf-line"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" title="พรีวิว PDF (ยังไม่ได้รับการอนุมัติ)" disabled>
                                        <i class="ri ri-file-pdf-line"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
