@section PageScripts {
<script>
    $(document).ready(function () {
        flatpickr('.flatpickr-date', { dateFormat: 'd/m/Y', allowInput: true });
        // pre-fill P1 print modal for first record
        setP1Print('P1-2569-00123', 'ปลาทูน่าโบนิโต (Sarda) ทั้งตัว แช่แข็ง', 'LOT-2561-001',
            'บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด',
            'บริษัท สยาม ซีฟูดส์ เพรสเซอร์ชั่น จำกัด', '5000', '10/04/2569', 'RMBS1-2561-0081');
    });

    function showP1Detail(p1No, product, lot, seller, buyer, saleWeight, balance, issueDate, rmbs1) {
        document.getElementById('detailP1Number').textContent = p1No !== '—' ? p1No : 'ยังไม่ออกเลขที่';
        document.getElementById('detailRmbs1').textContent = rmbs1;
        document.getElementById('detailProduct').textContent = product;
        document.getElementById('detailLot').textContent = lot;
        document.getElementById('detailSeller').textContent = seller;
        document.getElementById('detailBuyer').textContent = buyer;
        document.getElementById('detailSaleWeight').textContent = parseFloat(saleWeight).toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('detailSaleWeight2').textContent = parseFloat(saleWeight).toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('detailBalance').textContent = parseFloat(balance).toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('detailBalanceCalc').textContent = parseFloat(balance).toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('detailIssueDate').textContent = issueDate;
        // RMBS1 weight = sale + balance
        var total = parseFloat(saleWeight) + parseFloat(balance);
        document.getElementById('detailRmbs1Weight').textContent = total.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        // TOR 1.6(7): populate chain traceability (mockup static data)
        var rmbs1Ps = '10611280211800000561';
        var imdNo   = '23501201316100081';
        document.getElementById('detailRmbs1Ps').textContent      = rmbs1Ps;
        document.getElementById('detailRmbs1PsChain').textContent = rmbs1Ps;
        document.getElementById('detailImdChain').textContent     = imdNo;
        document.getElementById('detailP1Chain').textContent      = p1No !== '—' ? p1No : 'รอออกเลขที่';
        // set print modal too
        setP1Print(p1No, product, lot, seller, buyer, saleWeight, issueDate, rmbs1);
        new bootstrap.Modal(document.getElementById('modalP1Detail')).show();
    }

    function setP1Print(p1No, product, lot, seller, buyer, saleWeight, issueDate, rmbs1) {
        var sale = parseFloat(saleWeight) || 0;
        var balance = 0; // simplified mockup
        document.getElementById('printP1Number').textContent = p1No;
        document.getElementById('printIssueDate').textContent = issueDate;
        document.getElementById('printRmbs1').textContent = rmbs1;
        document.getElementById('printSeller').textContent = seller;
        document.getElementById('printBuyer').textContent = buyer;
        document.getElementById('printProduct').textContent = product;
        document.getElementById('printLot').textContent = lot;
        document.getElementById('printRmbs1WeightCell').textContent = sale.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('printSaleWeightCell').textContent = sale.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('printBalanceCell').textContent = balance.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('printTotalSale').textContent = sale.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('printTotalBalance').textContent = balance.toLocaleString('th-TH', { minimumFractionDigits: 3 });
        document.getElementById('printSellerSig').textContent = seller;
        document.getElementById('printSignDate').textContent = 'วันที่ ' + issueDate;
        document.getElementById('printOfficerDate').textContent = issueDate;
    }

    function printP1Form() {
        var content = document.getElementById('p1FormA4').outerHTML;
        var win = window.open('', '_blank', 'width=900,height=750');
        win.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>เอกสาร P1</title>' +
            '<style>body{margin:0;padding:0;background:#f0f0f0;font-family:Sarabun,sans-serif;}' +
            '@@media print{body{background:#fff;}@@page{size:A4;margin:0;}.no-print{display:none!important;}}</style></head><body>' +
            '<div class="no-print" style="text-align:center;padding:12px;background:#fff;border-bottom:1px solid #ddd;">' +
            '<button onclick="window.print()" style="padding:8px 24px;background:#003366;color:#fff;border:none;border-radius:4px;cursor:pointer;">⎙ สั่งพิมพ์</button>' +
            '&nbsp;&nbsp;<button onclick="window.close()" style="padding:8px 20px;background:#888;color:#fff;border:none;border-radius:4px;cursor:pointer;">✕ ปิด</button>' +
            '</div>' + content + '</body></html>');
        win.document.close();
        win.focus();
    }
</script>
}
