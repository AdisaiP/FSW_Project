@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@* ************** Content ************** *@
<h4 class="mb-1">เอกสาร P1 — Product Balance Stock No.1</h4>
<p class="mb-1 text-muted">รายการเอกสารควบคุมปริมาณสินค้า ที่ออกโดยระบบอัตโนมัติจากข้อมูล RMBS1 และ RMBS2</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Dashboards")" class="text-primary fw-semibold">หน้าแรก</a>
        </li>
        <li class="breadcrumb-item active text-secondary">เอกสาร P1</li>
    </ol>
</nav>

<!-- ==================== Info Banner: ระบบออก P1 อัตโนมัติ ==================== -->
<div class="alert alert-primary d-flex align-items-start gap-3 mb-4">
    <i class="ri ri-robot-line fs-4 mt-1 flex-shrink-0"></i>
    <div>
        <div class="fw-semibold mb-1">ระบบออกเอกสาร P1 อัตโนมัติจาก RMBS1 + RMBS2</div>
        <div class="small">
            เมื่อผู้ขายบันทึกการซื้อขายผลิตภัณฑ์แปรรูปเบื้องต้น / สำเร็จรูปใน
            <a href="@Url.Action("CreatePurchase", "ImportAdjustment")" class="alert-link">คำขออนุมัติปริมาณ (ซื้อต่อ)</a>
            ระบบจะสร้างเลขที่ P1 โดยอัตโนมัติ โดยดึงข้อมูล:
            <span class="badge bg-label-primary">ข้อมูลการผลิต RMBS1</span>
            <span class="badge bg-label-secondary ms-1">จำนวนที่ขาย RMBS2</span>
            <span class="badge bg-label-success ms-1">Balance Stock</span>
        </div>
    </div>
</div>

<!-- ==================== Summary Stats ==================== -->
<div class="row g-3 mb-4">
    <div class="col-6 col-sm-3">
        <div class="card text-center border-0 shadow-none bg-label-primary">
            <div class="card-body py-3">
                <div class="fs-3 fw-bold text-primary">@p1Records.Length</div>
                <div class="small text-muted">เอกสาร P1 ทั้งหมด</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-3">
        <div class="card text-center border-0 shadow-none bg-label-success">
            <div class="card-body py-3">
                <div class="fs-3 fw-bold text-success">@p1Records.Count(r => r.StatusText == "สมบูรณ์")</div>
                <div class="small text-muted">สมบูรณ์</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-3">
        <div class="card text-center border-0 shadow-none bg-label-warning">
            <div class="card-body py-3">
                <div class="fs-3 fw-bold text-warning">@p1Records.Count(r => r.StatusText is "รอผู้ซื้อยืนยัน" or "รออนุมัติ")</div>
                <div class="small text-muted">รอดำเนินการ</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-sm-3">
        <div class="card text-center border-0 shadow-none bg-label-secondary">
            <div class="card-body py-3">
                <div class="fs-3 fw-bold text-secondary">@p1Records.Count(r => r.StatusText == "ฉบับร่าง")</div>
                <div class="small text-muted">ฉบับร่าง</div>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Main Card: รายการ P1 ==================== -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="ri ri-file-list-3-line text-primary fs-5"></i>
            <h5 class="mb-0 fw-semibold">รายการเอกสาร P1 (Product Balance Stock No.1)</h5>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <!-- Export Excel mockup -->
            <button type="button" class="btn btn-sm btn-outline-success"
                onclick="alert('Export Excel รายการ P1 (mockup)')">
                <i class="ri ri-file-excel-2-line me-1"></i>Export Excel
            </button>
            <!-- สร้างใหม่ -->
            <a href="@Url.Action("CreatePurchase", "ImportAdjustment")" class="btn btn-sm btn-primary">
                <i class="ri ri-add-line me-1"></i>สร้างรายการซื้อขาย
            </a>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="card-body border-bottom pb-3">
        <div class="row g-2 align-items-end">
            <div class="col-sm-4 col-lg-3">
                <label class="form-label small mb-1">ค้นหาเลขที่ P1 / ผลิตภัณฑ์</label>
                <input type="text" class="form-control form-control-sm" placeholder="P1-2569-XXXXX หรือ ชื่อผลิตภัณฑ์" />
            </div>
            <div class="col-sm-3 col-lg-2">
                <label class="form-label small mb-1">สถานะ</label>
                <select class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="draft">ฉบับร่าง</option>
                    <option value="pending">รอดำเนินการ</option>
                    <option value="complete">สมบูรณ์</option>
                </select>
            </div>
            <div class="col-sm-3 col-lg-2">
                <label class="form-label small mb-1">วันที่ออกเอกสาร</label>
                <input type="text" class="form-control form-control-sm flatpickr-date" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary">
                    <i class="ri ri-search-line me-1"></i>ค้นหา
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0" style="font-size:0.85rem;">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:50px;">#</th>
                        <th>เลขที่ P1</th>
                        <th>วันที่ออก</th>
                        <th>เลขที่ RMBS1 (ต้นทาง)</th>
                        <th>ผลิตภัณฑ์ / รุ่น</th>
                        <th>ผู้ขาย</th>
                        <th>ผู้ซื้อ</th>
                        <th class="text-end">น้ำหนักที่ขาย (KGM)</th>
                        <th class="text-end">Balance คงเหลือ (KGM)</th>
                        <th class="text-center">สถานะ</th>
                        <th class="text-center">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in p1Records)
                    {
                        <tr>
                            <td class="text-center text-muted">@r.RowNo</td>
                            <td>
                                @if (r.P1Number != "—")
                                {
                                    <span class="fw-semibold text-primary">@r.P1Number</span>
                                    <br/>
                                    <span class="badge bg-label-primary" style="font-size:10px;">
                                        <i class="ri ri-robot-line me-1"></i>ออกอัตโนมัติ
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">— รอออกเลขที่</span>
                                }
                            </td>
                            <td class="text-nowrap">@r.IssuedDate</td>
                            <td>
                                <a href="@Url.Action("CreatePost", "ImportAdjustment")" class="text-primary small">
                                    @r.Rmbs1Number
                                </a>
                            </td>
                            <td>
                                <div class="fw-semibold" style="max-width:200px;white-space:normal;">@r.ProductName</div>
                                <span class="badge bg-label-secondary" style="font-size:10px;">
                                    <i class="ri ri-calendar-line me-1"></i>@r.LotCode
                                </span>
                            </td>
                            <td>
                                <div class="small" style="max-width:160px;white-space:normal;">@r.SellerName</div>
                            </td>
                            <td>
                                <div class="small" style="max-width:160px;white-space:normal;">@r.BuyerName</div>
                            </td>
                            <td class="text-end fw-semibold">
                                @r.SaleWeight.ToString("N3")
                            </td>
                            <td class="text-end">
                                @if (r.BalanceWeight > 0)
                                {
                                    <span class="text-warning fw-semibold">@r.BalanceWeight.ToString("N3")</span>
                                }
                                else
                                {
                                    <span class="text-success">0.000 <i class="ri ri-checkbox-circle-line"></i></span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @r.StatusClass">@r.StatusText</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <!-- ดูรายละเอียด -->
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary"
                                        title="ดูรายละเอียด"
                                        onclick="showP1Detail('@r.P1Number', '@r.ProductName', '@r.LotCode', '@r.SellerName', '@r.BuyerName', '@r.SaleWeight', '@r.BalanceWeight', '@r.IssuedDate', '@r.Rmbs1Number')">
                                        <i class="ri ri-eye-line"></i>
                                    </button>
                                    @if (r.P1Number != "—")
                                    {
                                        <!-- พิมพ์ P1 -->
                                        <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                            title="พิมพ์ P1"
                                            data-bs-toggle="modal" data-bs-target="#modalP1Print"
                                            onclick="setP1Print('@r.P1Number', '@r.ProductName', '@r.LotCode', '@r.SellerName', '@r.BuyerName', '@r.SaleWeight', '@r.IssuedDate', '@r.Rmbs1Number')">
                                            <i class="ri ri-printer-line"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="7" class="text-end fw-semibold text-muted">รวมน้ำหนักที่ขาย:</td>
                        <td class="text-end fw-bold text-primary">@p1Records.Sum(r => r.SaleWeight).ToString("N3")</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="card-footer text-muted small d-flex justify-content-between">
        <span>แสดง @p1Records.Length รายการ (mockup)</span>
        <span>ข้อมูล ณ วันที่ 28/04/2569</span>
    </div>
</div>

<!-- ==================== Modal: ดูรายละเอียด P1 ==================== -->
<div class="modal fade" id="modalP1Detail" tabindex="-1" aria-labelledby="modalP1DetailLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-label-primary">
                <h5 class="modal-title" id="modalP1DetailLabel">
                    <i class="ri ri-file-list-3-line me-2"></i>รายละเอียดเอกสาร P1
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Auto-issued badge -->
                <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" id="detailAutoIssuedBadge">
                    <i class="ri ri-robot-line fs-5"></i>
                    <div>
                        เอกสาร P1 เลขที่ <strong id="detailP1Number">—</strong>
                        ออกโดยระบบอัตโนมัติจากข้อมูล RMBS1 + RMBS2 แล้ว
                    </div>
                </div>

                <!-- Data source breakdown -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card border-primary h-100">
                            <div class="card-header bg-label-primary py-2">
                                <span class="fw-semibold small"><i class="ri ri-database-2-line me-1"></i>ข้อมูลจาก RMBS1</span>
                            </div>
                            <div class="card-body py-2">
                                <table class="table table-sm table-borderless mb-0" style="font-size:0.82rem;">
                                    <tr>
                                        <td class="text-muted" style="width:45%;">เลขที่ RMBS1:</td>
                                        <td><strong id="detailRmbs1">—</strong></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">ผลิตภัณฑ์:</td>
                                        <td id="detailProduct">—</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">รุ่นการผลิต:</td>
                                        <td><span class="badge bg-label-secondary" id="detailLot">—</span></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">ผู้ขาย (Seller):</td>
                                        <td id="detailSeller">—</td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-secondary h-100">
                            <div class="card-header bg-label-secondary py-2">
                                <span class="fw-semibold small"><i class="ri ri-exchange-line me-1"></i>ข้อมูลจาก RMBS2 (การซื้อขาย)</span>
                            </div>
                            <div class="card-body py-2">
                                <table class="table table-sm table-borderless mb-0" style="font-size:0.82rem;">
                                    <tr>
                                        <td class="text-muted" style="width:45%;">ผู้ซื้อ (Buyer):</td>
                                        <td id="detailBuyer">—</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">น้ำหนักที่ขาย:</td>
                                        <td><strong class="text-primary" id="detailSaleWeight">—</strong> KGM</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Balance คงเหลือ:</td>
                                        <td><strong class="text-warning" id="detailBalance">—</strong> KGM</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">วันที่ออกเอกสาร:</td>
                                        <td id="detailIssueDate">—</td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Balance Stock visual -->
                <div class="card border-success">
                    <div class="card-header bg-label-success py-2">
                        <span class="fw-semibold small"><i class="ri ri-scales-2-line me-1"></i>Product Balance Stock</span>
                    </div>
                    <div class="card-body py-3">
                        <div class="row text-center g-2">
                            <div class="col-4">
                                <div class="small text-muted">น้ำหนักจาก RMBS1</div>
                                <div class="fs-5 fw-bold text-primary" id="detailRmbs1Weight">—</div>
                                <div class="small text-muted">KGM (ต้นทาง)</div>
                            </div>
                            <div class="col-1 d-flex align-items-center justify-content-center">
                                <i class="ri ri-subtract-line fs-4 text-muted"></i>
                            </div>
                            <div class="col-4">
                                <div class="small text-muted">น้ำหนักที่ขาย RMBS2</div>
                                <div class="fs-5 fw-bold text-danger" id="detailSaleWeight2">—</div>
                                <div class="small text-muted">KGM (ขายออก)</div>
                            </div>
                            <div class="col-1 d-flex align-items-center justify-content-center">
                                <i class="ri ri-equal-line fs-4 text-muted"></i>
                            </div>
                            <div class="col-2">
                                <div class="small text-muted">Balance</div>
                                <div class="fs-5 fw-bold text-success" id="detailBalanceCalc">—</div>
                                <div class="small text-muted">KGM</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- ผลการพิจารณา RMBS1:PS + มาตรการตลอดสาย P1 (TOR 1.6(7)) -->
            <div class="card border mb-3">
                <div class="card-header py-2 d-flex align-items-center justify-content-between"
                    style="background:#eaf2fb;">
                    <span class="fw-semibold small"><i class="ri ri-shield-check-line me-1 text-primary"></i>
                        ผลการพิจารณา RMBS1:PS + มาตรการประเทศคู่ค้าตลอดสายเอกสาร P1
                    </span>
                    <span class="badge bg-label-primary small">TOR 1.6(7)</span>
                </div>
                <div class="card-body py-3">

                    <!-- Source info -->
                    <div class="alert alert-primary d-flex gap-2 align-items-start py-2 mb-3 small">
                        <i class="ri ri-links-line fs-5 flex-shrink-0 mt-1"></i>
                        <div>
                            <span class="fw-semibold">ระบบส่งผลการพิจารณาตลอดสาย P1 อัตโนมัติ</span>
                            <br/>มาตรการประเทศคู่ค้าจากผู้ขายต้นทาง (RMBS1:PS เลขที่ <strong id="detailRmbs1Ps">—</strong>)
                            จะถูกส่งต่อไปยังผู้ซื้อตลอดสายเอกสาร P1 นี้
                        </div>
                    </div>

