    function onProductCodeChange(code) {        var nameMap = {
            '1604.14.10': 'ปลาทูน่า แปรรูป (Tuna, processed)',
            '1604.20.10': 'ผลิตภัณฑ์ปลาแปรรูปอื่นๆ',
            '0303.41.00': 'ปลาทูน่าอัลบาคอร์ แช่แข็ง (Albacore Tuna, Frozen)'
        };
        var el = document.getElementById('p1ProductName');
        if (el) el.value = nameMap[code] || '—';
    }

    function calcP1Yield() {
        var units     = parseFloat(document.getElementById('p1UnitsProduced').value) || 0;
        var fillUnit  = parseFloat(document.getElementById('p1FillWeightUnit').value) || 0;
        var finalW    = parseFloat(document.getElementById('p1FinalWeight').value) || 0;
        var rawW      = parseFloat(document.getElementById('p1RawWeight').value) || 1;
        var quota     = parseFloat(document.getElementById('ccQuota') ? document.getElementById('ccQuota').value.replace(/,/g,'') : '5000') || 5000;

        // Fill weight รวม
        var fillTotal = units * fillUnit;
        var ftEl = document.getElementById('p1FillWeightTotal');
        if (ftEl) ftEl.textContent = fillTotal.toLocaleString('en-US', {minimumFractionDigits:3, maximumFractionDigits:3});

        // Balance P1 = โควตา − วัตถุดิบ (ใช้ rawW)
        var balance = Math.max(0, quota - rawW);
        var balEl = document.getElementById('p1BalanceDisplay');
        if (balEl) balEl.textContent = balance.toLocaleString('en-US', {minimumFractionDigits:3, maximumFractionDigits:3});

        // %Yield คำนวณ
        var yieldPct = rawW > 0 ? (finalW / rawW * 100) : 0;
        var yieldCalcEl = document.getElementById('p1YieldCalc');
        if (yieldCalcEl) yieldCalcEl.textContent = yieldPct.toFixed(2) + '%';

        // sync ไปที่ p2YieldRef
        var p2YRef = document.getElementById('p2YieldRef');
        if (p2YRef) p2YRef.textContent = yieldPct.toFixed(2) + '%';

        // ตรวจสอบกับฐาน
        var yieldBase = parseFloat(document.getElementById('p1YieldBase').value) || 60;
        var tol       = parseFloat(document.getElementById('p1YieldTolerance').value) || 5;
        var lo = yieldBase - tol, hi = yieldBase + tol;
        var pass = (yieldPct >= lo && yieldPct <= hi);

        var statusEl   = document.getElementById('p1YieldStatus');
        var okAlert    = document.getElementById('p1YieldOkAlert');
        var failAlert  = document.getElementById('p1YieldFailAlert');
        var failCalcEl = document.getElementById('p1YieldCalcFail');

        if (pass) {
            if (statusEl) { statusEl.style.background='#d1e7dd'; statusEl.style.color='#0a3622'; statusEl.style.borderColor='#badbcc'; statusEl.innerHTML='<i class="ri ri-check-double-line me-1"></i>ผ่านเกณฑ์ ✓'; }
            if (okAlert)   okAlert.classList.remove('d-none');
            if (failAlert) failAlert.classList.add('d-none');
        } else {
            if (statusEl) { statusEl.style.background='#f8d7da'; statusEl.style.color='#58151c'; statusEl.style.borderColor='#f1aeb5'; statusEl.innerHTML='<i class="ri ri-lock-2-line me-1"></i>ไม่ผ่านเกณฑ์ 🔒'; }
            if (okAlert)   okAlert.classList.add('d-none');
            if (failAlert) failAlert.classList.remove('d-none');
            if (failCalcEl) failCalcEl.textContent = yieldPct.toFixed(2) + '%';
        }

        // sync p2 summary
        calcP2Back();
    }

    function calcP2Back() {
        var p2W       = parseFloat(document.getElementById('p2ExportWeight').value) || 0;
        var yieldPct  = parseFloat(document.getElementById('p1YieldCalc') ?
            document.getElementById('p1YieldCalc').textContent : '60') || 60;
        var rawBack   = yieldPct > 0 ? (p2W / (yieldPct / 100)) : 0;
        var rawW      = parseFloat(document.getElementById('p1RawWeight').value) || 0;

        var rBackEl = document.getElementById('p2RawBackCalc');
        if (rBackEl) rBackEl.textContent = rawBack.toLocaleString('en-US', {minimumFractionDigits:3, maximumFractionDigits:3});

        var resEl = document.getElementById('p2CheckResult');
        var diff = Math.abs(rawBack - rawW);
        if (resEl) {
            if (diff < 1) {
                resEl.style.background='#d1e7dd'; resEl.style.color='#0a3622'; resEl.style.borderColor='#badbcc';
                resEl.innerHTML='<i class="ri ri-check-line me-1"></i>สอดคล้องกับ Balance P1 ✓';
            } else {
                resEl.style.background='#fff3cd'; resEl.style.color='#664d03'; resEl.style.borderColor='#ffda6a';
                resEl.innerHTML='<i class="ri ri-alert-line me-1"></i>มีส่วนต่าง ' + diff.toLocaleString('en-US',{minimumFractionDigits:3}) + ' KGM';
            }
        }

        // summary bar
        var sumRaw  = document.getElementById('p2SummaryRaw');
        var sumY    = document.getElementById('p2SummaryYield');
        var sumFill = document.getElementById('p2SummaryFill');
        var sumBal  = document.getElementById('p2SummaryBalance');
        if (sumRaw)  sumRaw.textContent  = rawW.toLocaleString('en-US',{minimumFractionDigits:3}) + ' KGM';
        if (sumY)    sumY.textContent    = yieldPct.toFixed(2) + '%';
        if (sumFill) sumFill.textContent = p2W.toLocaleString('en-US',{minimumFractionDigits:3}) + ' KGM';
        if (sumBal)  sumBal.textContent  = Math.max(0, rawW - rawBack).toLocaleString('en-US',{minimumFractionDigits:3}) + ' KGM';
    }
</script>
