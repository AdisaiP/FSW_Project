        if (dlDesc)  dlDesc.innerHTML    = '<strong>' + docNo + '</strong> — ' + (desc || '') + ' <span class="badge bg-label-success ms-2">' + (status || '') + '</span>';
        if (header)  header.style.borderBottom = '3px solid ' + (typeColors[type] || '#0d6efd');

        new bootstrap.Modal(document.getElementById('modalDocLink')).show();
    }

    // ==================== TOR 1.6(10): Lock P2 — ตรวจสอบกระบวนการผลิต ====================

    function toggleP2Lock() {
        var prodOk = document.getElementById('toggleP2ProdStatus').checked;
        var p1Ok   = document.getElementById('toggleP2P1Status').checked;

        // Update prod card
        var prodCard  = document.getElementById('p2ProdCheckCard');
        var prodIcon  = document.getElementById('p2ProdCheckIcon');
        var prodTitle = document.getElementById('p2ProdCheckTitle');
        var prodBadge = document.getElementById('p2ProdCheckBadge');
        if (prodOk) {
            prodCard.style.background = '#d1e7dd'; prodCard.style.borderColor = '#badbcc';
            prodIcon.className  = 'ri ri-flask-line fs-3 text-success';
            prodTitle.textContent = '\u0e1c\u0e25\u0e34\u0e15\u0e20\u0e31\u0e13\u0e11\u0e4c\u0e19\u0e35\u0e49\u0e1c\u0e48\u0e32\u0e19\u0e01\u0e23\u0e30\u0e1a\u0e27\u0e19\u0e01\u0e32\u0e23\u0e1c\u0e25\u0e34\u0e15\u0e02\u0e2d\u0e07\u0e2a\u0e16\u0e32\u0e19\u0e1b\u0e23\u0e30\u0e01\u0e2d\u0e1a\u0e01\u0e32\u0e23';
            prodBadge.className = 'badge bg-success mt-1';
            prodBadge.innerHTML = '<i class="ri ri-check-line me-1"></i>\u0e21\u0e35\u0e01\u0e23\u0e30\u0e1a\u0e27\u0e19\u0e01\u0e32\u0e23\u0e1c\u0e25\u0e34\u0e15 \u2713';
        } else {
