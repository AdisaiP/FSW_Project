        var header = document.getElementById('modalDocLinkHeader');
        var dlType = document.getElementById('dlType');
        var dlNum  = document.getElementById('dlNumber');
        var dlStat = document.getElementById('dlStatus');
        var dlDesc = document.getElementById('modalDocLinkDesc');

        if (dlType)  dlType.textContent  = typeLabels[type] || type.toUpperCase();
        if (dlNum)   { dlNum.textContent = docNo; dlNum.style.color = typeColors[type] || '#333'; }
