<div class="modal fade" id="modalAddProduction" tabindex="-1" aria-labelledby="modalAddProductionLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header text-white">
                <h5 class="modal-title" id="modalAddProductionLabel">
                    <i class="ri ri-add-circle-line me-2"></i>เพิ่มข้อมูลการผลิต
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <!-- ประเภทการดำเนินการ -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">ประเภทการดำเนินการ <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="selectOperationType">
                            <option value="">-- เลือกประเภท --</option>
                            <option value="แปรรูปวัตถุดิบ" selected>แปรรูปวัตถุดิบ</option>
                            <option value="ผลิตภัณฑ์ไม่แปรรูป">ผลิตภัณฑ์ไม่แปรรูป</option>
                            <option value="ขายต่อวัตถุดิบ">ขายต่อวัตถุดิบ</option>
                            <option value="ซื้อเพิ่มวัตถุดิบ">ซื้อเพิ่มวัตถุดิบ</option>
                        </select>
                    </div>
                    <!-- วันที่ดำเนินการ -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">วันที่ดำเนินการ <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm flatpickr-input" id="inputOperationDate"
                            placeholder="วว/ดด/ปปปป" readonly value="28/04/2569">
                    </div>
                    <!-- รุ่น (Lot) -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">รุ่น (Lot/Batch)</label>
                        <input type="text" class="form-control form-control-sm" id="inputLot"
                            placeholder="เช่น LOT-2561-001" value="LOT-2569-001">
                    </div>
                    <!-- รหัสการผลิต -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">รหัสการผลิต</label>
                        <input type="text" class="form-control form-control-sm" id="inputProductionCode"
                            placeholder="เช่น 9CCDD" value="">
                    </div>
                    <!-- รหัสผลิตภัณฑ์ -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">รหัสผลิตภัณฑ์</label>
                        <input type="text" class="form-control form-control-sm" id="inputProductCode"
                            placeholder="เช่น 3AASNNBELNNPP" value="">
                    </div>
                    <!-- ชื่อสินค้าและผลิตภัณฑ์ -->
                    <div class="col-12">
                        <label class="form-label small fw-semibold">ชื่อสินค้าและผลิตภัณฑ์ <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="inputProductName"
                            placeholder="ระบุชื่อสินค้า/ผลิตภัณฑ์" value="">
                    </div>
                    <!-- ปริมาณ -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">ปริมาณที่ดำเนินการ (กก.) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control form-control-sm" id="inputQuantity"
                            placeholder="0.000" min="0" step="0.001" value="">
                    </div>
                    <!-- ปริมาณสัตว์น้ำที่นำมาแปรรูปครั้งนี้ -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">ปริมาณสัตว์น้ำที่นำมาแปรรูปครั้งนี้ (กก.) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control form-control-sm" id="inputRawQty"
                            placeholder="0.000" min="0" step="0.001" value=""
                            oninput="calcProductionYield()">
                        <div class="form-text small">น้ำหนักวัตถุดิบที่นำเข้ากระบวนการผลิตในตั้งนี้ (ต่างจากปริมาณรวม RMBS1)</div>
                    </div>
                    <!-- Fill weight รวม -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">น้ำหนักเนื้อสัตว์น้ำในผลิตภัณฑ์สุดท้าย (Fill weight รวม กก.) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control form-control-sm" id="inputFillWeight"
                            placeholder="0.000" min="0" step="0.001" value=""
                            oninput="calcProductionYield()">
                        <div class="form-text small">น้ำหนักเนื้อสัตว์น้ำรวมที่บรรจุภัณฑ์แล้วทั้งหมด (= Fill weight/ชิ้น × จำนวนบรรจุภัณฑ์)</div>
                    </div>
                    <!-- %Yield คำนวณอัตโนมัติ -->
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">%Yield คำนวณได้ <span class="badge bg-label-info ms-1 fw-normal">ระบบคำนวณอัตโนมัติ</span></label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control form-control-sm" id="displayCalcYield"
