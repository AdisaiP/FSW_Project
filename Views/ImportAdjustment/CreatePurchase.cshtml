@{
ViewData["Title"] = "คำขอใบรับรองการแปรรูปสัตว์น้ำ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}


@* ************** Content ************** *@
<h4 class="mb-1">สร้างคำขออนุมัติปริมาณ (ซื้อต่อ)</h4>
<p class="mb-1">สร้างคำขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์นํ้านำเข้า (ซื้อต่อ)</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("IndexPurchase", "ImportAdjustment")" class="text-primary fw-semibold">ขออนุมัติปริมาณ (จับคู่ซื้อต่อ)</a>
        </li>
        <li class="breadcrumb-item active text-secondary">สร้างคำขออนุมัติปริมาณ (ซื้อต่อ)</li>
    </ol>
</nav>

<!-- ==================== Summary Card: P1 สรุปรายการซื้อขาย (TOR 1.6(1)) ==================== -->
<div class="card border-primary mb-4">
    <div class="card-header bg-label-primary d-flex align-items-center justify-content-between py-2">
        <div class="d-flex align-items-center gap-2">
            <i class="ri ri-shopping-cart-2-line fs-5 text-primary"></i>
            <span class="fw-semibold">สรุปรายการซื้อขาย — เอกสาร P1 (Product Balance Stock No.1)</span>
        </div>
        <span class="badge bg-warning text-dark"><i class="ri ri-draft-line me-1"></i>กำลังดำเนินการ</span>
    </div>
    <div class="card-body py-3">
        <div class="row g-3 align-items-center">
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-label-info rounded-circle d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                        <i class="ri ri-fish-line fs-5"></i>
                    </span>
                    <div>
                        <div class="small text-muted">ผลิตภัณฑ์ที่เลือก</div>
                        <div class="fw-semibold" id="summaryProductName">ปลาทูน่าโบนิโต แช่แข็ง (<span class="text-primary">SKJ-001</span>)</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-label-secondary rounded-circle d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                        <i class="ri ri-calendar-line fs-5"></i>
                    </span>
                    <div>
                        <div class="small text-muted">รุ่นการผลิต (Lot)</div>
                        <div class="fw-semibold" id="summaryLotCode">— <span class="text-muted small">ยังไม่ได้เลือก</span></div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-label-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                        <i class="ri ri-scales-2-line fs-5"></i>
                    </span>
                    <div>
                        <div class="small text-muted">น้ำหนักคงเหลือ (Balance)</div>
                        <div class="fw-semibold text-success" id="summaryBalance">5,000.000 <span class="text-muted small">KGM</span></div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-label-danger rounded-circle d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                        <i class="ri ri-arrow-right-up-line fs-5"></i>
                    </span>
                    <div>
                        <div class="small text-muted">น้ำหนักที่จะขาย</div>
                        <div class="fw-semibold text-danger" id="summaryQty">— <span class="text-muted small">ยังไม่ได้ระบุ</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Summary Card P1 -->

<div class="row">
    <div class="col-12">

        <!-- ===== Tabs ===== -->
        <form method="post" action="#">
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดคำขอ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
            </ul>
            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดคำขอ ==================== -->
                <div id="tab-detail" class="tab-pane fade show active">
                    <!-- ===== Accordion: ข้อมูล IMD และการจับคู่ ===== -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionIMD">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingIMD">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseIMDContent" aria-expanded="true"
                                    aria-controls="collapseIMDContent">
                                    <i class="icon-base ri ri-links-line me-2"></i>
                                    ข้อมูล IMD และการจับคู่เอกสาร
                                </button>
                            </h2>
                            <div id="collapseIMDContent" class="accordion-collapse collapse show"
                                aria-labelledby="headingIMD">
                                <div class="accordion-body p-0">

                                    <!-- ── รายละเอียด ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-information-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">รายละเอียด</h6>
                                        </div>
                                        <div class="row g-3">
                                            <!-- ผู้ประกอบการ -->
                                            <div class="col-12">
                                                <label class="form-label small">ผู้ประกอบการ <span class="text-danger">●</span></label>
                                                <input type="text" id="imdOperator" class="form-control bg-light"
                                                        placeholder="ชื่อผู้ประกอบการ"
                                                        value="บริษัท อินโนเวชั่นส์ โซลูชั่น แอนด์ เซอร์วิส จำกัด" readonly />
                                            </div>
                                            <!-- หน่วยงานพิจารณาออกเลขที่ RMBS1 -->
                                            <div class="col-12">
                                                <label class="form-label small">หน่วยงานพิจารณาออกเลขที่ RMBS1 <span class="text-danger">●</span></label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="imdRmbs1Unit" class="select2 form-select" disabled>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" selected>กองตรวจสอบคุณภาพสินค้าประมง</option>
                                                    </select>
                                                    <label for="imdRmbs1Unit">หน่วยงาน</label>
                                                </div>
                                            </div>
                                            <!-- ข้อมูลการขายต่อ -->
                                            <div class="col-md-8">
                                                <label class="form-label small">ข้อมูลการขายต่อ <span class="text-danger">●</span></label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="saleRefSelect" class="select2 form-select" required>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="1" data-date="30/07/2561" data-weight="5,000.000"
                                                            selected>
                                                            23501201316100086 | ปลาทูน่าโบนิโต (Sarda) ทั้งตัว แช่แข็ง | 30/07/2561 | 5,000.000 กก.
                                                        </option>
                                                        <option value="2" data-date="15/08/2561" data-weight="3,200.000">
                                                            23501201316100091 | ปลาโอดำ ทั้งตัว แช่แข็ง | 15/08/2561 | 3,200.000 กก.
                                                        </option>
                                                        <option value="3" data-date="20/09/2561" data-weight="7,500.000">
                                                            23501201316100105 | ปลาทูน่าครีบเหลือง ทั้งตัว แช่แข็ง | 20/09/2561 | 7,500.000 กก.
                                                        </option>
                                                    </select>
                                                    <label for="saleRefSelect">รหัส | ชื่อสินค้า | วันที่ | น้ำหนัก</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small">จำนวนวัตถุดิบที่ต้องการขายต่อ (กก.) <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <input type="number" id="saleRefQty" class="form-control text-end"
                                                        placeholder="0.000" step="0.001" min="0" value="5000"
                                                        oninput="updateSummaryQty(this.value)" />
                                                    <span class="input-group-text">KGM</span>
                                                </div>
                                            </div>
                                            <!-- รุ่นการผลิต (TOR 1.6(1)) -->
                                            <div class="col-md-6">
                                                <label class="form-label small">รุ่นการผลิต (Production Lot / Batch) <span class="text-danger">●</span></label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="lotCodeSelect" class="select2 form-select" required
                                                        onchange="updateSummaryLot(this)">
                                                        <option value="">-- เลือกรุ่นการผลิต --</option>
                                                        <option value="LOT-2561-001" data-weight="5,000.000" selected>
                                                            LOT-2561-001 | ผลิต 30/07/2561 | คงเหลือ 5,000.000 KGM
                                                        </option>
                                                        <option value="LOT-2561-002" data-weight="3,200.000">
                                                            LOT-2561-002 | ผลิต 15/08/2561 | คงเหลือ 3,200.000 KGM
                                                        </option>
                                                        <option value="LOT-2561-003" data-weight="7,500.000">
                                                            LOT-2561-003 | ผลิต 20/09/2561 | คงเหลือ 7,500.000 KGM
                                                        </option>
                                                    </select>
                                                    <label for="lotCodeSelect">รหัส Lot | วันที่ผลิต | น้ำหนักคงเหลือ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ประเภทผลิตภัณฑ์ที่ขาย</label>
                                                <input type="text" id="lotProductType" class="form-control bg-light"
                                                    value="ผลิตภัณฑ์แปรรูปเบื้องต้น (PS)" readonly />
                                                <div class="form-text text-muted"><i class="ri ri-information-line me-1"></i>ระบบดึงผลิตภัณฑ์จาก RMBS1 อัตโนมัติ</div>
                                            </div>
                                            <!-- ประเภทผู้ซื้อ -->
                                            <div class="col-12">
                                                <label class="form-label small fw-semibold">ประเภทผู้ซื้อ <span class="text-danger">●</span></label>
                                                <div class="d-flex align-items-center gap-3 flex-wrap">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="buyerType" id="buyerTypeFactory" value="factory" checked>
                                                        <label class="form-check-label" for="buyerTypeFactory">
                                                            <span class="badge bg-label-primary me-1"><i class="ri ri-building-4-line"></i></span> โรงงาน (Factory)
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="buyerType" id="buyerTypeNonFactory" value="non-factory">
                                                        <label class="form-check-label" for="buyerTypeNonFactory">
                                                            <span class="badge bg-label-secondary me-1"><i class="ri ri-store-line"></i></span> ไม่ใช่โรงงาน (Non-Factory)
                                                        </label>
                                                    </div>
                                                </div>
                                                <div class="alert alert-info small py-2 px-3 mt-2 mb-0" id="nonFactoryNote" style="display:none;">
                                                    <i class="ri ri-information-line me-1"></i>
                                                    กรณีผู้ซื้อ <strong>ไม่ใช่โรงงาน</strong>: หากผู้ซื้อขายต่อให้โรงงานอื่นในภายหลัง
                                                    ระบบจะออกเลขที่ RMBS1:PS ใหม่ให้โรงงานปลายทางอัตโนมัติ
                                                    พร้อมส่งมาตรการประเทศคู่ค้าตลอดสาย
                                                </div>
                                            </div>
                                            <!-- ชื่อผู้ซื้อ (TOR 1.6(1)) -->
                                            <div class="col-12" id="buyerNameRow">
                                                <label class="form-label small">ชื่อผู้ซื้อ / สถานประกอบการผู้ซื้อ <span class="text-danger">●</span></label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="buyerNameSelect" class="select2 form-select" required>
                                                        <option value="">— ค้นหาชื่อสถานประกอบการ —</option>
                                                        <option value="B001" selected>TH-12345 | บริษัท สยาม ซีฟูดส์ เพรสเซอร์ชั่น จำกัด</option>
                                                        <option value="B002">TH-23456 | บริษัท อีสาน ฟริช เพรสเซอร์ชั่น จำกัด</option>
                                                        <option value="B003">TH-34567 | ห้องหุ้นส่วน ทะเลไทย แคนนิง จำกัด</option>
                                                        <option value="B004">TH-45678 | บริษัท แพซิฟิค ฟิชเชียน เทรดดิ้ง จำกัด</option>
                                                        <option value="B005">TH-56789 | ร้านค้า ออเลี้ยง ชีฟฟูดส์ (ไม่ใช่โรงงาน)</option>
                                                    </select>
                                                    <label for="buyerNameSelect">รหัสสถานประกอบการ | ชื่อสถานประกอบการ</label>
                                                </div>
                                                <div class="form-text text-muted"><i class="ri ri-search-line me-1"></i>ค้นหาจากฐานข้อมูลทะเบียนสถานประกอบการในระบบ</div>
                                            </div>
                                            <!-- วันที่รับสัตว์น้ำเข้าโรงงาน -->
                                            <div class="col-md-6">
                                                <label class="form-label small">วันที่เริ่มรับสัตว์น้ำเข้าโรงงาน <span class="text-danger">●</span></label>
                                                <input type="text" id="ccRecvStart" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="17/08/2561" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">วันที่สิ้นสุดการรับสัตว์น้ำเข้าโรงงาน</label>
                                                <input type="text" id="ccRecvEnd" class="form-control flatpickr-date"
                                                    placeholder="วว/ดด/ปปปป" value="17/08/2561" />
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── ข้อมูลตรวจสอบการจับคู่ IMD ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-ship-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลตรวจสอบการจับคู่ IMD</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเรือจับ (Fishing Vessel)</label>
                                                <input type="text" id="imdFishingVessel" class="form-control bg-light"
                                                    value="MARTINEZ472" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ธงสัญชาติของเรือ </label>
                                                <input type="text" id="imdVesselFlag" class="form-control bg-light"
                                                    value="ปาปัวนิวกินี (PAPUA NEW GUINEA)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อเครื่องมือที่ใช้จับ </label>
                                                <input type="text" id="imdGearType" class="form-control bg-light"
                                                    value="อวนล้อมจับ (Purse seine)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ชื่อประเทศที่นำมาบรรจุ </label>
                                                <input type="text" id="imdPackagingCountry" class="form-control bg-light"
                                                    value="เวียดนาม (VIET NAM)" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่เริ่ม) </label>
                                                <input type="text" id="imdFishingStart" class="form-control bg-light"
                                                    value="1 พฤษภาคม 2561" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ช่วงเวลาทำการประมง (วันที่สิ้นสุด)</label>
                                                <input type="text" id="imdFishingEnd" class="form-control bg-light"
                                                    value="31 พฤษภาคม 2561" readonly />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small">ข้อมูลสัตว์น้ำ</label>
                                                <div class="input-group" style="height:48px;">
                                                    <input type="text" id="imdSpeciesData" class="form-control bg-light h-100"
                                                        value="0303.89.19 000/KGM [F020545S03030001/KGM]=ปลาทูน่าโบนิโต (Sarda) ทั้งตัว แช่แข็ง" readonly />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ── ข้อมูลตรวจสอบการจับคู่ CC/SCC/Other Document ── -->
                                    <div class="p-4 border-bottom">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="badge bg-label-primary rounded-circle me-2 d-inline-flex align-items-center justify-content-center" style="width:2.2rem;height:2.2rem;">
                                                <i class="ri ri-file-text-line fs-5"></i>
                                            </span>
                                            <h6 class="mb-0 fw-semibold">ข้อมูลตรวจสอบการจับคู่ CC/SCC/Other Document</h6>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small">Ref. System Document No.</label>
                                                <input type="text" id="ccRefDocNo" class="form-control bg-light"
                                                    value="S20180730SEA FANTASY XVI00033" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Reference Date</label>
                                                <input type="text" id="ccRefDate" class="form-control bg-light"
                                                    value="30 กรกฎาคม 2561" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Simplified Catch Certificate Number</label>
                                                <input type="text" id="ccNumber" class="form-control bg-light"
                                                    placeholder="Simplified Catch Certificate Number" value="SCC801WE1609" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">Validation date</label>
                                                <input type="text" id="ccValidDate" class="form-control flatpickr-date bg-light"
                                                    placeholder="วว/ดด/ปปปป" value="30/07/2561" readonly />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small">ประเทศของหน่วยงานที่รับรอง</label>
                                                <div class="form-floating form-floating-outline">
                                                    <select id="ccCertCountry" class="select2 form-select bg-light" disabled>
                                                        <option value="">-- เลือก --</option>
                                                        <option value="FR" selected>ฝรั่งเศส (FRANCE)</option>
                                                        <option value="US">สหรัฐอเมริกา</option>
                                                        <option value="JP">ญี่ปุ่น</option>
                                                    </select>
                                                    <label for="ccCertCountry">ประเทศ</label>
                                                </div>
