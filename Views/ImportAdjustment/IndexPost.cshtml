<!-- Filter card -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">ค้นหารายการ</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <!-- Row 1 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterImdNumber" class="form-label filter-form-label">เลขที่ IMD</label>
                <input type="text" id="filterImdNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่ IMD" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDocType" class="form-label filter-form-label">ประเภทเอกสารใช้ในการจับคู่</label>
                <select id="filterDocType" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="cc">CC</option>
                    <option value="scc">SCC</option>
                    <option value="other">Other Document</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterStatus" class="form-label filter-form-label">สถานะ</label>
                <select id="filterStatus" class="form-select form-select-sm">
                    <option value="">-- เลือกข้อมูล --</option>
                    <option value="รออนุมัติ">รออนุมัติ</option>
                    <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                    <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterVessel" class="form-label filter-form-label">ชื่อเรือประมง</label>
                <input type="text" id="filterVessel" class="form-control form-control-sm" placeholder="ระบุชื่อเรือประมง" />
            </div>
            <!-- Row 2 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterGear" class="form-label filter-form-label">ชื่อเครื่องมือที่ใช้จับ</label>
                <input type="text" id="filterGear" class="form-control form-control-sm" placeholder="ระบุชื่อเครื่องมือ" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCaptain" class="form-label filter-form-label">กัปตัน/ผู้ควบคุมเรือ</label>
                <input type="text" id="filterCaptain" class="form-control form-control-sm" placeholder="ระบุชื่อกัปตัน" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterCcNumber" class="form-label filter-form-label">CC/SCC/OtherDocument Number</label>
                <input type="text" id="filterCcNumber" class="form-control form-control-sm" placeholder="ระบุเลขที่เอกสาร" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterProduct" class="form-label filter-form-label">สินค้าประมง</label>
                <input type="text" id="filterProduct" class="form-control form-control-sm" placeholder="ระบุสินค้าประมง" />
            </div>
            <!-- Row 3 -->
            <div class="col-md-4 col-lg-3">
                <label for="filterAllocation" class="form-label filter-form-label">รูปแบบการจัดสรร</label>
                <select id="filterAllocation" class="form-select form-select-sm">
                    <option value="">ทั้งหมด</option>
                    <option value="all">จัดสรรทั้งหมด</option>
                    <option value="partial">จัดสรรบางส่วน</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterChangeType" class="form-label filter-form-label">ประเภทการขอเปลี่ยนแปลง</label>
                <select id="filterChangeType" class="form-select form-select-sm">
                    <option value="">-- เลือกข้อมูล --</option>
                    <option value="change">ขอเปลี่ยนแปลง</option>
                    <option value="cancel">ขอยกเลิก</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDateFrom" class="form-label filter-form-label">วันที่ทำรายการ</label>
                <input type="text" id="filterDateFrom" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="filterDateTo" class="form-label filter-form-label">ถึง</label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="text" id="filterDateTo" class="form-control form-control-sm" placeholder="วว/ดด/ปปปป" />
                    <button type="button" id="btnSearch" class="btn btn-primary btn-square" title="ค้นหา">
                        <i class="ri ri-search-line"></i>
                    </button>
                    <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                        <i class="ri ri-refresh-line"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการขออนุมัติปริมาณ (จับคู่ภายหลัง)</h5>
            <p class="text-muted small mb-0">แสดงรายการขออนุมัติปริมาณตั้งต้นวัตถุดิบสัตว์น้ำนำเข้าภายหลัง</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-outline-success btn-sm" onclick="exportExcelPost()" title="Export รายการทั้งหมดเป็น Excel">
                <i class="ri ri-file-excel-2-line me-1"></i>เพิ่มเติม Excel
            </button>
            <a href="@Url.Action("CreatePost", "ImportAdjustment")" class="btn btn-primary btn-sm">
                <i class="ri ri-add-line me-1"></i> สร้างคำขอ
            </a>
        </div>
    </div>
    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 imd-table">
            <thead class="text-center">
                <tr>
                    <th>วันที่</th>
                    <th style="min-width:300px;">เลขที่ IMD</th>
                    <th>เลขที่ CC</th>
                    <th>Validation date</th>
                    <th>ชื่อเรือประมง</th>
                    <th>ชื่อเครื่องมือ</th>
                    <th>Catch description</th>
                    <th>สินค้าประมง</th>
                    <th>ปริมาณสัตว์น้ำใน CC</th>
                    <th>ปริมาณสัตว์น้ำเข้าโรงงาน</th>
                    <th>เลขที่ P1</th>
                    <th>สถานะโควตา</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="imdTableBody">
                @foreach (var rec in imdRecords)
                {
                    <tr data-row="@rec.RowNo"
                        data-imd-number="@rec.ImdNumber"
                        data-doc-type="@rec.DocumentType"
                        data-status="@rec.StatusText"
                        data-vessel="@rec.VesselName"
                        data-gear="@rec.GearType"
                        data-captain=""
                        data-cc-number="@rec.CcNumber"
                        data-product="@rec.FisheryProducts"
                        data-allocation="all"
                        data-change-type=""
                        data-tx-date="@rec.TransactionDate.ToString("yyyy-MM-ddTHH:mm:ss")">
                        <td class="text-nowrap">@rec.TransactionDate.ToString("dd/MM/yyyy")<br /><small class="text-muted">(@rec.TransactionDate.ToString("HH:mm:ss"))</small></td>
                        <td>
                            @{
                                var docTypeLabel = rec.DocumentType == "cc" ? "เอกสาร CC" :
                                                   rec.DocumentType == "scc" ? "เอกสาร SCC" : "เอกสาร Other Document กรมประมงกำหนด";
                            }
                            <div class="fw-semibold">@rec.ImdNumber</div>
                            <div class="mt-1">
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-success rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-check-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">แหล่งที่มา :</span> ภายนอกระบบ [FSW]
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-info rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-building-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">ประเภทเอกสารที่ใช้จับคู่ :</span> @docTypeLabel
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1 mb-1">
                                    <span class="badge bg-label-danger rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-warning-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">รูปแบบการจัดสรร :</span> First Come First Serve
                                </div>
                                <div class="small text-muted d-flex align-items-center gap-1">
                                    <span class="badge bg-label-warning rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width:1.4rem;height:1.4rem;">
                                        <i class="ri ri-file-list-line" style="font-size:0.65rem;"></i>
                                    </span>
                                    <span class="fw-semibold">สถานะ :</span> <span class="ms-1">@rec.StatusText</span>
                                </div>
                                @if (rec.CertStatus == "นอกการรับรอง" || !rec.DestCountryOk)
                                {
                                    <div class="mt-1 d-flex flex-wrap gap-1">
                                        @if (rec.CertStatus == "นอกการรับรอง")
                                        {
                                            <span class="badge bg-danger" style="font-size:10px;">
                                                <i class="ri ri-lock-2-line me-1"></i>นอกการรับรอง 🔒
                                            </span>
                                        }
                                        @if (!rec.DestCountryOk)
                                        {
                                            <span class="badge bg-label-danger" style="font-size:10px;">
                                                <i class="ri ri-earth-line me-1"></i>ประเทศปลายทางไม่อยู่ในรายชื่อ 🔒
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        </td>
                        <td>@rec.CcNumber</td>
                        <td class="text-center text-nowrap">@rec.ValidationDate.ToString("dd/MM/yyyy")</td>
                        <td>@rec.VesselName</td>
                        <td>@rec.GearType</td>
                        <td>@rec.CatchDescription</td>
                        <td style="max-width:220px;">@rec.FisheryProducts</td>
                        <td class="text-end">@rec.QtyInCC.ToString("N2")</td>
                        <td class="text-end">@rec.QtyEnteringFactory.ToString("N2")</td>
                        <!-- เลขที่ P1 (TOR 1.6(3)) -->
                        <td class="text-nowrap">
                            @if (rec.P1Number != "—")
                            {
                                <a href="@Url.Action("IndexP1", "ImportAdjustment")" class="text-primary fw-semibold">
                                    @rec.P1Number
                                </a>
                                <br />
                                <span class="badge bg-label-primary" style="font-size:10px;">
                                    <i class="ri ri-robot-line me-1"></i>ออกอัตโนมัติ
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">— รอออกเลขที่</span>
                            }
                        </td>
                        <!-- สถานะโควตา (TOR 1.6(17)) -->
                        <td class="text-center">
                            @{
                                var quotaBadgeClass = rec.QuotaStatus == "เพียงพอ" ? "bg-success" :
                                                      rec.QuotaStatus == "ใกล้หมด" ? "bg-warning" : "bg-danger";
                                var quotaIcon = rec.QuotaStatus == "เพียงพอ" ? "ri-checkbox-circle-line" :
                                                rec.QuotaStatus == "ใกล้หมด" ? "ri-error-warning-line" : "ri-close-circle-line";
                            }
                            <span class="badge @quotaBadgeClass" style="font-size:10px;" title="คงเหลือ @rec.QuotaRemaining.ToString("N0") / ต้องการ @rec.QuotaRequired.ToString("N0") KGM">
                                <i class="ri @quotaIcon me-1"></i>@rec.QuotaStatus
                            </span>
                            @if (rec.QuotaStatus == "ไม่เพียงพอ")
                            {
                                <br/>
                                <small class="text-danger" style="font-size:9px;">
                                    คงเหลือ @rec.QuotaRemaining.ToString("N0") /<br/>ต้องการ @rec.QuotaRequired.ToString("N0") KGM
                                </small>
                            }
                            @if (rec.QuotaStatus == "ใกล้หมด")
                            {
                                <br/>
                                <small class="text-warning" style="font-size:9px;">
                                    คงเหลือ @rec.QuotaRemaining.ToString("N0") KGM
                                </small>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <a href="@Url.Action("CreateIMD", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top">
                                    <i class="ri ri-eye-line text-info"></i>
                                </a>
                                @if (rec.StatusText is "รออนุมัติ" or "ไม่อนุมัติ")
                                {
                                    <!-- แก้ไขได้เฉพาะรออนุมัติ/ไม่อนุมัติ -->
                                    <a href="@Url.Action("CreatePost", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </a>
                                    <!-- ยกเลิกการซื้อขาย -->
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger"
                                        title="ยกเลิกการซื้อขาย" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="showCancelModal('@rec.ImdNumber')">
                                        <i class="ri ri-close-circle-line text-danger"></i>
                                    </button>
                                }
                                else if (rec.StatusText == "อนุมัติแล้ว")
                                {
                                    <!-- อนุมัติแล้ว: ดู P1+P2 + พิมพ์ P1 + คัดลอก -->
                                    <!-- TOR 1.6(12): ดูรายละเอียด P1+P2 -->
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-info"
                                        title="ดูรายละเอียด P1 + P2" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="showP1P2Detail('@rec.P1Number', '@rec.ImdNumber', '@rec.FisheryProducts', '@rec.QtyEnteringFactory.ToString("N2")')">
                                        <i class="ri ri-eye-line text-info"></i>
                                    </button>
                                    <a href="@Url.Action("IndexP1", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-success" title="ดูเอกสาร P1" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-file-list-3-line text-success"></i>
                                    </a>
                                    <!-- ปุ่มพิมพ์ P1 (TOR 1.6(4)) -->
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-primary"
                                        title="พิมพ์เอกสาร P1 (PDF)" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="showP1PrintModal('@rec.P1Number', '@rec.ImdNumber', '@rec.FisheryProducts', '@rec.QtyEnteringFactory.ToString("N2")')">
                                        <i class="ri ri-printer-line text-primary"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                        title="คัดลอก" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="alert('คัดลอกรายการ (mockup)')">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning"
                                        title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="alert('แก้ไขรายการ (mockup)')">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-secondary"
                                        title="คัดลอก" data-bs-toggle="tooltip" data-bs-placement="top"
                                        onclick="alert('คัดลอกรายการ (mockup)')">
                                        <i class="ri ri-file-copy-line text-secondary"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="imdTableEmpty" class="d-none">
                    <td colspan="13" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่ค้นหา</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ==================== Modal: ยืนยันยกเลิกการซื้อขาย (TOR 1.6(3)) ==================== -->
<div class="modal fade" id="modalCancelSale" tabindex="-1" aria-labelledby="modalCancelSaleLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalCancelSaleLabel">
                    <i class="ri ri-close-circle-line me-2"></i>ยืนยันยกเลิกการซื้อขาย
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning d-flex gap-2 py-2 mb-3">
                    <i class="ri ri-alert-line fs-5 flex-shrink-0 mt-1"></i>
                    <div class="small">การยกเลิกจะคืนน้ำหนักกลับไปยัง Balance Stock ของ IMD เดิม และเลขที่ P1 (ถ้ามี) จะถูกยกเลิกอัตโนมัติ</div>
                </div>
                <table class="table table-sm table-borderless mb-0" style="font-size:0.9rem;">
                    <tr>
                        <td class="text-muted" style="width:40%;">เลขที่ IMD:</td>
                        <td class="fw-semibold" id="cancelImdNumber">—</td>
                    </tr>
                    <tr>
                        <td class="text-muted">เหตุผลการยกเลิก:</td>
                        <td></td>
                    </tr>
                </table>
                <textarea class="form-control mt-2" id="cancelReason" rows="3"
                    placeholder="ระบุเหตุผลการยกเลิก (จำเป็น)"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
                <button type="button" class="btn btn-danger" onclick="confirmCancel()">
                    <i class="ri ri-close-circle-line me-1"></i>ยืนยันยกเลิก
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ==================== Modal: P1 ออกอัตโนมัติ (แสดงหลังบันทึกใหม่) (TOR 1.6(3)) ==================== -->
<div class="modal fade" id="modalP1AutoIssuedPost" tabindex="-1" aria-labelledby="modalP1AutoIssuedPostLabel" aria-hidden="true"
    data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-primary">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalP1AutoIssuedPostLabel">
                    <i class="ri ri-robot-line me-2"></i>ระบบออกเอกสาร P1 อัตโนมัติแล้ว
                </h5>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i class="ri ri-file-list-3-line text-primary" style="font-size:3.5rem;"></i>
                </div>
                <p class="fw-semibold fs-6 mb-1">ระบบออกเอกสาร P1 อัตโนมัติเรียบร้อยแล้ว</p>
                <p class="text-muted small mb-3">หลังบันทึกการซื้อขาย ระบบดึงข้อมูล RMBS1 + RMBS2 ออกเลขที่ P1 ทันที</p>
                <div class="card border-0 bg-label-primary d-inline-block px-4 py-2 mb-3">
                    <div class="text-muted small">เลขที่เอกสาร P1 (ออกอัตโนมัติ)</div>
                    <div class="fs-4 fw-bold text-primary">P1-2569-00129</div>
                </div>
                <div class="row text-start g-2 px-2">
                    <div class="col-6 small">
                        <span class="text-muted">วันที่ออกเอกสาร:</span>
                        <div class="fw-semibold">28/04/2569</div>
                    </div>
                    <div class="col-6 small">
                        <span class="text-muted">ผลิตภัณฑ์:</span>
                        <div class="fw-semibold">ปลาทูน่าอัลบาคอร์ แช่แข็ง</div>
                    </div>
                    <div class="col-6 small">
                        <span class="text-muted">น้ำหนักจาก RMBS1:</span>
                        <div class="fw-semibold text-primary">240,000.000 KGM</div>
                    </div>
                    <div class="col-6 small">
                        <span class="text-muted">Balance คงเหลือ:</span>
                        <div class="fw-semibold text-success">0.000 KGM</div>
                    </div>
                </div>
                <div class="alert alert-primary small py-2 px-3 mt-3 mb-0 text-start">
                    <i class="ri ri-information-line me-1"></i>
                    ผู้ขายสามารถแก้ไขหรือยกเลิกรายการนี้ได้ หากสถานะยังเป็น "รออนุมัติ"
                    เมื่อยกเลิก ระบบจะคืน Balance Stock และยกเลิกเลขที่ P1 อัตโนมัติ
                </div>
            </div>
            <div class="modal-footer justify-content-center gap-2">
                <a href="@Url.Action("IndexP1", "ImportAdjustment")" class="btn btn-outline-primary btn-sm">
                    <i class="ri ri-eye-line me-1"></i>ดูเอกสาร P1
                </a>
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">
                    <i class="ri ri-check-line me-1"></i>รับทราบ
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modals TOR 1.6(3) -->

<!-- ==================== Modal: พิมพ์ฟอร์ม P1 (PDF Preview) (TOR 1.6(4)) ==================== -->
<div class="modal fade" id="modalP1PrintPost" tabindex="-1" aria-labelledby="modalP1PrintPostLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalP1PrintPostLabel">
                    <i class="ri ri-printer-line me-2"></i>พิมพ์ฟอร์ม P1 — Product Balance Stock No.1
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 bg-light">
                <!-- A4 Preview -->
                <div id="p1FormA4Post" style="background:#fff;max-width:794px;min-height:1123px;margin:0 auto;padding:40px 50px;font-family:'Sarabun',sans-serif;font-size:14px;border:1px solid #ddd;box-shadow:0 2px 12px rgba(0,0,0,.08);">
                    <!-- หัวกรมประมง -->
                    <div class="text-center mb-3">
                        <div style="font-size:16px;font-weight:700;color:#1a5276;">กรมประมง — Department of Fisheries</div>
                        <div style="font-size:13px;color:#555;">ระบบการจัดการวัตถุดิบสัตว์น้ำ (RMBS)</div>
                        <div style="font-size:18px;font-weight:800;margin-top:8px;color:#154360;letter-spacing:1px;">
                            เอกสาร P1 — Product Balance Stock No.1<br />
                            <span style="font-size:13px;font-weight:400;color:#888;">ฟอร์มอิเล็กทรอนิกส์ / Electronic Form (PDF)</span>
                        </div>
                        <div style="border-top:2px solid #154360;margin-top:8px;padding-top:6px;">
                            <span style="font-weight:700;color:#154360;font-size:15px;" id="printP1NumberPost">P1-2569-00121</span>
                            <span class="ms-3" style="font-size:12px;color:#777;" id="printP1DatePost">วันที่ออก: 10/07/2561</span>
                            <span class="ms-3 badge" style="background:#e8f4fd;color:#1565c0;font-size:11px;border:1px solid #90caf9;">
                                <i class="ri ri-robot-line me-1"></i>ออกอัตโนมัติโดยระบบ
                            </span>
                        </div>
                    </div>

                    <!-- ส่วนที่ 1: ข้อมูลผู้ขาย-ผู้ซื้อ -->
                    <div style="border:1px solid #aaa;border-radius:4px;margin-bottom:12px;">
                        <div style="background:#154360;color:#fff;padding:5px 12px;font-weight:700;font-size:13px;">
                            ส่วนที่ 1 — ข้อมูลผู้ขายและผู้ซื้อ
                        </div>
                        <div style="padding:10px 14px;">
                            <table style="width:100%;font-size:13px;border-collapse:collapse;">
                                <tr>
                                    <td style="width:50%;vertical-align:top;padding-right:12px;">
                                        <div style="font-weight:700;margin-bottom:4px;color:#154360;">ผู้ขาย (Seller)</div>
                                        <div>บริษัท ยูนิไทย ชิปยาร์ด แอนด์ เอนจิเนียริ่ง จำกัด</div>
                                        <div style="color:#666;">ทะเบียน: TH-12345 | โรงงานแปรรูป</div>
                                        <div style="color:#666;">ที่อยู่: 72/1 ถ.พระราม 3 เขตบางคอแหลม กรุงเทพ 10120</div>
                                    </td>
                                    <td style="width:50%;vertical-align:top;padding-left:12px;border-left:1px solid #ddd;">
                                        <div style="font-weight:700;margin-bottom:4px;color:#154360;">ผู้ซื้อ (Buyer)</div>
                                        <div>บริษัท ไทยยูเนี่ยน กรุ๊ป จำกัด (มหาชน)</div>
                                        <div style="color:#666;">ทะเบียน: TH-67890 | โรงงานแปรรูป</div>
                                        <div style="color:#666;">ที่อยู่: 72/1 ถ.พระราม 3 เขตบางคอแหลม กรุงเทพ 10120</div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- ส่วนที่ 2: ข้อมูลสินค้า / RMBS Balance -->
