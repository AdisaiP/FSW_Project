@section PageScripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['filterDateFrom', 'filterDateTo'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
            }
        });

        if (window.bootstrap && bootstrap.Tooltip) {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        function parseDateInput(value, endOfDay) {
            if (!value) return null;
            var parts = value.split('/');
            if (parts.length !== 3) return null;
            var d = parseInt(parts[0], 10);
            var m = parseInt(parts[1], 10) - 1;
            var y = parseInt(parts[2], 10);
            var dt = new Date(y, m, d, endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0);
            return Number.isNaN(dt.getTime()) ? null : dt;
        }

        function filterRows() {
            var imdNo = (document.getElementById('filterImdNumber').value || '').trim().toLowerCase();
            var docType = (document.getElementById('filterDocType').value || '').trim();
            var statusVal = (document.getElementById('filterStatus').value || '').trim();
            var vessel = (document.getElementById('filterVessel').value || '').trim().toLowerCase();
            var gear = (document.getElementById('filterGear').value || '').trim().toLowerCase();
            var captain = (document.getElementById('filterCaptain').value || '').trim().toLowerCase();
            var ccNo = (document.getElementById('filterCcNumber').value || '').trim().toLowerCase();
            var product = (document.getElementById('filterProduct').value || '').trim().toLowerCase();
            var allocation = (document.getElementById('filterAllocation').value || '').trim();
            var changeType = (document.getElementById('filterChangeType').value || '').trim();
            var fromDate = parseDateInput(document.getElementById('filterDateFrom').value, false);
            var toDate = parseDateInput(document.getElementById('filterDateTo').value, true);

            var rows = document.querySelectorAll('#imdTableBody tr[data-row]');
            var visible = 0;

            rows.forEach(function (row) {
                var match =
                    (!imdNo || (row.dataset.imdNumber || '').toLowerCase().includes(imdNo)) &&
                    (!docType || row.dataset.docType === docType) &&
                    (!statusVal || row.dataset.status === statusVal) &&
                    (!vessel || (row.dataset.vessel || '').toLowerCase().includes(vessel)) &&
                    (!gear || (row.dataset.gear || '').toLowerCase().includes(gear)) &&
                    (!captain || (row.dataset.captain || '').toLowerCase().includes(captain)) &&
                    (!ccNo || (row.dataset.ccNumber || '').toLowerCase().includes(ccNo)) &&
                    (!product || (row.dataset.product || '').toLowerCase().includes(product)) &&
                    (!allocation || row.dataset.allocation === allocation) &&
                    (!changeType || row.dataset.changeType === changeType) &&
                    (!fromDate || new Date(row.dataset.txDate) >= fromDate) &&
                    (!toDate || new Date(row.dataset.txDate) <= toDate);

                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });

            document.getElementById('imdTableEmpty').classList.toggle('d-none', visible !== 0);
        }

        document.getElementById('btnSearch').addEventListener('click', filterRows);
        document.getElementById('btnReset').addEventListener('click', function () {
            ['filterImdNumber', 'filterVessel', 'filterGear', 'filterCaptain', 'filterCcNumber', 'filterProduct', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            ['filterDocType', 'filterStatus', 'filterAllocation', 'filterChangeType'].forEach(function (id) {
                document.getElementById(id).value = '';
            });
            filterRows();
        });

        ['filterDocType', 'filterStatus', 'filterAllocation', 'filterChangeType'].forEach(function (id) {
            document.getElementById(id).addEventListener('change', filterRows);
        });

        ['filterImdNumber', 'filterVessel', 'filterGear', 'filterCaptain', 'filterCcNumber', 'filterProduct', 'filterDateFrom', 'filterDateTo'].forEach(function (id) {
            document.getElementById(id).addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); filterRows(); }
            });
        });

        // แสดง modal P1 auto-issued เมื่อกดสร้างใหม่ (simulate หลังบันทึก)
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('p1issued') === '1') {
            setTimeout(function () {
                new bootstrap.Modal(document.getElementById('modalP1AutoIssuedPost')).show();
            }, 500);
        }
    });

    // TOR 1.6(3): ยืนยันยกเลิกการซื้อขาย
    function showCancelModal(imdNo) {
        document.getElementById('cancelImdNumber').textContent = imdNo;
        document.getElementById('cancelReason').value = '';
        new bootstrap.Modal(document.getElementById('modalCancelSale')).show();
    }

    function confirmCancel() {
        var reason = document.getElementById('cancelReason').value.trim();
        if (!reason) {
            document.getElementById('cancelReason').classList.add('is-invalid');
            return;
        }
        document.getElementById('cancelReason').classList.remove('is-invalid');
        bootstrap.Modal.getInstance(document.getElementById('modalCancelSale')).hide();
        alert('ยกเลิกการซื้อขาย IMD: ' + document.getElementById('cancelImdNumber').textContent +
            '\nระบบได้ยกเลิกเลขที่ P1 และคืน Balance Stock อัตโนมัติแล้ว (mockup)');
    }

    // TOR 1.6(4): แสดง Modal พิมพ์ P1
    function showP1PrintModal(p1No, imdNo, product, qty) {
        // Update modal fields
        var p1Num = document.getElementById('printP1NumberPost');
        var p1Prod = document.getElementById('printP1ProductPost');
        var p1Qty1 = document.getElementById('printP1Qty1Post');
        var p1Qty2 = document.getElementById('printP1Qty2Post');
        var p1Date = document.getElementById('printP1DatePost');
        if (p1Num) p1Num.textContent = p1No;
        if (p1Prod) p1Prod.textContent = product || 'ผลิตภัณฑ์แปรรูปสัตว์น้ำ';
        if (p1Qty1) p1Qty1.textContent = qty || '0.000';
        if (p1Qty2) p1Qty2.textContent = qty || '0.000';
        if (p1Date) p1Date.textContent = 'วันที่ออก: ' + new Date().toLocaleDateString('th-TH');
        new bootstrap.Modal(document.getElementById('modalP1PrintPost')).show();
    }

    // TOR 1.6(4): พิมพ์ P1 Form
    function printP1FormPost() {
        var content = document.getElementById('p1FormA4Post').outerHTML;
        var win = window.open('', '_blank', 'width=900,height=700');
        win.document.write('<html><head><title>เอกสาร P1 — Product Balance Stock No.1</title>');
        win.document.write('<style>body{font-family:Sarabun,sans-serif;margin:0;}#p1FormA4Post{margin:0 auto;padding:30px 40px;max-width:794px;}</style>');
        win.document.write('</head><body>');
        win.document.write(content);
        win.document.write('<div style="text-align:center;margin-top:16px;"><button onclick="window.print()" style="padding:8px 24px;background:#154360;color:#fff;border:none;border-radius:4px;font-size:14px;cursor:pointer;">พิมพ์</button></div>');
        win.document.write('</body></html>');
        win.document.close();
    }

    // TOR 1.6(12): ดูรายละเอียด P1 + P2
    function showP1P2Detail(p1No, imdNo, product, qty) {
        // Populate P1 fields
        var p1Num = document.getElementById('detailP1Number');
        var imdEl = document.getElementById('detailImdNo');
        var prodEl = document.getElementById('detailProduct');
        var sellerEl = document.getElementById('detailSeller');
        if (p1Num) p1Num.textContent = p1No || 'P1-2569-00121';
        if (imdEl)  imdEl.textContent = imdNo || 'IMD-2569-00089';
        if (prodEl) prodEl.innerHTML  = (product || 'ปลาทูน่าอัลบาคอร์ แช่แข็ง') + '<br/><small class="text-primary">LOT-2561-001</small>';
        // Show modal
        new bootstrap.Modal(document.getElementById('modalP1P2Detail')).show();
    }

    function exportDetailP1Excel() {
        var p1No = document.getElementById('detailP1Number') ? document.getElementById('detailP1Number').textContent : 'P1';
        alert('Export Excel P1: ' + p1No + '.xlsx (mockup)\nระบบจะดาวน์โหลดรายละเอียด Balance Stock P1');
    }

    function exportDetailP2Excel() {
        var p1No = document.getElementById('detailP1Number') ? document.getElementById('detailP1Number').textContent : 'P1';
        alert('Export Excel P2 ที่เชื่อมกับ ' + p1No + ' (mockup)\nระบบจะดาวน์โหลดรายละเอียด P2 ทั้งหมด 2 รุ่น');
    }

    // TOR 1.6(4): Export Excel
    function exportExcelPost() {
        alert('Export Excel รายการทั้งหมดเป็นไฟล์ .xlsx (mockup)\nระบบจะดาวน์โหลดไฟล์ IMD_List_' + new Date().toISOString().slice(0,10) + '.xlsx');
    }

    function exportP1ExcelPost() {
        var p1No = document.getElementById('printP1NumberPost') ? document.getElementById('printP1NumberPost').textContent : 'P1';
        alert('Export Excel เอกสาร P1: ' + p1No + ' เป็นไฟล์ .xlsx (mockup)\nระบบจะดาวน์โหลด ' + p1No + '.xlsx');
    }

    function downloadP1PDFPost() {
        var p1No = document.getElementById('printP1NumberPost') ? document.getElementById('printP1NumberPost').textContent : 'P1';
        alert('ดาวน์โหลด PDF: ' + p1No + '.pdf (mockup)\nระบบจะเรนเดอร์ PDF และดาวน์โหลดอัตโนมัติ');
    }
</script>
}

