@{
    ViewData["Title"] = "ไม่สามารถเข้าถึงหน้าจอ";
    var deniedTitle = Convert.ToString(ViewData["DeniedTitle"]) ?? "คุณไม่มีสิทธิ์เข้าถึงหน้านี้";
    var deniedMessage = Convert.ToString(ViewData["DeniedMessage"]) ?? "คุณไม่มีสิทธิ์เข้าถึงหน้านี้";
    var backUrl = Convert.ToString(ViewData["BackUrl"]) ?? Url.Action("Index", "Dashboards") ?? "/";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-danger-subtle mt-4">
            <div class="card-body p-4 p-md-5 text-center">
                <span class="badge bg-label-danger rounded-pill px-3 py-2 mb-3">
                    <i class="ri ri-forbid-2-line me-1"></i> Access Denied
                </span>
                <h4 class="mb-2">@deniedTitle</h4>
                <p class="text-muted mb-4">@deniedMessage</p>
                <a href="@backUrl" class="btn btn-primary">
                    <i class="ri ri-arrow-left-line me-1"></i>กลับหน้าหลัก
                </a>
            </div>
        </div>
    </div>
</div>
