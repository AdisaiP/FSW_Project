@{
    ViewData["Title"] = "คำขอพิจารณาอนุมัติ %Yield";
}

@section PageStyles {
<style>
    .yield-status-badge { font-size: 0.72rem; }
    .import-drop-zone {
        border: 2px dashed #90a4ae;
        border-radius: 8px;
        background: #f8fafc;
        transition: border-color .2s, background .2s;
        cursor: pointer;
    }
    .import-drop-zone:hover, .import-drop-zone.dragover {
        border-color: #1976d2;
        background: #e3f2fd;
    }
</style>
}

<h4 class="mb-1">คำขอพิจารณาอนุมัติ %Yield</h4>
<p class="mb-1">นำเข้าและจัดการข้อมูล %Yield สำหรับวัตถุดิบสัตว์น้ำนำเข้าที่ผ่านการพิจารณาของสถานประกอบการที่อยู่ในการรับรอง</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item"><a href="@Url.Action("IndexAdjustRMBS1PS", "ImportAdjustment")" class="text-primary fw-semibold">RMBS1:PS</a></li>
        <li class="breadcrumb-item active">คำขออนุมัติ %Yield</li>
    </ol>
</nav>

<!-- ── Certification Status Bar (TOR 1.5(7)) ──
     Mockup: ตั้งค่า IS_CERTIFIED = true เพื่อแสดงสถานะในการรับรอง -->
<div class="alert alert-primary d-flex align-items-center gap-3 py-2 mb-4" id="alertCertifiedStatus">
    <i class="ri ri-shield-check-line fs-4 flex-shrink-0 text-primary"></i>
    <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <strong>สถานประกอบการ:</strong>
            <span>Alpha Office Automation Co., Ltd. (สาขา 00001)</span>
            <span class="badge bg-success ms-1">
                <i class="ri ri-checkbox-circle-line me-1"></i>อยู่ในการรับรองของกรมประมง
            </span>
        </div>
        <div class="small text-muted mt-1">
            <i class="ri ri-check-double-line text-success me-1"></i>
            <strong class="text-success">ระบบจะตรวจสอบ %Yield ทุกครั้ง</strong>ที่มีการบันทึกข้อมูลการผลิต —
            สถานประกอบการนี้อยู่ในการรับรองของกรมประมงและต้องผ่านการตรวจสอบ %Yield ทุกครั้ง
        </div>
    </div>
    <span class="badge bg-label-primary rounded-pill text-nowrap" style="font-size:0.7rem;">ใบอนุญาตเลขที่ FD-2567-1234</span>
</div>

<!-- ── (Reference: สถานการณ์นอกการรับรอง — แสดงเมื่อ IS_CERTIFIED = false)
<div class="alert alert-secondary d-flex align-items-center gap-3 py-2 mb-4" style="display:none;">
    <i class="ri ri-shield-line fs-4 flex-shrink-0 text-muted"></i>
    <div>
        <div class="d-flex align-items-center gap-2">
            <strong>สถานประกอบการ:</strong> XYZ Cold Storage Co., Ltd.
            <span class="badge bg-secondary ms-1">ไม่อยู่ในการรับรองของกรมประมง</span>
        </div>
        <div class="small text-muted mt-1">
            <i class="ri ri-skip-right-line me-1"></i>
            ระบบ<strong>ข้ามการตรวจสอบ %Yield อัตโนมัติ</strong>สำหรับสถานประกอบการนี้
            (ไม่อยู่ในการรับรองของกรมประมง)
        </div>
    </div>
</div>
── end reference ── -->

<!-- ── Alert สำเร็จ (แสดงหลังนำเข้า) ── -->
<div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-4" id="alertImportSuccess" style="display:none!important;">
    <i class="ri ri-checkbox-circle-line fs-5"></i>
    <div>
        <strong>นำเข้าข้อมูล %Yield สำเร็จ!</strong>
        <span id="alertImportSuccessMsg"> จำนวน 3 รายการเรียบร้อยแล้ว</span>
    </div>
    <button type="button" class="btn-close ms-auto" onclick="this.closest('.alert').style.setProperty('display','none','important');"></button>
</div>

<!-- ── Summary Cards ── -->
