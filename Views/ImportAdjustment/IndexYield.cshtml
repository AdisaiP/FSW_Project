@section PageScripts {
<script>
$(document).ready(function () {
    // Flatpickr for date filters
    if (typeof flatpickr !== 'undefined') {
        flatpickr('.flatpickr-date', { dateFormat: 'd/m/Y', locale: 'th' });
    }

    // Drag-and-drop highlight
    var zone = document.getElementById('dropZoneYield');
    if (zone) {
        zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
        zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
        zone.addEventListener('drop', function (e) {
            e.preventDefault();
            zone.classList.remove('dragover');
            var files = e.dataTransfer.files;
            if (files.length) handleYieldFileSelect({ files: files });
        });
    }
});

function handleYieldFileSelect(input) {
    var file = input.files && input.files[0];
    if (!file) return;
    var ext = file.name.split('.').pop().toLowerCase();
    if (!['xlsx','xls','csv'].includes(ext)) {
        alert('กรุณาเลือกไฟล์ .xlsx, .xls หรือ .csv เท่านั้น');
        return;
    }
    document.getElementById('selectedFileName').innerHTML =
        '<i class="ri ri-file-excel-2-line text-success me-1"></i><strong>' + file.name + '</strong> (' + (file.size/1024).toFixed(1) + ' KB)';
    // Show preview section and confirm button
    document.getElementById('previewSection').style.display = '';
    document.getElementById('btnConfirmImport').style.display = '';
}

function cancelPreview() {
    document.getElementById('previewSection').style.display = 'none';
    document.getElementById('selectedFileName').innerHTML = '';
    document.getElementById('fileYieldInput').value = '';
    document.getElementById('btnConfirmImport').style.display = 'none';
}

function confirmImport() {
    // Close modal
    var modalEl = document.getElementById('modalImportYield');
    if (modalEl) {
        var modal = bootstrap.Modal.getInstance(modalEl);
        if (modal) modal.hide();
    }
    cancelPreview();
    // Mockup: show success alert
    var alertEl = document.getElementById('alertImportSuccess');
    alertEl.style.removeProperty('display');
    alertEl.style.display = 'flex';
    document.getElementById('alertImportSuccessMsg').textContent = ' จำนวน 3 รายการเรียบร้อยแล้ว';
    window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
}
