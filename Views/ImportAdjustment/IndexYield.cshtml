</div>

<!-- ── Import Modal (TOR 1.5(1)) ── -->
<div class="modal fade" id="modalImportYield" tabindex="-1" aria-labelledby="modalImportYieldLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalImportYieldLabel">
                    <i class="ri ri-upload-2-line me-2 text-primary"></i>นำเข้าข้อมูล %Yield จาก Template File
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="cancelPreview()"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="ri ri-information-line me-1"></i>
                    ดาวน์โหลด Template Excel กรอกข้อมูล %Yield ตามรูปแบบที่กำหนด จากนั้นอัปโหลดไฟล์เพื่อนำเข้าข้อมูลหลายรายการพร้อมกัน
                    <br/>ใช้สำหรับ<strong>วัตถุดิบสัตว์น้ำนำเข้าที่ผ่านการพิจารณาแล้ว</strong>ของสถานประกอบการที่อยู่ในการรับรอง
                </div>
                <!-- Step 1: Download Template -->
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-label-primary rounded-circle" style="width:1.6rem;height:1.6rem;line-height:1.6rem;text-align:center;font-weight:700;">1</span>
                        <span class="fw-semibold small">ดาวน์โหลด Template File</span>
                    </div>
                    <p class="text-muted small mb-2">ดาวน์โหลดไฟล์ต้นแบบ Excel สำหรับกรอกข้อมูล %Yield ตามรูปแบบที่ระบบกำหนด</p>
                    <button type="button" class="btn btn-outline-success btn-sm"
                        onclick="alert('ดาวน์โหลด Template %Yield.xlsx (mockup)')">
                        <i class="ri ri-file-excel-2-line me-1"></i> ดาวน์โหลด Template %Yield.xlsx
                    </button>
                </div>
                <!-- Step 2: Upload File -->
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-label-primary rounded-circle" style="width:1.6rem;height:1.6rem;line-height:1.6rem;text-align:center;font-weight:700;">2</span>
                        <span class="fw-semibold small">อัปโหลดไฟล์ที่กรอกข้อมูลแล้ว</span>
                    </div>
                    <div class="import-drop-zone p-4 text-center mb-3" id="dropZoneYield"
                        onclick="document.getElementById('fileYieldInput').click()">
                        <i class="ri ri-upload-cloud-2-line fs-1 text-muted mb-2 d-block"></i>
                        <div class="fw-semibold">คลิกหรือลากวางไฟล์ที่นี่</div>
                        <div class="text-muted small mt-1">รองรับไฟล์ .xlsx, .xls, .csv (ขนาดไม่เกิน 5 MB)</div>
                        <input type="file" id="fileYieldInput" class="d-none" accept=".xlsx,.xls,.csv"
                            onchange="handleYieldFileSelect(this)" />
                    </div>
                    <div id="selectedFileName" class="text-muted small"></div>
                </div>
                <!-- Step 3: Preview Table -->
                <div class="border rounded p-3" id="previewSection" style="display:none;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-label-primary rounded-circle" style="width:1.6rem;height:1.6rem;line-height:1.6rem;text-align:center;font-weight:700;">3</span>
                        <span class="fw-semibold small">ตรวจสอบข้อมูลก่อนนำเข้า</span>
                    </div>
                    <div class="alert alert-warning py-2 small mb-2">
                        <i class="ri ri-alert-line me-1"></i>
                        กรุณาตรวจสอบข้อมูลด้านล่างให้ถูกต้องก่อนกดปุ่ม "ยืนยันนำเข้า"
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm small align-middle" id="previewTable">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width:2rem;">#</th>
                                    <th>ชื่อผลิตภัณฑ์</th>
                                    <th>รหัสผลิตภัณฑ์</th>
                                    <th>ประเภทวัตถุดิบ</th>
                                    <th>ชนิดสัตว์น้ำ</th>
                                    <th class="text-end">%Yield ที่ขอ</th>
                                    <th class="text-end">%Yield ปัจจุบัน</th>
                                    <th>สถานะตรวจสอบ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center text-muted">1</td>
                                    <td>Skipjack Tuna Canned in Brine</td>
                                    <td class="text-muted small">PROD-001</td>
                                    <td>วัตถุดิบนำเข้า</td>
                                    <td>ปลาทูน่าครีบเหลือง (YFT)</td>
                                    <td class="text-end fw-semibold">42.50%</td>
                                    <td class="text-end text-muted">40.00%</td>
                                    <td class="text-center"><span class="badge bg-label-success rounded-pill small">ผ่านการตรวจสอบ</span></td>
                                </tr>
                                <tr>
                                    <td class="text-center text-muted">2</td>
                                    <td>Tuna Chunk in Sunflower Oil</td>
                                    <td class="text-muted small">PROD-002</td>
                                    <td>วัตถุดิบนำเข้า</td>
                                    <td>ปลาทูน่าท้องแถบ (SKJ)</td>
                                    <td class="text-end fw-semibold">38.75%</td>
                                    <td class="text-end text-muted">40.00%</td>
                                    <td class="text-center"><span class="badge bg-label-success rounded-pill small">ผ่านการตรวจสอบ</span></td>
                                </tr>
                                <tr>
                                    <td class="text-center text-muted">3</td>
                                    <td>Mackerel Fillet Frozen</td>
                                    <td class="text-muted small">PROD-003</td>
                                    <td>วัตถุดิบนำเข้า</td>
                                    <td>ปลาแมคเคอเรล (MKR)</td>
                                    <td class="text-end fw-semibold">55.00%</td>
                                    <td class="text-end text-muted">52.00%</td>
                                    <td class="text-center"><span class="badge bg-label-warning rounded-pill small">รอตรวจสอบ</span></td>
                                </tr>
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="8" class="text-end small text-muted">พบข้อมูลทั้งหมด <strong>3 รายการ</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" onclick="cancelPreview()">
                    <i class="ri ri-close-line me-1"></i> ปิด
                </button>
                <button type="button" class="btn btn-primary btn-sm" id="btnConfirmImport"
                    onclick="confirmImport()" style="display:none;">
                    <i class="ri ri-check-double-line me-1"></i> ยืนยันนำเข้า 3 รายการ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Main Tabbed Card ── -->
<div class="card">
    <!-- Card header: title + action buttons -->
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2 pb-0 border-bottom-0">
        <div>
            <h5 class="card-title mb-1">คำขออนุมัติ %Yield</h5>
            <p class="text-muted small mb-0">จัดการคำขอ ตั้งค่า และฐานข้อมูล %Yield</p>
