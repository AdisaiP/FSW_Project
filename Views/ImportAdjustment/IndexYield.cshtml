                    <span class="badge bg-label-info rounded-pill ms-1" style="font-size:0.65rem;">TOR 1.5(5)</span>
                </button>
            </li>
        </ul>
    </div>

    <div class="tab-content" id="yieldMainTabsContent">

        <!-- ─── Tab 1: รายการคำขออนุมัติ %Yield ─── -->
        <div class="tab-pane fade show active" id="tab-requests" role="tabpanel" aria-labelledby="tab-requests-tab">
