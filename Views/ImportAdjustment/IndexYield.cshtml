    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">12</h5>
                        <small>คำขอทั้งหมด</small>
                    </div>
                    <span class="badge bg-label-primary rounded-circle p-2">
                        <i class="icon-base ri ri-percent-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">5</h5>
                        <small>รออนุมัติ</small>
                    </div>
                    <span class="badge bg-label-warning rounded-circle p-2">
                        <i class="icon-base ri ri-time-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">6</h5>
                        <small>อนุมัติแล้ว</small>
                    </div>
                    <span class="badge bg-label-success rounded-circle p-2">
                        <i class="icon-base ri ri-checkbox-circle-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">1</h5>
                        <small>ส่งคืนแก้ไข</small>
                    </div>
                    <span class="badge bg-label-danger rounded-circle p-2">
                        <i class="icon-base ri ri-arrow-go-back-line icon-24px"></i>
                    </span>
                </div>
            </div>
        </div>
