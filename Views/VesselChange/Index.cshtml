@model AspnetCoreMvcFull.Models.ChangeRequestIndexViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "พิจารณารายการขอเปลี่ยนแปลงข้อมูลในผังเรือ";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section PageStyles {
    <style>
        .vessel-change-table {
            font-size: 0.8rem;
        }

        .vessel-change-table th,
        .vessel-change-table td {
            padding: 0.45rem 0.5rem;
            vertical-align: middle;
            line-height: 1.3;
            white-space: normal;
            word-break: break-word;
        }

        .vessel-change-table thead th {
            word-break: keep-all;
            overflow-wrap: normal;
        }

        .vessel-change-table .btn-icon {
            width: 1.65rem;
            height: 1.65rem;
        }

        .vessel-change-table .form-check-input {
            margin-top: 0;
        }

        .filter-form-label {
            font-size: 0.8rem;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .btn-square {
            width: 40px;
            height: 40px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
    </style>
}

<h4 class="mb-1">พิจารณารายการขอเปลี่ยนแปลงข้อมูลในผังเรือ</h4>
<p class="mb-1">จัดการรายการคำขอเปลี่ยนแปลงข้อมูลในผังเรือ </p>

<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "VesselChange")" class="text-primary fw-semibold">หน้าหลัก</a>
        </li>
    </ol>
</nav>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">ค้นหารายการ</h5>
    </div>
    <div class="card-body">
        <form asp-action="Search" asp-controller="VesselChange" method="post">
            <div class="row g-3">
                <div class="col-md-4 col-lg-4">
                    <label for="filterAgency" class="form-label filter-form-label">หน่วยงาน <span class="text-danger">●</span></label>
                    <select id="filterAgency" class="form-select form-select-sm" asp-for="SearchCriteria.AgencyId">
                        <option value="">-- เลือกข้อมูลหน่วยงาน --</option>
                    </select>
                </div>

                <div class="col-md-4 col-lg-4">
                    <label for="filterEntrepreneur" class="form-label filter-form-label">ผู้ประกอบการ</label>
                    <select id="filterEntrepreneur" class="form-select form-select-sm" asp-for="SearchCriteria.EntrepreneurName">
                        <option value="">-- เลือกข้อมูล --</option>
                        <option value="Alpha Office Automation Co., Ltd. (สาขา 00002)">Alpha Office Automation Co., Ltd. (สาขา 00002)</option>
                        <option value="Beta Marine Services">Beta Marine Services</option>
                    </select>
                </div>

                <div class="col-md-4 col-lg-4">
                    <label for="filterStatus" class="form-label filter-form-label">สถานะ</label>
                    <select id="filterStatus" class="form-select form-select-sm" asp-for="SearchCriteria.Status">
                        <option value="">-- เลือกสถานะ --</option>
                    </select>
                </div>

                <div class="col-md-4 col-lg-4">
                    <label for="startDatePicker" class="form-label filter-form-label">วันที่ทำรายการ</label>
                    <input type="text"
                           id="startDatePicker"
                           class="form-control form-control-sm"
                           asp-for="SearchCriteria.StartDate"
                           placeholder="วว/ดด/ปปปป"
                           autocomplete="off" />
                </div>

                <div class="col-md-4 col-lg-4">
                    <label for="endDatePicker" class="form-label filter-form-label">ถึงวันที่</label>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="text"
                               id="endDatePicker"
                               class="form-control form-control-sm"
                               asp-for="SearchCriteria.EndDate"
                               placeholder="วว/ดด/ปปปป"
                               autocomplete="off" />
                        <button type="submit" class="btn btn-primary btn-square" title="สืบค้น">
                            <i class="ri ri-search-line"></i>
                        </button>
                        <button type="button" id="btnReset" class="btn btn-outline-secondary btn-square" title="ล้างค่า">
                            <i class="ri ri-refresh-line"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">รายการคำขอเปลี่ยนแปลง</h5>
            <p class="text-muted small mb-0">แสดงรายการคำขอเปลี่ยนแปลงข้อมูลในผังเรือ</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("CreateLayoutChange", "VesselChange")" class="btn btn-primary btn-sm" title="สร้างรายการขอเปลี่ยนแปลง">
                <i class="ri ri-add-line me-1"></i> สร้างคำขอ
            </a>
        </div>
    </div>

    <div class="table-responsive p-1">
        <table class="table table-bordered table-hover align-middle mb-0 vessel-change-table">
            <thead class="text-center">
                <tr>
                    <th style="width: 40px;"><input class="form-check-input" type="checkbox" id="selectAll" /></th>
                    <th style="width: 40px;"></th>
                    <th style="min-width: 140px;">เลขที่เอกสาร</th>
                    <th style="min-width: 180px;">ชื่อเอกสาร</th>
                    <th style="min-width: 220px;">ผู้ประกอบการ</th>
                    <th style="min-width: 220px;">เรื่อง</th>
                    <th style="width: 130px;">วันที่ทำรายการ</th>
                    <th style="width: 130px;">จัดการ</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.RequestItems != null && Model.RequestItems.Any())
                {
                    foreach (var item in Model.RequestItems)
                    {
                        <tr>
                            <td class="text-center">
                                <input class="form-check-input row-checkbox" type="checkbox" />
                            </td>
                            <td class="text-center"><i class='bx bx-star text-primary'></i></td>
                            <td class="text-nowrap">@item.DocumentNo</td>
                            <td class="small">@item.DocumentName</td>
                            <td class="small">@item.EntrepreneurDetails</td>
                            <td class="small">
                                <a href="javascript:void(0);" class="text-primary text-decoration-none">@item.Subject</a>
                            </td>
                            <td class="text-center text-nowrap">@item.TransactionDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a href="@Url.Action("CreateIMD", "ImportAdjustment")" class="btn btn-sm btn-icon btn-outline-info" title="รายละเอียด" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-eye-line text-info"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-warning" title="แก้ไข" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-pencil-line text-warning"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-success" title="ยื่นคำขอ" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-send-plane-line text-success"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-icon btn-outline-danger" title="ลบ" data-bs-toggle="tooltip" data-bs-placement="top">
                                        <i class="ri ri-delete-bin-line text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-3 text-muted">ไม่พบข้อมูล</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer bg-white border-top py-2 d-flex justify-content-end">
        <small class="text-muted">ผลลัพธ์ 1 ถึง @(Model?.RequestItems?.Count ?? 0) จาก @(Model?.RequestItems?.Count ?? 0)</small>
    </div>
</div>

@section VendorScripts {
    <script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@section PageScripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            ["startDatePicker", "endDatePicker"].forEach(function (id) {
                const input = document.getElementById(id);
                if (input) {
                    flatpickr(input, {
                        dateFormat: "d/m/Y",
                        allowInput: true,
                        locale: {
                            firstDayOfWeek: 1
                        }
                    });
                }
            });

            if (window.bootstrap && bootstrap.Tooltip) {
                document.querySelectorAll("[data-bs-toggle='tooltip']").forEach(function (el) {
                    new bootstrap.Tooltip(el);
                });
            }

            const selectAll = document.getElementById('selectAll');
            const checkboxes = Array.from(document.querySelectorAll('.row-checkbox'));

            function syncSelectAllState() {
                if (!selectAll) return;
                const checkedCount = checkboxes.filter(function (cb) { return cb.checked; }).length;
                selectAll.checked = checkboxes.length > 0 && checkedCount === checkboxes.length;
                selectAll.indeterminate = checkedCount > 0 && checkedCount < checkboxes.length;
            }

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    checkboxes.forEach(function (cb) {
                        cb.checked = selectAll.checked;
                    });
                    syncSelectAllState();
                });
            }

            checkboxes.forEach(function (cb) {
                cb.addEventListener('change', syncSelectAllState);
            });

            syncSelectAllState();

            const btnReset = document.getElementById('btnReset');
            if (btnReset) {
                btnReset.addEventListener('click', function () {
                    ['filterAgency', 'filterEntrepreneur', 'filterStatus', 'startDatePicker', 'endDatePicker'].forEach(function (id) {
                        const input = document.getElementById(id);
                        if (input) {
                            input.value = '';
                        }
                    });

                    if (selectAll) {
                        selectAll.checked = false;
                        selectAll.indeterminate = false;
                    }

                    checkboxes.forEach(function (cb) {
                        cb.checked = false;
                    });
                });
            }
        });
    </script>
}
