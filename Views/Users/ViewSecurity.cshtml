@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "ความปลอดภัย";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; border-color:#369a3a; color:#fff; }
  .mfa-method-card {
    border:1.5px solid var(--bs-border-color); border-radius:10px;
    padding:1.25rem; transition:all .18s ease;
  }
  .mfa-method-card.is-active { border-color:var(--dpim-green); background:rgba(65,173,73,.04); }
  .mfa-icon { width:48px; height:48px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.5rem; flex-shrink:0; }
  .form-check-input:checked { background-color:var(--dpim-green); border-color:var(--dpim-green); }
  .qr-placeholder { width:160px; height:160px; border:1px solid var(--bs-border-color); border-radius:8px; display:flex; align-items:center; justify-content:center; background:var(--bs-gray-100); }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.mfa-toggle').forEach(function (toggle) {
    toggle.addEventListener('change', function () {
      var card = this.closest('.mfa-method-card');
      if (this.checked) { card.classList.add('is-active'); }
      else { card.classList.remove('is-active'); }
    });
  });

  var btnSetup = document.getElementById('btnSetupAuthApp');
  if (btnSetup) {
    btnSetup.addEventListener('click', function () {
      new bootstrap.Modal(document.getElementById('modalSetupAuthApp')).show();
    });
  }

  var btnBackup = document.getElementById('btnSaveBackupCodes');
  if (btnBackup) {
    btnBackup.addEventListener('click', function () {
      var codes = document.getElementById('backupCodesList').innerText;
      var blob = new Blob([codes], { type: 'text/plain' });
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'dpim-backup-codes.txt';
      a.click();
    });
  }

  document.querySelectorAll('.btn-delete-device').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var row = this.closest('tr');
      var deviceName = row.querySelector('td:first-child').textContent.trim();
      if (confirm('ลบอุปกรณ์ "' + deviceName + '" ออกจากรายการที่เชื่อถือ?')) {
        row.remove();
      }
    });
  });

  var btnDeleteAll = document.getElementById('btnDeleteAllDevices');
  if (btnDeleteAll) {
    btnDeleteAll.addEventListener('click', function () {
      if (confirm('ยืนยันลบอุปกรณ์ที่เชื่อถือทั้งหมด? คุณจะต้องยืนยัน MFA ในการ Login ครั้งถัดไปจากทุกอุปกรณ์')) {
        document.querySelectorAll('#tableDevices tbody tr').forEach(function(r) { r.remove(); });
      }
    });
  }

  var btnChangePwd = document.getElementById('btnChangePassword');
  if (btnChangePwd) {
    btnChangePwd.addEventListener('click', function () {
      new bootstrap.Modal(document.getElementById('modalChangePassword')).show();
    });
  }

  var btnSavePwd = document.getElementById('btnSavePassword');
  if (btnSavePwd) {
    btnSavePwd.addEventListener('click', function () {
      var newPwd = document.getElementById('newPassword').value;
      var confirmPwd = document.getElementById('confirmNewPassword').value;
      if (!newPwd) { alert('กรุณากรอกรหัสผ่านใหม่'); return; }
      if (newPwd !== confirmPwd) { alert('รหัสผ่านไม่ตรงกัน'); return; }
      bootstrap.Modal.getInstance(document.getElementById('modalChangePassword')).hide();
      alert('เปลี่ยนรหัสผ่านสำเร็จ');
    });
  }
});
</script>
}

@* ============================================================ *@
<div class="container-xxl flex-grow-1 container-p-y">

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb breadcrumb-style1 mb-4">
      <li class="breadcrumb-item"><a href="/">หน้าหลัก</a></li>
      <li class="breadcrumb-item"><a href="/Users/ViewAccount">โปรไฟล์ผู้ใช้งาน</a></li>
      <li class="breadcrumb-item active">ความปลอดภัย</li>
    </ol>
  </nav>

  <h4 class="page-title-dpim mb-4">ตั้งค่าความปลอดภัย</h4>

  <ul class="nav nav-pills mb-4 flex-wrap gap-2">
    <li class="nav-item">
      <a class="nav-link" href="/Users/ViewAccount">
        <i class="ri ri-user-line me-1"></i>ข้อมูลส่วนตัว
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link active" href="/Users/ViewSecurity">
        <i class="ri ri-shield-line me-1"></i>ความปลอดภัย
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link" href="/Users/ViewAddresses">
        <i class="ri ri-map-line me-1"></i>บัญชีที่อยู่
      </a>
    </li>
  </ul>

  <div class="row g-4">

    <!-- Section: Change Password -->
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">
            <i class="ri ri-lock-unlock-line me-2" style="color:var(--dpim-blue);"></i>รหัสผ่าน
          </h5>
          <button id="btnChangePassword" type="button" class="btn btn-sm btn-outline-secondary">
            <i class="ri ri-edit-line me-1"></i>เปลี่ยนรหัสผ่าน
          </button>
        </div>
        <div class="card-body">
          <div class="d-flex align-items-center gap-3">
            <div style="width:40px;height:40px;border-radius:8px;background:rgba(35,64,143,.1);display:flex;align-items:center;justify-content:center;">
              <i class="ri ri-lock-line" style="color:var(--dpim-blue);font-size:1.2rem;"></i>
            </div>
            <div>
              <div class="fw-semibold">รหัสผ่านถูกเข้ารหัสและจัดเก็บอย่างปลอดภัย</div>
              <div class="text-muted" style="font-size:.85rem;">เปลี่ยนรหัสผ่านครั้งล่าสุด: 01/01/2569</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: MFA Methods -->
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">
            <i class="ri ri-shield-line me-2" style="color:var(--dpim-blue);"></i>การยืนยันตัวตนสองขั้นตอน (MFA)
          </h5>
          <p class="card-subtitle text-muted mt-1 mb-0" style="font-size:.85rem;">เปิดใช้งาน MFA เพื่อเพิ่มความปลอดภัยในการเข้าสู่ระบบ</p>
        </div>
        <div class="card-body">
          <div class="row g-3">

            <!-- Email OTP -->
            <div class="col-md-6">
              <div class="mfa-method-card is-active">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="d-flex gap-3 align-items-center">
                    <div class="mfa-icon" style="background:rgba(35,64,143,.1);">
                      <i class="ri ri-mail-line" style="color:var(--dpim-blue);"></i>
                    </div>
                    <div>
                      <div class="fw-semibold">Email OTP</div>
                      <div class="text-muted" style="font-size:.82rem;">adisaip@dpim.go.th</div>
                    </div>
                  </div>
                  <div class="form-check form-switch mb-0">
                    <input class="form-check-input mfa-toggle" type="checkbox" checked />
                  </div>
                </div>
                <div class="mt-2">
                  <span class="badge" style="background:rgba(65,173,73,.15);color:#155724;font-size:.78rem;">
                    <i class="ri ri-check-line me-1"></i>กำลังใช้งาน
                  </span>
                </div>
              </div>
            </div>

            <!-- Authenticator App -->
            <div class="col-md-6">
              <div class="mfa-method-card">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="d-flex gap-3 align-items-center">
                    <div class="mfa-icon" style="background:rgba(65,173,73,.1);">
                      <i class="ri ri-smartphone-line" style="color:var(--dpim-green);"></i>
                    </div>
                    <div>
                      <div class="fw-semibold">Authenticator App</div>
                      <div class="text-muted" style="font-size:.82rem;">Google / Microsoft Authenticator</div>
                    </div>
                  </div>
                  <div class="form-check form-switch mb-0">
                    <input class="form-check-input mfa-toggle" type="checkbox" />
                  </div>
                </div>
                <div class="mt-2">
                  <button id="btnSetupAuthApp" type="button" class="btn btn-sm btn-outline-secondary">
                    <i class="ri ri-qr-code-line me-1"></i>ตั้งค่า / แสดง QR Code
                  </button>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Section: Trusted Devices -->
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <div>
            <h5 class="card-title mb-0">
              <i class="ri ri-device-line me-2" style="color:var(--dpim-blue);"></i>อุปกรณ์ที่เชื่อถือ (Trusted Devices)
            </h5>
            <p class="card-subtitle text-muted mt-1 mb-0" style="font-size:.85rem;">อุปกรณ์เหล่านี้ไม่ต้องยืนยัน MFA ในการ Login ครั้งถัดไป</p>
          </div>
          <button id="btnDeleteAllDevices" type="button" class="btn btn-sm btn-outline-danger">
            <i class="ri ri-delete-bin-line me-1"></i>ลบทั้งหมด
          </button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table id="tableDevices" class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>อุปกรณ์</th>
                  <th>Browser / OS</th>
                  <th>IP Address</th>
                  <th>วันที่เพิ่ม</th>
                  <th>หมดอายุ</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="ri ri-macbook-line" style="color:var(--dpim-blue);font-size:1.2rem;"></i>
                      <span class="fw-semibold">MacBook Pro</span>
                    </div>
                  </td>
                  <td><span class="text-muted" style="font-size:.85rem;">Chrome 124 / macOS 14</span></td>
                  <td><code style="font-size:.82rem;">192.168.1.100</code></td>
                  <td>01/04/2569</td>
                  <td><span class="badge bg-label-success">01/05/2569</span></td>
                  <td>
                    <button class="btn btn-sm btn-icon btn-outline-danger btn-delete-device" title="ลบ">
                      <i class="ri ri-delete-bin-line"></i>
                    </button>
                  </td>
                </tr>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="ri ri-smartphone-line" style="color:var(--dpim-green);font-size:1.2rem;"></i>
                      <span class="fw-semibold">iPhone 15 Pro</span>
                    </div>
                  </td>
                  <td><span class="text-muted" style="font-size:.85rem;">Safari / iOS 17</span></td>
                  <td><code style="font-size:.82rem;">192.168.1.105</code></td>
                  <td>15/04/2569</td>
                  <td><span class="badge bg-label-success">15/05/2569</span></td>
                  <td>
                    <button class="btn btn-sm btn-icon btn-outline-danger btn-delete-device" title="ลบ">
                      <i class="ri ri-delete-bin-line"></i>
                    </button>
                  </td>
                </tr>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <i class="ri ri-computer-line" style="color:#6c757d;font-size:1.2rem;"></i>
                      <span class="fw-semibold">PC Office</span>
                    </div>
                  </td>
                  <td><span class="text-muted" style="font-size:.85rem;">Edge 124 / Windows 11</span></td>
                  <td><code style="font-size:.82rem;">10.0.0.50</code></td>
                  <td>20/04/2569</td>
                  <td><span class="badge bg-label-warning">20/05/2569</span></td>
                  <td>
                    <button class="btn btn-sm btn-icon btn-outline-danger btn-delete-device" title="ลบ">
                      <i class="ri ri-delete-bin-line"></i>
                    </button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Modal: Setup Authenticator App -->
<div class="modal fade" id="modalSetupAuthApp" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ri ri-qr-code-line me-2"></i>ตั้งค่า Authenticator App</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <ol class="mb-4" style="font-size:.9rem;">
          <li class="mb-2">ดาวน์โหลด <strong>Google Authenticator</strong> หรือ <strong>Microsoft Authenticator</strong></li>
          <li class="mb-2">เปิดแอปและเลือก "เพิ่มบัญชี" แล้วสแกน QR Code</li>
          <li class="mb-2">สแกน QR Code ด้านล่าง หรือกรอก Secret Key ด้วยตนเอง</li>
          <li>กรอก 6-digit OTP เพื่อยืนยันการตั้งค่า</li>
        </ol>
        <div class="text-center mb-4">
          <div class="qr-placeholder mx-auto mb-2">
            <div class="text-center">
              <i class="ri ri-qr-code-line" style="font-size:3rem;color:var(--bs-gray-500);"></i>
              <div class="text-muted" style="font-size:.75rem;">QR Code (Mock)</div>
            </div>
          </div>
          <div class="text-muted" style="font-size:.82rem;">
            Secret Key: <code>DPIM-XXXX-YYYY-ZZZZ</code>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">กรอก OTP 6 หลักเพื่อยืนยัน</label>
          <input type="text" class="form-control text-center fs-5 fw-bold" maxlength="6" placeholder="000000"
                 style="letter-spacing:.3em;" />
        </div>
        <div class="mt-3">
          <div class="fw-semibold mb-2" style="font-size:.88rem;">Backup Codes (บันทึกไว้ในที่ปลอดภัย)</div>
          <div id="backupCodesList" class="p-3 rounded" style="background:var(--bs-gray-100);font-family:monospace;font-size:.85rem;line-height:2;">
            DPIM-A1B2-C3D4<br/>
            DPIM-E5F6-G7H8<br/>
            DPIM-I9J0-K1L2<br/>
            DPIM-M3N4-O5P6<br/>
            DPIM-Q7R8-S9T0
          </div>
          <button id="btnSaveBackupCodes" type="button" class="btn btn-sm btn-outline-secondary mt-2">
            <i class="ri ri-download-line me-1"></i>ดาวน์โหลด Backup Codes
          </button>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
        <button type="button" class="btn btn-dpim-green" data-bs-dismiss="modal">
          <i class="ri ri-check-line me-1"></i>ยืนยันการตั้งค่า
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Change Password -->
<div class="modal fade" id="modalChangePassword" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ri ri-lock-unlock-line me-2"></i>เปลี่ยนรหัสผ่าน</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">รหัสผ่านปัจจุบัน <span class="text-danger">*</span></label>
            <input type="password" class="form-control" placeholder="กรอกรหัสผ่านปัจจุบัน" />
          </div>
          <div class="col-12">
            <label class="form-label">รหัสผ่านใหม่ <span class="text-danger">*</span></label>
            <input type="password" id="newPassword" class="form-control" placeholder="อย่างน้อย 8 ตัวอักษร" />
            <div class="form-text text-muted">ต้องมีตัวอักษรพิมพ์ใหญ่, ตัวเลข, และสัญลักษณ์</div>
          </div>
          <div class="col-12">
            <label class="form-label">ยืนยันรหัสผ่านใหม่ <span class="text-danger">*</span></label>
            <input type="password" id="confirmNewPassword" class="form-control" placeholder="กรอกรหัสผ่านใหม่อีกครั้ง" />
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" id="btnSavePassword" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>บันทึก
        </button>
      </div>
    </div>
  </div>
</div>
