@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "โปรไฟล์ผู้ใช้งาน";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .avatar-wrapper { position:relative; width:96px; height:96px; margin:0 auto; }
  .avatar-wrapper img { width:96px; height:96px; border-radius:50%; border:3px solid var(--dpim-blue); object-fit:cover; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; border-color:#369a3a; color:#fff; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  var btnEdit = document.getElementById('btnEditGeneral');
  if (btnEdit) {
    btnEdit.addEventListener('click', function () {
      var fields = document.querySelectorAll('.general-field');
      var isEditing = this.dataset.editing === 'true';
      if (isEditing) {
        this.innerHTML = '<i class="ri ri-edit-line me-1"></i>แก้ไขข้อมูล';
        this.classList.replace('btn-dpim-green', 'btn-outline-secondary');
        this.dataset.editing = 'false';
        fields.forEach(function(f) { f.setAttribute('readonly', ''); });
        alert('บันทึกข้อมูลสำเร็จ');
      } else {
        this.innerHTML = '<i class="ri ri-save-line me-1"></i>บันทึก';
        this.classList.replace('btn-outline-secondary', 'btn-dpim-green');
        this.dataset.editing = 'true';
        fields.forEach(function(f) { f.removeAttribute('readonly'); });
      }
    });
  }

  document.querySelectorAll('.btn-edit-sensitive').forEach(function (btn) {
    btn.addEventListener('click', function () {
      new bootstrap.Modal(document.getElementById('modalVerifyPassword')).show();
    });
  });

  var btnVerify = document.getElementById('btnVerifyPwd');
  if (btnVerify) {
    btnVerify.addEventListener('click', function () {
      var pwd = document.getElementById('verifyPassword').value;
      if (!pwd) { alert('กรุณากรอกรหัสผ่าน'); return; }
      bootstrap.Modal.getInstance(document.getElementById('modalVerifyPassword')).hide();
      new bootstrap.Modal(document.getElementById('modalEditSensitive')).show();
    });
  }

  var btnSave = document.getElementById('btnSaveSensitive');
  if (btnSave) {
    btnSave.addEventListener('click', function () {
      bootstrap.Modal.getInstance(document.getElementById('modalEditSensitive')).hide();
      alert('บันทึกข้อมูลสำคัญสำเร็จ ระบบจะส่งการแจ้งเตือนไปยังอีเมลของคุณ');
    });
  }

  /* ── Favorite Menu Tab (F10) ── */
  var tabFav = document.getElementById('tabFavoriteMenu');
  var mainContent = document.querySelector('.row.g-4');
  var favSection = document.getElementById('section-favorite-menu');

  function updateFavCount() {
    var checked = document.querySelectorAll('.fav-check:checked');
    document.getElementById('favCount').textContent = checked.length + ' เมนูที่เลือก';
    var preview = document.getElementById('favPreview');
    preview.innerHTML = '';
    checked.forEach(function (c) {
      var div = document.createElement('div');
      div.innerHTML = '<i class="ri ri-arrow-right-s-line me-1"></i>' + c.dataset.menu;
      preview.appendChild(div);
    });
  }

  if (tabFav) {
    tabFav.addEventListener('click', function (e) {
      e.preventDefault();
      document.querySelectorAll('.nav-link').forEach(function (l) { l.classList.remove('active'); });
      this.classList.add('active');
      if (mainContent) mainContent.style.display = 'none';
      if (favSection) favSection.style.display = '';
      updateFavCount();
    });
  }

  document.querySelectorAll('.fav-check').forEach(function (c) {
    c.addEventListener('change', updateFavCount);
  });

  if (document.getElementById('btnSaveFavorite')) {
    document.getElementById('btnSaveFavorite').addEventListener('click', function () {
      alert('บันทึกเมนูโปรดสำเร็จ');
    });
  }

});
</script>
}

