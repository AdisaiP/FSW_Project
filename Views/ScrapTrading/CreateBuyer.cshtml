@section PageScripts {
<script>
$(document).ready(function () {

    // ── Flatpickr ──
    function initFp(el) {
        if (el && !el._flatpickr) flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true });
    }
    document.querySelectorAll('.flatpickr-date').forEach(function(el) { initFp(el); });

    // ── Select2 ──
    $('.select2').select2({ width: '100%' });

    // ── ประเภทผู้ซื้อต่อ toggle ──
    $('input[name="resellBuyerType"]').on('change', function () {
        if ($(this).val() === 'inside') {
            $('#resellBuyerInsideSection').removeClass('d-none');
            $('#resellBuyerOutsideSection').addClass('d-none');
        } else {
            $('#resellBuyerInsideSection').addClass('d-none');
            $('#resellBuyerOutsideSection').removeClass('d-none');
        }
    });

    // ── เปิด modal ค้นหาผู้ซื้อต่อ ──
    $('#btnSearchResellBuyer').on('click', function () {
        new bootstrap.Modal(document.getElementById('modalSearchResellBuyer')).show();
    });

    $(document).on('click', '.resell-buyer-row', function () {
        $('.resell-buyer-row').removeClass('table-active');
        $(this).addClass('table-active').find('input[type=radio]').prop('checked', true);
    });

    $('#btnConfirmSelectResellBuyer').on('click', function () {
        var $sel = $('input[name=resellBuyerSelect]:checked').closest('tr');
        if ($sel.length === 0) { alert('กรุณาเลือกผู้ซื้อต่อก่อน'); return; }
        $('#resellBuyerName').val($sel.data('name'));
        $('#resellBuyerTaxId').val($sel.data('tax'));
        $('#resellBuyerPhone').val($sel.data('phone'));
        $('#resellBuyerLicense').val($sel.data('license'));
        $('#resellBuyerAddress').val($sel.data('address'));
        bootstrap.Modal.getInstance(document.getElementById('modalSearchResellBuyer')).hide();
    });

    // ── คำนวณน้ำหนักรวมขายต่อ ──
    function recalcResell() {
        var total = 0;
        $('input[id^="resellWeight"]').each(function () {
            total += parseFloat($(this).val()) || 0;
        });
        $('#totalResellWeight').text(total.toLocaleString('th-TH', { minimumFractionDigits: 3 }));
    }
    $(document).on('input', 'input[id^="resellWeight"]', function () { recalcResell(); });

    // ── PDF Preview ──
    $('#btnPreviewPdf').on('click', function () {
        new bootstrap.Modal(document.getElementById('modalPdfPreview')).show();
    });

    // ── ยืนยันรับซื้อ ──
    $('#btnConfirmPurchase').on('click', function () {
        if (!$('#confirmDate').val()) { alert('กรุณาระบุวันที่ยืนยันรับซื้อ'); return; }
        if (!$('#receiveWeightTotal').val()) { alert('กรุณาระบุน้ำหนักรับจริง'); return; }
        if (!confirm('ยืนยันการรับซื้อเศษเหลือรายการนี้ใช่หรือไม่?')) return;
        $('#alertResellPending').removeClass('alert-info').addClass('alert-success')
            .html('<i class="ri ri-check-circle-line fs-5 flex-shrink-0"></i> <span>ยืนยันรับซื้อแล้ว — สามารถบันทึกขายต่อหรือสร้างหนังสือรับรองปลาป่นได้</span>');
        alert('บันทึกยืนยันรับซื้อเรียบร้อยแล้ว (mockup)');
    });

    // ── บันทึกขายต่อ ──
    $('#btnSaveResell').on('click', function () {
        if (!$('#resellBuyerName').val() && !$('#extResellBuyerName').val()) {
            alert('กรุณาระบุผู้ซื้อต่อ'); return;
        }
        if (!$('#resellDate').val()) { alert('กรุณาระบุวันที่ขายต่อ'); return; }
        alert('บันทึกการขายต่อและออกหนังสือกำกับเรียบร้อยแล้ว (mockup)');
    });

    // ── สร้างหนังสือปลาป่น ──
    $('#btnCreateFishmeal').on('click', function () {
        if (!$('#fishmealPlant').val()) { alert('กรุณาระบุโรงงานปลาป่น'); return; }
        if (!$('#fishmealProductWeight').val()) { alert('กรุณาระบุน้ำหนักปลาป่นที่ผลิตได้'); return; }
        if (!confirm('ยืนยันการสร้างหนังสือรับรองแหล่งที่มาของปลาป่นใช่หรือไม่?')) return;
        alert('สร้างหนังสือรับรองแหล่งที่มาของปลาป่นเรียบร้อยแล้ว (mockup)');
    });
});
</script>
}
