@{
    ViewData["Title"] = "บันทึกการขายเศษเหลือ";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/select2/select2.css" />
<link rel="stylesheet" href="~/vendor/libs/flatpickr/flatpickr.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/select2/select2.js"></script>
<script src="~/vendor/libs/flatpickr/flatpickr.js"></script>
}

@* ============================================================ Content ============================================================ *@
<h4 class="mb-1">บันทึกการขายเศษเหลือ</h4>
<p class="mb-1">บันทึกการขายเศษเหลือจากการแปรรูปสัตว์น้ำนำเข้า และออกหนังสือกำกับการซื้อขาย</p>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-6">
    <ol class="breadcrumb breadcrumb-style1" style="--bs-breadcrumb-divider: '>'; font-size: 0.75rem;">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "ScrapTrading")" class="text-primary fw-semibold">การซื้อขายเศษเหลือ</a>
        </li>
        <li class="breadcrumb-item active text-secondary">บันทึกการขายเศษเหลือ</li>
    </ol>
</nav>

<div class="row">
    <div class="col-12">

        <form method="post" action="#">
        <div class="nav-align-top nav-tabs-shadow mb-4">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-detail" aria-controls="tab-detail" aria-selected="true">
                        <i class="ri ri-file-list-2-line me-1"></i> รายละเอียดการขาย
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-scrap" aria-controls="tab-scrap" aria-selected="false">
                        <i class="ri ri-archive-line me-1"></i> รายการเศษเหลือ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-evidence" aria-controls="tab-evidence" aria-selected="false">
                        <i class="ri ri-folder-open-line me-1"></i> หลักฐานประกอบ
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab"
                        data-bs-target="#tab-history" aria-controls="tab-history" aria-selected="false">
                        <i class="ri ri-time-line me-1"></i> ประวัติการดำเนินการ
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                <!-- ==================== TAB 1: รายละเอียดการขาย ==================== -->
                <div id="tab-detail" class="tab-pane fade show active">

                    <!-- Accordion: ข้อมูลเลขที่หนังสือ -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionDocInfo">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingDocInfo">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseDocInfo" aria-expanded="true" aria-controls="collapseDocInfo">
                                    <i class="icon-base ri ri-file-list-line me-2"></i>
                                    ข้อมูลเลขที่หนังสือกำกับ
                                </button>
                            </h2>
                            <div id="collapseDocInfo" class="accordion-collapse collapse show" aria-labelledby="headingDocInfo">
                                <div class="accordion-body p-0">
                                    <div class="p-4">
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="docNo"
                                                        value="(ระบบจะออกเลขที่ให้อัตโนมัติ)" readonly />
                                                    <label for="docNo">เลขที่หนังสือกำกับการซื้อขายเศษเหลือ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="docDate" class="form-control flatpickr-date"
                                                        placeholder="วว/ดด/ปปปป" value="@DateTime.Now.ToString("dd/MM/yyyy")" />
                                                    <label for="docDate">วันที่ซื้อขาย <span class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="docStatus"
                                                        value="ร่าง" readonly />
                                                    <label for="docStatus">สถานะ</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Accordion: ข้อมูลผู้ขาย -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionSeller">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingSeller">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseSeller" aria-expanded="true" aria-controls="collapseSeller">
                                    <i class="icon-base ri ri-store-2-line me-2"></i>
                                    ข้อมูลผู้ขาย (ผู้แปรรูปสัตว์น้ำ)
                                </button>
                            </h2>
                            <div id="collapseSeller" class="accordion-collapse collapse show" aria-labelledby="headingSeller">
                                <div class="accordion-body p-0">
                                    <div class="p-4">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="sellerName"
                                                        value="บริษัท ซีฟู้ด โปรเซสซิ่ง จำกัด" readonly />
                                                    <label for="sellerName">ชื่อผู้ขาย / ชื่อกิจการ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="sellerTaxId"
                                                        value="0105556089321" readonly />
                                                    <label for="sellerTaxId">เลขทะเบียนนิติบุคคล / เลขประจำตัวผู้เสียภาษี</label>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="sellerLicenseNo"
                                                        value="TH-SMK-2025-0312" readonly />
                                                    <label for="sellerLicenseNo">เลขที่ใบอนุญาตโรงงาน</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="sellerAddress"
                                                        value="99/1 หมู่ 5 ถนนพระราม 2 ตำบลท่าทราย อำเภอเมืองสมุทรสาคร จังหวัดสมุทรสาคร 74000" readonly />
                                                    <label for="sellerAddress">ที่อยู่</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectSeller" class="select2 form-select" required>
                                                        <option value="">-- เลือกผู้ขาย/ผู้ติดต่อ --</option>
                                                        <option value="1" selected>นาย สมชาย รักษาผล (ผู้จัดการ)</option>
                                                    </select>
                                                    <label for="selectSeller">ผู้ติดต่อ / ผู้ลงนาม <span class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="sellerPhone" class="form-control"
                                                        placeholder="เบอร์โทรศัพท์" value="034-456-789" />
                                                    <label for="sellerPhone">เบอร์โทรศัพท์</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Accordion: ข้อมูลผู้ซื้อ -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionBuyer">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingBuyer">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseBuyer" aria-expanded="true" aria-controls="collapseBuyer">
                                    <i class="icon-base ri ri-user-received-line me-2"></i>
                                    ข้อมูลผู้ซื้อ
                                </button>
                            </h2>
                            <div id="collapseBuyer" class="accordion-collapse collapse show" aria-labelledby="headingBuyer">
                                <div class="accordion-body p-0">
                                    <div class="p-4">

                                        <!-- ประเภทผู้ซื้อ -->
                                        <div class="row g-3 mb-4">
                                            <div class="col-12">
                                                <label class="form-label fw-semibold">ประเภทผู้ซื้อ <span class="text-danger">●</span></label>
                                                <div class="d-flex gap-4">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="buyerType"
                                                            id="buyerTypeInside" value="inside" checked />
                                                        <label class="form-check-label" for="buyerTypeInside">
                                                            <i class="ri ri-computer-line me-1 text-primary"></i>
                                                            ผู้ซื้ออยู่ <strong>ภายในระบบ</strong> [FSW]
                                                        </label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="buyerType"
                                                            id="buyerTypeOutside" value="outside" />
                                                        <label class="form-check-label" for="buyerTypeOutside">
                                                            <i class="ri ri-user-line me-1 text-secondary"></i>
                                                            ผู้ซื้ออยู่ <strong>ภายนอกระบบ</strong>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- In-system buyer search -->
                                        <div id="buyerInsideSection" class="row g-3">
                                            <div class="col-12">
                                                <label class="form-label small">ค้นหาผู้ซื้อในระบบ <span class="text-danger">●</span></label>
                                                <div class="input-group">
                                                    <button type="button" class="btn btn-outline-secondary"
                                                        id="btnSearchBuyer" title="ค้นหาผู้ซื้อในระบบ">
                                                        <i class="ri ri-search-line"></i>
                                                    </button>
                                                    <input type="text" id="buyerName" class="form-control"
                                                        placeholder="ชื่อผู้ซื้อ / เลขทะเบียน"
                                                        value="บริษัท ปลาป่นไทย จำกัด" />
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="buyerTaxId"
                                                        value="0105563089444" readonly />
                                                    <label for="buyerTaxId">เลขทะเบียนนิติบุคคล</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="buyerLicense"
                                                        value="FM-TH-2025-0087" readonly />
                                                    <label for="buyerLicense">ทะเบียนโรงงาน (ถ้ามี)</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="buyerPhone"
                                                        value="02-345-6789" readonly />
                                                    <label for="buyerPhone">เบอร์โทรศัพท์</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" class="form-control bg-light" id="buyerAddress"
                                                        value="123 ถนนสุขุมวิท แขวงคลองเตย เขตคลองเตย กรุงเทพมหานคร 10110" readonly />
                                                    <label for="buyerAddress">ที่อยู่ผู้ซื้อ</label>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Out-of-system buyer form (hidden by default) -->
                                        <div id="buyerOutsideSection" class="row g-3 d-none">
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="extBuyerName" class="form-control"
                                                        placeholder="ชื่อผู้ซื้อ / กิจการ" />
                                                    <label for="extBuyerName">ชื่อผู้ซื้อ / กิจการ <span class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="extBuyerTaxId" class="form-control"
                                                        placeholder="เลขทะเบียน / เลขบัตรประชาชน" />
                                                    <label for="extBuyerTaxId">เลขทะเบียน / เลขประจำตัว</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="extBuyerPhone" class="form-control"
                                                        placeholder="เบอร์โทรศัพท์" />
                                                    <label for="extBuyerPhone">เบอร์โทรศัพท์</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="extBuyerType" class="form-control"
                                                        placeholder="ประเภทกิจการ เช่น โรงงานปลาป่น" />
                                                    <label for="extBuyerType">ประเภทกิจการ</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="extBuyerAddress" class="form-control"
                                                        placeholder="ที่อยู่ผู้ซื้อ" />
                                                    <label for="extBuyerAddress">ที่อยู่ <span class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Accordion: เงื่อนไขการซื้อขาย -->
                    <div class="accordion accordion-custom-button mb-4" id="accordionTrade">
                        <div class="accordion-item active">
                            <h2 class="accordion-header" id="headingTrade">
                                <button type="button" class="accordion-button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseTrade" aria-expanded="true" aria-controls="collapseTrade">
                                    <i class="icon-base ri ri-hand-coin-line me-2"></i>
                                    เงื่อนไขการซื้อขาย
                                </button>
                            </h2>
                            <div id="collapseTrade" class="accordion-collapse collapse show" aria-labelledby="headingTrade">
                                <div class="accordion-body p-0">
                                    <div class="p-4">
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="deliveryDate" class="form-control flatpickr-date"
                                                        placeholder="วว/ดด/ปปปป" />
                                                    <label for="deliveryDate">วันที่ส่งมอบ <span class="text-danger">●</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <select id="selectDeliveryLocation" class="select2 form-select">
                                                        <option value="">-- เลือกสถานที่ส่งมอบ --</option>
                                                        <option value="seller">สถานที่ผู้ขาย</option>
                                                        <option value="buyer">สถานที่ผู้ซื้อ</option>
                                                        <option value="other">สถานที่อื่น</option>
                                                    </select>
                                                    <label for="selectDeliveryLocation">สถานที่ส่งมอบ</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating form-floating-outline">
                                                    <input type="text" id="vehicleNo" class="form-control"
                                                        placeholder="ทะเบียนรถ" />
                                                    <label for="vehicleNo">ทะเบียนรถขนส่ง (ถ้ามี)</label>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating form-floating-outline">
                                                    <textarea id="remarkTrade" class="form-control" style="height:80px;"
                                                        placeholder="หมายเหตุ"></textarea>
                                                    <label for="remarkTrade">หมายเหตุ / เงื่อนไขเพิ่มเติม</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <!-- /TAB 1 -->

                <!-- ==================== TAB 2: รายการเศษเหลือ (TOR 1.6(19.1)) ==================== -->
                <div id="tab-scrap" class="tab-pane fade" role="tabpanel">

                    <!-- Toolbar -->
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div>
                            <span class="fw-semibold small">รายการเศษเหลือจากการผลิต</span>
                            <span class="text-muted small ms-2">— เลือกจากรายการ RMBS2 ที่มีเศษเหลือคงเหลือ (TOR 1.6(19.1))</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-success btn-sm"
                                onclick="alert('Export Excel รายการเศษเหลือ (mockup)')">
                                <i class="ri ri-file-excel-2-line me-1"></i> Export Excel
                            </button>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btnAddScrap"
                                data-bs-toggle="modal" data-bs-target="#modalSelectScrap">
                                <i class="ri ri-add-line me-1"></i> เพิ่มรายการเศษเหลือ
                            </button>
                        </div>
                    </div>

                    <!-- P1 Reference Banner -->
                    <div class="alert alert-secondary d-flex align-items-center gap-2 py-2 mb-3" style="font-size:0.82rem;">
                        <i class="ri ri-file-paper-2-line fs-5 flex-shrink-0"></i>
                        <div>
                            อ้างอิง P1: <strong class="text-primary">P1-2569-00046</strong>
                            &nbsp;|&nbsp; รุ่นผลิต: LOT-2561-001, LOT-2561-002
                            &nbsp;|&nbsp; น้ำหนักเศษเหลือทั้งหมดจากการผลิต: <strong>1,240.000 กก.</strong>
                        </div>
                    </div>

                    <!-- Summary Cards -->
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3">
                            <div class="card border-secondary h-100">
                                <div class="card-body py-2 px-3 text-center">
                                    <div class="text-muted small">น้ำหนักเศษเหลือจากการผลิต</div>
                                    <div class="fw-bold text-dark fs-6">1,240.000 <span class="fw-normal text-muted" style="font-size:0.75rem;">กก.</span></div>
                                    <div class="small text-muted" style="font-size:0.7rem;">(เพดานสูงสุด)</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-warning h-100">
                                <div class="card-body py-2 px-3 text-center">
                                    <div class="text-muted small">ขายแล้ว (ก่อนรายการนี้)</div>
                                    <div class="fw-bold text-warning fs-6" id="summaryAlreadySold">500.000 <span class="fw-normal text-muted" style="font-size:0.75rem;">กก.</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-success h-100">
                                <div class="card-body py-2 px-3 text-center">
                                    <div class="text-muted small">คงเหลือ (ขายได้อีก)</div>
                                    <div class="fw-bold text-success fs-6" id="summaryRemaining">740.000 <span class="fw-normal text-muted" style="font-size:0.75rem;">กก.</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card h-100" id="cardThisSell">
                                <div class="card-body py-2 px-3 text-center">
                                    <div class="text-muted small">น้ำหนักในรายการนี้</div>
                                    <div class="fw-bold fs-6" id="summaryThisSell">750.000 <span class="fw-normal text-muted" style="font-size:0.75rem;">กก.</span></div>
                                    <div class="small" id="summaryValidBadge">
                                        <span class="badge bg-success" style="font-size:0.65rem;">✅ ไม่เกินเพดาน</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Alert น้ำหนักรวมเกิน -->
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-2" id="alertOverWeight" style="display:none;">
