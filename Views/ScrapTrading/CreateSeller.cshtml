                                <td class="small">456/1 ถนนพระราม 2 สมุทรสาคร</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" id="btnConfirmSelectBuyer">
                    <i class="ri ri-check-line me-1"></i> เลือกผู้ซื้อ
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modal Search Buyer -->

<!-- ==================== Modal: เพิ่มหลักฐานประกอบ ==================== -->
<div class="modal fade" id="modalAddEvidence" tabindex="-1" aria-labelledby="modalAddEvidenceLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAddEvidenceLabel">
                    เพิ่มหลักฐานประกอบ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small">ประเภทเอกสาร</label>
                        <select id="ev_doctype" class="form-select form-select-sm">
                            <option value="">-- เลือกประเภทเอกสาร --</option>
                            <option value="invoice">ใบแจ้งหนี้ / Invoice</option>
                            <option value="receipt">ใบเสร็จรับเงิน</option>
                            <option value="delivery">ใบส่งมอบสินค้า</option>
                            <option value="other">อื่นๆ</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">ตัวเอกสาร</label>
                        <select id="ev_document_kind" class="form-select form-select-sm">
                            <option value="">-- เลือกตัวเอกสาร --</option>
                            <option value="original">เอกสารตัวจริง</option>
                            <option value="copy">เอกสารฉบับสำเนา</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small">ชื่อหลักฐาน / ชื่อของ <span class="text-danger">●</span></label>
                        <input type="text" id="ev_name" class="form-control form-control-sm" placeholder="ชื่อหลักฐาน" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">เลขที่เอกสาร</label>
                        <input type="text" id="ev_docno" class="form-control form-control-sm" placeholder="เลขที่เอกสาร" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">ผู้ออกเอกสาร</label>
                        <input type="text" id="ev_issuer" class="form-control form-control-sm" placeholder="ผู้ออกเอกสาร" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">วันที่ออกเอกสาร</label>
                        <div class="input-group">
                            <input type="text" id="ev_issue_date" class="form-control form-control-sm flatpickr-date" placeholder="วว/ดด/ปปปป" />
                            <span class="input-group-text px-2"><i class="ri ri-calendar-line"></i></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">วันที่หมดอายุ</label>
                        <div class="input-group">
                            <input type="text" id="ev_expire_date" class="form-control form-control-sm flatpickr-date" placeholder="วว/ดด/ปปปป" />
                            <span class="input-group-text px-2"><i class="ri ri-calendar-line"></i></span>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label small">แนบไฟล์เอกสาร</label>
                        <input type="file" id="ev_file" class="form-control form-control-sm"
                            accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <div class="form-text text-muted">รองรับ PDF, JPG, PNG, DOC (ขนาดไม่เกิน 10 MB)</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="ri ri-close-line me-1"></i> ยกเลิก
                </button>
                <button type="button" class="btn btn-primary" id="btnConfirmAddEvidence">
                    <i class="ri ri-save-line me-1"></i> บันทึก
                </button>
            </div>
        </div>
    </div>
</div>
<!-- /Modal Evidence -->

@section PageScripts {
<script>
$(document).ready(function () {

    // ── Flatpickr ──
    function initFp(el) {
        if (el && !el._flatpickr) {
            flatpickr(el, { dateFormat: 'd/m/Y', allowInput: true,
                appendTo: document.body,
                onReady: function(s, d, fp) { fp.calendarContainer.style.zIndex = '9999'; }
            });
        }
    }
    document.querySelectorAll('.flatpickr-date').forEach(function(el) { initFp(el); });
    $('#modalAddEvidence').on('shown.bs.modal', function() {
        initFp(document.getElementById('ev_issue_date'));
        initFp(document.getElementById('ev_expire_date'));
        $('#ev_name,#ev_docno,#ev_issuer,#ev_issue_date,#ev_expire_date').val('');
        $('#ev_doctype,#ev_document_kind').val('');
        $('#ev_file').val('');
    });

    // ── Select2 ──
    $('.select2').select2({ width: '100%' });

    // ── ประเภทผู้ซื้อ toggle ──
    $('input[name="buyerType"]').on('change', function () {
        if ($(this).val() === 'inside') {
            $('#buyerInsideSection').removeClass('d-none');
            $('#buyerOutsideSection').addClass('d-none');
        } else {
            $('#buyerInsideSection').addClass('d-none');
            $('#buyerOutsideSection').removeClass('d-none');
        }
    });

    // ── เปิด modal ค้นหาผู้ซื้อ ──
    $('#btnSearchBuyer').on('click', function () {
        new bootstrap.Modal(document.getElementById('modalSearchBuyer')).show();
    });

    // ── คลิก buyer row ──
    $(document).on('click', '.buyer-select-row', function () {
        $('.buyer-select-row').removeClass('table-active');
        $(this).addClass('table-active').find('input[type=radio]').prop('checked', true);
    });

    $('#btnConfirmSelectBuyer').on('click', function () {
        var $sel = $('input[name=buyerSelect]:checked').closest('tr');
        if ($sel.length === 0) { alert('กรุณาเลือกผู้ซื้อก่อน'); return; }
        $('#buyerName').val($sel.data('name'));
        $('#buyerTaxId').val($sel.data('tax'));
        $('#buyerLicense').val($sel.data('license'));
        $('#buyerPhone').val($sel.data('phone'));
        $('#buyerAddress').val($sel.data('address'));
        bootstrap.Modal.getInstance(document.getElementById('modalSearchBuyer')).hide();
    });

    // ── เลือก Scrap row ──
    $(document).on('click', '.scrap-select-row', function () {
        $(this).toggleClass('table-active');
        var $cb = $(this).find('input[type=checkbox]');
        $cb.prop('checked', !$cb.prop('checked'));
    });

    // ── เพิ่มรายการเศษเหลือ ──
    var _scrapCounter = 1;
    $('#btnConfirmSelectScrap').on('click', function () {
        var added = 0;
        $('.scrap-select-row.table-active').each(function () {
            var $row = $(this);
            var itemId = 'si' + (++_scrapCounter);
            var rmbs1 = $row.data('rmbs1');
            var rmbs2 = $row.data('rmbs2');
            var product = $row.data('product');
            var scrapType = $row.data('scrap-type');
            var available = parseFloat($row.data('available')) || 0;
            // check not already added
            var exists = $('#scrapItemTbody tr[data-rmbs2="' + rmbs2 + '"]').length > 0;
            if (exists) return;
            var rowNum = $('#scrapItemTbody tr').length + 1;
            var $tr = $('<tr data-item-id="' + itemId + '" data-rmbs1="' + rmbs1 + '" data-rmbs2="' + rmbs2 + '" data-available="' + available + '">' +
                '<td class="text-center text-muted small">' + rowNum + '</td>' +
                '<td class="text-primary">' + rmbs1 + '</td>' +
                '<td class="text-primary">' + rmbs2 + '</td>' +
                '<td>' + product + '</td>' +
                '<td>' + scrapType + '</td>' +
                '<td class="text-end">' + available.toLocaleString('th-TH', {minimumFractionDigits: 3}) + '</td>' +
                '<td><input type="text" class="form-control form-control-sm input-buyer-name" placeholder="ชื่อผู้ซื้อ" /></td>' +
        '<td class="text-end"></td>' +
        '<td class="text-end"><input type="number" class="form-control form-control-sm text-end input-sell-weight" style="min-width:120px;" value="' + available + '" step="0.001" min="0" max="' + available + '" /></td>' +
                '<td class="text-center"><button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-scrap-item" title="ลบ"><i class="ri ri-delete-bin-line text-danger"></i></button></td>' +
                '</tr>');
            $('#scrapItemTbody').append($tr);
            added++;
        });
        if (added === 0 && $('.scrap-select-row.table-active').length === 0) {
            alert('กรุณาเลือกรายการเศษเหลืออย่างน้อย 1 รายการ');
            return;
        }
        recalcTotal();
        bootstrap.Modal.getInstance(document.getElementById('modalSelectScrap')).hide();
        $('.scrap-select-row').removeClass('table-active').find('input[type=checkbox]').prop('checked', false);
    });

    // ── ลบ scrap row ──
    $(document).on('click', '.btn-remove-scrap-item', function () {
        $(this).closest('tr').remove();
        reindexScrap();
        recalcTotal();
    });

    function reindexScrap() {
        $('#scrapItemTbody tr').each(function (i) {
            $(this).find('td:first').text(i + 1);
        });
    }

    var PRODUCTION_SCRAP_WEIGHT = 740; // กก. — คงเหลือที่ขายได้ (mockup P1-2569-00046)

    function recalcTotal() {
        var total = 0;
        var hasRowError = false;
        // ── ตรวจสอบระดับรายการ (per-row) ──
        $('#scrapItemTbody tr').each(function () {
            var $row = $(this);
            var available = parseFloat($row.data('available')) || 0;
            var sell = parseFloat($row.find('.input-sell-weight').val()) || 0;
            var $badge = $row.find('.row-ctrl-badge');
            if (sell > available) {
                $badge.removeClass('bg-success').addClass('bg-danger').text('❌ เกิน');
                $row.find('.input-sell-weight').addClass('border-danger');
                hasRowError = true;
            } else {
                $badge.removeClass('bg-danger').addClass('bg-success').text('✅ ไม่เกิน');
                $row.find('.input-sell-weight').removeClass('border-danger');
            }
            total += sell;
        });
        // ── ตรวจสอบระดับรวม ──
        $('#totalSellWeight').text(total.toLocaleString('th-TH', {minimumFractionDigits: 3}));
        var diff = total - PRODUCTION_SCRAP_WEIGHT;
        $('#totalDiff').text((diff >= 0 ? '-' : '+') + Math.abs(diff).toLocaleString('th-TH', {minimumFractionDigits: 3}));
        $('#summaryThisSell').html(total.toLocaleString('th-TH', {minimumFractionDigits: 3}) + ' <span class="fw-normal text-muted" style="font-size:0.75rem;">กก.</span>');
        if (total > PRODUCTION_SCRAP_WEIGHT || hasRowError) {
            $('#alertOverWeight').show();
            $('#alertWeightOk').hide();
            $('#totalSellWeight').addClass('text-danger').removeClass('text-success');
            $('#totalCtrlBadge').removeClass('bg-success').addClass('bg-danger').text('❌ เกินเพดาน');
            $('#summaryValidBadge').html('<span class="badge bg-danger" style="font-size:0.65rem;">❌ เกินเพดาน</span>');
            $('#cardThisSell').addClass('border-danger').removeClass('border-success');
        } else {
            $('#alertOverWeight').hide();
            $('#alertWeightOk').show();
            $('#totalSellWeight').addClass('text-success').removeClass('text-danger');
            $('#totalCtrlBadge').removeClass('bg-danger').addClass('bg-success').text('✅ ไม่เกิน');
            $('#summaryValidBadge').html('<span class="badge bg-success" style="font-size:0.65rem;">✅ ไม่เกินเพดาน</span>');
            $('#cardThisSell').addClass('border-success').removeClass('border-danger');
        }
    }

    $(document).on('input', '.input-sell-weight', function () { recalcTotal(); });

    // ── หลักฐานประกอบ ──
    $('#btnConfirmAddEvidence').on('click', function () {
        var name = $.trim($('#ev_name').val());
        if (!name) { alert('กรุณากรอกชื่อหลักฐานประกอบ'); return; }
        var docno   = $('#ev_docno').val() || '—';
        var issuer  = $('#ev_issuer').val() || '—';
        var issuedt = $('#ev_issue_date').val() || '—';
        var expdt   = $('#ev_expire_date').val() || '—';
        var fileName = '';
        var fileEl = document.getElementById('ev_file');
        if (fileEl && fileEl.files && fileEl.files.length > 0) { fileName = fileEl.files[0].name; }
        var rowNum = $('#evidenceTbody tr:not(.text-muted)').length + 1;
        $('#evidenceTbody tr.text-muted').remove();
        var $row = $('<tr>' +
            '<td class="text-center text-muted small">' + rowNum + '</td>' +
            '<td><div class="fw-semibold text-primary">' + name + '</div>' +
            (fileName ? '<div class="text-muted small mt-1"><i class="ri ri-attachment-2 me-1"></i>' + fileName + '</div>' : '') +
            '</td>' +
            '<td>' + docno + '</td>' +
            '<td>' + issuedt + '</td>' +
            '<td>' + expdt + '</td>' +
            '<td>' + issuer + '</td>' +
            '<td class="text-center"><button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-remove-evidence" title="ลบ"><i class="ri ri-delete-bin-line"></i></button></td>' +
            '</tr>');
        $('#evidenceTbody').append($row);
        bootstrap.Modal.getInstance(document.getElementById('modalAddEvidence')).hide();
    });

    $(document).on('click', '.btn-remove-evidence', function () {
        $(this).closest('tr').remove();
        if ($('#evidenceTbody tr').length === 0) {
            $('#evidenceTbody').append('<tr class="text-center text-muted"><td colspan="7" class="py-3 fst-italic small">ยังไม่มีหลักฐานประกอบ</td></tr>');
        }
    });

    // ── บันทึกร่าง ──
    $('#btnSaveDraft').on('click', function () {
        alert('บันทึกร่างเรียบร้อยแล้ว (mockup)');
    });

    recalcTotal();
});
</script>
}
