              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Modal: Edit Email Template -->
<div class="modal fade" id="modalTemplate" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" style="color:var(--dpim-blue);">แก้ไข Template อีเมล</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">ชื่อ Template</label>
            <input type="text" id="tplName" class="form-control" readonly style="background:var(--bs-gray-100);" />
          </div>
          <div class="col-md-6">
            <label class="form-label">หัวเรื่อง (Subject) <span class="text-danger">*</span></label>
            <input type="text" id="tplSubject" class="form-control" />
          </div>
          <div class="col-12">
            <label class="form-label">เนื้อหาอีเมล (HTML)</label>
            <div class="border rounded p-2" style="min-height:150px;background:var(--bs-card-bg);font-family:monospace;font-size:.82rem;">
              &lt;p&gt;เรียนคุณ {{full_name}}&lt;/p&gt;<br/>
              &lt;p&gt;รหัส OTP ของคุณคือ: &lt;strong&gt;{{otp_code}}&lt;/strong&gt;&lt;/p&gt;<br/>
              &lt;p&gt;รหัสจะหมดอายุใน 5 นาที&lt;/p&gt;<br/>
              &lt;p&gt;กรมอุตสาหกรรมพื้นฐานและการเหมืองแร่ (กพร.)&lt;/p&gt;
            </div>
            <div class="form-text">ตัวแปรที่ใช้ได้: {{full_name}} {{email}} {{otp_code}} {{ref_no}} {{link}} {{expire_date}}</div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" id="btnSaveTemplate" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>บันทึก Template
        </button>
      </div>
    </div>
  </div>
</div>
