@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "Data Analyzer";
}

@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
<link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.css" />
<link rel="stylesheet" href="~/vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css" />
}

@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
<script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.js"></script>
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .stat-card { border-radius:12px; padding:1.25rem 1.5rem; color:#fff; display:flex; align-items:center; gap:1.25rem; }
  .stat-card-icon { width:54px; height:54px; border-radius:50%; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; font-size:1.6rem; flex-shrink:0; }
  .stat-card-val { font-size:1.75rem; font-weight:800; line-height:1; }
  .stat-card-label { font-size:.8rem; opacity:.85; margin-top:.2rem; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ── Summary Cards ────────────────────────────────────────────────────────────
  // (static mock, no JS needed — rendered in HTML below)

  // ── Bar: ผู้ใช้ใหม่รายเดือน ─────────────────────────────────────────────────
  new ApexCharts(document.getElementById('chartNewUsers'), {
    chart: { type: 'bar', height: 280, toolbar: { show: false } },
    series: [{ name: 'ผู้ใช้ใหม่', data: [18,25,32,20,38,45,29,52,44,37,61,55] }],
    xaxis: { categories: ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'] },
    colors: ['#23408F'],
    plotOptions: { bar: { borderRadius: 6, columnWidth: '55%' } },
    dataLabels: { enabled: false },
    grid: { borderColor: '#e0e0e0', strokeDashArray: 4 },
    tooltip: { theme: 'light' }
  }).render();

  // ── Line: Login Activity (7 วัน) ─────────────────────────────────────────────
  new ApexCharts(document.getElementById('chartLoginActivity'), {
    chart: { type: 'area', height: 280, toolbar: { show: false }, zoom: { enabled: false } },
    series: [
      { name: 'Login สำเร็จ', data: [280,310,295,340,280,315,330] },
      { name: 'Login ล้มเหลว', data: [12,18,10,22,14,9,16] }
    ],
    xaxis: { categories: ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัส','ศุกร์','เสาร์'] },
    colors: ['#41AD49', '#dc3545'],
    stroke: { curve: 'smooth', width: 2.5 },
    fill: { type: 'gradient', gradient: { opacityFrom:.3, opacityTo:.05 } },
    dataLabels: { enabled: false },
    grid: { borderColor: '#e0e0e0', strokeDashArray: 4 },
    legend: { position: 'top' },
    tooltip: { theme: 'light' }
  }).render();

  // ── Donut: MFA Adoption ──────────────────────────────────────────────────────
  new ApexCharts(document.getElementById('chartMFAAdoption'), {
    chart: { type: 'donut', height: 280 },
    series: [68, 22, 10],
    labels: ['ใช้ MFA', 'ไม่ได้ใช้ MFA', 'รอยืนยัน'],
    colors: ['#23408F','#41AD49','#adb5bd'],
    dataLabels: { enabled: true, formatter: function(val) { return val.toFixed(0) + '%'; } },
    legend: { position: 'bottom' },
    plotOptions: { pie: { donut: { size: '65%', labels: {
      show: true,
      total: { show: true, label: 'MFA Rate', color: '#23408F',
        formatter: function () { return '68%'; } }
    } } } },
    tooltip: { theme: 'light' }
  }).render();

  // ── DataTable: Top Active Users ──────────────────────────────────────────────
  new DataTable('#tableTopUsers', {
    language: {
      search: 'ค้นหา:', lengthMenu: 'แสดง _MENU_ รายการ',
      info: 'แสดง _START_-_END_ จาก _TOTAL_ รายการ',
      paginate: { first:'แรก', last:'สุดท้าย', next:'ถัดไป', previous:'ก่อนหน้า' }
    },
    order: [[2, 'desc']],
    pageLength: 5,
    responsive: true,
  });

});
</script>
}

