@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "นโยบายรหัสผ่านและความปลอดภัย";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; color:#fff; }
  .section-card { border-radius:.75rem; border:1px solid var(--bs-border-color); margin-bottom:1.5rem; }
  .section-card .section-header { background:rgba(35,64,143,.05); border-bottom:1px solid var(--bs-border-color); border-radius:.75rem .75rem 0 0; padding:.75rem 1.25rem; }
  .policy-row { display:flex; align-items:center; justify-content:space-between; padding:.55rem 0; border-bottom:1px solid var(--bs-border-color); }
  .policy-row:last-child { border-bottom:none; }
  .policy-label { font-size:.87rem; font-weight:500; }
  .policy-desc { font-size:.77rem; color:var(--bs-secondary-color); }
  .role-badge-card { border:1px solid var(--bs-border-color); border-radius:.5rem; padding:.5rem .75rem; display:flex; align-items:center; justify-content:space-between; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Save buttons ── */
  document.querySelectorAll('.btn-save-policy').forEach(function (btn) {
    btn.addEventListener('click', function () {
      alert('บันทึกนโยบายสำเร็จ');
    });
  });

  /* ── Role/Group modal ── */
  document.getElementById('btnAddRole').addEventListener('click', function () {
    document.getElementById('roleName').value = '';
    document.getElementById('roleDesc').value = '';
    document.querySelectorAll('.perm-check').forEach(function (c) { c.checked = false; });
    document.getElementById('modalRoleTitle').textContent = 'เพิ่มกลุ่มผู้ใช้';
    new bootstrap.Modal(document.getElementById('modalRole')).show();
  });

  document.querySelectorAll('.btn-edit-role').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.getElementById('roleName').value = this.dataset.name || '';
      document.getElementById('roleDesc').value = this.dataset.desc || '';
      document.getElementById('modalRoleTitle').textContent = 'แก้ไขกลุ่มผู้ใช้';
      new bootstrap.Modal(document.getElementById('modalRole')).show();
    });
  });

  document.querySelectorAll('.btn-delete-role').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (confirm('ลบกลุ่มผู้ใช้นี้?')) btn.closest('.role-badge-card').remove();
    });
  });

  document.getElementById('btnSaveRole').addEventListener('click', function () {
    bootstrap.Modal.getInstance(document.getElementById('modalRole')).hide();
    alert('บันทึกกลุ่มผู้ใช้สำเร็จ');
  });
});
</script>
}

@* ============================================================ *@
<div class="container-xxl flex-grow-1 container-p-y">

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb breadcrumb-style1 mb-4">
      <li class="breadcrumb-item"><a href="/">หน้าหลัก</a></li>
      <li class="breadcrumb-item active">นโยบายรหัสผ่านและความปลอดภัย</li>
    </ol>
  </nav>

  <h4 class="page-title-dpim mb-4">นโยบายรหัสผ่านและความปลอดภัย</h4>

  <div class="row g-4">

    <!-- Left Column -->
    <div class="col-lg-8">

      <!-- Section 1: Password Rules -->
      <div class="section-card">
        <div class="section-header">
          <h6 class="mb-0" style="color:var(--dpim-blue);">
            <i class="ri ri-lock-line me-2"></i>กฎรหัสผ่าน
          </h6>
        </div>
        <div class="p-4">
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">ความยาวขั้นต่ำ (ตัวอักษร)</label>
              <input type="number" class="form-control" value="8" min="6" max="32" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">ความยาวสูงสุด (ตัวอักษร)</label>
              <input type="number" class="form-control" value="64" min="8" max="128" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">ไม่ซ้ำรหัสผ่านล่าสุด (ครั้ง)</label>
              <input type="number" class="form-control" value="5" min="0" max="24" />
              <div class="form-text">0 = ไม่มีข้อกำหนด</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">อายุรหัสผ่านสูงสุด (วัน)</label>
              <input type="number" class="form-control" value="90" min="0" />
              <div class="form-text">0 = ไม่มีกำหนดหมดอายุ</div>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">ข้อกำหนดเพิ่มเติม</label>
            <div class="d-flex flex-column gap-2">
              @foreach (var r in new[] {
                new { id="reqUpper", label="ต้องมีตัวพิมพ์ใหญ่ (A-Z)", checked_=true },
                new { id="reqLower", label="ต้องมีตัวพิมพ์เล็ก (a-z)", checked_=true },
                new { id="reqNum",   label="ต้องมีตัวเลข (0-9)", checked_=true },
                new { id="reqSym",   label="ต้องมีสัญลักษณ์ (!@@#$%^&*)", checked_=false },
                new { id="reqNoSpace", label="ห้ามมีช่องว่าง", checked_=true }
              })
              {
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="@r.id" @(r.checked_ ? "checked" : "") />
                  <label class="form-check-label" for="@r.id" style="font-size:.87rem;">@r.label</label>
                </div>
              }
            </div>
          </div>
          <button class="btn btn-dpim btn-save-policy">
            <i class="ri ri-save-line me-1"></i>บันทึกกฎรหัสผ่าน
          </button>
        </div>
      </div>

      <!-- Section 2: Account Lockout -->
      <div class="section-card">
        <div class="section-header">
          <h6 class="mb-0" style="color:var(--dpim-blue);">
            <i class="ri ri-shield-cross-line me-2"></i>การล็อกบัญชี (Account Lockout)
          </h6>
        </div>
        <div class="p-4">
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label class="form-label fw-semibold">จำนวนครั้งที่ผิดพลาดก่อนล็อก</label>
              <input type="number" class="form-control" value="5" min="1" max="20" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">ระยะเวลาล็อก (นาที)</label>
              <input type="number" class="form-control" value="30" min="1" />
              <div class="form-text">0 = ต้อง Unlock โดย Admin</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">รีเซ็ตนับหลังจาก (นาที)</label>
              <input type="number" class="form-control" value="15" min="1" />
            </div>
          </div>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="autoUnlock" checked />
            <label class="form-check-label" for="autoUnlock" style="font-size:.87rem;">Unlock อัตโนมัติหลังหมดเวลา</label>
          </div>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="notifyLockout" checked />
            <label class="form-check-label" for="notifyLockout" style="font-size:.87rem;">ส่งอีเมลแจ้งเตือนเมื่อบัญชีถูกล็อก</label>
          </div>
          <button class="btn btn-dpim btn-save-policy">
            <i class="ri ri-save-line me-1"></i>บันทึกการตั้งค่าล็อกบัญชี
          </button>
        </div>
      </div>

      <!-- Section 3: Session Security -->
      <div class="section-card">
        <div class="section-header">
          <h6 class="mb-0" style="color:var(--dpim-blue);">
            <i class="ri ri-time-line me-2"></i>ความปลอดภัย Session
          </h6>
        </div>
        <div class="p-4">
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Session Timeout (นาที)</label>
              <input type="number" class="form-control" value="60" min="5" />
              <div class="form-text">หมดอายุเมื่อไม่มีการใช้งาน</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Remember Me Duration (วัน)</label>
              <input type="number" class="form-control" value="30" min="1" max="365" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">จำนวน Session พร้อมกันสูงสุด</label>
              <input type="number" class="form-control" value="3" min="1" />
              <div class="form-text">0 = ไม่จำกัด</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Trusted Device Period (วัน)</label>
              <input type="number" class="form-control" value="30" min="1" />
            </div>
          </div>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="secureOnly" checked />
            <label class="form-check-label" for="secureOnly" style="font-size:.87rem;">บังคับ HTTPS เท่านั้น</label>
          </div>
          <button class="btn btn-dpim btn-save-policy">
            <i class="ri ri-save-line me-1"></i>บันทึกการตั้งค่า Session
          </button>
        </div>
      </div>
    </div>

    <!-- Right Column: Roles & Groups -->
    <div class="col-lg-4">
      <div class="card h-auto">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="card-title mb-0" style="color:var(--dpim-blue);">
            <i class="ri ri-group-line me-2"></i>กลุ่มผู้ใช้และบทบาท
          </h6>
          <button id="btnAddRole" class="btn btn-dpim btn-sm">
            <i class="ri ri-add-line"></i>
          </button>
        </div>
        <div class="card-body">
          <div class="d-flex flex-column gap-2">
            @foreach (var role in new[] {
              new { name="ผู้ประกอบการ", members=251, desc="เข้าถึงระบบหลัก DPIM" },
              new { name="เจ้าหน้าที่ กพร.", members=18, desc="อนุมัติคำขอ + จัดการระบบ" },
              new { name="Admin", members=5, desc="จัดการผู้ใช้และระบบทั้งหมด" },
              new { name="Viewer", members=10, desc="ดูข้อมูลอย่างเดียว" },
              new { name="Report-Only", members=4, desc="เข้าถึงรายงานเท่านั้น" }
            })
            {
              <div class="role-badge-card">
                <div>
                  <div class="fw-semibold" style="font-size:.87rem;">@role.name</div>
                  <div style="font-size:.75rem;color:var(--bs-secondary-color);">
                    @role.members สมาชิก · @role.desc
                  </div>
                </div>
                <div class="d-flex gap-1">
                  <button class="btn btn-icon btn-sm btn-outline-secondary btn-edit-role"
                    data-name="@role.name" data-desc="@role.desc" title="แก้ไข">
                    <i class="ri ri-edit-line" style="font-size:.85rem;"></i>
                  </button>
                  <button class="btn btn-icon btn-sm btn-outline-danger btn-delete-role" title="ลบ">
                    <i class="ri ri-delete-bin-line" style="font-size:.85rem;"></i>
                  </button>
                </div>
              </div>
            }
          </div>
        </div>
      </div>

      <!-- Password Strength Preview -->
      <div class="card mt-4">
        <div class="card-header">
          <h6 class="card-title mb-0" style="color:var(--dpim-blue);">
            <i class="ri ri-shield-line me-2"></i>ทดสอบความแข็งแกร่งรหัสผ่าน
          </h6>
        </div>
        <div class="card-body">
          <input type="text" id="pwdTest" class="form-control mb-2" placeholder="กรอกรหัสผ่านทดสอบ" />
          <div class="progress mb-2" style="height:6px;">
            <div class="progress-bar bg-success" style="width:60%;"></div>
          </div>
          <div class="d-flex justify-content-between" style="font-size:.78rem;">
            <span class="text-muted">ความแข็งแกร่ง:</span>
            <span class="fw-semibold text-success">ปานกลาง</span>
          </div>
        </div>
      </div>
    </div>

  </div>

</div>

<!-- Modal: เพิ่ม/แก้ไขกลุ่มผู้ใช้ -->
<div class="modal fade" id="modalRole" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" id="modalRoleTitle" style="color:var(--dpim-blue);"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">ชื่อกลุ่ม/บทบาท <span class="text-danger">*</span></label>
            <input type="text" id="roleName" class="form-control" />
          </div>
          <div class="col-12">
            <label class="form-label">คำอธิบาย</label>
            <input type="text" id="roleDesc" class="form-control" />
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">สิทธิ์ (Permissions)</label>
            <div class="row g-2">
              @foreach (var p in new[] {
                "เข้าดูข้อมูลระบบหลัก", "จัดการผู้ใช้งาน", "อนุมัติคำขอ",
                "ออกใบรับรอง", "จัดการรายงาน", "ตั้งค่าระบบ",
                "ดู Audit Log", "จัดการ SSO", "บริหาร Privacy Policy"
              })
              {
                <div class="col-6">
                  <div class="form-check">
                    <input class="form-check-input perm-check" type="checkbox" id="perm-@p.GetHashCode()" />
                    <label class="form-check-label" for="perm-@p.GetHashCode()" style="font-size:.83rem;">@p</label>
                  </div>
                </div>
              }
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" id="btnSaveRole" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>บันทึก
        </button>
      </div>
    </div>
  </div>
</div>
