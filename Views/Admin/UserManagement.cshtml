<!-- Modal: เพิ่ม/แก้ไขผู้ใช้งาน -->
<div class="modal fade" id="modalUser" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" id="modalUserTitle" style="color:var(--dpim-blue);"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="formUser">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">ชื่อ <span class="text-danger">*</span></label>
              <input type="text" id="uFirstname" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">นามสกุล <span class="text-danger">*</span></label>
              <input type="text" id="uLastname" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">อีเมล <span class="text-danger">*</span></label>
              <input type="email" id="uEmail" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">เบอร์โทรศัพท์</label>
              <input type="tel" class="form-control" maxlength="10" />
            </div>
            <div class="col-md-6">
              <label class="form-label">ประเภทสมาชิก <span class="text-danger">*</span></label>
              <select id="uType" class="form-select" required>
                <option value="">-- เลือก --</option>
                <option value="บุคคลธรรมดา">บุคคลธรรมดา</option>
                <option value="นิติบุคคล">นิติบุคคล</option>
                <option value="วิสาหกิจชุมชน">วิสาหกิจชุมชน</option>
                <option value="เจ้าหน้าที่">เจ้าหน้าที่</option>
                <option value="ผู้ประกอบการ">ผู้ประกอบการ</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">บทบาทหลัก</label>
              <select id="uRole" class="form-select">
                <option value="">-- เลือก --</option>
                <option value="ผู้ประกอบการ">ผู้ประกอบการ</option>
                <option value="เจ้าหน้าที่">เจ้าหน้าที่</option>
                <option value="Admin">Admin</option>
                <option value="Viewer">Viewer</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">วันที่เปิดใช้งาน (Activate Date)</label>
              <input type="date" id="uActivate" class="form-control" />
            </div>
            <div class="col-md-6">
              <label class="form-label">สถานะ</label>
              <select id="uStatus" class="form-select">
                <option value="Active">Active</option>
                <option value="Pending">Pending</option>
                <option value="Suspended">Suspended</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">หมายเหตุ (เจ้าหน้าที่)</label>
              <textarea class="form-control" rows="2"></textarea>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" id="btnSaveUser" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>บันทึก
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal: กำหนดกลุ่มและบทบาท -->
<div class="modal fade" id="modalAssignGroup" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" style="color:var(--dpim-blue);">กำหนดกลุ่มและบทบาท</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-3 text-muted" style="font-size:.87rem;">
          ผู้ใช้: <strong id="assignUserName"></strong>
        </p>
        <div class="mb-3">
          <label class="form-label fw-semibold">บทบาทหลัก</label>
          <select class="form-select">
            <option value="">-- เลือก --</option>
            <option value="ผู้ประกอบการ">ผู้ประกอบการ</option>
            <option value="เจ้าหน้าที่">เจ้าหน้าที่</option>
            <option value="Admin">Admin</option>
            <option value="Viewer">Viewer</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">กลุ่มผู้ใช้ (เลือกได้หลายกลุ่ม)</label>
          <div class="border rounded p-2" style="max-height:200px;overflow-y:auto;">
            @foreach (var g in new[] { "DPIM-Portal", "Mining-System", "Officer-Level1", "Officer-Level2", "Admin-Group", "Report-Viewer", "Certificate-Manager", "SSO-Integration" })
            {
              <label class="group-check-item">
                <input type="checkbox" class="form-check-input" />
                <span style="font-size:.87rem;">@g</span>
              </label>
            }
          </div>
        </div>
        <div class="mb-2">
