@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "บริหารจัดการผู้ใช้งาน";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; border-color:#369a3a; color:#fff; }
  .stat-card { border-radius:.75rem; border:none; }
  .stat-card .stat-icon { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.4rem; }
  .role-badge { font-size:.72rem; padding:.2em .55em; border-radius:.4em; }
  .user-avatar-sm { width:32px; height:32px; border-radius:50%; object-fit:cover; border:2px solid #e0e7ef; }
  .group-check-item { display:flex; align-items:center; gap:.5rem; padding:.4rem .5rem; border-radius:.4rem; cursor:pointer; }
  .group-check-item:hover { background:rgba(35,64,143,.06); }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  /* ── DataTable ── */
  var dt = $('#userTable').DataTable({
    language: { url: '/json/datatable-th.json', sEmptyTable: 'ไม่พบข้อมูล', sZeroRecords: 'ไม่พบผลการค้นหา' },
    pageLength: 10,
    order: [[0, 'asc']],
    columnDefs: [{ orderable: false, targets: [-1] }]
  });

  /* Filter status */
  document.getElementById('fStatus').addEventListener('change', function () {
    dt.column(6).search(this.value).draw();
  });
  document.getElementById('fType').addEventListener('change', function () {
    dt.column(3).search(this.value).draw();
  });

  /* ── Modal: เพิ่มผู้ใช้ ── */
  document.getElementById('btnAddUser').addEventListener('click', function () {
    document.getElementById('modalUserTitle').textContent = 'เพิ่มผู้ใช้งาน';
    document.getElementById('formUser').reset();
    new bootstrap.Modal(document.getElementById('modalUser')).show();
  });

  /* ── Modal: แก้ไข ── */
  document.querySelectorAll('.btn-edit-user').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.getElementById('modalUserTitle').textContent = 'แก้ไขผู้ใช้งาน';
      document.getElementById('uFirstname').value = this.dataset.fname || '';
      document.getElementById('uLastname').value = this.dataset.lname || '';
      document.getElementById('uEmail').value = this.dataset.email || '';
      document.getElementById('uType').value = this.dataset.type || '';
      document.getElementById('uRole').value = this.dataset.role || '';
      document.getElementById('uStatus').value = this.dataset.status || 'Active';
      new bootstrap.Modal(document.getElementById('modalUser')).show();
    });
  });

  /* ── Modal: กำหนดกลุ่ม ── */
  document.querySelectorAll('.btn-assign-group').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.getElementById('assignUserName').textContent = this.dataset.name || '';
      new bootstrap.Modal(document.getElementById('modalAssignGroup')).show();
    });
  });

  /* ── Reset Password ── */
  document.querySelectorAll('.btn-reset-pwd').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var name = this.closest('tr').querySelector('.user-name').textContent;
      if (confirm('รีเซ็ตรหัสผ่านให้ ' + name + '?\nระบบจะส่งรหัสผ่านชั่วคราวทางอีเมล')) {
        alert('ส่งรหัสผ่านชั่วคราวไปยังอีเมลสำเร็จ');
      }
    });
  });

  /* ── Suspend / Revoke ── */
  document.querySelectorAll('.btn-suspend-user').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var name = this.closest('tr').querySelector('.user-name').textContent;
      if (confirm('ระงับการใช้งานบัญชี ' + name + '?')) {
        alert('ระงับบัญชีสำเร็จ');
      }
    });
  });

  /* Save User */
  document.getElementById('btnSaveUser').addEventListener('click', function () {
    var form = document.getElementById('formUser');
    if (!form.checkValidity()) { form.reportValidity(); return; }
    bootstrap.Modal.getInstance(document.getElementById('modalUser')).hide();
    alert('บันทึกข้อมูลผู้ใช้งานสำเร็จ');
  });

  /* Save Group Assignment */
  document.getElementById('btnSaveGroup').addEventListener('click', function () {
    bootstrap.Modal.getInstance(document.getElementById('modalAssignGroup')).hide();
    alert('บันทึกกลุ่มและบทบาทสำเร็จ');
  });
});
</script>
}

