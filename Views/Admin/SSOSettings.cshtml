@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "ตั้งค่าระบบ SSO";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .btn-dpim-green:hover { background:#369a3a; color:#fff; }
  .nav-tabs .nav-link.active { color:var(--dpim-blue); border-bottom:2px solid var(--dpim-blue); font-weight:600; }
  .provider-card { border:1px solid var(--bs-border-color); border-radius:.75rem; padding:1rem; transition:all .2s; }
  .provider-card.is-enabled { border-color:var(--dpim-green); background:rgba(65,173,73,.05); }
  .provider-icon { width:44px; height:44px; border-radius:.5rem; display:flex; align-items:center; justify-content:center; font-size:1.4rem; }
  .field-help { font-size:.78rem; color:var(--bs-secondary-color); }
  .conn-status-dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
  .conn-status-dot.online { background:var(--dpim-green); }
  .conn-status-dot.offline { background:#dc3545; }
  .conn-status-dot.unknown { background:#aaa; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Tab nav ── */
  document.querySelectorAll('[data-sso-tab]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('[data-sso-tab]').forEach(function (b) { b.classList.remove('active'); });
      document.querySelectorAll('.sso-tab-content').forEach(function (c) { c.classList.add('d-none'); });
      this.classList.add('active');
      document.getElementById('tab-' + this.dataset.ssoTab).classList.remove('d-none');
    });
  });

  /* ── Test LDAP connection ── */
  document.getElementById('btnTestLdap').addEventListener('click', function () {
    this.disabled = true;
    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>กำลังทดสอบ...';
    var self = this;
    setTimeout(function () {
      self.disabled = false;
      self.innerHTML = '<i class="ri ri-plug-line me-1"></i>ทดสอบการเชื่อมต่อ';
      alert('เชื่อมต่อ LDAP สำเร็จ! พบผู้ใช้ 128 รายการ');
    }, 1800);
  });

  /* ── Provider toggles ── */
  document.querySelectorAll('.provider-toggle').forEach(function (sw) {
    sw.addEventListener('change', function () {
      var card = this.closest('.provider-card');
      if (this.checked) card.classList.add('is-enabled');
      else card.classList.remove('is-enabled');
    });
  });

  /* ── System Actions ── */
  document.querySelectorAll('.btn-edit-system').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var name = this.dataset.name;
      new bootstrap.Modal(document.getElementById('modalEditSystem')).show();
      document.getElementById('sysName').value = name || '';
    });
  });
  document.querySelectorAll('.btn-delete-system').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (confirm('ลบการเชื่อมต่อนี้?')) alert('ลบสำเร็จ');
    });
  });

  /* ── Add System ── */
  document.getElementById('btnAddSystem').addEventListener('click', function () {
    document.getElementById('sysName').value = '';
    new bootstrap.Modal(document.getElementById('modalEditSystem')).show();
  });

  document.getElementById('btnSaveSystem').addEventListener('click', function () {
    bootstrap.Modal.getInstance(document.getElementById('modalEditSystem')).hide();
    alert('บันทึกระบบที่เชื่อมต่อสำเร็จ');
  });

  /* ── Save buttons ── */
  document.getElementById('btnSaveLdap').addEventListener('click', function () { alert('บันทึกการตั้งค่า Directory Service สำเร็จ'); });
  document.getElementById('btnSaveOAuth').addEventListener('click', function () { alert('บันทึกการตั้งค่า OAuth/OIDC สำเร็จ'); });
  document.getElementById('btnSaveLinked').addEventListener('click', function () { alert('บันทึกการตั้งค่าบัญชีที่เชื่อมโยงสำเร็จ'); });
});
</script>
}

