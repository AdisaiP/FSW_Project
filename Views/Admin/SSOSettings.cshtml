<!-- Modal: เพิ่ม/แก้ไขระบบ -->
<div class="modal fade" id="modalEditSystem" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" style="color:var(--dpim-blue);">ตั้งค่าระบบที่เชื่อมต่อ</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">ชื่อระบบ</label>
            <input type="text" id="sysName" class="form-control" />
          </div>
          <div class="col-md-6">
            <label class="form-label">ประเภทการเชื่อมต่อ</label>
            <select class="form-select">
              <option>OAuth 2.0</option>
              <option>OIDC</option>
              <option>SAML 2.0</option>
              <option>Azure AD</option>
              <option>API Key</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Endpoint URL</label>
            <input type="url" class="form-control" placeholder="https://" />
          </div>
          <div class="col-12">
            <label class="form-label">คำอธิบาย</label>
            <textarea class="form-control" rows="2"></textarea>
          </div>
        </div>
      </div>
