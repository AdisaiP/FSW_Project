@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "นโยบาย MFA";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .policy-card { border:1.5px solid var(--bs-border-color); border-radius:10px; padding:1.25rem; margin-bottom:1rem; transition:border-color .18s ease; }
  .policy-card.is-active { border-color:var(--dpim-blue); background:rgba(35,64,143,.03); }
  .form-check-input:checked { background-color:var(--dpim-blue); border-color:var(--dpim-blue); }
  .form-switch .form-check-input:checked { background-color:var(--dpim-blue); }
  .policy-extra { display:none; margin-top:.75rem; padding-top:.75rem; border-top:1px solid var(--bs-border-color); }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; border-color:#1b3175; color:#fff; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Toggle extra config on switch change
  document.querySelectorAll('.policy-toggle').forEach(function (sw) {
    sw.addEventListener('change', function () {
      var card = this.closest('.policy-card');
      card.classList.toggle('is-active', this.checked);
      var extra = card.querySelector('.policy-extra');
      if (extra) extra.style.display = this.checked ? '' : 'none';
    });
    // Init
    var card = sw.closest('.policy-card');
    card.classList.toggle('is-active', sw.checked);
    var extra = card.querySelector('.policy-extra');
    if (extra) extra.style.display = sw.checked ? '' : 'none';
  });

  document.getElementById('btnSaveMFA')?.addEventListener('click', function () {
    alert('บันทึกนโยบาย MFA สำเร็จ!');
  });

  document.getElementById('riskThreshold')?.addEventListener('input', function () {
    document.getElementById('riskVal').textContent = this.value;
  });
});
</script>
}

@* ============================================================ *@
<div class="container-xxl flex-grow-1 container-p-y">

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb breadcrumb-style1 mb-4">
      <li class="breadcrumb-item"><a href="/">หน้าหลัก</a></li>
      <li class="breadcrumb-item active">นโยบาย MFA</li>
    </ol>
  </nav>

  <h4 class="page-title-dpim mb-4">ตั้งค่านโยบาย Multi-Factor Authentication (MFA)</h4>

  <div class="row g-4">
    <div class="col-lg-8">

      <!-- MFA Required For -->
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0"><i class="ri ri-group-line me-2" style="color:var(--dpim-blue);"></i>กำหนดกลุ่มที่ต้องใช้ MFA</h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="d-flex align-items-center gap-2 cursor-pointer">
                <input class="form-check-input" type="checkbox" checked style="width:20px;height:20px;" />
                <div>
                  <div class="fw-semibold">ผู้ประกอบการ</div>
                  <div class="text-muted" style="font-size:.78rem;">Self-Service Users</div>
                </div>
              </label>
            </div>
            <div class="col-md-4">
              <label class="d-flex align-items-center gap-2 cursor-pointer">
                <input class="form-check-input" type="checkbox" checked style="width:20px;height:20px;" />
                <div>
                  <div class="fw-semibold">เจ้าหน้าที่</div>
                  <div class="text-muted" style="font-size:.78rem;">Officer Users</div>
                </div>
              </label>
            </div>
            <div class="col-md-4">
              <label class="d-flex align-items-center gap-2 cursor-pointer">
                <input class="form-check-input" type="checkbox" checked style="width:20px;height:20px;" />
                <div>
                  <div class="fw-semibold">ผู้ดูแลระบบ</div>
                  <div class="text-muted" style="font-size:.78rem;">Admin Users</div>
                </div>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- Policy Cards -->
      <div class="policy-card is-active">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-bold mb-1">Risk-Based MFA</div>
            <div class="text-muted" style="font-size:.85rem;">บังคับ MFA เมื่อตรวจพบความเสี่ยงสูงผิดปกติ (เช่น IP ต่างประเทศ, ล็อกอินผิดหลายครั้ง)</div>
          </div>
          <div class="form-check form-switch ms-3">
            <input class="form-check-input policy-toggle" type="checkbox" checked style="width:3rem;height:1.5rem;" />
          </div>
        </div>
        <div class="policy-extra">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Risk Score Threshold (0-100)</label>
          <div class="d-flex align-items-center gap-3">
            <input type="range" class="form-range flex-grow-1" min="0" max="100" value="60" id="riskThreshold" />
            <span class="fw-bold" style="color:var(--dpim-blue);min-width:30px;" id="riskVal">60</span>
          </div>
          <div class="text-muted" style="font-size:.78rem;">MFA จะถูกบังคับเมื่อ Risk Score &ge; ค่าที่กำหนด</div>
        </div>
      </div>

      <div class="policy-card is-active">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-bold mb-1">Location-Based MFA</div>
            <div class="text-muted" style="font-size:.85rem;">บังคับ MFA เมื่อเข้าสู่ระบบจาก IP หรือประเทศที่ไม่ได้ระบุ</div>
          </div>
          <div class="form-check form-switch ms-3">
            <input class="form-check-input policy-toggle" type="checkbox" checked style="width:3rem;height:1.5rem;" />
          </div>
        </div>
        <div class="policy-extra">
          <label class="form-label fw-semibold" style="font-size:.85rem;">ประเทศที่อนุญาต (Allowed Countries)</label>
          <input type="text" class="form-control mb-2" value="TH" placeholder="เช่น TH, SG, JP (คั่นด้วยจุลภาค)" />
          <label class="form-label fw-semibold" style="font-size:.85rem;">IP Range ที่เชื่อถือ</label>
          <input type="text" class="form-control" value="192.168.0.0/16, 10.0.0.0/8" placeholder="CIDR notation" />
        </div>
      </div>

      <div class="policy-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-bold mb-1">Trusted Device</div>
            <div class="text-muted" style="font-size:.85rem;">ไม่ต้อง MFA อีกครั้งบนอุปกรณ์ที่เชื่อถือแล้ว</div>
          </div>
          <div class="form-check form-switch ms-3">
            <input class="form-check-input policy-toggle" type="checkbox" style="width:3rem;height:1.5rem;" />
          </div>
        </div>
        <div class="policy-extra">
          <label class="form-label fw-semibold" style="font-size:.85rem;">ระยะเวลาหมดอายุ (วัน)</label>
          <div class="input-group" style="max-width:200px;">
            <input type="number" class="form-control" value="30" min="1" max="365" />
            <span class="input-group-text">วัน</span>
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-end mt-3">
        <button id="btnSaveMFA" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>บันทึกนโยบาย
        </button>
      </div>
    </div>

    <!-- Right: Info -->
    <div class="col-lg-4">
      <div class="card">
        <div class="card-body">
          <div class="text-center mb-3">
            <i class="ri ri-shield-line" style="font-size:3rem;color:var(--dpim-blue);"></i>
            <h6 class="mt-2 fw-bold" style="color:var(--dpim-blue);">MFA คืออะไร?</h6>
          </div>
          <p style="font-size:.82rem;color:#495057;">
            Multi-Factor Authentication (MFA) คือการยืนยันตัวตนหลายขั้นตอน ช่วยป้องกันการเข้าถึงที่ไม่ได้รับอนุญาต แม้รหัสผ่านจะรั่วไหล
          </p>
          <hr />
          <div style="font-size:.82rem;">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="ri ri-checkbox-circle-line" style="color:var(--dpim-green);"></i>
              <span>Email OTP</span>
            </div>
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="ri ri-checkbox-circle-line" style="color:var(--dpim-green);"></i>
              <span>Authenticator App (TOTP)</span>
            </div>
            <div class="d-flex align-items-center gap-2">
              <i class="ri ri-checkbox-circle-line" style="color:var(--dpim-green);"></i>
              <span>SMS OTP</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

