@{
  Layout = "_ContentNavbarLayout";
  ViewData["Title"] = "รายการสิ่งที่ต้องดำเนินการ";
}

@section PageStyles {
<style>
  :root { --dpim-green:#41AD49; --dpim-blue:#23408F; }
  .page-title-dpim { color:var(--dpim-blue); border-left:4px solid var(--dpim-green); padding-left:.75rem; }
  .btn-dpim { background:var(--dpim-blue); border-color:var(--dpim-blue); color:#fff; }
  .btn-dpim:hover { background:#1b3175; color:#fff; }
  .btn-dpim-green { background:var(--dpim-green); border-color:var(--dpim-green); color:#fff; }
  .stat-todo { border-radius:.75rem; border:none; padding:1rem 1.25rem; }
  .todo-item { border:1px solid var(--bs-border-color); border-radius:.75rem; padding:1rem 1.25rem; transition:.2s; background:var(--bs-card-bg); }
  .todo-item:hover { border-color:var(--dpim-blue); box-shadow:0 2px 8px rgba(35,64,143,.1); }
  .todo-item.is-done { opacity:.55; }
  .todo-item.is-done .todo-title { text-decoration:line-through; }
  .todo-priority { width:4px; border-radius:2px; min-height:44px; align-self:stretch; flex-shrink:0; }
  .todo-priority.high { background:#dc3545; }
  .todo-priority.medium { background:#e6a800; }
  .todo-priority.low { background:var(--dpim-green); }
  .todo-category-badge { font-size:.72rem; padding:.2em .5em; border-radius:.4em; }
  .filter-btn { border-radius:2rem; font-size:.82rem; padding:.3rem .9rem; }
  .filter-btn.active { background:var(--dpim-blue); color:#fff; border-color:var(--dpim-blue); }
  @@keyframes fade-out { to { opacity:0; transform:translateY(-8px); max-height:0; overflow:hidden; padding:0; margin:0; } }
  .removing { animation:fade-out .3s forwards; }
</style>
}

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Filter tabs ── */
  document.querySelectorAll('.todo-filter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.todo-filter-btn').forEach(function (b) {
        b.classList.remove('active');
      });
      this.classList.add('active');
      var filter = this.dataset.filter;
      document.querySelectorAll('.todo-item').forEach(function (item) {
        if (filter === 'all') {
          item.style.display = '';
        } else if (filter === 'pending') {
          item.style.display = item.classList.contains('is-done') ? 'none' : '';
        } else if (filter === 'done') {
          item.style.display = item.classList.contains('is-done') ? '' : 'none';
        } else {
          item.style.display = item.dataset.category === filter ? '' : 'none';
        }
      });
    });
  });

  /* ── Mark Done ── */
  document.querySelectorAll('.btn-mark-done').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = this.closest('.todo-item');
      item.classList.add('is-done');
      this.innerHTML = '<i class="ri ri-checkbox-circle-line me-1"></i>เสร็จแล้ว';
      this.disabled = true;
      this.className = 'btn btn-sm btn-outline-success btn-mark-done';
      updateStats();
    });
  });

  /* ── Dismiss ── */
  document.querySelectorAll('.btn-dismiss-todo').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = this.closest('.todo-item');
      item.classList.add('removing');
      setTimeout(function () { item.remove(); updateStats(); }, 300);
    });
  });

  function updateStats() {
    var all = document.querySelectorAll('.todo-item').length;
    var done = document.querySelectorAll('.todo-item.is-done').length;
    var pending = all - done;
    document.getElementById('statAll').textContent = all;
    document.getElementById('statPending').textContent = pending;
    document.getElementById('statDone').textContent = done;
  }

  /* ── Add Todo ── */
  document.getElementById('btnSaveTodo').addEventListener('click', function () {
    bootstrap.Modal.getInstance(document.getElementById('modalAddTodo')).hide();
    alert('เพิ่มรายการสำเร็จ');
  });
});
</script>
}

@* ============================================================ *@
