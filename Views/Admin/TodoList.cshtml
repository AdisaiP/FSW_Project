<!-- Modal: เพิ่มรายการ Todo -->
<div class="modal fade" id="modalAddTodo" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom:2px solid var(--dpim-green);">
        <h5 class="modal-title" style="color:var(--dpim-blue);">เพิ่มรายการสิ่งที่ต้องดำเนินการ</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">ชื่อรายการ <span class="text-danger">*</span></label>
            <input type="text" class="form-control" placeholder="กรอกชื่อรายการ..." />
          </div>
          <div class="col-md-6">
            <label class="form-label">หมวดหมู่</label>
            <select class="form-select">
              <option value="access">คำขอสิทธิ์</option>
              <option value="cert">ใบรับรอง</option>
              <option value="policy">นโยบาย</option>
              <option value="system">ระบบ</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">ความสำคัญ</label>
            <select class="form-select">
              <option value="high">สูง</option>
              <option value="medium" selected>กลาง</option>
              <option value="low">ต่ำ</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label">รายละเอียด</label>
            <textarea class="form-control" rows="2"></textarea>
          </div>
          <div class="col-12">
            <label class="form-label">ลิงก์ (ถ้ามี)</label>
            <input type="url" class="form-control" placeholder="https://..." />
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" id="btnSaveTodo" class="btn btn-dpim">
          <i class="ri ri-save-line me-1"></i>เพิ่มรายการ
        </button>
      </div>
    </div>
  </div>
</div>
