@{
  TempData.Keep();
  string? currentPage = ViewContext.HttpContext.Request.Path;
}

<!-- Menu -->
<aside id="layout-menu" class="layout-menu menu-vertical menu">

  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="Dashboards" asp-action="Index" class="app-brand-link">
      <span class="app-brand-logo demo flex-shrink-0" style="width:36px;height:36px;display:inline-flex;align-items:center;justify-content:center;">
        <img src="~/img/dpim-logo.png" alt="DPIM Logo" style="width:48px;height:48px;object-fit:contain;"
             onerror="this.src='/img/branding/logo.png'" />
      </span>
      <span class="app-brand-text demo ms-2" style="letter-spacing:0;line-height:1.3;text-transform:none;min-width:0;">
        <span class="d-block text-muted fw-normal" style="font-size:0.75rem;line-height:1.35;">กรมอุตสาหกรรมพื้นฐาน<br>และการเหมืองแร่</span>
      </span>
    </a>
    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.47365 11.7183C8.11707 12.0749 8.11707 12.6531 8.47365 13.0097L12.071 16.607C12.4615 16.9975 12.4615 17.6305 12.071 18.021C11.6805 18.4115 11.0475 18.4115 10.657 18.021L5.83009 13.1941C5.37164 12.7356 5.37164 11.9924 5.83009 11.5339L10.657 6.707C11.0475 6.31653 11.6805 6.31653 12.071 6.707C12.4615 7.09747 12.4615 7.73053 12.071 8.121L8.47365 11.7183Z" fill-opacity="0.9"/>
        <path d="M14.3584 11.8336C14.0654 12.1266 14.0654 12.6014 14.3584 12.8944L18.071 16.607C18.4615 16.9975 18.4615 17.6305 18.071 18.021C17.6805 18.4115 17.0475 18.4115 16.657 18.021L11.6819 13.0459C11.3053 12.6693 11.3053 12.0587 11.6819 11.6821L16.657 6.707C17.0475 6.31653 17.6805 6.31653 18.071 6.707C18.4615 7.09747 18.4615 7.73053 18.071 8.121L14.3584 11.8336Z" fill-opacity="0.4"/>
      </svg>
    </a>
  </div>

  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">


    <!-- ===== ผู้ประกอบการ ===== -->
    <li class="menu-header mt-2">
      <span class="menu-header-text">ผู้ประกอบการ</span>
    </li>

    <li class='menu-item@(currentPage == "/Users/ViewAccount" ? " active" : "")'>
      <a asp-controller="Users" asp-action="ViewAccount" class="menu-link">
        <i class="menu-icon icon-base ri ri-user-line"></i>
        <div>โปรไฟล์ผู้ใช้</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Users/ViewSecurity" ? " active" : "")'>
      <a asp-controller="Users" asp-action="ViewSecurity" class="menu-link">
        <i class="menu-icon icon-base ri ri-shield-line"></i>
        <div>ความปลอดภัย</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Users/ViewAddresses" ? " active" : "")'>
      <a asp-controller="Users" asp-action="ViewAddresses" class="menu-link">
        <i class="menu-icon icon-base ri ri-map-pin-line"></i>
        <div>บัญชีที่อยู่</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Users/Certificate" ? " active" : "")'>
      <a asp-controller="Users" asp-action="Certificate" class="menu-link">
        <i class="menu-icon icon-base ri ri-medal-line"></i>
        <div>ใบรับรองอิเล็กทรอนิกส์</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Auth/AccessRequest" ? " active" : "")'>
      <a asp-controller="Auth" asp-action="AccessRequest" class="menu-link">
        <i class="menu-icon icon-base ri ri-key-line"></i>
        <div>ยื่นคำขอสิทธิ์</div>
      </a>
    </li>

    <!-- ===== เจ้าหน้าที่ ===== -->
    <li class="menu-header mt-2">
      <span class="menu-header-text">เจ้าหน้าที่</span>
    </li>

    <li class='menu-item@(currentPage == "/Officer/AccessRequestList" ? " active" : "")'>
      <a asp-controller="Officer" asp-action="AccessRequestList" class="menu-link">
        <i class="menu-icon icon-base ri ri-list-check"></i>
        <div>รายการคำขอสิทธิ์</div>
        <div class="badge badge-center text-bg-warning rounded-pill ms-auto" style="font-size:.7rem;">3</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Officer/RegisterUser" ? " active" : "")'>
      <a asp-controller="Officer" asp-action="RegisterUser" class="menu-link">
        <i class="menu-icon icon-base ri ri-user-add-line"></i>
        <div>ลงทะเบียนผู้ใช้ (Walk-In)</div>
      </a>
    </li>

    <!-- ===== Admin / SSO ===== -->
    <li class="menu-header mt-2">
      <span class="menu-header-text">ผู้ดูแลระบบ</span>
    </li>

    <li class='menu-item@(currentPage == "/Admin/UserManagement" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="UserManagement" class="menu-link">
        <i class="menu-icon icon-base ri ri-group-line"></i>
        <div>จัดการผู้ใช้งาน</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Admin/SSOSettings" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="SSOSettings" class="menu-link">
        <i class="menu-icon icon-base ri ri-links-line"></i>
        <div>ตั้งค่า SSO</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Admin/PasswordPolicy" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="PasswordPolicy" class="menu-link">
        <i class="menu-icon icon-base ri ri-lock-password-line"></i>
        <div>นโยบายรหัสผ่าน</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Admin/MFAPolicy" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="MFAPolicy" class="menu-link">
        <i class="menu-icon icon-base ri ri-smartphone-line"></i>
        <div>MFA Policy</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Admin/EmailNotification" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="EmailNotification" class="menu-link">
        <i class="menu-icon icon-base ri ri-mail-line"></i>
        <div>การแจ้งเตือนอีเมล</div>
      </a>
    </li>

    <!-- Admin sub-menu: Policy & Consent -->
    <li class='menu-item@(currentPage.StartsWith("/Admin/Privacy") || currentPage.StartsWith("/Admin/Cookie") ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base ri ri-shield-check-line"></i>
        <div>นโยบาย & ความยินยอม</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Admin/PrivacyPolicy" ? " active" : "")'>
          <a asp-controller="Admin" asp-action="PrivacyPolicy" class="menu-link">
            <div>Privacy Policy</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Admin/CookieConsent" ? " active" : "")'>
          <a asp-controller="Admin" asp-action="CookieConsent" class="menu-link">
            <div>Cookie Consent</div>
          </a>
        </li>
      </ul>
    </li>

    <!-- Admin sub-menu: Reports & Logs -->
    <li class='menu-item@(currentPage == "/Admin/AuditLog" || currentPage == "/Admin/DataAnalyzer" || currentPage == "/Admin/Reports" ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base ri ri-bar-chart-2-line"></i>
        <div>รายงาน & Log</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Admin/AuditLog" ? " active" : "")'>
          <a asp-controller="Admin" asp-action="AuditLog" class="menu-link">
            <div>Audit Log</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Admin/DataAnalyzer" ? " active" : "")'>
          <a asp-controller="Admin" asp-action="DataAnalyzer" class="menu-link">
            <div>วิเคราะห์ข้อมูล</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Admin/Reports" ? " active" : "")'>
          <a asp-controller="Admin" asp-action="Reports" class="menu-link">
            <div>รายงานสรุป</div>
          </a>
        </li>
      </ul>
    </li>

    <li class='menu-item@(currentPage == "/Admin/TodoList" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="TodoList" class="menu-link">
        <i class="menu-icon icon-base ri ri-checkbox-multiple-line"></i>
        <div>Todo List</div>
        <div class="badge badge-center text-bg-danger rounded-pill ms-auto" style="font-size:.7rem;">4</div>
      </a>
    </li>

    <li class='menu-item@(currentPage == "/Admin/FAQ" ? " active" : "")'>
      <a asp-controller="Admin" asp-action="FAQ" class="menu-link">
        <i class="menu-icon icon-base ri ri-question-line"></i>
        <div>FAQ</div>
      </a>
    </li>

  </ul>
</aside>

<div class="menu-mobile-toggler d-xl-none rounded-1">
  <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large text-bg-secondary p-2 rounded-1">
    <i class="ri ri-menu-line icon-base"></i>
    <i class="ri ri-arrow-right-s-line icon-base"></i>
  </a>
</div>
<!-- / Menu -->
